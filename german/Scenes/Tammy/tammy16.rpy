# game/Scenes/Tammy/tammy16.rpy:20
translate german tammy16_39bb639d:

    # tm "Oh hey, [pcname]!"
    tm "Oh hey, [pcname]!"

# game/Scenes/Tammy/tammy16.rpy:22
translate german tammy16_c7aa7331:

    # tm "I wanted to let you know that I got another fight!"
    tm "Ich wollte dir nur sagen, dass ich noch einen Kampf habe!"

# game/Scenes/Tammy/tammy16.rpy:23
translate german tammy16_46fcf508:

    # pc "Oh yeah? Awesome!"
    pc "Ach ja? Super!"

# game/Scenes/Tammy/tammy16.rpy:25
translate german tammy16_537005d0:

    # tm "Yeah! I mean, it's the same opponent. Sara Death."
    tm "Ja! Ich meine, es ist dieselbe Gegnerin. Sara Death."

# game/Scenes/Tammy/tammy16.rpy:26
translate german tammy16_ff4ca977:

    # tm "They couldn't find anybody else to fight me around here."
    tm "Sie konnten hier in der Gegend einfach niemanden anderen finden, der gegen mich antritt."

# game/Scenes/Tammy/tammy16.rpy:27
translate german tammy16_c040e3a2:

    # pc "Still. A rematch! That'll be fun."
    pc "Trotzdem. Ein Rückkampf! Das wird Spaß machen."

# game/Scenes/Tammy/tammy16.rpy:29
translate german tammy16_65a45e79:

    # tm "Yeah, so it's Friday evening. You're going to come, right?"
    tm "Ja, es ist also Freitagabend. Du kommst doch, oder?"

# game/Scenes/Tammy/tammy16.rpy:30
translate german tammy16_a248948f:

    # pc "Of course."
    pc "Natürlich."

# game/Scenes/Tammy/tammy16.rpy:31
translate german tammy16_0d0b0b78:

    # tm "Good. Suzy's coming to this one too."
    tm "Gut. Suzy kommt diesmal auch mit."

# game/Scenes/Tammy/tammy16.rpy:33
translate german tammy16_a716e406:

    # tm "I'm so fucking excited!"
    tm "Ich bin so verdammt aufgeregt!"

# game/Scenes/Tammy/tammy16.rpy:34
translate german tammy16_c03b2498:

    # tm "Ready to work out?"
    tm "Bereit zum Trainieren?"

# game/Scenes/Tammy/tammy16.rpy:35
translate german tammy16_81e72625:

    # pc "Yeah, let's do it!"
    pc "Ja, los geht’s!"

# game/Scenes/Tammy/tammy16.rpy:46
translate german tammy16b_d3127e62:

    # "Tonight is Tammy's fight. I better head over to the gym to support her."
    "Heute Abend ist Tammys Kampf. Ich gehe besser rüber ins Fitnessstudio, um sie zu unterstützen."

# game/Scenes/Tammy/tammy16.rpy:50
translate german tammy16b_fc7a2349:

    # "The place is packed tonight. Even more people than the first fight. I guess everybody wants to see the rematch."
    "Der Laden ist heute Abend brechend voll. Noch mehr Leute als beim ersten Kampf. Ich schätze, alle wollen die Revanche sehen."

# game/Scenes/Tammy/tammy16.rpy:51
translate german tammy16b_c1a9fded:

    # "I spot Tammy and Suzy hanging out near the ring and walk over to them."
    "Ich entdecke Tammy und Suzy, die in der Nähe des Rings herumstehen, und gehe zu ihnen hinüber."

# game/Scenes/Tammy/tammy16.rpy:54
translate german tammy16b_ef965655:

    # tm "Hey, [pcname]. You in my corner again?"
    tm "Hey, [pcname]. Bist du wieder in meiner Ecke?"

# game/Scenes/Tammy/tammy16.rpy:55
translate german tammy16b_351f8f78:

    # pc "I'm always in your corner, girl."
    pc "Ich bin immer in deiner Ecke, Mädel."

# game/Scenes/Tammy/tammy16.rpy:58
translate german tammy16b_7de5fb0a:

    # tm "I know you are. Love you!"
    tm "Ich weiß, dass du es bist. Ich liebe dich!"

# game/Scenes/Tammy/tammy16.rpy:59
translate german tammy16b_ce2ae2bf:

    # pc "Love you too."
    pc "Ich liebe dich auch."

# game/Scenes/Tammy/tammy16.rpy:60
translate german tammy16b_fbdb8489:

    # "Chuck, the gym owner and referee, steps onto the stage and speaks into a microphone."
    "Chuck, der Besitzer des Fitnessstudios und Ringrichter, betritt die Bühne und spricht ins Mikrofon."

# game/Scenes/Tammy/tammy16.rpy:61
translate german tammy16b_03a792fe:

    # "Chuck" "All right, everybody. Fighters to the ring."
    "Chuck" "Okay, alle zusammen. Kämpferinnen in den Ring."

# game/Scenes/Tammy/tammy16.rpy:64
translate german tammy16b_bc20373a:

    # tm "Guess I gotta go. Wish me luck."
    tm "Ich muss wohl los. Wünscht mir Glück."

# game/Scenes/Tammy/tammy16.rpy:65
translate german tammy16b_70969e05:

    # ss "You don't need it. You're going to wipe the mat with her."
    ss "Das brauchst du nicht. Du wirst sie in Grund und Boden rammen."

# game/Scenes/Tammy/tammy16.rpy:66
translate german tammy16b_8407fcdb:

    # pc "You trained so hard. You're a beast."
    pc "Du hast so hart trainiert. Du bist ein Biest."

# game/Scenes/Tammy/tammy16.rpy:67
translate german tammy16b_0fc82d62:

    # tm "Thanks, guys."
    tm "Danke, Leute."

# game/Scenes/Tammy/tammy16.rpy:70
translate german tammy16b_4d3281d1:

    # ss "You better get up there in her corner. She needs you."
    ss "Du solltest besser in ihre Ecke gehen. Sie braucht dich."

# game/Scenes/Tammy/tammy16.rpy:71
translate german tammy16b_2cda7690:

    # pc "You don't want to?"
    pc "Willst du nicht?"

# game/Scenes/Tammy/tammy16.rpy:72
translate german tammy16b_2475c65e:

    # ss "No, I'm going to go cheer from the back. I don't like to see her get hit."
    ss "Nein, ich werde von hinten anfeuern. Ich mag es nicht, wenn sie Schläge abbekommt."

# game/Scenes/Tammy/tammy16.rpy:73
translate german tammy16b_7ebf9a37:

    # ss "But you'll hear me, I'm sure."
    ss "Aber du wirst mich hören, da bin ich mir sicher."

# game/Scenes/Tammy/tammy16.rpy:76
translate german tammy16b_8ba7b5ed:

    # "I climb up into Tammy's corner as Chuck introduces the fighters."
    "Ich klettere in Tammys Ecke, während Chuck die Kämpferinnen vorstellt."

# game/Scenes/Tammy/tammy16.rpy:77
translate german tammy16b_263516ea:

    # "Sara Death looks somehow even bigger and more jacked than she did last time they fought."
    "Sara Death sieht irgendwie noch größer und muskulöser aus als beim letzten Kampf."

# game/Scenes/Tammy/tammy16.rpy:78
translate german tammy16b_dd7b01f4:

    # "Tammy is so much smaller it's sometimes hard to believe that she can take an opponent like that down."
    "Tammy ist so viel kleiner, dass man manchmal kaum glauben kann, dass sie eine solche Gegnerin besiegen kann."

# game/Scenes/Tammy/tammy16.rpy:79
translate german tammy16b_edae56fc:

    # "Chuck" "... Our return opponent in this rematch, Sara Death!"
    "Chuck" "... Unsere Gegnerin in diesem Rückkampf: Sara Death!"

# game/Scenes/Tammy/tammy16.rpy:83
translate german tammy16b_a31e4957:

    # "Chuck" "And in this corner, undefeated so far in her amateur fighting career and hoping to continue that streak tonight..."
    "Chuck" "Und in dieser Ecke, bisher ungeschlagen in ihrer Amateur-Kampfkarriere und in der Hoffnung, diese Serie heute Abend fortzusetzen..."

# game/Scenes/Tammy/tammy16.rpy:85
translate german tammy16b_83b35d9b:

    # "Chuck" "And in this corner, looking to get revenge on the beating she took last fight..."
    "Chuck" "Und in dieser Ecke, die auf Rache für die Niederlage im letzten Kampf sinnt..."

# game/Scenes/Tammy/tammy16.rpy:86
translate german tammy16b_96ba703d:

    # "Chuck" "... standing five-foot-six-inches tall and weighing in at 130 pounds..."
    "Chuck" "... mit einer Größe von 1,68 m und einem Gewicht von 59 kg..."

# game/Scenes/Tammy/tammy16.rpy:87
translate german tammy16b_ec4b18ff:

    # "Chuck" "Tammy \"Wham! Bam!\" Zamora!"
    "Chuck" "Tammy „Wham! Bam!“ Zamora!"

# game/Scenes/Tammy/tammy16.rpy:90
translate german tammy16b_6f4f75f7:

    # "Chuck takes them to the middle of the ring and goes over the rules with them."
    "Chuck führt sie in die Mitte des Rings und geht mit ihnen die Regeln durch."

# game/Scenes/Tammy/tammy16.rpy:91
translate german tammy16b_0b6f40cb:

    # "Sara smiles the whole time. I can see Sara and Tammy muttering something to each other and laughing."
    "Sara lächelt die ganze Zeit. Ich kann sehen, wie Sara und Tammy sich etwas zuflüstern und lachen."

# game/Scenes/Tammy/tammy16.rpy:92
translate german tammy16b_24d8b054:

    # "Even though they're about to beat the crap out of each other, it seems like they're having a good time."
    "Obwohl sie sich gleich die Seele aus dem Leib prügeln werden, scheint es, als hätten sie Spaß."

# game/Scenes/Tammy/tammy16.rpy:93
translate german tammy16b_1b6ae11e:

    # "When they're done, they touch gloves and return to their corners."
    "Als sie fertig sind, berühren sie die Handschuhe und kehren in ihre Ecken zurück."

# game/Scenes/Tammy/tammy16.rpy:96
translate german tammy16b_fcfdafdf:

    # pc "You got this."
    pc "Du schaffst das."

# game/Scenes/Tammy/tammy16.rpy:97
translate german tammy16b_3caaf546:

    # tm "You're goddamn right."
    tm "Da hast du verdammt recht."

# game/Scenes/Tammy/tammy16.rpy:98
translate german tammy16b_0929120c:

    # "Chuck" "Three... Two... One... FIGHT!"
    "Chuck" "Drei… Zwei… Eins… KAMPF!"

# game/Scenes/Tammy/tammy16.rpy:101
translate german tammy16b_ec9b5571:

    # "They both rush to the middle of the ring and the crowd goes wild."
    "Beide stürmen in die Mitte des Rings und die Menge tobt."

# game/Scenes/Tammy/tammy16.rpy:104
translate german tammy16b_679f2669:

    # "Even over the yells of all of those around me, I can hear Suzy in the back, cheering loudly for our girlfriend."
    "Selbst über die Rufe all derer um mich herum hinweg kann ich Suzy im Hintergrund hören, wie sie unsere Freundin laut anfeuert."

# game/Scenes/Tammy/tammy16.rpy:107
translate german tammy16b_647f4a54:

    # "They circle around each other a bit, testing out their range, looking for openings."
    "Sie umkreisen sich ein wenig, testen ihre Reichweite und suchen nach Lücken."

# game/Scenes/Tammy/tammy16.rpy:110
translate german tammy16b_5d7efc88:

    # "Tammy is trying to stay loose, moving in and out quickly to land leg kicks."
    "Tammy versucht, locker zu bleiben, bewegt sich schnell vor und zurück, um Beintritte zu landen."

# game/Scenes/Tammy/tammy16.rpy:111
translate german tammy16b_e3d4107b:

    # "She knows that getting too close would mean that she could be taken down to the ground."
    "Sie weiß, dass zu nah herankommen bedeuten würde, dass sie zu Boden geworfen werden könnte."

# game/Scenes/Tammy/tammy16.rpy:112
translate german tammy16b_a88a4b4f:

    # "Having the much larger Sara on top of her could easily lead to her getting overwhelmed."
    "Die viel größere Sara auf sich zu haben, könnte leicht dazu führen, dass sie überwältigt wird."

# game/Scenes/Tammy/tammy16.rpy:115
translate german tammy16b_a3883dc3:

    # "Of course, taking one of those big fists on her chin could knock her down as well."
    "Natürlich könnte auch ein Schlag mit einer dieser großen Fäuste auf ihr Kinn sie zu Boden schicken."

# game/Scenes/Tammy/tammy16.rpy:116
translate german tammy16b_b3da4826:

    # "Every second she's in this fight, there's more of a chance of her getting hit and knocked out."
    "Mit jeder Sekunde, die sie in diesem Kampf steht, steigt die Wahrscheinlichkeit, dass sie getroffen und ausgeknockt wird."

# game/Scenes/Tammy/tammy16.rpy:119
translate german tammy16b_cdd3604c:

    # "Tammy is able to land a few good hits, but Sara just takes them and keeps coming."
    "Tammy kann ein paar gute Treffer landen, aber Sara steckt sie einfach weg und kommt weiter auf sie zu."

# game/Scenes/Tammy/tammy16.rpy:122
translate german tammy16b_248b11e5:

    # "Then the referee calls the end of the round and steps in to separate them back to their corners."
    "Dann pfeift der Ringrichter das Ende der Runde und greift ein, um die beiden wieder in ihre Ecken zu trennen."

# game/Scenes/Tammy/tammy16.rpy:125
translate german tammy16b_5dca43c0:

    # tm "How am I looking out there?"
    tm "Wie sehe ich da draußen aus?"

# game/Scenes/Tammy/tammy16.rpy:126
translate german tammy16b_40609e22:

    # pc "You look great. Really fucking sexy."
    pc "Du siehst toll aus. Verdammt sexy."

# game/Scenes/Tammy/tammy16.rpy:127
translate german tammy16b_4586870d:

    # tm "Haha, I need a real coach."
    tm "Haha, ich brauche einen richtigen Trainer."

# game/Scenes/Tammy/tammy16.rpy:128
translate german tammy16b_4e5ec89e:

    # pc "Seriously, you're looking good. Moving fast. Staying on your toes."
    pc "Im Ernst, du siehst gut aus. Du bewegst dich schnell. Bleib auf den Zehenspitzen."

# game/Scenes/Tammy/tammy16.rpy:129
translate german tammy16b_eafbc9cd:

    # pc "I liked those leg kicks. They seemed to slow her down a bit. Her being slow is good. You can take advantage of that."
    pc "Die Beintritte haben mir gefallen. Die scheinen sie ein bisschen verlangsamt zu haben. Dass sie langsam ist, ist gut. Das kannst du ausnutzen."

# game/Scenes/Tammy/tammy16.rpy:130
translate german tammy16b_2d3b068d:

    # pc "Just be careful about her taking you down."
    pc "Pass nur auf, dass sie dich nicht zu Boden bringt."

# game/Scenes/Tammy/tammy16.rpy:131
translate german tammy16b_ec4282cb:

    # tm "Yeah, that's what I'm scared of. I've never been on the ground with her before."
    tm "Ja, genau davor habe ich Angst. Ich war noch nie mit ihr am Boden."

# game/Scenes/Tammy/tammy16.rpy:132
translate german tammy16b_6ef7cd76:

    # pc "You got this. I'm pretty sure you won that first round. Just keep moving and stay hard to hit."
    pc "Du schaffst das. Ich bin mir ziemlich sicher, dass du die erste Runde gewonnen hast. Bleib einfach in Bewegung und lass dich nicht treffen."

# game/Scenes/Tammy/tammy16.rpy:133
translate german tammy16b_850254f5:

    # tm "You got it. Thanks, coach."
    tm "Verstanden. Danke, Coach."

# game/Scenes/Tammy/tammy16.rpy:136
translate german tammy16b_2221ccc4:

    # "When the bell rings, they're right back in the middle of the ring again, trading punches."
    "Als die Glocke läutet, stehen sie sofort wieder in der Mitte des Rings und tauschen Schläge aus."

# game/Scenes/Tammy/tammy16.rpy:137
translate german tammy16b_c6a976b0:

    # "Tammy is able to block most of Sara's punches and sneak in a few of her own."
    "Tammy kann die meisten von Saras Schlägen abwehren und selbst ein paar unterbringen."

# game/Scenes/Tammy/tammy16.rpy:140
translate german tammy16b_9dbf1b1c:

    # "Then Tammy hops back and gets another hard kick to Sara's leg, the slap of shin on thigh echoing through the gym."
    "Dann hüpft Tammy zurück und landet einen weiteren harten Tritt gegen Saras Bein, wobei das Aufprallen des Schienbeins auf den Oberschenkel durch die Halle hallt."

# game/Scenes/Tammy/tammy16.rpy:141
translate german tammy16b_4c60ba4c:

    # "Sara winces. That one hurt."
    "Sara zuckt zusammen. Der hat wehgetan."

# game/Scenes/Tammy/tammy16.rpy:144
translate german tammy16b_e41ad8f5:

    # "The pain and the frustration gets to Sara then and she growls in anger as she charges forward."
    "Der Schmerz und die Frustration überwältigen Sara in diesem Moment und sie knurrt vor Wut, während sie nach vorne stürmt."

# game/Scenes/Tammy/tammy16.rpy:145
translate german tammy16b_03576045:

    # "She's throwing haymakers now, backing Tammy up towards the ropes."
    "Sie schlägt jetzt mit voller Wucht zu und drängt Tammy zurück in Richtung Seile."

# game/Scenes/Tammy/tammy16.rpy:146
translate german tammy16b_028976a4:

    # "Sara has lost all defense in this moment. If Tammy could take advantage of it, she might be able to end the fight."
    "Sara hat in diesem Moment jegliche Verteidigung verloren. Wenn Tammy das ausnutzen könnte, wäre sie vielleicht in der Lage, den Kampf zu beenden."

# game/Scenes/Tammy/tammy16.rpy:149
translate german tammy16b_5dc11d33:

    # "But then one of the punches connects, cracking against Tammy's jaw and rolling her eyes back."
    "Doch dann trifft einer der Schläge, knallt gegen Tammys Kiefer und lässt ihre Augen nach hinten rollen."

# game/Scenes/Tammy/tammy16.rpy:150
translate german tammy16b_ade70eed:

    # "I hear Suzy in the back cry out in shock as Tammy falls to the mat."
    "Ich höre, wie Suzy im Hintergrund vor Schreck aufschreit, als Tammy auf die Matte fällt."

# game/Scenes/Tammy/tammy16.rpy:153
translate german tammy16b_76769a9d:

    # "At first, I think that's it, that Tammy is knocked out, but she quickly shakes her head and starts fighting back."
    "Zuerst denke ich, das war’s, dass Tammy k.o. ist, aber sie schüttelt schnell den Kopf und beginnt, sich zu wehren."

# game/Scenes/Tammy/tammy16.rpy:154
translate german tammy16b_8cf6bab3:

    # "But now Sara is on top of her, raining punches down onto her."
    "Doch nun sitzt Sara auf ihr und lässt eine Schläge auf sie niederprasseln."

# game/Scenes/Tammy/tammy16.rpy:155
translate german tammy16b_f5522b72:

    # "Chuck is close and I can tell he's about to stop the fight."
    "Chuck ist ganz nah und ich merke, dass er im Begriff ist, den Kampf abzubrechen."

# game/Scenes/Tammy/tammy16.rpy:158
translate german tammy16b_12ebb29b:

    # "What happens next is so fast that I can barely follow it."
    "Was als Nächstes passiert, geht so schnell, dass ich es kaum verfolgen kann."

# game/Scenes/Tammy/tammy16.rpy:159
translate german tammy16b_a46fd698:

    # "Tammy grabs Sara's wrist and bucks her hips, moving her legs up towards Sara's head."
    "Tammy packt Saras Handgelenk, stößt ihre Hüften nach oben und bewegt ihre Beine in Richtung Saras Kopf."

# game/Scenes/Tammy/tammy16.rpy:162
translate german tammy16b_14e97ff6:

    # "Then Tammy rotates and has Sara's arm fully stretched out."
    "Dann dreht sich Tammy und streckt Saras Arm vollständig durch."

# game/Scenes/Tammy/tammy16.rpy:163
translate german tammy16b_ca12b0e7:

    # "Sara cries out in pain. If she doesn't tap soon, Tammy could easily break her arm."
    "Sara schreit vor Schmerz. Wenn sie nicht bald aufgibt, könnte Tammy ihr leicht den Arm brechen."

# game/Scenes/Tammy/tammy16.rpy:166
translate german tammy16b_f3df8ee4:

    # "She reluctantly taps and the crowd goes insane."
    "Sie gibt widerwillig auf und die Menge tobt."

# game/Scenes/Tammy/tammy16.rpy:169
translate german tammy16b_2d3791c3:

    # "I can't hear anything, the room is so loud and suddenly Suzy is right there, jumping up onto my shoulder."
    "Ich kann nichts hören, es ist so laut im Raum, und plötzlich ist Suzy direkt neben mir und springt auf meine Schulter."

# game/Scenes/Tammy/tammy16.rpy:170
translate german tammy16b_be32fa84:

    # "I hold her high while she cheers."
    "Ich halte sie hoch, während sie jubelt."

# game/Scenes/Tammy/tammy16.rpy:173
translate german tammy16b_411f816b:

    # "Chuck announces the winner, but it's impossible to hear him over the roaring crowd."
    "Chuck verkündet die Siegerin, aber es ist unmöglich, ihn über die tosende Menge hinweg zu hören."

# game/Scenes/Tammy/tammy16.rpy:174
translate german tammy16b_67d97e00:

    # "Tammy and Sara are both crying in the ring. Suzy's crying on my shoulder. Hell, I'm crying a little bit too."
    "Tammy und Sara weinen beide im Ring. Suzy weint an meiner Schulter. Verdammt, ich weine auch ein bisschen."

# game/Scenes/Tammy/tammy16.rpy:177
translate german tammy16b_09e2a5ca:

    # "Then Tammy runs over and kisses Suzy."
    "Dann rennt Tammy herüber und küsst Suzy."

# game/Scenes/Tammy/tammy16.rpy:178
translate german tammy16b_5354153a:

    # ss "You're a fucking queen! I love you!"
    ss "Du bist eine verdammte Königin! Ich liebe dich!"

# game/Scenes/Tammy/tammy16.rpy:179
translate german tammy16b_4039bf0e:

    # tm "I love both of you so fucking much!"
    tm "Ich liebe euch beide so verdammt sehr!"

# game/Scenes/Tammy/tammy16.rpy:182
translate german tammy16b_c191fa62:

    # "The next half hour passes by in a blur as everybody congratulates Tammy and wants to talk to her and Sara."
    "Die nächste halbe Stunde vergeht wie im Flug, während alle Tammy gratulieren und mit ihr und Sara reden wollen."

# game/Scenes/Tammy/tammy16.rpy:183
translate german tammy16b_693b77ad:

    # "I hear them already planning another fight. Maybe in Whiterock next time."
    "Ich höre, wie sie schon den nächsten Kampf planen. Vielleicht das nächste Mal in Whiterock."

# game/Scenes/Tammy/tammy16.rpy:187
translate german tammy16b_3c502a36:

    # "Eventually the gym clears out. Tammy and Sara head back to the showers together, while Suzy and I wait up front for her."
    "Schließlich leert sich die Halle. Tammy und Sara gehen zusammen zurück zu den Duschen, während Suzy und ich vorne auf sie warten."

# game/Scenes/Tammy/tammy16.rpy:188
translate german tammy16b_559ff5f9:

    # ss "Tonight was crazy."
    ss "Heute Abend war es verrückt."

# game/Scenes/Tammy/tammy16.rpy:189
translate german tammy16b_c417e350:

    # pc "Yeah."
    pc "Ja."

# game/Scenes/Tammy/tammy16.rpy:190
translate german tammy16b_90a33a46:

    # ss "I've never seen her take a punch that hard. That was scary."
    ss "Ich habe noch nie gesehen, dass sie so einen harten Schlag abbekommen hat. Das war beängstigend."

# game/Scenes/Tammy/tammy16.rpy:191
translate german tammy16b_a0a77eb7:

