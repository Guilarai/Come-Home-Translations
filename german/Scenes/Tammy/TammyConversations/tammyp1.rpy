translate german tammyp1_f68fca00:

    # tm "Serious? No, not really."
    tm "Ernsthaft? Nein, nicht wirklich."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:13
translate german tammyp1_45410ac1:

    # tm "I don't even think that I've had any that I would call a boyfriend, serious or not."
    tm "Ich glaube nicht mal, dass ich jemals jemanden hatte, den ich als Freund bezeichnen würde, ob ernsthaft oder nicht."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:15
translate german tammyp1_9613f9be:

    # tm "Fuck-buddies, one-night-stands, and friends-with-benefits. That's about it really."
    tm "Fick-Kumpels, One-Night-Stands und Freunde mit gewissen Vorzügen. Das war’s eigentlich auch schon."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:16
translate german tammyp1_a4d167d7:

    # pc "Just not interested in anything serious?"
    pc "Einfach kein Interesse an etwas Ernstem?"

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:18
translate german tammyp1_e8284d4f:

    # tm "Not really?"
    tm "Nicht wirklich?"

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:19
translate german tammyp1_d5059dde:

    # tm "I mean, maybe one day, but I'm in no hurry to settle down."
    tm "Ich meine, vielleicht irgendwann mal, aber ich habe es nicht eilig, mich festzulegen."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:20
translate german tammyp1_2a7e7bf2:

    # pc "I get that. You're still young."
    pc "Ich verstehe das. Du bist noch jung."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:21
translate german tammyp1_66cb2833:

    # tm "Oh don't give me that crap. You're only like three years older."
    tm "Ach komm mir nicht mit diesem Quatsch. Du bist doch nur etwa drei Jahre älter."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:22
translate german tammyp1_cc48a516:

    # pc "Fine. We're still young."
    pc "Na gut. Wir sind noch jung."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:23
translate german tammyp1_1dc3a604:

    # tm "Yeah we are. No reason to settle down yet."
    tm "Ja, das sind wir. Kein Grund, sich schon festzulegen."

# game/Scenes/Tammy/TammyConversations/tammyp1.rpy:25
translate german tammyp1_1124e964:

    # tm "I just want to have fun."
    tm "Ich will einfach nur Spaß haben."

