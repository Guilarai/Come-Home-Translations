# game/Scenes/Tammy/TammyMMA/tammymma.rpy:17
translate german tammymmanormal_55eb3e45:

    # tm "All right! I'm glad you came. Let's get to business."
    tm "Alles klar! Ich bin froh, dass du gekommen bist. Lass uns zur Sache kommen."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:18
translate german tammymmanormal_095f6c6f:

    # tm "We're going to start with some stand-up. Get you started on the base punching and kicking technique."
    tm "Wir fangen mit ein paar Stand-up-Übungen an. Ich bringe dir die grundlegenden Schlag- und Tritttechniken bei."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:19
translate german tammymmanormal_bccaba74:

    # pc "You're going to punch me, aren't you?"
    pc "Du wirst mich schlagen, oder?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:21
translate german tammymmanormal_e526c3d8:

    # tm "Oh definitely."
    tm "Oh, auf jeden Fall."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:23
translate german tammymmanormal_98c55581:

    # "I get up into the ring with Tammy and she demonstrates punching."
    "Ich steige mit Tammy in den Ring und sie demonstriert mir die Schläge."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:24
translate german tammymmanormal_65f9479a:

    # "I try to block, but I just don't have the motions down yet."
    "Ich versuche zu blocken, aber ich habe die Bewegungen noch nicht ganz drauf."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:26
translate german tammymmanormal_295f5a57:

    # "And kicking."
    "Und Tritte."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:27
translate german tammymmanormal_70863c7f:

    # "It hurts, but I can tell she's not going full-strength."
    "Es tut weh, aber ich merke, dass sie nicht mit voller Kraft zuschlägt."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:29
translate german tammymmanormal_8aa64221:

    # "Then she gives me a chance to try to hit her."
    "Dann gibt sie mir die Chance, zu versuchen, sie zu treffen."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:30
translate german tammymmanormal_90068145:

    # "But she blocks every punch I throw."
    "Aber sie blockt jeden Schlag ab, den ich ausführe."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:32
translate german tammymmanormal_dd5027d0:

    # tm "Focus on technique. Don't worry about actually hitting me, just make sure that your movements are correct."
    tm "Konzentriere dich auf die Technik. Mach dir keine Gedanken darüber, mich tatsächlich zu treffen, achte einfach darauf, dass deine Bewegungen korrekt sind."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:35
translate german tammymmanormal_bfe308ae:

    # "Tammy and I spar in the ring for a while."
    "Tammy und ich sparren eine Weile im Ring."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:39
translate german tammymmanormal_0bc42d9a:

    # tm "You did good for a first session."
    tm "Das hast du für eine erste Einheit gut gemacht."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:42
translate german tammymmanormal_a242518d:

    # tm "Good job. Keep training with me and you'll be a fighting machine in no time."
    tm "Gut gemacht. Trainier weiter mit mir und du wirst im Handumdrehen eine Kampfmaschine sein."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:45
translate german tammymmanormal_cc85c375:

    # "Now I need to hurry and get to school."
    "Jetzt muss ich mich beeilen und zur Schule."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:48
translate german tammymmanormal_7844d429:

    # tm "Want to hit the showers with me?"
    tm "Willst du mit mir duschen gehen?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:52
translate german tammymmanormal_f7e04aed:

    # "I feel sore and tired, but it was fun and I did learn a lot."
    "Ich bin erschöpft und habe Muskelkater, aber es hat Spaß gemacht und ich habe viel gelernt."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:53
translate german tammymmanormal_37ff6d3e:

    # "We say our goodbyes and go our separate ways."
    "Wir verabschieden uns und gehen getrennte Wege."

