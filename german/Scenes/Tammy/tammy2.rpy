# game/Scenes/Tammy/tammy2.rpy:12
translate german tammy2_58882cf4:

    # "I spend some time working out with Tammy."
    "Ich verbringe einige Zeit damit, mit Tammy zu trainieren."

# game/Scenes/Tammy/tammy2.rpy:13
translate german tammy2_f8739613:

    # "First I spot her."
    "Zuerst passe ich auf sie auf."

# game/Scenes/Tammy/tammy2.rpy:16
translate german tammy2_b03ba21e:

    # "Then she spots me."
    "Dann passt sie auf mich auf."

# game/Scenes/Tammy/tammy2.rpy:20
translate german tammy2_f59c8527:

    # "Then we start chatting a bit between reps."
    "Dann fangen wir an, uns zwischen den Sätzen ein bisschen zu unterhalten."

# game/Scenes/Tammy/tammy2.rpy:21
translate german tammy2_e027ab69:

    # tm "You ever think about trying MMA?"
    tm "Hast du schon mal darüber nachgedacht, MMA auszuprobieren?"

# game/Scenes/Tammy/tammy2.rpy:22
translate german tammy2_08f599b9:

    # pc "MMA? Like fighting?"
    pc "MMA? So wie Kämpfen?"

# game/Scenes/Tammy/tammy2.rpy:23
translate german tammy2_7ed92c4d:

    # tm "Yeah, like fighting. I train every weekend in the morning."
    tm "Ja, so wie Kämpfen. Ich trainiere jedes Wochenende morgens."

# game/Scenes/Tammy/tammy2.rpy:24
translate german tammy2_690f9781:

    # tm "You could come join me sometime."
    tm "Du könntest mal mitkommen."

# game/Scenes/Tammy/tammy2.rpy:25
translate german tammy2_50211aa2:

    # pc "You're just looking for an excuse to beat me up."
    pc "Du suchst nur nach einer Ausrede, um mich zu verprügeln."

# game/Scenes/Tammy/tammy2.rpy:27
translate german tammy2_d669bb2f:

    # "She punches me hard in the arm."
    "Sie schlägt mir hart auf den Arm."

# game/Scenes/Tammy/tammy2.rpy:28
translate german tammy2_68bd08bc:

    # tm "Ha! I don't need an excuse for that."
    tm "Ha! Dafür brauche ich keine Ausrede."

# game/Scenes/Tammy/tammy2.rpy:29
translate german tammy2_dedf8f6f:

    # pc "Ow! Damn."
    pc "Aua! Verdammt."

# game/Scenes/Tammy/tammy2.rpy:31
translate german tammy2_eb4630f0:

    # tm "See that's why you need to come train in MMA. You got a nice body, but you're too soft."
    tm "Siehst du, genau deshalb musst du zum MMA-Training kommen. Du hast einen schönen Körper, aber du bist zu weich."

# game/Scenes/Tammy/tammy2.rpy:32
translate german tammy2_eb998a13:

    # pc "You think I have a nice body?"
    pc "Du findest, ich habe einen schönen Körper?"

# game/Scenes/Tammy/tammy2.rpy:33
translate german tammy2_9ac6fb46:

    # tm "Well, yeah."
    tm "Na ja, schon."

# game/Scenes/Tammy/tammy2.rpy:34
translate german tammy2_cce51848:

    # pc "Alright, I'll come wrestle with you some time."
    pc "Okay, ich komme mal vorbei und ringe mit dir."

# game/Scenes/Tammy/tammy2.rpy:35
translate german tammy2_bdefbf8e:

    # tm "Good. I'm looking forward to it. Mornings and Afternoons on the weekends, I'll be here."
    tm "Gut. Ich freu mich drauf. Am Wochenende bin ich morgens und nachmittags hier."

# game/Scenes/Tammy/tammy2.rpy:39
translate german tammy2_7cd89556:

    # "We finish our workout and say goodbye to each other."
    "Wir beenden unser Training und verabschieden uns voneinander."

# game/Scenes/Tammy/tammy2.rpy:41
translate german tammy2_d33670c7:

    # "I have to admit, rolling around on the mat with her has a certain appeal."
    "Ich muss zugeben, mit ihr auf der Matte herumzurollen, hat einen gewissen Reiz."

# game/Scenes/Tammy/tammy2.rpy:42
translate german tammy2_bf0d0df4:

    # "For now though, I leave the gym and go out to my car."
    "Aber erst mal verlasse ich das Fitnessstudio und gehe zu meinem Auto."

translate german strings:

    # game/Scenes/Tammy/tammy2.rpy:2
    old "Workout with Tammy on the weekend again."
    new "Trainier am Wochenende wieder mit Tammy."

    # game/Scenes/Tammy/tammy2.rpy:3
    old "Then she will ask if you want to train MMA with her."
    new "Dann wird sie dich fragen, ob du mit ihr MMA trainieren willst."

