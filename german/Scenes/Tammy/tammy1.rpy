# game/Scenes/Tammy/tammy1.rpy:53
translate german tammy1_6f40d8bb:

    # "I should check out that boxing club in the afternoon on the weekend sometime."
    "Ich sollte mir diesen Boxclub am Wochenende mal am Nachmittag ansehen."

# game/Scenes/Tammy/tammy1.rpy:57
