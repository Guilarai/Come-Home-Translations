# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:12
translate german julianaq3_257df889:

    # bn "Are you seeing other girls?"
    bn "Triffst du dich auch mit anderen Mädchen?"

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:16
translate german julianaq3_deef2833:

    # bn "I figured."
    bn "Das habe ich mir schon gedacht."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:17
translate german julianaq3_09696dc4:

    # bn "That's okay. I'm not looking for anything serious really."
    bn "Das ist okay. Ich suche eigentlich nichts Ernstes."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:21
translate german julianaq3_b69318c3:

    # bn "Really? Just me?"
    bn "Wirklich? Nur mich?"

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:22
translate german julianaq3_29bd1f5e:

    # bn "I should tell you then that I'm not really looking for anything serious."
    bn "Dann sollte ich dir sagen, dass ich auch nicht wirklich etwas Ernstes suche."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:24
translate german julianaq3_56db5227:

    # bn "I feel like I should sleep with around five guys or so, maybe some girls too, before I decide to be exclusive with anybody."
    bn "Ich habe das Gefühl, ich sollte mit etwa fünf Jungs schlafen, vielleicht auch mit ein paar Mädchen, bevor ich mich entscheide, mit jemandem eine feste Beziehung einzugehen."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:25
translate german julianaq3_218f8d04:

    # bn "Not that I'm in a big hurry or anything."
    bn "Nicht, dass ich es besonders eilig hätte oder so."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:26
translate german julianaq3_5dd1b732:

    # bn "I just want to make sure that I try a few different people before I decide what I like."
    bn "Ich will nur sichergehen, dass ich ein paar verschiedene Leute ausprobiere, bevor ich mich entscheide, was mir gefällt."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:30
translate german julianaq3_207b8ce0:

    # bn "I'm glad you're okay with it."
    bn "Ich bin froh, dass du damit kein Problem hast."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:33
translate german julianaq3_a3dfa0a9:

    # bn "Then you're going to have to just show me that there couldn't possibly be anyone better out there."
    bn "Dann musst du mir einfach zeigen, dass es unmöglich jemanden Besseren da draußen geben könnte."

# game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:34
translate german julianaq3_eff253cc:

    # pc "I might be able to do that."
    pc "Das könnte ich vielleicht schaffen."

translate german strings:

    # game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:28
    old "That makes sense"
    new "Das leuchtet ein."

    # game/Scenes/Juliana/JulianaConversations/julianaq3.rpy:31
    old "What if I don't want you to see anybody else?"
    new "Was, wenn ich nicht will, dass du dich mit anderen triffst?"

