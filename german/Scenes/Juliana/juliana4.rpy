    bn "Das ist alles ganz neu für mich, ich muss es langsam angehen lassen."

# game/Scenes/Juliana/juliana4.rpy:189
translate german juliana4_fe333677:

    # bn "I'll let you know when I'm ready."
    bn "Ich sag dir Bescheid, wenn ich bereit bin."

# game/Scenes/Juliana/juliana4.rpy:190
translate german juliana4_f2a25528:

    # pc "That's fine. No hurry."
    pc "Das ist in Ordnung. Keine Eile."

# game/Scenes/Juliana/juliana4.rpy:191
translate german juliana4_7767853c:

    # bn "Thank you, [pcname]."
    bn "Danke, [pcname]."

# game/Scenes/Juliana/juliana4.rpy:195
translate german juliana4_708f41ce:

    # bn "I enjoyed that, but you should probably go."
    bn "Das hat mir Spaß gemacht, aber du solltest jetzt wohl gehen."

# game/Scenes/Juliana/juliana4.rpy:196
translate german juliana4_5223f941:

    # bn "Thank you again for helping me out though. You're a good person."
    bn "Trotzdem nochmals danke, dass du mir geholfen hast. Du bist ein guter Mensch."

# game/Scenes/Juliana/juliana4.rpy:197
translate german juliana4_07c9c5ab:

    # pc "You're welcome."
    pc "Gern geschehen."

# game/Scenes/Juliana/juliana4.rpy:200
translate german juliana4_92b8b462:

    # bn "I'll see you later, [pcname]."
    bn "Bis später, [pcname]."

# game/Scenes/Juliana/juliana4.rpy:201
translate german juliana4_65609586:

    # pc "Okay, bye Juliana."
    pc "Okay, tschüss, Juliana."

# game/Scenes/Juliana/juliana4.rpy:204
translate german juliana4_001c1069:

    # "She walks me down to the front door and let me out, locking it behind me."
    "Sie begleitet mich zur Haustür, lässt mich hinaus und schließt hinter mir ab."

# game/Scenes/Juliana/juliana4.rpy:209
translate german juliana4_8ea4ab8e:

    # "I'm a little surprised at how inexperienced she is in romantic things."
    "Ich bin ein wenig überrascht, wie unerfahren sie in romantischen Dingen ist."

# game/Scenes/Juliana/juliana4.rpy:210
translate german juliana4_d537cd20:

    # "Does that mean that she is a virgin?"
    "Heißt das, dass sie noch Jungfrau ist?"

# game/Scenes/Juliana/juliana4.rpy:211
translate german juliana4_6fd7fe6b:

    # "It seems possible for sure."
    "Das scheint auf jeden Fall möglich zu sein."

# game/Scenes/Juliana/juliana4.rpy:212
translate german juliana4_2140f844:

    # "I'd love to help her out with that."
    "Ich würde ihr dabei gerne helfen."

