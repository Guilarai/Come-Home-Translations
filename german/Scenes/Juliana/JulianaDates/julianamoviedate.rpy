# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:32
translate german julianamovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Wir kommen im Kino an und setzen uns ganz nach hinten."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:33
translate german julianamovietheaterstartdate_cd1f1d61:

    # bn "What kind of movie are we watching?"
    bn "Was für einen Film schauen wir uns an?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:37
translate german julianamovietheaterstartdate_9753ecc6:

    # bn "That sounds very nice."
    bn "Das klingt sehr schön."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:38
translate german julianamovietheaterstartdate_08edcd3e:

    # bn "I like romantic movies."
    bn "Ich mag romantische Filme."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:43
translate german julianamovietheaterstartdate_22be6204:

    # bn "Oh really?"
    bn "Ach wirklich?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:44
translate german julianamovietheaterstartdate_a7aa68a8:

    # bn "I'm not really interested dumb action movies, but okay."
    bn "Ich interessiere mich nicht wirklich für dumme Actionfilme, aber okay."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:50
translate german julianamovietheaterstartdate_a36785e7:

    # bn "Oh really? I don't really like scary movies at all."
    bn "Ach wirklich? Ich mag Horrorfilme überhaupt nicht."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:51
translate german julianamovietheaterstartdate_5b88690f:

    # bn "Unless they're about hauntings, or they have some sort of romance in them."
    bn "Es sei denn, es geht um Spuk oder sie enthalten eine Art Liebesgeschichte."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:52
translate german julianamovietheaterstartdate_ffedd8a3:

    # bn "Most horror movies are really dumb."
    bn "Die meisten Horrorfilme sind wirklich dumm."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:58
translate german julianamovietheaterstartdate_352ba7de:

    # bn "Oh okay."
    bn "Oh okay."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:59
translate german julianamovietheaterstartdate_9c6a96f5:

    # bn "I try to enjoy comedies, but I don't always get the jokes."
    bn "Ich versuche, Komödien zu genießen, aber ich verstehe die Witze nicht immer."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:60
translate german julianamovietheaterstartdate_74eb3e05:

    # bn "There's a lot of times that I just don't understand what is supposed to be funny and what's not."
    bn "Es kommt oft vor, dass ich einfach nicht verstehe, was lustig sein soll und was nicht."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:61
translate german julianamovietheaterstartdate_cf50250b:

    # bn "But I'll try my best to laugh at the parts I'm supposed to."
    bn "Aber ich werde mein Bestes geben, an den Stellen zu lachen, an denen ich lachen soll."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:63
translate german julianamovietheaterstartdate_2fcc7df5:

    # "There's a little time before the movie starts for us to chat some."
    "Es bleibt noch ein bisschen Zeit, bevor der Film anfängt, damit wir uns ein bisschen unterhalten können."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:67
translate german julianamovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Endlich beginnt der Film und wir verstummen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:70
translate german julianamovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Sie streckt die Hand aus und hält meine Hand auf der Armlehne."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:74
translate german julianamovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Die Trailer dauern etwa fünfzehn Minuten, dann geht der Film richtig los."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:78
translate german julianamovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Während des Films lehnt sie sich an meine Schulter und taucht ganz in die Geschichte ein."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:80
translate german julianamovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Dann, während einer besonders romantischen Szene, hebt sie den Kopf und legt ihre Lippen auf meine."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:81
translate german julianamovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "Den Rest des Films sehen wir uns nicht wirklich an, sondern konzentrieren uns stattdessen darauf, rumzumachen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:84
translate german julianamovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Während des Films lehnt sie sich an meine Schulter und taucht ganz in die Geschichte ein."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:86
translate german julianamovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Der Film scheint ihr ganz gut zu gefallen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:89
translate german julianamovietheaterstartdate_dcbaecf4:

    # "Juliana watches the movie, but she looks annoyed the entire time."
    "Juliana schaut sich den Film an, sieht aber die ganze Zeit genervt aus."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:92
translate german julianamovietheaterstartdate_40670365:

    # "Eventually, she turns towards me."
    "Schließlich dreht sie sich zu mir um."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:93
translate german julianamovietheaterstartdate_b867ff88:

    # bn "This movie is really bad, isn't it? It might be the worst movie I've ever seen."
    bn "Dieser Film ist wirklich schlecht, oder? Das könnte der schlechteste Film sein, den ich je gesehen habe."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:94
translate german julianamovietheaterstartdate_e3d0d8a6:

    # "She does not speak quietly, and some people in front of us turn and look at us."
    "Sie spricht nicht leise, und einige Leute vor uns drehen sich um und schauen uns an."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:95
translate german julianamovietheaterstartdate_d58327fc:

    # pc "Do you want to leave?"
    pc "Willst du gehen?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:97
translate german julianamovietheaterstartdate_25b2e9a4:

    # bn "No, can we just kiss or something instead? I don't care about watching this."
    bn "Nein, können wir uns stattdessen einfach küssen oder so? Mir ist es egal, ob wir das anschauen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:98
translate german julianamovietheaterstartdate_4f1735dd:

    # pc "Sounds good to me."
    pc "Klingt gut für mich."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:100
translate german julianamovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Ich beuge mich vor und küsse sie, und wir schauen uns den Film nicht mehr wirklich an, sondern konzentrieren uns stattdessen aufeinander."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:103
translate german julianamovietheaterstartdate_c1b8c885:

    # "The horror movie was not about hauntings and had no romance in it."
    "In dem Horrorfilm ging es nicht um Spuk und es gab keine Romanze darin."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:104
translate german julianamovietheaterstartdate_003c9dc3:

    # "I'm pretty sure Juliana hated it."
    "Ich bin mir ziemlich sicher, dass Juliana ihn gehasst hat."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:105
translate german julianamovietheaterstartdate_27d6edde:

    # "At one point, I even tried holding her hand, but she was not interested."
    "Einmal habe ich sogar versucht, ihre Hand zu halten, aber sie hatte kein Interesse."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:106
translate german julianamovietheaterstartdate_d58327fc_1:

    # pc "Do you want to leave?"
    pc "Willst du gehen?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:107
translate german julianamovietheaterstartdate_4aa1d16b:

    # bn "We're already too far in. I have to know which of these dumb girls is going to live."
    bn "Wir sind schon zu weit drin. Ich muss wissen, welche dieser dummen Mädchen überleben wird."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:108
translate german julianamovietheaterstartdate_880b4aa8:

    # pc "Okay..."
    pc "Okay..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:111
translate german julianamovietheaterstartdate_92b7555a:

    # "At first, I'm not sure that Juliana is going to like the movie at all."
    "Zuerst bin ich mir nicht sicher, ob Juliana den Film überhaupt mögen wird."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:112
translate german julianamovietheaterstartdate_c421db42:

    # "She looks frustrated through the beginning."
    "Am Anfang sieht sie frustriert aus."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:113
translate german julianamovietheaterstartdate_4e4b3a2b:

    # "But then..."
    "Aber dann..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:115
translate german julianamovietheaterstartdate_bd97c290:

    # "During one of the dumb jokes, she bursts into a fit of laughter that seems to go on forever."
    "Während eines der dummen Witze bricht sie in einen Lachanfall aus, der ewig anzuhalten scheint."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:116
translate german julianamovietheaterstartdate_fa75bbc3:

    # pc "Are you okay?"
    pc "Geht es dir gut?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:117
translate german julianamovietheaterstartdate_5b62109c:

    # bn "Yes. I'm sorry. It's so funny though."
    bn "Ja. Tut mir leid. Aber es ist so lustig."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:118
translate german julianamovietheaterstartdate_6ecb5d88:

    # bn "It's funny because he farted in a place where it was awkward to fart."
    bn "Es ist lustig, weil er an einem Ort gefurzt hat, an dem es peinlich ist zu furzen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:119
translate german julianamovietheaterstartdate_b59d1ff2:

    # bn "And he couldn't stop farting!"
    bn "Und er konnte nicht aufhören zu furzen!"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:120
translate german julianamovietheaterstartdate_9ef4273c:

    # "Once she starts laughing, she barely stops throughout the rest of the movie."
    "Sobald sie anfängt zu lachen, hört sie für den Rest des Films kaum noch auf."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:124
translate german julianamovietheaterstartdate_e42d81a7:

    # bn "I really liked that. I love when they go through some hardships, but stay together in the end."
    bn "Das hat mir wirklich gut gefallen. Ich liebe es, wenn sie einige Schwierigkeiten durchmachen, aber am Ende zusammenbleiben."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:125
translate german julianamovietheaterstartdate_fe15de53:

    # bn "Thank you for bringing me. I enjoyed all of it."
    bn "Danke, dass du mich mitgenommen hast. Mir hat alles gefallen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:129
translate german julianamovietheaterstartdate_71eb6066:

    # bn "Well, thanks for bringing me, but maybe not an action movie next time?"
    bn "Na ja, danke, dass du mich mitgenommen hast, aber vielleicht lieber kein Actionfilm das nächste Mal?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:130
translate german julianamovietheaterstartdate_6f6931a9:

    # bn "Even the noise of it was giving me a headache."
    bn "Schon der Lärm hat mir Kopfschmerzen bereitet."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:134
translate german julianamovietheaterstartdate_5bf0a9a9:

    # bn "That was the dumbest thing I've ever seen in my life."
    bn "Das war das Dümmste, was ich je in meinem Leben gesehen habe."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:135
translate german julianamovietheaterstartdate_2f39e364:

    # pc "It was pretty bad."
    pc "Es war ziemlich schlecht."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:136
translate german julianamovietheaterstartdate_02a07558:

    # bn "I hated it."
    bn "Ich fand es schrecklich."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:137
translate german julianamovietheaterstartdate_09c476ba:

    # bn "No more horror movies. They're all trash."
    bn "Keine Horrorfilme mehr. Die sind alle Müll."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:138
translate german julianamovietheaterstartdate_459e0f19:

    # pc "Okay. No more horror movies."
    pc "Okay. Keine Horrorfilme mehr."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:141
translate german julianamovietheaterstartdate_850f6df3:

    # bn "That was so funny."
    bn "Das war so lustig."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:142
translate german julianamovietheaterstartdate_4083c4d8:

    # bn "I'm sorry if I laughed too much."
    bn "Tut mir leid, wenn ich zu viel gelacht habe."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:143
translate german julianamovietheaterstartdate_cd4369b1:

    # pc "No, it was fun to see you cut loose like that."
    pc "Nein, es hat Spaß gemacht, dich so aus dir herausgehen zu sehen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:144
translate german julianamovietheaterstartdate_f50c4948:

    # bn "I guess I don't laugh very often, huh?"
    bn "Ich schätze, ich lache nicht sehr oft, oder?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:145
translate german julianamovietheaterstartdate_b459f5c7:

    # bn "But when I do... wow, you have to look out."
    bn "Aber wenn ich es tue … wow, dann musst du aufpassen."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:146
translate german julianamovietheaterstartdate_985a02fd:

    # "We hang out after the movie and chat during the credits."
    "Wir bleiben nach dem Film noch zusammen und unterhalten uns während des Abspanns."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:150
translate german julianamovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Als der Abspann endet, gehen wir gemeinsam nach draußen zu meinem Auto."

