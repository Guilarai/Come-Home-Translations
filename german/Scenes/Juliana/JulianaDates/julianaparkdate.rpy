# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:28
translate german julianaparkstartdate_1271ced5:

    # "Juliana and I walk around the trails, chit-chatting for a while."
    "Juliana und ich spazieren die Wege entlang und plaudern eine Weile."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:36
translate german julianaparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "Schließlich erreichen wir die Bank auf halber Strecke."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:42
translate german julianaparkstartdate_d2cc15d6:

    # "We sit next to each other on the bench for a bit, listening to the morning birds sing."
    "Wir sitzen eine Weile nebeneinander auf der Bank und lauschen dem morgendlichen Vogelgezwitscher."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:44
translate german julianaparkstartdate_7104b1ef:

    # bn "This is really nice."
    bn "Das ist wirklich schön."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:45
translate german julianaparkstartdate_c417e350:

    # pc "Yeah."
    pc "Ja."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:47
translate german julianaparkstartdate_7bdeb8b7:

    # bn "I really like you, [pcname]. I look forward to any time I get to spend with you."
    bn "Ich mag dich wirklich sehr, [pcname]. Ich freue mich auf jede Minute, die ich mit dir verbringen kann."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:48
translate german julianaparkstartdate_d7904a68:

    # pc "I like you too, Juliana."
    pc "Ich mag dich auch, Juliana."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:49
translate german julianaparkstartdate_cde9a4ac:

    # bn "Do you maybe want to kiss some more? Like we did on my bed?"
    bn "Willst du dich vielleicht noch ein bisschen mehr küssen? So wie auf meinem Bett?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:51
translate german julianaparkstartdate_f49a462d:

    # "I lean in and kiss her and she pulls me in deeper, hungry for more."
    "Ich beuge mich vor und küsse sie, und sie zieht mich tiefer an sich, hungrig nach mehr."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:52
translate german julianaparkstartdate_78efd588:

    # "She moans into my mouth, barely able to control her hands as they touch my chest and arms."
    "Sie stöhnt in meinen Mund hinein und kann ihre Hände kaum unter Kontrolle halten, während sie meine Brust und meine Arme berühren."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:54
translate german julianaparkstartdate_79d7237e:

    # "I touch her too, keeping my hands away from her more sensitive areas for now. I'm not sure how far she is ready to go and I don't want to pressure her."
    "Ich berühre sie auch, halte meine Hände aber vorerst von ihren empfindlicheren Stellen fern. Ich bin mir nicht sicher, wie weit sie bereit ist zu gehen, und ich will sie nicht unter Druck setzen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:55
translate german julianaparkstartdate_2cb8d2e6:

    # "We kiss like that for a while before finally pulling away."
    "Wir küssen uns eine Weile so, bevor wir uns schließlich voneinander lösen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:57
translate german julianaparkstartdate_5f798c5f:

    # bn "Wow."
    bn "Wow."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:58
translate german julianaparkstartdate_6a1c0d46:

    # bn "I've never felt like that before. It's incredible."
    bn "So habe ich mich noch nie gefühlt. Es ist unglaublich."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:59
translate german julianaparkstartdate_d95bd6ed:

    # bn "Does it feel like that for you too?"
    bn "Fühlt es sich für dich auch so an?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:60
translate german julianaparkstartdate_0c391334:

    # pc "Like what?"
    pc "Wie denn?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:61
translate german julianaparkstartdate_cbf3c8a2:

    # bn "Just like fire, spreading all through you."
    bn "Einfach wie Feuer, das sich in dir ausbreitet."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:62
translate german julianaparkstartdate_f85c6ac5:

    # bn "Like all my nerves coming alive and dancing in my skin."
    bn "Als würden alle meine Nerven zum Leben erwachen und in meiner Haut tanzen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:63
translate german julianaparkstartdate_1ae6abfe:

    # pc "Yeah, it feels like that for me too."
    pc "Ja, für mich fühlt es sich auch so an."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:64
translate german julianaparkstartdate_e40b3a25:

    # bn "Incredible."
    bn "Unglaublich."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:65
translate german julianaparkstartdate_7fd26fb6:

    # bn "What time is it?"
    bn "Wie spät ist es?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:66
translate german julianaparkstartdate_d038199e:

    # pc "Just about time for us to head back to school."
    pc "Es wird langsam Zeit, dass wir zurück zur Schule gehen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:67
translate german julianaparkstartdate_bd5f19a8:

    # bn "Yeah, that's what I thought. Let's enjoy this for one more minute though."
    bn "Ja, das habe ich mir auch gedacht. Aber lass uns das noch eine Minute lang genießen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:68
translate german julianaparkstartdate_08551511:

    # pc "You got it."
    pc "Klar."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:69
translate german julianaparkstartdate_10106d85:

    # "We sit there for another minute, just enjoying the quiet, enjoying the warmth of each other's bodies."
    "Wir sitzen noch eine Minute da und genießen einfach die Stille, genießen die Wärme unserer Körper."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:70
translate german julianaparkstartdate_da3cd183:

    # "Then it's time to get back to school."
    "Dann ist es Zeit, zurück zur Schule zu gehen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:77
translate german julianaparkstartdate_ebc1db78:

    # bn "I had a really good time, [pcname]. I hope we can do that again soon."
    bn "Ich hatte eine wirklich schöne Zeit, [pcname]. Ich hoffe, wir können das bald wiederholen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:78
translate german julianaparkstartdate_97cc796e:

    # bn "Any time you'd rather go to the park instead of study, just let me know."
    bn "Wenn du lieber in den Park gehen möchtest, anstatt zu lernen, sag mir einfach Bescheid."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:79
translate german julianaparkstartdate_f350b961:

    # bn "There's plenty of other time to study throughout the day."
    bn "Es gibt den ganzen Tag über genug andere Gelegenheiten zum Lernen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:80
translate german julianaparkstartdate_f8733479:

    # pc "I will, Juliana. Looking forward to our next date."
    pc "Das werde ich, Juliana. Ich freue mich schon auf unser nächstes Date."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:81
translate german julianaparkstartdate_d8a5a64b:

    # bn "Is that what that was?"
    bn "War das denn das?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:82
translate german julianaparkstartdate_c4b7f80e:

    # pc "Sure, I'd call it a date."
    pc "Klar, ich würde es als Date bezeichnen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:83
translate german julianaparkstartdate_b2c60616:

    # bn "Wow, I just had my first date and I didn't even realize it."
    bn "Wow, ich hatte gerade mein erstes Date und habe es nicht einmal gemerkt."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:84
translate german julianaparkstartdate_3d335832:

    # pc "Not a big deal. There will be plenty more."
    pc "Keine große Sache. Es werden noch viele weitere folgen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:85
translate german julianaparkstartdate_7c86fcff:

    # bn "Yeah, I guess so. Still, it was incredible."
    bn "Ja, ich schätze schon. Trotzdem war es unglaublich."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:87
translate german julianaparkstartdate_bed43be6:

    # bn "Well, we better head to class."
    bn "Na ja, wir sollten besser zum Unterricht gehen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:91
translate german julianaparkstartdate_b0662d5f:

    # "I step up to her and pull her in for a kiss before we go."
    "Ich trete auf sie zu und ziehe sie zu mir heran, um sie zu küssen, bevor wir gehen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:92
translate german julianaparkstartdate_d196e134:

    # "Then after a few moments, we pull away once again."
    "Nach ein paar Augenblicken lösen wir uns wieder voneinander."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:94
translate german julianaparkstartdate_92b8b462:

    # bn "I'll see you later, [pcname]."
    bn "Bis später, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:97
translate german julianaparkstartdate_24be2fc8:

    # "I step up to her and pull her in for a hug before we go."
    "Ich trete auf sie zu und ziehe sie zu mir heran, um sie zu umarmen, bevor wir gehen."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:98
translate german julianaparkstartdate_d196e134_1:

    # "Then after a few moments, we pull away once again."
    "Nach ein paar Augenblicken lösen wir uns wieder voneinander."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:100
translate german julianaparkstartdate_92b8b462_1:

    # bn "I'll see you later, [pcname]."
    bn "Bis später, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:103
translate german julianaparkstartdate_449d1425:

    # pc "Bye Juliana."
    pc "Tschüss, Juliana."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:104
translate german julianaparkstartdate_a8de1634:

    # bn "See you later, [pcname]."
    bn "Bis später, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:105
translate german julianaparkstartdate_3768ae38:

    # "With that, we both go to class."
    "Damit gehen wir beide zum Unterricht."

