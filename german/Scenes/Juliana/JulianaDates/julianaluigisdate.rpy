# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:38
translate german julianaluigisstartdate_c91b3eb2:

    # bn "I sometimes like to wear it when I'm going out on a nice date."
    bn "Ich trage sie manchmal gerne, wenn ich zu einem schönen Date gehe."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:39
translate german julianaluigisstartdate_c295710b:

    # bn "Not that I've had many dates."
    bn "Nicht, dass ich schon viele Dates gehabt hätte."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:40
translate german julianaluigisstartdate_a71bf22a:

    # pc "Well it's very pretty."
    pc "Nun, sie ist sehr hübsch."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:41
translate german julianaluigisstartdate_3dc0e34e:

    # "She turns away and blushes a little."
    "Sie wendet sich ab und errötet ein wenig."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:43
translate german julianaluigisstartdate_313b6a1f:

    # bn "Oh, um. I don't know."
    bn "Oh, ähm. Ich weiß nicht."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:44
translate german julianaluigisstartdate_2f29693a:

    # bn "I like to wear them when I go out somewhere nice."
    bn "Ich trage sie gerne, wenn ich irgendwohin ausgehe, wo es schön ist."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:47
translate german julianaluigisstartdate_1431cc27:

    # bn "Thank you."
    bn "Danke."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:48
translate german julianaluigisstartdate_3dc0e34e_1:

    # "She turns away and blushes a little."
    "Sie wendet sich ab und errötet ein wenig."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:50
translate german julianaluigisstartdate_563fa2c8:

    # bn "Okay. Well I prefer the wig when I go somewhere nice."
    bn "Okay. Nun, ich ziehe die Perücke vor, wenn ich irgendwohin ausgehe, wo es schön ist."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:51
translate german julianaluigisstartdate_e256026f:

    # "I'm not really sure how to respond, so we end up driving the rest of the way to the restaurant in an awkward silence."
    "Ich bin mir nicht ganz sicher, wie ich darauf reagieren soll, also fahren wir den Rest des Weges zum Restaurant in einer unangenehmen Stille."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:54
translate german julianaluigisstartdate_62345451:

    # "When we get to Luigi's, we sit and order our meals."
    "Als wir bei Luigi’s ankommen, setzen wir uns hin und bestellen unser Essen."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:55
translate german julianaluigisstartdate_c57a5228:

    # "Then we chat for a while."
    "Dann unterhalten wir uns eine Weile."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:58
translate german julianaluigisstartdate_0875967f:

    # "The server brings our food out, and we continue talking while we eat."
    "Der Kellner bringt unser Essen, und wir reden weiter, während wir essen."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:60
translate german julianaluigisstartdate_dbe7b11f:

    # "When we're done eating, we just hang around and talk for a little more."
    "Als wir fertig gegessen haben, bleiben wir noch ein bisschen sitzen und unterhalten uns weiter."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:63
translate german julianaluigisstartdate_018a4945:

    # "After our conversation, I pay for the food and we leave the restaurant and drive back to Juliana's house."
    "Nach unserem Gespräch bezahle ich das Essen, wir verlassen das Restaurant und fahren zurück zu Julianas Haus."

