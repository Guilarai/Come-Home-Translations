# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:28
translate german julianaicecreamstartdate_6e86a495:

    # bn "I'll have vanilla please."
    bn "Ich nehme bitte Vanille."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:29
translate german julianaicecreamstartdate_e28b03b7:

    # pc "Just vanilla? You don't want a flavor?"
    pc "Nur Vanille? Willst du keine Geschmacksrichtung?"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:30
translate german julianaicecreamstartdate_c049ae90:

    # bn "I like vanilla. It's the finest of the flavors."
    bn "Ich mag Vanille. Das ist die beste aller Geschmacksrichtungen."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:32
translate german julianaicecreamstartdate_bf0f1fe7:

    # pc "\"Gotta see the show, 'cause then you'll know the vertigo is gonna grow 'cause it's so dangerous, you'll have to sign a waiver?\""
    pc "„Du musst dir die Show ansehen, denn dann weißt du, dass der Schwindel zunehmen wird, weil es so gefährlich ist, dass du eine Verzichtserklärung unterschreiben musst?“"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:33
translate german julianaicecreamstartdate_3a694dff:

    # bn "Uh... what?"
    bn "Äh... was?"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:34
translate german julianaicecreamstartdate_3efc5a94:

    # pc "Oh, it's from a song. I thought you were making a reference."
    pc "Oh, das ist aus einem Lied. Ich dachte, du würdest darauf anspielen."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:35
translate german julianaicecreamstartdate_43de1e25:

    # bn "I'm sorry, I don't know the song."
    bn "Tut mir leid, ich kenne das Lied nicht."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:36
translate german julianaicecreamstartdate_385889cf:

    # pc "Oh... okay. Ignore that then."
    pc "Oh... okay. Dann ignorier das einfach."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:41
translate german julianaicecreamstartdate_a716a63e:

    # "We sit down and enjoy our ice cream and chat for a while."
    "Wir setzen uns hin, genießen unser Eis und unterhalten uns eine Weile."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:49
translate german julianaicecreamstartdate_bec02a72:

    # "With the ice cream finished, our conversation slows down."
    "Nachdem wir das Eis aufgegessen haben, lässt unser Gespräch nach."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:50
translate german julianaicecreamstartdate_1b4b54ec:

    # bn "I think I'm ready for you to come back to my house now."
    bn "Ich glaube, ich bin jetzt bereit, dass du mit zu mir nach Hause kommst."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:51
translate german julianaicecreamstartdate_18e0895f:

    # pc "Okay, let's go."
    pc "Okay, lass uns gehen."

