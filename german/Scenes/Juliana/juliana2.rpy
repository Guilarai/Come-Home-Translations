# game/Scenes/Juliana/juliana2.rpy:13
translate german juliana2_ba25a872:

    # "The school day goes by normally until English class."
    "Der Schultag verläuft normal bis zur Englischstunde."

# game/Scenes/Juliana/juliana2.rpy:14
translate german juliana2_5631544c:

    # "Mrs. McGee lectures all period about the archetypes and subtext of the short story we are reading."
    "Mrs. McGee hält die ganze Stunde lang einen Vortrag über die Archetypen und den Subtext der Kurzgeschichte, die wir lesen."

# game/Scenes/Juliana/juliana2.rpy:15
translate german juliana2_88daeb16:

    # "The entire time, I don't even look at Juliana, I'm still so annoyed with her."
    "Die ganze Zeit über schaue ich Juliana nicht einmal an, ich bin immer noch so genervt von ihr."

# game/Scenes/Juliana/juliana2.rpy:18
translate german juliana2_1c2cecc3:

    # "When the class is over, I gather my things and get up to leave."
    "Als der Unterricht vorbei ist, packe ich meine Sachen zusammen und stehe auf, um zu gehen."

# game/Scenes/Juliana/juliana2.rpy:19
translate german juliana2_290ef46a:

    # bn "[pcname]?"
    bn "[pcname]?"

# game/Scenes/Juliana/juliana2.rpy:20
translate german juliana2_fc83ac13:

    # "I think about continuing to walk, but the nervousness in her voice makes me stop."
    "Ich überlege, einfach weiterzugehen, aber die Nervosität in ihrer Stimme lässt mich innehalten."

# game/Scenes/Juliana/juliana2.rpy:24
translate german juliana2_395d1511:

    # bn "[pcname], can you just talk to me for a second?"
    bn "[pcname], kannst du kurz mit mir reden?"

# game/Scenes/Juliana/juliana2.rpy:25
translate german juliana2_63023601:

    # pc "Okay."
    pc "Okay."

# game/Scenes/Juliana/juliana2.rpy:28
translate german juliana2_9da0d89a:

    # bn "I'm sorry about the things I wrote on your essay."
    bn "Es tut mir leid wegen dem, was ich in deine Hausarbeit geschrieben habe."

# game/Scenes/Juliana/juliana2.rpy:29
translate german juliana2_ec9b7d74:

    # bn "I know that sometimes I can be too harsh. Too blunt with my words."
    bn "Ich weiß, dass ich manchmal zu hart sein kann. Zu direkt mit meinen Worten."

# game/Scenes/Juliana/juliana2.rpy:30
translate german juliana2_e1eed4cc:

    # bn "I'm not good with talking to people. I get nervous and my words come out muddled."
    bn "Ich bin nicht gut darin, mit Leuten zu reden. Ich werde nervös und meine Worte kommen durcheinander heraus."

# game/Scenes/Juliana/juliana2.rpy:31
translate german juliana2_439f936e:

    # bn "When I was editing your essay, I failed to take into account that there was a person on the other side of the writing."
    bn "Als ich deine Hausarbeit korrigiert habe, habe ich nicht bedacht, dass auf der anderen Seite des Textes eine Person steht."

# game/Scenes/Juliana/juliana2.rpy:32
translate german juliana2_828e0032:

    # bn "And I apologize for that. I should have been kinder."
    bn "Und dafür entschuldige ich mich. Ich hätte netter sein sollen."

# game/Scenes/Juliana/juliana2.rpy:33
translate german juliana2_6ac1535a:

    # "I look at her, genuinely sorry for what she had written."
    "Ich schaue sie an, aufrichtig traurig über das, was sie geschrieben hat."

# game/Scenes/Juliana/juliana2.rpy:34
translate german juliana2_4af91df8:

    # "It's difficult for me to stay mad after that."
    "Es fällt mir schwer, danach noch wütend zu bleiben."

# game/Scenes/Juliana/juliana2.rpy:35
translate german juliana2_7836aabb:

    # pc "I forgive you."
    pc "Ich vergebe dir."

# game/Scenes/Juliana/juliana2.rpy:36
translate german juliana2_359954db:

    # pc "Besides, your input did help me get an A on that essay."
    pc "Außerdem haben mir deine Anmerkungen geholfen, eine Eins für diesen Aufsatz zu bekommen."

# game/Scenes/Juliana/juliana2.rpy:39
translate german juliana2_49b20716:

    # bn "Good. I'm glad."
    bn "Gut. Das freut mich."

# game/Scenes/Juliana/juliana2.rpy:40
translate german juliana2_36f62856:

    # bn "That was my intention. To help you fix your essay."
    bn "Das war meine Absicht. Dir zu helfen, deinen Aufsatz zu verbessern."

# game/Scenes/Juliana/juliana2.rpy:41
translate german juliana2_5d0adf4a:

    # pc "Well you did a good job there."
    pc "Nun, das hast du gut gemacht."

# game/Scenes/Juliana/juliana2.rpy:44
translate german juliana2_a559e42c:

    # bn "I could help you more if you want."
    bn "Ich könnte dir noch mehr helfen, wenn du willst."

# game/Scenes/Juliana/juliana2.rpy:45
translate german juliana2_7e811564:

    # bn "If you want to maybe study together sometime?"
    bn "Wenn du vielleicht mal zusammen lernen möchtest?"

# game/Scenes/Juliana/juliana2.rpy:46
translate german juliana2_ff08c86f:

    # bn "I'm usually in the café here on campus in the morning."
    bn "Ich bin morgens meistens hier im Café auf dem Campus."

# game/Scenes/Juliana/juliana2.rpy:47
translate german juliana2_e4b8a84b:

    # bn "You could come by and study with me if you want."
    bn "Du könntest vorbeikommen und mit mir lernen, wenn du willst."

# game/Scenes/Juliana/juliana2.rpy:52
translate german juliana2_1abdf9b6:

    # bn "Good, I'm looking forward to it!"
    bn "Gut, ich freue mich darauf!"

# game/Scenes/Juliana/juliana2.rpy:53
translate german juliana2_d63c89db:

    # bn "Okay, well I better get on to my next class."
    bn "Okay, nun, ich muss mich besser auf meine nächste Stunde vorbereiten."

# game/Scenes/Juliana/juliana2.rpy:54
translate german juliana2_9c9c1091:

    # bn "I'm glad we talked."
    bn "Ich bin froh, dass wir uns unterhalten haben."

# game/Scenes/Juliana/juliana2.rpy:57
translate german juliana2_b237b55e:

    # bn "Okay, well if you change your mind, I'll be there."
    bn "Okay, nun, falls du es dir anders überlegst, ich bin da."

# game/Scenes/Juliana/juliana2.rpy:58
translate german juliana2_5dfb772a:

    # bn "I better get on to my next class."
    bn "Ich gehe besser zu meiner nächsten Stunde."

# game/Scenes/Juliana/juliana2.rpy:59
translate german juliana2_268fafe9:

    # bn "But I'm glad we talked."
    bn "Aber ich bin froh, dass wir uns unterhalten haben."

# game/Scenes/Juliana/juliana2.rpy:62
translate german juliana2_fa503b05:

    # "With that, she walks out of Mrs. McGee's class and rushes down the hall."
    "Damit verlässt sie Mrs. McGees Klasse und eilt den Flur entlang."

# game/Scenes/Juliana/juliana2.rpy:63
translate german juliana2_5b956f56:

    # "I head the opposite direction towards my own class."
    "Ich gehe in die entgegengesetzte Richtung zu meiner eigenen Klasse."

# game/Scenes/Juliana/juliana2.rpy:64
translate german juliana2_02bf7eb2:

    # "The rest of the day passes quickly and without incident, then it's time to go to work."
    "Der Rest des Tages vergeht schnell und ohne Zwischenfälle, dann ist es Zeit, zur Arbeit zu gehen."

translate german strings:

    # game/Scenes/Juliana/juliana2.rpy:2
    old "After the scene where Juliana critiques your essay,"
    new "Nach der Szene, in der Juliana deinen Aufsatz kritisiert,"

