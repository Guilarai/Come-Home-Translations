    tm "Hm, nun, sie wollte aus irgendeinem Grund einen Mann."

# game/Scenes/MrsMills/mills0.rpy:67
translate german mills0_2b17c9bb:

    # tm "Anyways, I'll get the coffees ready."
    tm "Wie auch immer, ich mache den Kaffee fertig."

# game/Scenes/MrsMills/mills0.rpy:68
