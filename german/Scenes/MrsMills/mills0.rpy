    voice 'voices/mills_thankyou2.mp3'

# game/Scenes/MrsMills/mills0.rpy:85
translate german mills0_818c6ce6:

    # bs "Thank you, [pcname]."
    bs "Danke, [pcname]."

# game/Scenes/MrsMills/mills0.rpy:86
translate german mills0_b4ece937:

    # bs "Now you can get to cleaning. I'm going to relax here for a few minutes."
    bs "Jetzt kannst du mit dem Putzen anfangen. Ich werde mich hier ein paar Minuten ausruhen."

# game/Scenes/MrsMills/mills0.rpy:87
translate german mills0_1ca80c77_2:

    # pc "Yes, ma'am."
    pc "Ja, Ma'am."

# game/Scenes/MrsMills/mills0.rpy:88
translate german mills0_25119040:

    # "I wouldn't mind relaxing and drinking my coffee too, but I pick up the duster and get to work."
    "Ich hätte nichts dagegen, mich auch auszuruhen und meinen Kaffee zu trinken, aber ich nehme den Staubwedel und mache mich an die Arbeit."

# game/Scenes/MrsMills/mills0.rpy:91
translate german mills0_85cd7035:

    # "While I clean the office, I can't shake the feeling that her eyes are on me."
    "Während ich das Büro putze, werde ich das Gefühl nicht los, dass ihre Augen auf mir ruhen."

# game/Scenes/MrsMills/mills0.rpy:92
translate german mills0_897769e5:

    # "That she is watching me."
    "Dass sie mich beobachtet."

# game/Scenes/MrsMills/mills0.rpy:93
translate german mills0_531ca259:

    # "When I get the opportunity, I sneak a look over at her."
    "Als sich die Gelegenheit bietet, werfe ich einen verstohlenen Blick zu ihr hinüber."

# game/Scenes/MrsMills/mills0.rpy:96
translate german mills0_367f3b05:

    # "Sure enough, she is sitting in her chair, rotated towards me, staring directly at me."
    "Und tatsächlich, sie sitzt in ihrem Stuhl, zu mir gedreht, und starrt mich direkt an."

# game/Scenes/MrsMills/mills0.rpy:97
translate german mills0_1bdeed63:

    # "I continue working and try not to let it bother me."
    "Ich arbeite weiter und versuche, mich davon nicht stören zu lassen."

# game/Scenes/MrsMills/mills0.rpy:100
translate german mills0_9f676768:

    # "It does bother me a little though."
    "Es stört mich allerdings ein wenig."

# game/Scenes/MrsMills/mills0.rpy:102
translate german mills0_0c2c0972:

    # "Especially with what Tammy had told me."
    "Vor allem angesichts dessen, was Tammy mir erzählt hatte."

# game/Scenes/MrsMills/mills0.rpy:103
translate german mills0_b6d20688:

    # "Had Mrs. Mills just hired me for eye candy?"
    "Hatte Mrs. Mills mich nur als Augenweide eingestellt?"

# game/Scenes/MrsMills/mills0.rpy:104
translate german mills0_31f90d79:

    # "I brave a glance at her again."
    "Ich wage noch einen Blick auf sie."

# game/Scenes/MrsMills/mills0.rpy:107
translate german mills0_e3be7f5c:

    # "She is still openly staring at me, like it doesn't even bother her if I catch her."
    "Sie starrt mich immer noch unverhohlen an, als würde es sie nicht einmal stören, wenn ich sie dabei erwische."

# game/Scenes/MrsMills/mills0.rpy:109
translate german mills0_e184f093:

    # "Then she smiles."
    "Dann lächelt sie."

# game/Scenes/MrsMills/mills0.rpy:110
translate german mills0_516a48ac:

    # bs "Yes, [pcname]? Is there a problem?"
    bs "Ja, [pcname]? Gibt es ein Problem?"

# game/Scenes/MrsMills/mills0.rpy:111
translate german mills0_726bc933:

    # pc "No ma'am. Just, you're staring at me."
    pc "Nein, Ma’am. Es ist nur so, dass Sie mich anstarren."

# game/Scenes/MrsMills/mills0.rpy:112
translate german mills0_c0bf0f06:

    # bs "That's true."
    bs "Das stimmt."

# game/Scenes/MrsMills/mills0.rpy:113
