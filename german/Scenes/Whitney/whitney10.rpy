    # "My phone buzzes in my pocket. It's Whitney calling."
    "Mein Handy vibriert in meiner Tasche. Es ist Whitney."

# game/Scenes/Whitney/whitney10.rpy:15
translate german whitney10_cabe2426:

    # pc "Hey, Whitney. What's up?"
    pc "Hey, Whitney. Was gibt’s?"

# game/Scenes/Whitney/whitney10.rpy:16
translate german whitney10_b9006bbe:

    # wt "Oh hey. Are you busy?"
    wt "Oh hey. Hast du viel zu tun?"

# game/Scenes/Whitney/whitney10.rpy:17
translate german whitney10_bc1428f9:

    # pc "Not really."
    pc "Nicht wirklich."

# game/Scenes/Whitney/whitney10.rpy:19
translate german whitney10_87d76db1:

    # wt "I have this craving for that burger place we went to before. Would you want to go get dinner with me again?"
    wt "Ich habe total Lust auf den Burgerladen, in dem wir neulich waren. Hast du Lust, wieder mit mir essen zu gehen?"

# game/Scenes/Whitney/whitney10.rpy:20
translate german whitney10_240f7709:

    # pc "Are you asking me out on a date?"
    pc "Willst du mich um ein Date bitten?"

# game/Scenes/Whitney/whitney10.rpy:22
translate german whitney10_b86f93de:

    # wt "You can call it whatever you like. I just want a burger."
    wt "Nenn es, wie du willst. Ich will einfach nur einen Burger."

# game/Scenes/Whitney/whitney10.rpy:23
translate german whitney10_91e1bb14:

    # wt "And your company is nice as well."
    wt "Und deine Gesellschaft ist auch ganz nett."

# game/Scenes/Whitney/whitney10.rpy:27
translate german whitney10_7c538ce6:

    # wt "Great! I'll drive over and pick you up at your place in about half an hour."
    wt "Super! Ich fahre in etwa einer halben Stunde vorbei und hole dich bei dir ab."

# game/Scenes/Whitney/whitney10.rpy:28
translate german whitney10_ac8c00ba:

    # pc "Sounds good. See you then."
    pc "Klingt gut. Bis dann."

# game/Scenes/Whitney/whitney10.rpy:29
translate german whitney10_2c71ca5c:

    # "We hang up and I go home and get ready."
    "Wir legen auf und ich gehe nach Hause, um mich fertig zu machen."

# game/Scenes/Whitney/whitney10.rpy:33
translate german whitney10_2aaf9014:

    # wt "Oh, okay then."
    wt "Oh, okay dann."

# game/Scenes/Whitney/whitney10.rpy:34
translate german whitney10_f7a5b1c0:

    # wt "Well, if you want to sometime, just give me a call in the evening. I'm usually free."
    wt "Na ja, wenn du mal Lust hast, ruf mich einfach abends an. Ich habe meistens Zeit."

# game/Scenes/Whitney/whitney10.rpy:35
translate german whitney10_bf0c9413:

    # pc "Okay, Whitney. Talk to you later."
    pc "Okay, Whitney. Bis später."

# game/Scenes/Whitney/whitney10.rpy:36
translate german whitney10_a7e7a8bf:

    # wt "Bye, [pcname]."
    wt "Tschüss, [pcname]."

