# game/Scenes/Whitney/whitney14.rpy:18
translate german whitney14_50df7566:

    # "My phone buzzes in my pocket. Whitney's calling."
    "Mein Handy vibriert in meiner Tasche. Whitney ruft an."

# game/Scenes/Whitney/whitney14.rpy:22
translate german whitney14_9baa4d84:

    # wt "Are you ready?"
    wt "Bist du bereit?"

# game/Scenes/Whitney/whitney14.rpy:23
translate german whitney14_8a4963b6:

    # pc "Ready for what?"
    pc "Bereit wofür?"

# game/Scenes/Whitney/whitney14.rpy:24
translate german whitney14_ab83914e:

    # wt "To move forward with the next step of the plan."
    wt "Um mit dem nächsten Schritt des Plans fortzufahren."

# game/Scenes/Whitney/whitney14.rpy:25
translate german whitney14_191f52bf:

    # pc "What {i}is{/i} the next step?"
    pc "Was {i}ist{/i} der nächste Schritt?"

# game/Scenes/Whitney/whitney14.rpy:27
translate german whitney14_d8555685:

    # wt "We need diamonds. Two large diamonds."
    wt "Wir brauchen Diamanten. Zwei große Diamanten."

# game/Scenes/Whitney/whitney14.rpy:28
translate german whitney14_6121f377:

    # pc "That's probably really expensive."
    pc "Das ist wahrscheinlich sehr teuer."

# game/Scenes/Whitney/whitney14.rpy:30
translate german whitney14_e03107d2:

    # wt "We're not going to pay for them."
    wt "Wir werden nicht dafür bezahlen."

# game/Scenes/Whitney/whitney14.rpy:31
translate german whitney14_5bb78b12:

    # pc "Wait, what?"
    pc "Moment, was?"

# game/Scenes/Whitney/whitney14.rpy:32
translate german whitney14_68482c5f:

    # wt "We're going to steal them, just like I did with your dad."
    wt "Wir werden sie stehlen, genau wie ich es bei deinem Vater gemacht habe."

# game/Scenes/Whitney/whitney14.rpy:33
translate german whitney14_b16d9c4d:

    # pc "I thought you were really rich. Why can't you just buy them?"
    pc "Ich dachte, du wärst richtig reich. Warum kannst du sie nicht einfach kaufen?"

# game/Scenes/Whitney/whitney14.rpy:35
translate german whitney14_e7291356:

    # wt "The ones that we need, at the purity level that we require, are beyond even the money that I have available."
    wt "Die, die wir brauchen, mit dem Reinheitsgrad, den wir verlangen, übersteigen sogar das Geld, das mir zur Verfügung steht."

# game/Scenes/Whitney/whitney14.rpy:36
translate german whitney14_18b47f23:

    # wt "Besides, these diamonds were not humanely harvested. I don't feel bad about stealing from these greedy companies."
    wt "Außerdem wurden diese Diamanten nicht auf humane Weise abgebaut. Ich habe kein schlechtes Gewissen dabei, diese gierigen Unternehmen zu bestehlen."

# game/Scenes/Whitney/whitney14.rpy:37
translate german whitney14_79651c65:

    # wt "What we are doing with them is far more important than some aristocrat wearing it on her finger."
    wt "Was wir mit ihnen machen, ist viel wichtiger, als dass irgendeine Aristokratin sie an ihrem Finger trägt."

# game/Scenes/Whitney/whitney14.rpy:38
translate german whitney14_c5daad32:

    # pc "How are we going to pull this off? What if we get caught?"
    pc "Wie wollen wir das durchziehen? Was, wenn wir erwischt werden?"

# game/Scenes/Whitney/whitney14.rpy:40
translate german whitney14_09e85fe5:

    # wt "That's for me to take care of. I'll explain it to you before you go in."
    wt "Darum kümmere ich mich. Ich erkläre es dir, bevor du reingehst."

# game/Scenes/Whitney/whitney14.rpy:41
translate german whitney14_30dd8227:

    # pc "I have to go in?"
    pc "Ich muss reingehen?"

# game/Scenes/Whitney/whitney14.rpy:43
translate german whitney14_87885119:

    # wt "Of course you do. I'm in a wheelchair."
    wt "Natürlich musst du das. Ich sitze im Rollstuhl."

# game/Scenes/Whitney/whitney14.rpy:44
translate german whitney14_2416510e:

    # wt "But I've arranged everything. You won't get caught. Just like your father didn't get caught when he did this before."
    wt "Aber ich habe alles arrangiert. Du wirst nicht erwischt werden. Genau wie dein Vater nicht erwischt wurde, als er das früher gemacht hat."

# game/Scenes/Whitney/whitney14.rpy:45
translate german whitney14_f06e3a9b:

    # pc "We're robbing the same place?"
    pc "Wir rauben denselben Ort aus?"

# game/Scenes/Whitney/whitney14.rpy:47
translate german whitney14_d1a56e79:

    # wt "Of course not. That would be dumb."
    wt "Natürlich nicht. Das wäre dumm."

# game/Scenes/Whitney/whitney14.rpy:48
translate german whitney14_ed2f7d18:

    # wt "Just trust me. I know what I'm doing here. Come to my house and we'll get ready."
    wt "Vertrau mir einfach. Ich weiß, was ich tue. Komm zu mir nach Hause, dann machen wir uns fertig."

# game/Scenes/Whitney/whitney14.rpy:50
translate german whitney14_50df7566_1:

    # "My phone buzzes in my pocket. Whitney's calling."
    "Mein Handy vibriert in meiner Tasche. Whitney ruft an."

# game/Scenes/Whitney/whitney14.rpy:54
translate german whitney14_6b748407:

    # wt "Are you ready to take the diamonds?"
    wt "Bist du bereit, die Diamanten zu holen?"

# game/Scenes/Whitney/whitney14.rpy:55
translate german whitney14_f8d534ae:

    # pc "Tonight?"
    pc "Heute Abend?"

# game/Scenes/Whitney/whitney14.rpy:56
translate german whitney14_d9b8f3ae:

    # wt "No better time."
    wt "Es gibt keinen besseren Zeitpunkt."

# game/Scenes/Whitney/whitney14.rpy:59
translate german whitney14_355c90d9:

    # rj "Whoa! Holupaminute!"
    rj "Halt mal kurz!"

# game/Scenes/Whitney/whitney14.rpy:62
translate german rjwhitneywarning_73195949:

    # rj "I just want to let you know that doing this scene right now will cause you to miss out on Whitney's romance storyline."
    rj "Ich möchte dich nur darauf hinweisen, dass du Whitneys Liebesgeschichte verpasst, wenn du diese Szene jetzt spielst."

# game/Scenes/Whitney/whitney14.rpy:63
translate german rjwhitneywarning_ba4a28b5:

    # rj "If you're not interested in Whitney romantically, no problem, do the diamond heist tonight."
    rj "Wenn du kein romantisches Interesse an Whitney hast, kein Problem, mach den Diamantenraub heute Nacht."

# game/Scenes/Whitney/whitney14.rpy:64
translate german rjwhitneywarning_3d1165e2:

    # rj "Otherwise, you might want to advance some with Whitney..."
    rj "Andernfalls solltest du vielleicht erst mal mit Whitney weiterkommen …"

# game/Scenes/Whitney/whitney14.rpy:66
translate german rjwhitneywarning_8f5726ba:

    # rj "... to the point where you cum all over her face..."
    rj "… bis zu dem Punkt, an dem du ihr ins Gesicht spritzt …"

# game/Scenes/Whitney/whitney14.rpy:68
translate german rjwhitneywarning_9f0eac4a:

    # rj "... before doing the diamond heist."
    rj "… bevor du den Diamantenraub machst."

# game/Scenes/Whitney/whitney14.rpy:69
translate german rjwhitneywarning_369e3555:

    # rj "It's up to you. If you tell her that you don't want to do it tonight, she'll call you again next Saturday night."
    rj "Es liegt an dir. Wenn du ihr sagst, dass du es heute Abend nicht machen willst, ruft sie dich nächsten Samstagabend wieder an."

# game/Scenes/Whitney/whitney14.rpy:70
translate german rjwhitneywarning_63505504:

    # rj "Did you get all that?"
    rj "Hast du alles verstanden?"

# game/Scenes/Whitney/whitney14.rpy:76
translate german rjwhitneywarning_4ecb53ff:

    # rj "Fine, I'll repeat it."
    rj "Na gut, ich wiederhole es noch mal."

# game/Scenes/Whitney/whitney14.rpy:79
translate german rjwhitneywarning_3a9d25c3:

    # rj "Okay, that's it. Sorry to interrupt! See ya!"
    rj "Okay, das war’s. Entschuldige die Unterbrechung! Bis dann!"

# game/Scenes/Whitney/whitney14.rpy:84
translate german rjwhitneywarning_49e2edaf:

    # wt "Great, come over to my lab and we'll get ready."
    wt "Super, komm rüber in mein Labor, dann machen wir uns bereit."

# game/Scenes/Whitney/whitney14.rpy:85
translate german rjwhitneywarning_a7e78a4e:

    # pc "Okay, I'm leaving now."
    pc "Okay, ich gehe jetzt."

# game/Scenes/Whitney/whitney14.rpy:87
translate german rjwhitneywarning_19b39e94:

    # pc "I'm not ready yet."
    pc "Ich bin noch nicht bereit."

# game/Scenes/Whitney/whitney14.rpy:89
translate german rjwhitneywarning_76d673a0:

    # wt "Okay."
    wt "Okay."

# game/Scenes/Whitney/whitney14.rpy:90
translate german rjwhitneywarning_c22c8a75:

    # wt "We should do this soon though, if we are going to do it."
    wt "Wir sollten es aber bald machen, wenn wir es tun wollen."

# game/Scenes/Whitney/whitney14.rpy:91
translate german rjwhitneywarning_23677720:

    # wt "Your father cannot wait forever."
    wt "Dein Vater kann nicht ewig warten."

# game/Scenes/Whitney/whitney14.rpy:92
translate german rjwhitneywarning_395cd6d9:

    # pc "I know. Soon."
    pc "Ich weiß. Bald."

# game/Scenes/Whitney/whitney14.rpy:94
translate german rjwhitneywarning_2adac8aa:

    # wt "Okay. We can try next week then."
    wt "Okay. Dann versuchen wir es nächste Woche."

# game/Scenes/Whitney/whitney14.rpy:95
translate german rjwhitneywarning_0db4d881:

    # wt "I'll talk to you later, [pcname]."
    wt "Wir sprechen uns später, [pcname]."

# game/Scenes/Whitney/whitney14.rpy:96
translate german rjwhitneywarning_663246d7:

    # pc "Okay. Bye, Whitney."
    pc "Okay. Tschüss, Whitney."

# game/Scenes/Whitney/whitney14.rpy:99
translate german rjwhitneywarning_012c7d57:

    # "We hang up. How am I supposed to steal diamonds?"
    "Wir legen auf. Wie soll ich denn Diamanten stehlen?"

# game/Scenes/Whitney/whitney14.rpy:100
translate german rjwhitneywarning_514c7ad2:

    # "This is all getting really serious."
    "Das wird jetzt alles richtig ernst."

# game/Scenes/Whitney/whitney14.rpy:108
translate german rjwhitneywarning_8652a2fb:

    # "I arrive at her house and walk through the courtyard towards the front door."
    "Ich komme bei ihrem Haus an und gehe durch den Innenhof zur Haustür."

# game/Scenes/Whitney/whitney14.rpy:109
translate german rjwhitneywarning_7bd312b7:

    # "Her voice startles me when it blares over the intercom."
    "Ihre Stimme erschreckt mich, als sie aus der Gegensprechanlage dröhnt."

# game/Scenes/Whitney/whitney14.rpy:110
translate german rjwhitneywarning_1bb0325b:

    # wt "Hi, [pcname]. I'm in the lab. The door is unlocked."
    wt "Hi, [pcname]. Ich bin im Labor. Die Tür ist unverschlossen."

# game/Scenes/Whitney/whitney14.rpy:113
translate german rjwhitneywarning_dc712c6d:

    # "I make my way to the lab, where Whitney is waiting for me."
    "Ich gehe zum Labor, wo Whitney auf mich wartet."

# game/Scenes/Whitney/whitney14.rpy:114
translate german rjwhitneywarning_5214e180:

    # wt "Your clothing is in the back of the van. Go ahead and get changed."
    wt "Deine Kleidung liegt hinten im Transporter. Zieh dich ruhig um."

# game/Scenes/Whitney/whitney14.rpy:115
translate german rjwhitneywarning_b37180b5:

    # pc "I have to wear different clothing?"
    pc "Ich muss andere Kleidung tragen?"

# game/Scenes/Whitney/whitney14.rpy:116
translate german rjwhitneywarning_61bb1ca5:

    # wt "Yes, you do. Everybody is going to know it's you in that blue shirt."
    wt "Ja, musst du. Jeder wird wissen, dass du es bist in dem blauen Hemd."

# game/Scenes/Whitney/whitney14.rpy:117
translate german rjwhitneywarning_c33734b6:

    # pc "Fine. But I like my blue shirt."
    pc "Na gut. Aber ich mag mein blaues Hemd."

# game/Scenes/Whitney/whitney14.rpy:120
translate german rjwhitneywarning_a3f1d669:

    # "I go to the back of the van and change clothes."
    "Ich gehe zum Heck des Lieferwagens und ziehe mich um."

# game/Scenes/Whitney/whitney14.rpy:123
translate german rjwhitneywarning_f46c6704:

    # pc "Is this really necessary?"
    pc "Ist das wirklich notwendig?"

# game/Scenes/Whitney/whitney14.rpy:124
translate german rjwhitneywarning_ec008765:

    # wt "Yes, if you don't want to be recognized on camera."
    wt "Ja, wenn du nicht vor der Kamera erkannt werden willst."

# game/Scenes/Whitney/whitney14.rpy:125
translate german rjwhitneywarning_56afcb31:

    # wt "I was able to plot a route that would avoid getting the van on camera, but I cannot do anything about the cameras inside the building."
    wt "Ich konnte eine Route ausarbeiten, bei der der Lieferwagen nicht vor die Kamera gerät, aber gegen die Kameras im Gebäude kann ich nichts ausrichten."

# game/Scenes/Whitney/whitney14.rpy:126
translate german rjwhitneywarning_2c6002d9:

    # pc "So, fill me in. What is the crazy plan here?"
    pc "Also, klär mich auf. Was ist hier der verrückte Plan?"

# game/Scenes/Whitney/whitney14.rpy:129
translate german rjwhitneywarning_506ca14d:

    # wt "I am going to park over here where you will get out and make your way to the back entrance of the jewelry store..."
    wt "Ich werde hier parken, wo du aussteigst und dich zum Hintereingang des Juweliergeschäfts begibst..."

# game/Scenes/Whitney/whitney14.rpy:132
translate german rjwhitneywarning_6b7981aa:

    # wt "...here."
    wt "...hier."

# game/Scenes/Whitney/whitney14.rpy:133
translate german rjwhitneywarning_c840c904:

    # wt "The store has a deadbolt that requires a key, but I have a solution for that."
    wt "Das Geschäft hat ein Sicherheitsschloss, für das man einen Schlüssel braucht, aber dafür habe ich eine Lösung."

# game/Scenes/Whitney/whitney14.rpy:136
translate german rjwhitneywarning_cb3653db:

    # wt "This is a lockpicking gun. You just put the end of it into the lock and squeeze the trigger."
    wt "Das ist eine Schlossknackpistole. Du steckst einfach das Ende davon ins Schloss und drückst den Abzug."

# game/Scenes/Whitney/whitney14.rpy:137
translate german rjwhitneywarning_1ba42d5f:

    # wt "I'm sure it will work on the door there."
    wt "Ich bin mir sicher, dass es bei der Tür dort funktionieren wird."

# game/Scenes/Whitney/whitney14.rpy:138
translate german rjwhitneywarning_368080b9:

    # pc "Wait, is that a Nintendo gun? Like for Duck Hunt?"
    pc "Moment, ist das eine Nintendo-Pistole? So wie bei „Duck Hunt“?"

# game/Scenes/Whitney/whitney14.rpy:139
translate german rjwhitneywarning_cb7a5d6f:

    # wt "It was. I modified it. Now it's a lockpicking gun."
    wt "Das war sie. Ich habe sie umgebaut. Jetzt ist es eine Panzersprengpistole."

# game/Scenes/Whitney/whitney14.rpy:140
translate german rjwhitneywarning_880b4aa8:

    # pc "Okay..."
    pc "Okay..."

# game/Scenes/Whitney/whitney14.rpy:141
translate german rjwhitneywarning_18b9d86b:

    # pc "So, that's it? Just zap the lock and I'm in?"
    pc "Das war’s also? Einfach das Schloss zappen und ich bin drin?"

# game/Scenes/Whitney/whitney14.rpy:144
translate german rjwhitneywarning_57ed69cc:

    # wt "Well, yes, you'll be able to get in the building then, but there is a security system."
    wt "Nun ja, du wirst dann zwar ins Gebäude kommen, aber es gibt ein Sicherheitssystem."

# game/Scenes/Whitney/whitney14.rpy:145
translate german rjwhitneywarning_b3ded7f6:

    # wt "Fortunately, you and I will be in contact the entire time and just before you go in, I will disable the alarms remotely."
    wt "Zum Glück bleiben wir die ganze Zeit in Kontakt, und kurz bevor du hineingehst, werde ich die Alarmanlage aus der Ferne deaktivieren."

# game/Scenes/Whitney/whitney14.rpy:146
translate german rjwhitneywarning_45436a60:

    # pc "You can do that?"
    pc "Das kannst du?"

# game/Scenes/Whitney/whitney14.rpy:147
translate german rjwhitneywarning_ed1b329a:

    # wt "Of course I can do that."
    wt "Natürlich kann ich das."

# game/Scenes/Whitney/whitney14.rpy:150
translate german rjwhitneywarning_6e0c3693:

    # wt "When you first go in, you will be in the back storage area. You'll have to make your way through there to the office, where the safe is kept."
    wt "Wenn du hineingehst, befindest du dich zunächst im hinteren Lagerbereich. Du musst dich von dort zum Büro durcharbeiten, wo der Safe steht."

# game/Scenes/Whitney/whitney14.rpy:151
translate german rjwhitneywarning_1547e2f3:

    # pc "A safe? How are we supposed to get into that? Do you know the combination?"
    pc "Ein Safe? Wie sollen wir da reinkommen? Kennst du die Kombination?"

# game/Scenes/Whitney/whitney14.rpy:152
translate german rjwhitneywarning_9778d18a:

    # wt "Yes, actually. I do."
    wt "Ja, tatsächlich. Die kenne ich."

# game/Scenes/Whitney/whitney14.rpy:153
translate german rjwhitneywarning_a7d1f229:

    # pc "How?"
    pc "Wie?"

# game/Scenes/Whitney/whitney14.rpy:154
translate german rjwhitneywarning_284142b3:

    # wt "Don't worry about that. I told you I've been working on this. I haven't just been sitting over here the whole time, twiddling my thumbs."
    wt "Mach dir darüber keine Sorgen. Ich habe dir doch gesagt, dass ich daran gearbeitet habe. Ich habe nicht die ganze Zeit hier gesessen und Däumchen gedreht."

# game/Scenes/Whitney/whitney14.rpy:155
translate german rjwhitneywarning_b9a33198:

    # wt "The safe has a keypad combination. The code is 96678552."
    wt "Der Safe hat eine Tastaturkombination. Der Code lautet 96678552."

# game/Scenes/Whitney/whitney14.rpy:156
translate german rjwhitneywarning_c386084f:

    # wt "Don't write it down anywhere. I'll remind you over the radio if you forget."
    wt "Schreib ihn nirgendwo auf. Ich werde dich über Funk daran erinnern, falls du ihn vergisst."

# game/Scenes/Whitney/whitney14.rpy:159
translate german rjwhitneywarning_ddf4be87:

    # wt "Once you get the safe open, you're going to have to find the diamonds. This is the only part I'm not completely sure of."
    wt "Sobald du den Safe geöffnet hast, musst du die Diamanten finden. Das ist der einzige Teil, bei dem ich mir nicht ganz sicher bin."

# game/Scenes/Whitney/whitney14.rpy:160
translate german rjwhitneywarning_d61f0ea5:

    # wt "They are diamonds that have not been inset into any jewelry yet."
    wt "Es sind Diamanten, die noch nicht in Schmuck eingefasst wurden."

# game/Scenes/Whitney/whitney14.rpy:161
translate german rjwhitneywarning_0bb7be7d:

    # wt "They need to be real diamonds too, not the synthetic ones. The hoop will only work on real diamonds."
    wt "Es müssen auch echte Diamanten sein, keine synthetischen. Der Reif funktioniert nur bei echten Diamanten."

# game/Scenes/Whitney/whitney14.rpy:162
translate german rjwhitneywarning_7b883c0e:

    # wt "They are large and clear and are likely stored wrapped in tissue paper or cloth and in individual bags."
    wt "Sie sind groß und klar und werden wahrscheinlich in Seidenpapier oder Stoff gewickelt und in einzelnen Beuteln aufbewahrt."

# game/Scenes/Whitney/whitney14.rpy:163
translate german rjwhitneywarning_c8a5f5b0:

    # wt "I believe they're going to be near the bottom shelf of the safe."
    wt "Ich glaube, sie befinden sich in der unteren Ablage des Safes."

# game/Scenes/Whitney/whitney14.rpy:164
translate german rjwhitneywarning_ff090bab:

    # pc "How do you possibly know all of this?"
    pc "Woher weißt du das alles?"

# game/Scenes/Whitney/whitney14.rpy:167
translate german rjwhitneywarning_52c41d0c:

    # wt "I have been monitoring this place for weeks."
    wt "Ich beobachte diesen Ort schon seit Wochen."

# game/Scenes/Whitney/whitney14.rpy:168
translate german rjwhitneywarning_c2154aa2:

    # wt "There is a building across the street that has an outside camera. I was able to move that camera to where it aims directly through the front windows of the jewelry shop."
    wt "Auf der anderen Straßenseite steht ein Gebäude mit einer Außenkamera. Ich konnte diese Kamera so ausrichten, dass sie direkt durch die Schaufenster des Juweliergeschäfts blickt."

# game/Scenes/Whitney/whitney14.rpy:169
translate german rjwhitneywarning_919dc7c4:

    # wt "Then, by changing the visual frequency a bit, I could look through the one-way mirror and into the back office where the safe is."
    wt "Dann konnte ich, indem ich die Bildfrequenz ein wenig veränderte, durch den Einwegspiegel in das Hinterzimmer blicken, wo sich der Safe befindet."

# game/Scenes/Whitney/whitney14.rpy:170
translate german rjwhitneywarning_9a1523a7:

    # wt "Then I just watched and gathered information."
    wt "Dann habe ich einfach zugesehen und Informationen gesammelt."

# game/Scenes/Whitney/whitney14.rpy:173
translate german rjwhitneywarning_a32a886a:

    # pc "You're quite scary sometimes, you know?"
    pc "Du bist manchmal ziemlich beängstigend, weißt du das?"

# game/Scenes/Whitney/whitney14.rpy:174
translate german rjwhitneywarning_6c97b1cc:

    # pc "I'm really glad you're not evil. You could really cause some trouble."
    pc "Ich bin wirklich froh, dass du nicht böse bist. Du könntest wirklich Ärger machen."

# game/Scenes/Whitney/whitney14.rpy:175
translate german rjwhitneywarning_4e966f59:

    # wt "Yes. Yes, I could."
    wt "Ja. Ja, das könnte ich."

# game/Scenes/Whitney/whitney14.rpy:176
translate german rjwhitneywarning_f91c3d58:

    # wt "Let's go."
    wt "Los geht’s."

# game/Scenes/Whitney/whitney14.rpy:179
translate german rjwhitneywarning_a1b12283:

    # "Whitney drives us back to town, then takes a convoluted path to avoid the various cameras, before parking in the back area of a nearby store and turning the van off."
    "Whitney fährt uns zurück in die Stadt, nimmt dann einen Umweg, um den verschiedenen Kameras auszuweichen, bevor sie im Hinterhof eines nahegelegenen Ladens parkt und den Motor abstellt."

# game/Scenes/Whitney/whitney14.rpy:180
translate german rjwhitneywarning_28d35bb9:

    # pc "I don't know about this. I'm really nervous."
    pc "Ich weiß nicht so recht. Ich bin wirklich nervös."

# game/Scenes/Whitney/whitney14.rpy:181
translate german rjwhitneywarning_9b33cddb:

    # wt "You're going to be fine. I promise."
    wt "Das wird schon gut gehen. Ich verspreche es dir."

# game/Scenes/Whitney/whitney14.rpy:182
translate german rjwhitneywarning_6e34f9e6:

    # wt "I don't know any other way for us to get these diamonds. And we need them for the hoop to work."
    wt "Ich weiß keinen anderen Weg, wie wir an diese Diamanten kommen können. Und wir brauchen sie, damit der Ring funktioniert."

