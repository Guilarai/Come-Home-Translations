# TODO: Translation updated at 2026-06-02 13:31

# game/Scenes/Update19/Act3/act3scene4.rpy:4
translate german act3scene4_594c2912:

    # "In a blink, I'm suddenly back in the Ice Queen's throne room."
    "Im Handumdrehen bin ich plötzlich wieder im Thronsaal der Eiskönigin."

# game/Scenes/Update19/Act3/act3scene4.rpy:6
translate german act3scene4_41d6859f:

    # "My friends are still frozen around me, but I feel my body thawing."
    "Meine Freunde sind immer noch um mich herum eingefroren, aber ich spüre, wie mein Körper auftaut."

# game/Scenes/Update19/Act3/act3scene4.rpy:9
translate german act3scene4_785bdb9f:

    # "When I can move again, I stumble forward and almost fall."
    "Als ich mich wieder bewegen kann, stolpere ich nach vorne und falle fast hin."

# game/Scenes/Update19/Act3/act3scene4.rpy:10
translate german act3scene4_9fe7bb42:

    # "But I'm able to stop myself and it seems that the Ice Queen didn't notice."
    "Aber ich kann mich gerade noch auffangen, und es scheint, als hätte die Eiskönigin nichts bemerkt."

# game/Scenes/Update19/Act3/act3scene4.rpy:11
translate german act3scene4_269679eb:

    # "Time to make my move."
    "Zeit, meinen Zug zu machen."

# game/Scenes/Update19/Act3/act3scene4.rpy:15
translate german act3scene4_f4ddd564:

    # "I rush up and hug her from behind, pulling her close to me."
    "Ich eile zu ihr hin und umarme sie von hinten, ziehe sie fest an mich."

# game/Scenes/Update19/Act3/act3scene4.rpy:16
translate german act3scene4_6145e44f:

    # sp "WHAT!?"
    sp "WAS!?"

# game/Scenes/Update19/Act3/act3scene4.rpy:17
translate german act3scene4_d519fcc2:

    # sp "{i}WHAT{/i} are you doing? Unhand me!"
    sp "{i}WAS{/i} machst du da? Lass mich los!"

# game/Scenes/Update19/Act3/act3scene4.rpy:20
translate german act3scene4_0d90b60a:

    # pc "I'm sorry that you lost Suzy. I'm so sorry that happened to you."
    pc "Es tut mir leid, dass du Suzy verloren hast. Es tut mir so leid, dass dir das passiert ist."

# game/Scenes/Update19/Act3/act3scene4.rpy:21
translate german act3scene4_641a9d68:

    # sp "Don't say her name--"
    sp "Sag nicht ihren Namen –"

# game/Scenes/Update19/Act3/act3scene4.rpy:22
translate german act3scene4_ad5d8a1e:

    # pc "I know your heart is broken."
    pc "Ich weiß, dass dein Herz gebrochen ist."

# game/Scenes/Update19/Act3/act3scene4.rpy:23
translate german act3scene4_c39f9ad8:

    # pc "That just shows how much love you had."
    pc "Das zeigt nur, wie sehr du geliebt hast."

# game/Scenes/Update19/Act3/act3scene4.rpy:24
translate german act3scene4_eb5ca914:

    # sp "You don't know--"
    sp "Du weißt nicht –"

# game/Scenes/Update19/Act3/act3scene4.rpy:27
translate german act3scene4_82d048f3:

    # pc "Suzy wants you to know that she loves you so much."
    pc "Suzy möchte, dass du weißt, dass sie dich so sehr liebt."

# game/Scenes/Update19/Act3/act3scene4.rpy:28
translate german act3scene4_acba1f83:

    # sp "Stop--"
    sp "Hör auf –"

# game/Scenes/Update19/Act3/act3scene4.rpy:31
translate german act3scene4_cdd644dd:

    # pc "She wants you to know that she's going to always be with you."
    pc "Sie möchte, dass du weißt, dass sie immer bei dir sein wird."

# game/Scenes/Update19/Act3/act3scene4.rpy:32
translate german act3scene4_10d0ad27:

    # sp "How do you--"
    sp "Wie kannst du –"

# game/Scenes/Update19/Act3/act3scene4.rpy:35
translate german act3scene4_978f88d1:

    # pc "And she doesn't like seeing what you've become."
    pc "Und sie mag es nicht, zu sehen, was aus dir geworden ist."

# game/Scenes/Update19/Act3/act3scene4.rpy:36
translate german act3scene4_8144a68d:

    # pc "She wants you to be warm and loving again, like she remembers you."
    pc "Sie möchte, dass du wieder warmherzig und liebevoll bist, so wie sie dich in Erinnerung hat."

# game/Scenes/Update19/Act3/act3scene4.rpy:37
translate german act3scene4_ad07f09a:

    # sp "I'm not--"
    sp "Ich bin nicht –"

# game/Scenes/Update19/Act3/act3scene4.rpy:40
translate german act3scene4_38d06822:

    # "She doesn't finish her sentence, instead bursting into tears and crumpling in my arms."
    "Sie beendet ihren Satz nicht, sondern bricht in Tränen aus und sinkt in meinen Armen zusammen."

# game/Scenes/Update19/Act3/act3scene4.rpy:41
translate german act3scene4_5b98a3b5:

    # pc "I'm sorry, Lisa. I'm sorry she's gone."
    pc "Es tut mir leid, Lisa. Es tut mir leid, dass sie nicht mehr da ist."

# game/Scenes/Update19/Act3/act3scene4.rpy:42
translate german act3scene4_d761b7e0:

    # pc "I love you."
    pc "Ich liebe dich."

# game/Scenes/Update19/Act3/act3scene4.rpy:45
translate german act3scene4_3689094d:

    # "I hold her for a long time while she cries."
    "Ich halte sie lange fest, während sie weint."

# game/Scenes/Update19/Act3/act3scene4.rpy:46
translate german act3scene4_fcd85bea:

    # "I wonder if she's ever let herself really feel the loss."
    "Ich frage mich, ob sie sich jemals erlaubt hat, den Verlust wirklich zu spüren."

# game/Scenes/Update19/Act3/act3scene4.rpy:47
translate german act3scene4_6f05f3c1:

    # "I wonder if she's ever had anybody to hold her like this."
    "Ich frage mich, ob sie jemals jemanden hatte, der sie so gehalten hat."

# game/Scenes/Update19/Act3/act3scene4.rpy:50
translate german act3scene4_49651a35:

    # "After some time, she stops crying and sits up again."
    "Nach einer Weile hört sie auf zu weinen und setzt sich wieder auf."

# game/Scenes/Update19/Act3/act3scene4.rpy:51
translate german act3scene4_77d46c18:

    # sp "Who {i}are{/i} you?"
    sp "Wer {i}bist{/i} du?"

# game/Scenes/Update19/Act3/act3scene4.rpy:52
translate german act3scene4_22be1576:

    # pc "It's a long story..."
    pc "Das ist eine lange Geschichte..."

# game/Scenes/Update19/Act3/act3scene4.rpy:53
translate german act3scene4_0eb855c9:

    # "So I tell her everything about the other world, about the bracelet, about coming here to see her."
    "Also erzähle ich ihr alles über die andere Welt, über das Armband, darüber, wie ich hierhergekommen bin, um sie zu sehen."

# game/Scenes/Update19/Act3/act3scene4.rpy:56
translate german act3scene4_299824e4:

    # sp "You did so much to find your father."
    sp "Du hast so viel getan, um deinen Vater zu finden."

# game/Scenes/Update19/Act3/act3scene4.rpy:57
translate german act3scene4_4aa0965e:

    # pc "Well yeah... I love him."
    pc "Nun ja... Ich liebe ihn."

# game/Scenes/Update19/Act3/act3scene4.rpy:58
translate german act3scene4_2c93668b:

    # sp "I suppose so. I'd do anything to get Suzy back."
    sp "Das kann ich mir vorstellen. Ich würde alles tun, um Suzy zurückzubekommen."

# game/Scenes/Update19/Act3/act3scene4.rpy:61
translate german act3scene4_f8215d8f:

    # pc "I know, [mom]... but sometimes people can't come back."
    pc "Ich weiß, [mom]... aber manchmal können Menschen nicht zurückkommen."

# game/Scenes/Update19/Act3/act3scene4.rpy:62
translate german act3scene4_2022e63e:

    # pc "We lose people that we love sometimes..."
    pc "Manchmal verlieren wir Menschen, die wir lieben..."

# game/Scenes/Update19/Act3/act3scene4.rpy:63
translate german act3scene4_d1689608:

    # pc "...and we have to find a way to deal with that without hurting ourselves or others."
    pc "...und wir müssen einen Weg finden, damit umzugehen, ohne uns selbst oder anderen wehzutun."

# game/Scenes/Update19/Act3/act3scene4.rpy:66
translate german act3scene4_c3dfeaa2:

    # sp "How? How can a person deal with that sort of loss?"
    sp "Wie? Wie kann man mit so einem Verlust umgehen?"

# game/Scenes/Update19/Act3/act3scene4.rpy:68
translate german act3scene4_8b7fb492:

    # pc "Well, in my world..."
    pc "Nun, in meiner Welt..."

# game/Scenes/Update19/Act3/act3scene4.rpy:72
translate german act3scene4_22817e0f:

    # pc "... Nora lost what she thought her life was going to be."
    pc "... hat Nora das verloren, was sie sich für ihr Leben vorgestellt hatte."

# game/Scenes/Update19/Act3/act3scene4.rpy:73
translate german act3scene4_a6290b41:

    # pc "The man that was supposed to love her treated her badly and she was forced into this new life."
    pc "Der Mann, der sie eigentlich lieben sollte, hat sie schlecht behandelt, und sie wurde in dieses neue Leben gezwungen."

# game/Scenes/Update19/Act3/act3scene4.rpy:74
translate german act3scene4_1e07804a:

    # pc "But she dove in and accepted it and is thriving on her own now."
    pc "Aber sie hat sich darauf eingelassen und es akzeptiert und kommt jetzt ganz alleine zurecht."

# game/Scenes/Update19/Act3/act3scene4.rpy:75
translate german act3scene4_03b53305:

    # pc "She's discovering that there's a lot of love out there if you let yourself be open to it."
    pc "Sie entdeckt, dass es da draußen viel Liebe gibt, wenn man sich ihr nur öffnet."

# game/Scenes/Update19/Act3/act3scene4.rpy:79
translate german act3scene4_ff6ea314:

    # pc "... Reba's father passed away and it put her whole family in a sort of limbo."
    pc "... Rebas Vater ist verstorben, und das hat ihre ganze Familie in eine Art Schwebezustand versetzt."

# game/Scenes/Update19/Act3/act3scene4.rpy:80
translate german act3scene4_0115c38f:

    # pc "Her mother seems to have given up on her own life and Reba has been forced to take care of her."
    pc "Ihre Mutter scheint ihr eigenes Leben aufgegeben zu haben, und Reba ist gezwungen, sich um sie zu kümmern."

# game/Scenes/Update19/Act3/act3scene4.rpy:81
translate german act3scene4_233c26c0:

    # pc "But she's trying her best to move on and be a better version of herself, while also not forgetting about her family."
    pc "Aber sie gibt ihr Bestes, um weiterzumachen und eine bessere Version ihrer selbst zu werden, ohne dabei ihre Familie zu vergessen."

# game/Scenes/Update19/Act3/act3scene4.rpy:85
translate german act3scene4_b0752170:

    # pc "... Dana lost what she thought her life was going to be."
    pc "... Dana hat das verloren, was sie sich für ihr Leben vorgestellt hatte."

# game/Scenes/Update19/Act3/act3scene4.rpy:86
translate german act3scene4_4054bf2c:

    # pc "The man that was supposed to love her treated her badly and her family didn't support her."
    pc "Der Mann, der sie eigentlich lieben sollte, hat sie schlecht behandelt, und ihre Familie hat sie nicht unterstützt."

# game/Scenes/Update19/Act3/act3scene4.rpy:87
translate german act3scene4_e1dbd7a3:

    # pc "But she's finding herself again, and discovering that there's a lot of love out there if you let yourself be open to it."
    pc "Aber sie findet wieder zu sich selbst und entdeckt, dass es da draußen viel Liebe gibt, wenn man sich dafür öffnet."

# game/Scenes/Update19/Act3/act3scene4.rpy:91
translate german act3scene4_684ddcd7:

    # pc "... Adrian embraced her true self and some of the people she loved didn't support her."
    pc "... Adrian hat ihr wahres Ich angenommen, und einige der Menschen, die sie liebte, haben sie nicht unterstützt."

# game/Scenes/Update19/Act3/act3scene4.rpy:92
translate german act3scene4_0baf3bdf:

    # pc "She lost her father because he loved {i}his{/i} idea of who she was more than her actual self."
    pc "Sie hat ihren Vater verloren, weil er {i}seine{/i} Vorstellung davon, wer sie war, mehr liebte als ihr tatsächliches Selbst."

# game/Scenes/Update19/Act3/act3scene4.rpy:93
translate german act3scene4_0778a7bc:

    # pc "But she's happier than she's ever been and finding people who love her for who she really is."
    pc "Aber sie ist glücklicher als je zuvor und findet Menschen, die sie so lieben, wie sie wirklich ist."

# game/Scenes/Update19/Act3/act3scene4.rpy:97
translate german act3scene4_9eadd263:

    # pc "... Kendra is sick and will likely not live to be very old."
    pc "... Kendra ist krank und wird wahrscheinlich nicht sehr alt werden."

# game/Scenes/Update19/Act3/act3scene4.rpy:98
translate german act3scene4_5cec7ee5:

    # pc "When she dies, she will lose everybody and everybody will lose her."
    pc "Wenn sie stirbt, wird sie alle verlieren, und alle werden sie verlieren."

# game/Scenes/Update19/Act3/act3scene4.rpy:99
translate german act3scene4_fa1731ad:

    # pc "But she's determined to still love as hard as she can and enjoy life as much as she can while she's alive."
    pc "Aber sie ist entschlossen, weiterhin so intensiv wie möglich zu lieben und das Leben so sehr wie möglich zu genießen, solange sie lebt."

# game/Scenes/Update19/Act3/act3scene4.rpy:103
translate german act3scene4_a64c27f0:

    # pc "... Juliana lost both of her parents and has grown up with her grandmother."
    pc "... Juliana hat beide Elternteile verloren und ist bei ihrer Großmutter aufgewachsen."

# game/Scenes/Update19/Act3/act3scene4.rpy:104
translate german act3scene4_1653b6af:

    # pc "She's had a hard time making friends and has a lot of fear about loving someone and losing them."
    pc "Es fiel ihr schwer, Freunde zu finden, und sie hat große Angst davor, jemanden zu lieben und ihn zu verlieren."

# game/Scenes/Update19/Act3/act3scene4.rpy:105
translate german act3scene4_3e7f244a:

    # pc "But she's learning to put herself out there anyways, to make herself vulnerable."
    pc "Aber sie lernt, sich trotzdem zu öffnen und sich verletzlich zu zeigen."

# game/Scenes/Update19/Act3/act3scene4.rpy:106
translate german act3scene4_57cb2c2d:

    # pc "Because the rewards are worth it."
    pc "Denn die Belohnung ist es wert."

# game/Scenes/Update19/Act3/act3scene4.rpy:110
translate german act3scene4_6fd90af8:

    # pc "... Mi-Cha hasn't lost anything yet, but she knows she will."
    pc "... Mi-Cha hat noch nichts verloren, aber sie weiß, dass es so kommen wird."

# game/Scenes/Update19/Act3/act3scene4.rpy:111
translate german act3scene4_c726ce2f:

    # pc "She came to a place, gave her heart to somebody, and now she's being forced to leave that place and her love behind."
    pc "Sie kam an einen Ort, schenkte jemandem ihr Herz, und nun ist sie gezwungen, diesen Ort und ihre Liebe zurückzulassen."

# game/Scenes/Update19/Act3/act3scene4.rpy:112
translate german act3scene4_3d2ddad3:

    # pc "Maybe it'll work out, but in the end. She knows it's better to love and lose than never love at all."
    pc "Vielleicht wird alles gut, aber letztendlich weiß sie: Es ist besser zu lieben und zu verlieren, als gar nicht zu lieben."

# game/Scenes/Update19/Act3/act3scene4.rpy:119
translate german act3scene4_322b87f1:

    # pc "... Mari has lost everything. Her whole family taken from her in a moment."
    pc "... Mari hat alles verloren. Ihre ganze Familie wurde ihr in einem Augenblick genommen."

# game/Scenes/Update19/Act3/act3scene4.rpy:120
translate german act3scene4_29625c9a:

    # pc "She still lives in the shadow of that tragedy, but she shines brightly anyways."
    pc "Sie lebt immer noch im Schatten dieser Tragödie, aber sie strahlt trotzdem hell."

# game/Scenes/Update19/Act3/act3scene4.rpy:121
translate german act3scene4_6a46eb5e:

    # pc "She carries on with their love inside of her, knowing that they would be proud of her."
    pc "Sie trägt ihre Liebe in sich weiter und weiß, dass sie stolz auf sie wären."

# game/Scenes/Update19/Act3/act3scene4.rpy:125
translate german act3scene4_62feec4d:

    # pc "... Izzy lost both of her parents and has been put into a position where she has to care for her two little brothers."
    pc "... Izzy hat beide Elternteile verloren und ist in eine Lage geraten, in der sie sich um ihre beiden kleinen Brüder kümmern muss."

# game/Scenes/Update19/Act3/act3scene4.rpy:126
translate german act3scene4_e5564799:

    # pc "She could be resentful of this, but she loves those two boys so much."
    pc "Sie könnte darüber verbittert sein, aber sie liebt diese beiden Jungen so sehr."

# game/Scenes/Update19/Act3/act3scene4.rpy:127
translate german act3scene4_289024f9:

    # pc "When she thought she lost them, she fought so hard to get them back."
    pc "Als sie dachte, sie hätte sie verloren, kämpfte sie so hart, um sie zurückzubekommen."

# game/Scenes/Update19/Act3/act3scene4.rpy:131
translate german act3scene4_a06ddb36:

    # pc "... Jamie loved a boy so much, but he tossed her aside without a word."
    pc "... Jamie liebte einen Jungen so sehr, doch er hat sie ohne ein Wort fallen lassen."

# game/Scenes/Update19/Act3/act3scene4.rpy:132
translate german act3scene4_9714d5b1:

    # pc "But she kept moving forward, just being herself."
    pc "Aber sie hat weitergemacht und einfach sie selbst geblieben."

# game/Scenes/Update19/Act3/act3scene4.rpy:133
translate german act3scene4_7f79356e:

    # pc "And eventually, things came back around and worked out for her."
    pc "Und schließlich hat sich das Blatt gewendet und alles hat sich für sie zum Guten gewendet."

# game/Scenes/Update19/Act3/act3scene4.rpy:137
translate german act3scene4_d7d23337:

    # pc "And then there's me..."
    pc "Und dann bin da noch ich..."

# game/Scenes/Update19/Act3/act3scene4.rpy:139
translate german act3scene4_6cc0d265:

    # pc "Well, I can only talk about myself..."
    pc "Nun, ich kann nur über mich selbst sprechen..."

# game/Scenes/Update19/Act3/act3scene4.rpy:140
translate german act3scene4_cdb25042:

    # pc "I lost my mom when I was a teenager and it was really hard on me."
    pc "Ich habe meine Mutter verloren, als ich ein Teenager war, und das war wirklich schwer für mich."

# game/Scenes/Update19/Act3/act3scene4.rpy:141
translate german act3scene4_739643a0:

    # pc "I took it out on the people around me and did things I regret."
    pc "Ich habe es an den Menschen in meiner Umgebung ausgelassen und Dinge getan, die ich bereue."

# game/Scenes/Update19/Act3/act3scene4.rpy:142
translate german act3scene4_ac0e651a:

    # pc "But I've done my best to change that and make things right."
    pc "Aber ich habe mein Bestes getan, das zu ändern und die Dinge wieder in Ordnung zu bringen."

# game/Scenes/Update19/Act3/act3scene4.rpy:145
translate german act3scene4_e7e67352:

    # sp "I suppose that's what I should do now."
    sp "Ich nehme an, das sollte ich jetzt tun."

# game/Scenes/Update19/Act3/act3scene4.rpy:146
translate german act3scene4_1e770403:

    # pc "I think so."
    pc "Ich glaube schon."

# game/Scenes/Update19/Act3/act3scene4.rpy:147
translate german act3scene4_2610ae2e:

    # sp "I feel so ashamed. How can I face people?"
    sp "Ich schäme mich so sehr. Wie kann ich den Leuten noch in die Augen sehen?"

# game/Scenes/Update19/Act3/act3scene4.rpy:150
translate german act3scene4_5c7a5888:

    # pc "The ones that really matter still love you, Lisa."
    pc "Die, die wirklich wichtig sind, lieben dich immer noch, Lisa."

# game/Scenes/Update19/Act3/act3scene4.rpy:151
translate german act3scene4_34903c2d:

    # pc "They feel the same loss that you feel."
    pc "Sie empfinden denselben Verlust, den du empfindest."

# game/Scenes/Update19/Act3/act3scene4.rpy:152
translate german act3scene4_a346789c:

    # pc "But they feel like they lost {i}you{/i} as well."
    pc "Aber sie haben das Gefühl, auch {i}dich{/i} verloren zu haben."

# game/Scenes/Update19/Act3/act3scene4.rpy:155
translate german act3scene4_02541c65:

    # tm "It's true, Your Majesty."
    tm "Das ist wahr, Eure Majestät."

# game/Scenes/Update19/Act3/act3scene4.rpy:156
translate german act3scene4_e56ac275:

    # tm "I miss Suzy so much."
    tm "Ich vermisse Suzy so sehr."

# game/Scenes/Update19/Act3/act3scene4.rpy:157
translate german act3scene4_2b1387cd:

    # tm "And I miss you too."
    tm "Und ich vermisse dich auch."

# game/Scenes/Update19/Act3/act3scene4.rpy:160
translate german act3scene4_909876ef:

    # sp "Oh God, I'm so sorry, Tammy. Of course you miss her too."
    sp "Oh Gott, es tut mir so leid, Tammy. Natürlich vermisst du sie auch."

# game/Scenes/Update19/Act3/act3scene4.rpy:161
translate german act3scene4_ddc42ef4:

    # sp "I'll fix this. I'll make it better."
    sp "Ich werde das in Ordnung bringen. Ich werde es besser machen."

# game/Scenes/Update19/Act3/act3scene4.rpy:165
translate german act3scene4_f8a1c7af:

    # sp "Starting with this."
    sp "Angefangen damit."

