translate german battletutorial_b91f1b47:

    # rj "It's pretty easy."
    rj "Es ist ziemlich einfach."

# game/Scenes/Update19/Combat/battletutorial.rpy:16
translate german battletutorial_91800a12:

    # rj "Each character has two abilities. Hovering over one will tell you what it does."
    rj "Jeder Charakter hat zwei Fähigkeiten. Wenn du mit der Maus darüber fährst, erfährst du, was sie bewirken."

# game/Scenes/Update19/Combat/battletutorial.rpy:17
translate german battletutorial_2ab13a0a:

    # rj "If any allies die, they won't be able to fight again until you rest."
    rj "Wenn Verbündete sterben, können sie erst wieder kämpfen, wenn du dich ausruhst."

# game/Scenes/Update19/Combat/battletutorial.rpy:18
translate german battletutorial_7ed19b5b:

    # rj "If the MC dies, you'll have to restart the battle."
    rj "Wenn der Hauptcharakter stirbt, musst du den Kampf neu starten."

# game/Scenes/Update19/Combat/battletutorial.rpy:20
translate german battletutorial_a7a058b6:

    # rj "If you {i}really{/i} hate the combat, you can just open up the menu during a fight and click Skip Battle."
    rj "Wenn du den Kampf {i}wirklich{/i} hasst, kannst du während des Kampfes einfach das Menü öffnen und auf „Kampf überspringen“ klicken."

# game/Scenes/Update19/Combat/battletutorial.rpy:21
translate german battletutorial_a5f1e8ea:

    # rj "But there is a Steam achievement for not skipping any battles, so keep that in mind."
    rj "Aber es gibt eine Steam-Errungenschaft dafür, keinen Kampf zu überspringen, also denk daran."

# game/Scenes/Update19/Combat/battletutorial.rpy:23
translate german battletutorial_0c42154f:

    # rj "Okay, that's it, have fun!"
    rj "Okay, das war’s, viel Spaß!"

