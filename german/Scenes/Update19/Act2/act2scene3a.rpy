# game/Scenes/Update19/Act2/act2scene3a.rpy:29
translate german u19a2s3a_b6f125ff:

    # gg "Get the fuck away from me, you trolls!"
    gg "Verpisst euch, ihr Trolle!"

# game/Scenes/Update19/Act2/act2scene3a.rpy:30
translate german u19a2s3a_91f50fe5:

    # "We come to a clearing and I see her - though she looks more like her character in Souls of War than her real life appearance."
    "Wir kommen auf eine Lichtung und ich sehe sie – obwohl sie eher wie ihre Figur in „Souls of War“ aussieht als wie sie im echten Leben."

# game/Scenes/Update19/Act2/act2scene3a.rpy:43
translate german u19a2s3a_7fe530c1:

    # "I pull out my sword and get ready to head in to fight."
    "Ich ziehe mein Schwert und mache mich bereit, in den Kampf zu ziehen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:45
translate german u19a2s3a_4a6014ee:

    # sst "Trolls... I hate trolls. Let's help her."
    sst "Trolle… Ich hasse Trolle. Lass uns ihr helfen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:47
translate german u19a2s3a_c989b003:

    # rb "Do you think you're going to be able to fight those things? You'll definitely need my help."
    rb "Glaubst du, du kannst gegen diese Dinger kämpfen? Du wirst auf jeden Fall meine Hilfe brauchen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:48
translate german u19a2s3a_993e94f1:

    # rb "Let's do this."
    rb "Lass es uns tun."

# game/Scenes/Update19/Act2/act2scene3a.rpy:50
translate german u19a2s3a_4ce0d393:

    # cw "Trolls. Why is it always trolls?"
    cw "Trolle. Warum sind es immer Trolle?"

# game/Scenes/Update19/Act2/act2scene3a.rpy:51
translate german u19a2s3a_112afcc5:

    # cw "I'm not holding back this time."
    cw "Diesmal halte ich mich nicht zurück."

# game/Scenes/Update19/Act2/act2scene3a.rpy:63
translate german u19a2s3a_0991b910:

    # "We charge in together, letting out a battle cry to grab the trolls' attention."
    "Wir stürmen gemeinsam vor und stoßen einen Schlachtruf aus, um die Aufmerksamkeit der Trolle auf uns zu lenken."

# game/Scenes/Update19/Act2/act2scene3a.rpy:65
translate german u19a2s3a_48878a66:

    # "I charge in, letting out a battle cry to grab the trolls' attention."
    "Ich stürme vor und stoße einen Schlachtruf aus, um die Aufmerksamkeit der Trolle auf mich zu lenken."

# game/Scenes/Update19/Act2/act2scene3a.rpy:87
translate german adrianbattleconversation1_2035d9aa:

    # gg "Thanks for the help! Who are you?"
    gg "Danke für die Hilfe! Wer bist du?"

# game/Scenes/Update19/Act2/act2scene3a.rpy:88
translate german adrianbattleconversation1_6340393e:

    # pc "Hey Adrian. I'm [pcname]."
    pc "Hey Adrian. Ich bin [pcname]."

# game/Scenes/Update19/Act2/act2scene3a.rpy:89
translate german adrianbattleconversation1_450920cd:

    # gg "Wait, how do you know my name?"
    gg "Moment, woher kennst du meinen Namen?"

# game/Scenes/Update19/Act2/act2scene3a.rpy:93
translate german adrianbattleconversation1_c70dcaa4:

    # sst "Not really important right now. Trolls to fight."
    sst "Das ist jetzt nicht so wichtig. Wir müssen gegen Trolle kämpfen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:97
translate german adrianbattleconversation1_fca5f34c:

    # rb "Who cares!? Pay attention and let's kill these bluggars!"
    rb "Wen interessiert das schon!? Passt auf und lasst uns diese Mistkerle erledigen!"

# game/Scenes/Update19/Act2/act2scene3a.rpy:101
translate german adrianbattleconversation1_b326ef94:

    # cw "We'll deal with that later. First, we kill trolls."
    cw "Darum kümmern wir uns später. Erst mal töten wir Trolle."

# game/Scenes/Update19/Act2/act2scene3a.rpy:103
translate german adrianbattleconversation1_113539de:

    # pc "Let's get through this fight first, then I'll explain."
    pc "Lasst uns erst diesen Kampf hinter uns bringen, dann erkläre ich es euch."

# game/Scenes/Update19/Act2/act2scene3a.rpy:104
translate german adrianbattleconversation1_79fe09a9:

    # gg "Right! Let's do this!"
    gg "Genau! Los geht’s!"

# game/Scenes/Update19/Act2/act2scene3a.rpy:117
translate german u19a2s3a_b_b4116a01:

    # gg "That could have been bad. Thanks for showing up when you did."
    gg "Das hätte böse enden können. Danke, dass ihr gerade noch rechtzeitig aufgetaucht seid."

# game/Scenes/Update19/Act2/act2scene3a.rpy:118
translate german u19a2s3a_b_5d1eff79:

    # gg "Who are you anyway?"
    gg "Wer seid ihr eigentlich?"

# game/Scenes/Update19/Act2/act2scene3a.rpy:122
translate german u19a2s3a_b_4e5f032f:

    # sst "I'm Nora. Nice to meet you."
    sst "Ich bin Nora. Schön, euch kennenzulernen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:123
translate german u19a2s3a_b_64478cd6:

    # pc "And I'm [pcname]."
    pc "Und ich bin [pcname]."

# game/Scenes/Update19/Act2/act2scene3a.rpy:127
translate german u19a2s3a_b_f8814411:

    # rb "I'm Reba. Your magic is so dang pretty!"
    rb "Ich bin Reba. Deine Magie ist so verdammt schön!"

# game/Scenes/Update19/Act2/act2scene3a.rpy:128
translate german u19a2s3a_b_64478cd6_1:

    # pc "And I'm [pcname]."
    pc "Und ich bin [pcname]."

# game/Scenes/Update19/Act2/act2scene3a.rpy:132
translate german u19a2s3a_b_1a145250:

    # cw "I'm Dana. Nice to meet you."
    cw "Ich bin Dana. Schön, dich kennenzulernen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:133
translate german u19a2s3a_b_64478cd6_2:

    # pc "And I'm [pcname]."
    pc "Und ich bin [pcname]."

# game/Scenes/Update19/Act2/act2scene3a.rpy:137
translate german u19a2s3a_b_cb77909a:

    # pc "I'm [pcname]."
    pc "Ich bin [pcname]."

# game/Scenes/Update19/Act2/act2scene3a.rpy:140
translate german u19a2s3a_b_abe29e36:

    # gg "And I'm Adrian. But somehow, you already knew that."
    gg "Und ich bin Adrian. Aber irgendwie wusstest du das ja schon."

# game/Scenes/Update19/Act2/act2scene3a.rpy:141
translate german u19a2s3a_b_4d841c2b:

    # gg "So... how do you know me?"
    gg "Also... woher kennst du mich?"

# game/Scenes/Update19/Act2/act2scene3a.rpy:145
translate german u19a2s3a_b_9e8398d6:

    # sst "I've heard this one. I'm going to go take a dip while you explain."
    sst "Das habe ich schon mal gehört. Ich gehe mich kurz abkühlen, während du es erklärst."

# game/Scenes/Update19/Act2/act2scene3a.rpy:149
translate german u19a2s3a_b_cc0d08f1:

    # rb "I'll let you explain this to her while I go loot the bodies."
    rb "Ich überlasse es dir, ihr das zu erklären, während ich die Leichen plündere."

# game/Scenes/Update19/Act2/act2scene3a.rpy:153
translate german u19a2s3a_b_81912442:

    # cw "I'll let you handle this. I'm going to clean up a bit."
    cw "Ich überlasse das dir. Ich werde mich erst mal ein bisschen aufräumen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:156
translate german u19a2s3a_b_cedc4a56:

    # "It takes some time, but I explain to Adrian about coming from another world, about the bracelet, and about the Ice Queen."
    "Es dauert eine Weile, aber ich erkläre Adrian, dass ich aus einer anderen Welt komme, erzähle ihm vom Armband und von der Eiskönigin."

# game/Scenes/Update19/Act2/act2scene3a.rpy:159
translate german u19a2s3a_b_8770d065:

    # gg "Sounds like you're on a quest. I love a good quest. I'm in."
    gg "Klingt, als wärst du auf einer Mission. Ich liebe gute Missionen. Ich bin dabei."

# game/Scenes/Update19/Act2/act2scene3a.rpy:160
translate german u19a2s3a_b_dc879346:

    # pc "That didn't take much convincing."
    pc "Da musste ich dich nicht lange überreden."

# game/Scenes/Update19/Act2/act2scene3a.rpy:161
translate german u19a2s3a_b_69959806:

    # gg "Nah, this sounds like fun."
    gg "Nee, das klingt nach Spaß."

# game/Scenes/Update19/Act2/act2scene3a.rpy:162
translate german u19a2s3a_b_44fb0b42:

    # gg "Besides, you came in and rescued me out of the goodness of your heart. How can I deny you my assistance now?"
    gg "Außerdem bist du hereingekommen und hast mich aus reiner Herzensgüte gerettet. Wie könnte ich dir jetzt meine Hilfe verweigern?"

# game/Scenes/Update19/Act2/act2scene3a.rpy:163
translate german u19a2s3a_b_38929c6b:

    # pc "After seeing the spells you were slinging, I could definitely use your help."
    pc "Nachdem ich gesehen habe, welche Zaubersprüche du gewirkt hast, könnte ich deine Hilfe definitiv gebrauchen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:166
translate german u19a2s3a_b_28aee061:

    # gg "Then let's get going, [pcname]. No time to waste."
    gg "Dann lass uns loslegen, [pcname]. Keine Zeit zu verlieren."

# game/Scenes/Update19/Act2/act2scene3a.rpy:167
translate german u19a2s3a_b_a77fc863:

    # gg "We gotta get you back to your world."
    gg "Wir müssen dich zurück in deine Welt bringen."

# game/Scenes/Update19/Act2/act2scene3a.rpy:177
translate german u19a2s3a_b_a80cff90:

    # "Nora rejoins us... and we continue north together."
    "Nora schließt sich uns wieder an … und wir ziehen gemeinsam weiter nach Norden."

