# game/Scenes/School/SocialStudies/ss1.rpy:12
translate german ss1_cdbb8564:

    # "Ms. Welch starts class by handing out the tests that we did the previous week."
    "Frau Welch beginnt den Unterricht damit, die Tests auszuteilen, die wir in der vergangenen Woche geschrieben haben."

# game/Scenes/School/SocialStudies/ss1.rpy:13
translate german ss1_5d9d5d63:

    # gg "How did you do?"
    gg "Wie ist es gelaufen?"

# game/Scenes/School/SocialStudies/ss1.rpy:14
translate german ss1_0dbc34a9:

    # pc "I aced it. Perfect A+"
    pc "Ich habe es mit Bravour geschafft. Perfekte 1+."

# game/Scenes/School/SocialStudies/ss1.rpy:16
translate german ss1_9872da7c:

    # gg "Wow, nice! I might need to study with you sometime."
    gg "Wow, super! Vielleicht muss ich mal mit dir lernen."

# game/Scenes/School/SocialStudies/ss1.rpy:20
translate german ss1_edc93756:

    # "She turns back to the front and then Ms. Welch starts lecturing."
    "Sie dreht sich wieder nach vorne und dann beginnt Frau Welch mit ihrem Vortrag."

# game/Scenes/School/SocialStudies/ss1.rpy:23
translate german ss1_ac33b73f:

    # gg "Can't wait."
    gg "Ich kann es kaum erwarten."

# game/Scenes/School/SocialStudies/ss1.rpy:24
translate german ss1_34213f63:

    # "After that, Ms. Welch starts lecturing and we both turn to the front and try to stay awake."
    "Danach beginnt Frau Welch mit ihrem Vortrag und wir drehen uns beide nach vorne und versuchen, wach zu bleiben."

# game/Scenes/School/SocialStudies/ss1.rpy:28
translate german ss1_38327323:

    # "Ms. Welch goes on and on about the questions that were missed the most on the test."
    "Frau Welch redet endlos über die Fragen, die im Test am häufigsten falsch beantwortet wurden."

# game/Scenes/School/SocialStudies/ss1.rpy:29
translate german ss1_60ee67bc:

    # "Then she starts in on what we will be covering with the next test which will be next week."
    "Dann fängt sie an, zu erklären, was wir für den nächsten Test durchnehmen werden, der nächste Woche stattfindet."

# game/Scenes/School/SocialStudies/ss1.rpy:30
translate german ss1_18c2b08f:

    # "I try to pay attention, but it's hard when I really just don't care about the subject matter at all, and my mind is going everywhere else."
    "Ich versuche, aufmerksam zu sein, aber das ist schwer, wenn mir das Thema wirklich völlig egal ist und meine Gedanken überall hinwandern."

# game/Scenes/School/SocialStudies/ss1.rpy:32
translate german ss1_b4a5181e:

    # "I think about my dad. I think about work. I think about what Ms. Welch would look like without that dress on."
    "Ich denke an meinen Vater. Ich denke an die Arbeit. Ich denke darüber nach, wie Frau Welch wohl ohne dieses Kleid aussehen würde."

# game/Scenes/School/SocialStudies/ss1.rpy:34
translate german ss1_5a4862a5:

    # sst "Right, [pcname]?"
    sst "Richtig, [pcname]?"

# game/Scenes/School/SocialStudies/ss1.rpy:38
translate german ss1_b0461cd6:

    # sst "Good, I'll see you there."
    sst "Gut, wir sehen uns dort."

# game/Scenes/School/SocialStudies/ss1.rpy:40
translate german ss1_4b943e43:

    # pc "Uh, what did I just agree to?"
    pc "Äh, wozu habe ich gerade zugestimmt?"

# game/Scenes/School/SocialStudies/ss1.rpy:41
translate german ss1_f0083f96:

    # gg "You agreed to go to the courtyard this evening to help her register voters."
    gg "Du hast zugestimmt, heute Abend in den Innenhof zu gehen, um ihr bei der Wählerregistrierung zu helfen."

# game/Scenes/School/SocialStudies/ss1.rpy:42
translate german ss1_0e03a1ab:

    # pc "Oh God. I don't want to do that."
    pc "Oh Gott. Das will ich nicht machen."

# game/Scenes/School/SocialStudies/ss1.rpy:43
translate german ss1_5684dd44:

    # gg "Then why did you agree to it?"
    gg "Warum hast du dann zugestimmt?"

# game/Scenes/School/SocialStudies/ss1.rpy:44
translate german ss1_51548651:

    # pc "I don't know. I wasn't listening."
    pc "Ich weiß nicht. Ich habe nicht zugehört."

# game/Scenes/School/SocialStudies/ss1.rpy:47
translate german ss1_c2ff44a1:

    # sst "Uhh?"
    sst "Äh?"

# game/Scenes/School/SocialStudies/ss1.rpy:48
translate german ss1_d43b4dca:

    # sst "I expect you to pay attention in class, [pcname]."
    sst "Ich erwarte, dass du im Unterricht aufpasst, [pcname]."

# game/Scenes/School/SocialStudies/ss1.rpy:50
translate german ss1_2e379803:

    # sst "I was talking about how important it is to vote."
    sst "Ich habe darüber gesprochen, wie wichtig es ist, wählen zu gehen."

# game/Scenes/School/SocialStudies/ss1.rpy:51
translate german ss1_ef5f7136:

    # sst "And how myself and a group of students are going to be in the courtyard later this evening registering students to vote."
    sst "Und dass ich und eine Gruppe von Schülern später am Abend im Innenhof sein werden, um Schüler für die Wahl zu registrieren."

# game/Scenes/School/SocialStudies/ss1.rpy:53
translate german ss1_03dfffcf:

    # sst "And since you can't keep focused in class, I expect you to be there to help."
    sst "Und da du dich im Unterricht nicht konzentrieren kannst, erwarte ich, dass du dort bist, um zu helfen."

# game/Scenes/School/SocialStudies/ss1.rpy:54
translate german ss1_3a72700b:

    # sst "You will be there, won't you, [pcname]."
    sst "Du wirst doch da sein, oder, [pcname]?"

# game/Scenes/School/SocialStudies/ss1.rpy:55
translate german ss1_403d0486:

    # pc "I'll be there."
    pc "Ich werde da sein."

# game/Scenes/School/SocialStudies/ss1.rpy:57
translate german ss1_3807a033:

    # sst "Good."
    sst "Gut."

# game/Scenes/School/SocialStudies/ss1.rpy:58
translate german ss1_50770a51:

    # sst "I'll see you then."
    sst "Wir sehen uns dann."

# game/Scenes/School/SocialStudies/ss1.rpy:60
translate german ss1_eb0964ca:

    # sst "And if anybody else wants to join [pcname] and I, you are all invited to come help."
    sst "Und wenn noch jemand Lust hat, sich [pcname] und mir anzuschließen, seid ihr alle herzlich eingeladen, mitzuhelfen."

# game/Scenes/School/SocialStudies/ss1.rpy:63
translate german ss1_84ba533b:

    # sst "At least he's honest."
    sst "Wenigstens ist er ehrlich."

# game/Scenes/School/SocialStudies/ss1.rpy:65
