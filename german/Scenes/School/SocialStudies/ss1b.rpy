# game/Scenes/School/SocialStudies/ss1b.rpy:13
translate german ss1b_40e9560a:

    # "I leave work and head back to school."
    "Ich verlasse die Arbeit und gehe zurück zur Schule."

# game/Scenes/School/SocialStudies/ss1b.rpy:14
translate german ss1b_ec832fb4:

    # "I had promised to help register voters and as much as I really don't want to, I also don't want to make Ms. Welch upset."
    "Ich hatte versprochen, bei der Wählerregistrierung zu helfen, und so sehr ich das auch nicht möchte, will ich Frau Welch auch nicht verärgern."

# game/Scenes/School/SocialStudies/ss1b.rpy:16
translate german ss1b_4da2fb67:

    # "Plus Adrian said she'd be there. She seems cool. Maybe it will be okay."
    "Außerdem hat Adrian gesagt, dass sie da sein wird. Sie scheint cool zu sein. Vielleicht wird es ja ganz okay."

# game/Scenes/School/SocialStudies/ss1b.rpy:18
translate german ss1b_a6c1cd2f:

    # "Plus Adrian said she's be there. She's always fun."
    "Außerdem hat Adrian gesagt, dass sie da sein wird. Mit ihr ist es immer lustig."

# game/Scenes/School/SocialStudies/ss1b.rpy:20
translate german ss1b_5560e008:

    # "I head to the courtyard and spot Ms. Welch immediately. She is walking around with a clipboard and a stack of cards and talking to anybody that will slow down for her."
    "Ich gehe in den Innenhof und entdecke Frau Welch sofort. Sie läuft mit einem Klemmbrett und einem Stapel Karten herum und spricht jeden an, der für sie stehen bleibt."

# game/Scenes/School/SocialStudies/ss1b.rpy:21
translate german ss1b_9913bec3:

    # "After a couple of minutes, she notices me."
    "Nach ein paar Minuten bemerkt sie mich."

# game/Scenes/School/SocialStudies/ss1b.rpy:25
translate german ss1b_d41d8cd9:

    # voice 'voices/welch_hey1.mp3'
    voice 'voices/welch_hey1.mp3'

# game/Scenes/School/SocialStudies/ss1b.rpy:26
translate german ss1b_07e132ed:

    # sst "Hey, [pcname]. I wasn't sure you'd actually come."
    sst "Hey, [pcname]. Ich war mir nicht sicher, ob du wirklich kommen würdest."

# game/Scenes/School/SocialStudies/ss1b.rpy:27
translate german ss1b_4b5514dd:

    # pc "I said I would."
    pc "Ich habe gesagt, dass ich komme."

# game/Scenes/School/SocialStudies/ss1b.rpy:28
translate german ss1b_2dda22d7:

    # sst "Yeah, well so did half a dozen other people, but it's just me here."
    sst "Ja, das haben ein halbes Dutzend andere Leute auch gesagt, aber ich bin die Einzige, die hier ist."

# game/Scenes/School/SocialStudies/ss1b.rpy:29
translate german ss1b_9d676f13:

    # pc "Okay, well what do I have to do?"
    pc "Okay, was muss ich tun?"

# game/Scenes/School/SocialStudies/ss1b.rpy:30
translate german ss1b_79f584de:

    # sst "Just grab whoever you can that will talk to you and ask them if they're registered to vote."
    sst "Sprich einfach jeden an, der mit dir redet, und frag ihn, ob er wahlberechtigt ist."

# game/Scenes/School/SocialStudies/ss1b.rpy:31
translate german ss1b_9375e7cf:

    # sst "If they're not, they just have to fill out these cards and we'll mail it in for them to get them registered."
    sst "Wenn nicht, muss er nur diese Karten ausfüllen, und wir schicken sie per Post ein, damit er registriert wird."

# game/Scenes/School/SocialStudies/ss1b.rpy:35
translate german ss1b_7637ac45:

    # gg "Sounds easy."
    gg "Klingt einfach."

# game/Scenes/School/SocialStudies/ss1b.rpy:36
translate german ss1b_1d8c05e0:

    # sst "Oh Adrian, you're here too. Good."
    sst "Oh, Adrian, du bist auch hier. Gut."

# game/Scenes/School/SocialStudies/ss1b.rpy:37
translate german ss1b_03ea6ef8:

    # sst "Okay, you two tag-team that half of the courtyard over there, and I'll take the other half. Got it?"
    sst "Okay, ihr zwei kümmert euch gemeinsam um die Hälfte des Innenhofs dort drüben, und ich übernehme die andere Hälfte. Verstanden?"

# game/Scenes/School/SocialStudies/ss1b.rpy:38
translate german ss1b_e5894730:

    # gg "Maybe you could show us how it's done one time?"
    gg "Vielleicht könntest du uns einmal zeigen, wie das geht?"

# game/Scenes/School/SocialStudies/ss1b.rpy:39
translate german ss1b_af66e2d7:

    # sst "Good idea. Okay, watch this."
    sst "Gute Idee. Okay, schau zu."

# game/Scenes/School/SocialStudies/ss1b.rpy:43
translate german ss1b_de281672:

    # sst "You. Are you registered to vote?"
    sst "Du. Bist du wahlberechtigt?"

# game/Scenes/School/SocialStudies/ss1b.rpy:44
translate german ss1b_79442302:

    # "Student" "Uh, I don't know."
    "Student" "Äh, ich weiß es nicht."

# game/Scenes/School/SocialStudies/ss1b.rpy:45
translate german ss1b_a30d7196:

    # sst "If you don't know, then you're probably not."
    sst "Wenn du es nicht weißt, bist du es wahrscheinlich nicht."

# game/Scenes/School/SocialStudies/ss1b.rpy:46
translate german ss1b_3e43629b:

    # sst "That's okay, because I can get you registered today."
    sst "Das ist okay, denn ich kann dich heute registrieren lassen."

# game/Scenes/School/SocialStudies/ss1b.rpy:47
translate german ss1b_21ff49d5:

    # "Student" "I'm really not interested."
    "Student" "Ich habe wirklich kein Interesse."

# game/Scenes/School/SocialStudies/ss1b.rpy:49
translate german ss1b_d41d8cd9_1:

    # voice "voices/welch_ss1b_1.mp3"
    voice "voices/welch_ss1b_1.mp3"

# game/Scenes/School/SocialStudies/ss1b.rpy:50
translate german ss1b_388218d2:

    # sst "You're not interested in your country? Not interested in doing your part to help support democracy?"
    sst "Du hast kein Interesse an deinem Land? Kein Interesse daran, deinen Teil zur Unterstützung der Demokratie beizutragen?"

# game/Scenes/School/SocialStudies/ss1b.rpy:52
translate german ss1b_d41d8cd9_2:

    # voice "voices/welch_ss1b_2.mp3"
    voice "voices/welch_ss1b_2.mp3"

# game/Scenes/School/SocialStudies/ss1b.rpy:53
translate german ss1b_e1981279:

    # sst "Your forefathers fought in wars! They were shot at! Slept in the mud and blood on the battlefield!"
    sst "Deine Vorfahren haben in Kriegen gekämpft! Sie wurden beschossen! Haben im Schlamm und Blut auf dem Schlachtfeld geschlafen!"

# game/Scenes/School/SocialStudies/ss1b.rpy:55
translate german ss1b_d41d8cd9_3:

    # voice "voices/welch_ss1b_3.mp3"
    voice "voices/welch_ss1b_3.mp3"

# game/Scenes/School/SocialStudies/ss1b.rpy:56
translate german ss1b_d0eba8ab:

    # sst "And you can't fill out a fucking voter's registration card to do your part?"
    sst "Und du kannst nicht mal eine verdammte Wählerregistrierungskarte ausfüllen, um deinen Teil beizutragen?"

# game/Scenes/School/SocialStudies/ss1b.rpy:57
translate german ss1b_6300c7dd:

    # "Student" "Okay fine, I'll fill out the card."
    "Student" "Okay, gut, ich fülle die Karte aus."

# game/Scenes/School/SocialStudies/ss1b.rpy:58
translate german ss1b_e51ea0c1:

    # sst "Good. Here."
    sst "Gut. Hier."

# game/Scenes/School/SocialStudies/ss1b.rpy:59
translate german ss1b_1994b030:

    # "The student quickly fills out the card and hands it back to her. She clips it to her clipboard and he quickly scurries away."
    "Der Schüler füllt die Karte schnell aus und gibt sie ihr zurück. Sie heftet sie an ihr Klemmbrett und er huscht schnell davon."

# game/Scenes/School/SocialStudies/ss1b.rpy:60
translate german ss1b_cdc68244:

    # sst "Thank you! You're a true patriot."
    sst "Danke! Du bist ein echter Patriot."

# game/Scenes/School/SocialStudies/ss1b.rpy:64
translate german ss1b_b3e19edf:

    # sst "See how I cornered him so that he couldn't run away easily?"
    sst "Siehst du, wie ich ihn in die Enge getrieben habe, damit er nicht so leicht weglaufen konnte?"

# game/Scenes/School/SocialStudies/ss1b.rpy:65
translate german ss1b_b36089e7:

    # sst "That's the trick. You have to make it really hard for them to get away from you."
    sst "Das ist der Trick. Man muss es ihnen wirklich schwer machen, sich von einem zu entfernen."

# game/Scenes/School/SocialStudies/ss1b.rpy:66
translate german ss1b_a247dc20:

    # sst "Then you guilt them. It always works."
    sst "Dann machst du ihnen Schuldgefühle. Das funktioniert immer."

# game/Scenes/School/SocialStudies/ss1b.rpy:67
translate german ss1b_be82cdc0:

    # sst "Alright, you two get to work."
    sst "Also gut, ihr beiden macht euch an die Arbeit."

# game/Scenes/School/SocialStudies/ss1b.rpy:70
translate german ss1b_beadb08d:

    # "With that, Ms. Welch walks away to her side of the courtyard and starts cornering other students."
    "Damit geht Frau Welch zu ihrer Seite des Innenhofs und fängt an, andere Schüler in die Enge zu treiben."

# game/Scenes/School/SocialStudies/ss1b.rpy:71
translate german ss1b_a2e23acd:

    # gg "This is going to suck. Why did I agree to this again?"
    gg "Das wird nervig. Warum habe ich dem noch mal zugestimmt?"

# game/Scenes/School/SocialStudies/ss1b.rpy:74
translate german ss1b_94e6c190:

    # gg "Okay, well let's get to work."
    gg "Okay, na dann, machen wir uns an die Arbeit."

# game/Scenes/School/SocialStudies/ss1b.rpy:79
translate german ss1b_5fca9b32:

    # gg "What? No!"
    gg "Was? Nein!"

# game/Scenes/School/SocialStudies/ss1b.rpy:80
translate german ss1b_4d50e201:

    # gg "Okay, maybe."
    gg "Okay, vielleicht."

# game/Scenes/School/SocialStudies/ss1b.rpy:81
translate german ss1b_c39ff304:

    # gg "Anyway, we better get to work."
    gg "Wie auch immer, wir machen uns besser an die Arbeit."

# game/Scenes/School/SocialStudies/ss1b.rpy:85
translate german ss1b_da5d175e:

    # gg "You may be onto something there."
    gg "Da könntest du auf etwas gestoßen sein."

# game/Scenes/School/SocialStudies/ss1b.rpy:88
translate german ss1b_e66c9878:

    # "She takes half the cards from my hand and walks off towards a group of students."
    "Sie nimmt mir die Hälfte der Karten aus der Hand und geht auf eine Gruppe von Schülern zu."

# game/Scenes/School/SocialStudies/ss1b.rpy:89
translate german ss1b_0f12b4ae:

    # "I look around for a target of my own and then pursue."
    "Ich schaue mich nach einem eigenen Ziel um und folge ihr dann."

# game/Scenes/School/SocialStudies/ss1b.rpy:92
translate german ss1b_1d9a6e64:

    # "I spend the next hour talking to as many students as I can and trying to convince them to register."
    "Die nächste Stunde verbringe ich damit, mit so vielen Schülern wie möglich zu sprechen und sie davon zu überzeugen, sich einzutragen."

# game/Scenes/School/SocialStudies/ss1b.rpy:93
translate german ss1b_e9fbd9a8:

    # "It isn't something I really enjoy, but I seem to be somewhat good at it, because at the end of the hour, I have filled out every one of the cards."
    "Es macht mir nicht wirklich Spaß, aber ich scheine ziemlich gut darin zu sein, denn am Ende der Stunde habe ich jede einzelne Karte ausgefüllt."

# game/Scenes/School/SocialStudies/ss1b.rpy:98
translate german ss1b_ca773934:

    # sst "Wow you two did great."
    sst "Wow, ihr zwei habt das toll gemacht."

# game/Scenes/School/SocialStudies/ss1b.rpy:99
translate german ss1b_82c118d8:

    # gg "My stack is way smaller than his."
    gg "Mein Stapel ist viel kleiner als seiner."

# game/Scenes/School/SocialStudies/ss1b.rpy:102
translate german ss1b_33053153:

    # sst "Size of the stack doesn't always matter."
    sst "Auf die Größe des Stapels kommt es nicht immer an."

# game/Scenes/School/SocialStudies/ss1b.rpy:103
translate german ss1b_d17e6a5f:

    # sst "I mean, in this case it kind of does, but still it's the thought that counts and all of that."
    sst "Ich meine, in diesem Fall schon irgendwie, aber trotzdem zählt der Gedanke und so weiter."

# game/Scenes/School/SocialStudies/ss1b.rpy:106
translate german ss1b_1ba196ba:

    # sst "Great job you two!"
    sst "Tolle Arbeit, ihr zwei!"

# game/Scenes/School/SocialStudies/ss1b.rpy:107
translate german ss1b_f71f0211:

    # sst "I'm so happy you came to help."
    sst "Ich bin so froh, dass ihr gekommen seid, um zu helfen."

# game/Scenes/School/SocialStudies/ss1b.rpy:108
translate german ss1b_0262c012:

    # sst "You'll both get some extra credit in class."
    sst "Ihr bekommt beide ein paar Extrapunkte im Unterricht."

# game/Scenes/School/SocialStudies/ss1b.rpy:110
translate german ss1b_7a503afc:

    # sst "Okay, well I have to head home. I have a bunch of tests to grade."
    sst "Okay, nun muss ich nach Hause. Ich habe einen Haufen Tests zu benoten."

# game/Scenes/School/SocialStudies/ss1b.rpy:111
translate german ss1b_75ac6d76:

    # sst "See you two in class."
    sst "Wir sehen uns im Unterricht."

# game/Scenes/School/SocialStudies/ss1b.rpy:112
translate german ss1b_209b1712:

    # pc "See ya."
    pc "Bis dann."

# game/Scenes/School/SocialStudies/ss1b.rpy:113
translate german ss1b_86df4cb8:

    # gg "Bye, Ms. Welch."
    gg "Tschüss, Frau Welch."

# game/Scenes/School/SocialStudies/ss1b.rpy:115
translate german ss1b_cd2476cd:

    # gg "She's pretty cool huh?"
    gg "Sie ist ziemlich cool, oder?"

# game/Scenes/School/SocialStudies/ss1b.rpy:116
translate german ss1b_dfa08ace:

    # pc "Yeah, she is."
    pc "Ja, das ist sie."

# game/Scenes/School/SocialStudies/ss1b.rpy:118
translate german ss1b_83a2171d:

    # gg "Well, I guess I better head home too."
    gg "Na ja, ich glaube, ich gehe auch besser nach Hause."

# game/Scenes/School/SocialStudies/ss1b.rpy:119
translate german ss1b_cb4ae3c1:

    # gg "This was fun."
    gg "Das hat Spaß gemacht."

# game/Scenes/School/SocialStudies/ss1b.rpy:120
translate german ss1b_2643738c:

    # pc "I don't know about that."
    pc "Da bin ich mir nicht so sicher."

# game/Scenes/School/SocialStudies/ss1b.rpy:122
translate german ss1b_a7d94599:

    # gg "Well it wasn't too bad anyways. I wish we could have hung out a little more."
    gg "Na ja, es war jedenfalls nicht so schlimm. Ich wünschte, wir hätten noch ein bisschen länger zusammen sein können."

# game/Scenes/School/SocialStudies/ss1b.rpy:123
translate german ss1b_70708b12:

    # pc "Maybe some other time?"
    pc "Vielleicht ein anderes Mal?"

# game/Scenes/School/SocialStudies/ss1b.rpy:125
translate german ss1b_31b66347:

    # gg "I'd really like that."
    gg "Das würde mir wirklich gefallen."

# game/Scenes/School/SocialStudies/ss1b.rpy:127
translate german ss1b_8527dcd3:

    # gg "Okay, well I'll see you later."
    gg "Okay, dann bis später."

# game/Scenes/School/SocialStudies/ss1b.rpy:128
translate german ss1b_c9145064:

    # gg "Have a good night."
    gg "Schöne Nacht."

# game/Scenes/School/SocialStudies/ss1b.rpy:129
translate german ss1b_eb61ef6e:

    # pc "You too."
    pc "Dir auch."

# game/Scenes/School/SocialStudies/ss1b.rpy:132
translate german ss1b_47c957ef:

    # "Adrian walks towards the east-side parking lot, while I head to where my car is parked on the west side."
    "Adrian geht zum Parkplatz auf der Ostseite, während ich zu meinem Auto auf der Westseite gehe."

# game/Scenes/School/SocialStudies/ss1b.rpy:133
translate german ss1b_a6d4e2ab:

    # "It was kind of boring, but not an awful way to spend an evening, I guess."
    "Es war irgendwie langweilig, aber keine schlechte Art, einen Abend zu verbringen, schätze ich."

# game/Scenes/School/SocialStudies/ss1b.rpy:134
translate german ss1b_135033ce:

    # "Both Adrian and Ms. Welch are pretty cool people and I wouldn't mind getting to know them a little better."
    "Sowohl Adrian als auch Frau Welch sind ziemlich coole Leute, und ich hätte nichts dagegen, sie ein bisschen besser kennenzulernen."

# game/Scenes/School/SocialStudies/ss1b.rpy:136
translate german ss1b_c7b80bd5:

    # "I'm not sure about Ms. Welch, but Adrian is definitely into me. Maybe I'll pursue that later."
    "Bei Frau Welch bin ich mir nicht sicher, aber Adrian steht definitiv auf mich. Vielleicht gehe ich dem später mal nach."

# game/Scenes/School/SocialStudies/ss1b.rpy:137
translate german ss1b_021babeb:

    # "For now, it's getting pretty late and I need to head home."
    "Im Moment wird es schon ziemlich spät und ich muss nach Hause."

translate german strings:

    # game/Scenes/School/SocialStudies/ss1b.rpy:2
    old "After the previous scene where Ms. Welch requests your help registering voters,"
    new "Nach der vorherigen Szene, in der Frau Welch dich um Hilfe bei der Wählerregistrierung bittet,"

    # game/Scenes/School/SocialStudies/ss1b.rpy:75
    old "You wanted to hang out with me"
    new "wolltest du mit mir abhängen"

