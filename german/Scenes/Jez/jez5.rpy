translate german jez5_98ca1a51:

    # "My phone buzzes in my pocket."
    "Mein Handy vibriert in meiner Tasche."

# game/Scenes/Jez/jez5.rpy:13
translate german jez5_450455fc:

    # "It's Detective Rodriguez. I wonder if she's found something out about my dad."
    "Es ist Detective Rodriguez. Ich frage mich, ob sie etwas über meinen Vater herausgefunden hat."

# game/Scenes/Jez/jez5.rpy:16
translate german jez5_bea5e8cb:

    # pc "Hello?"
    pc "Hallo?"

# game/Scenes/Jez/jez5.rpy:18
translate german jez5_d41d8cd9:

    # voice 'voices/jez_hey.mp3'
    voice 'voices/jez_hey.mp3'

# game/Scenes/Jez/jez5.rpy:19
translate german jez5_31f304d3:

    # det "Hey, [pcname]."
    det "Hey, [pcname]."

# game/Scenes/Jez/jez5.rpy:20
translate german jez5_704218da:

    # pc "Did you find anything?"
    pc "Hast du etwas herausgefunden?"

# game/Scenes/Jez/jez5.rpy:22
translate german jez5_dd220c64:

    # det "What? Oh! About your dad?"
    det "Was? Oh! Über deinen Vater?"

# game/Scenes/Jez/jez5.rpy:24
translate german jez5_e8fe8a8c:

    # det "Oh God, no I'm sorry. I wasn't calling about your dad, but I can understand why you'd think that."
    det "Oh Gott, nein, tut mir leid. Ich habe nicht wegen deines Vaters angerufen, aber ich kann verstehen, warum du das denkst."

# game/Scenes/Jez/jez5.rpy:25
translate german jez5_1559f8f9:

    # det "With me being a detective and on your dad's case and all."
    det "Da ich ja Detective bin und an dem Fall deines Vaters arbeite und so."

# game/Scenes/Jez/jez5.rpy:26
translate german jez5_8c3ac124:

    # det "God, I'm a horrible detective aren't I?"
    det "Gott, ich bin eine furchtbare Detective, nicht wahr?"

# game/Scenes/Jez/jez5.rpy:27
translate german jez5_a807c23e:

    # pc "No, I don't think so. What did you call for then?"
    pc "Nein, das glaube ich nicht. Warum hast du dann angerufen?"

# game/Scenes/Jez/jez5.rpy:30
translate german jez5_d41d8cd9_1:

    # voice 'voices/jez_5_1.mp3'
    voice 'voices/jez_5_1.mp3'

# game/Scenes/Jez/jez5.rpy:31
translate german jez5_0a63889f:

    # det "Well, I had kind of a rough day and I wanted to talk to somebody."
    det "Nun, ich hatte einen ziemlich anstrengenden Tag und wollte mit jemandem reden."

# game/Scenes/Jez/jez5.rpy:33
translate german jez5_d41d8cd9_2:

    # voice 'voices/jez_5_2.mp3'
    voice 'voices/jez_5_2.mp3'

# game/Scenes/Jez/jez5.rpy:34
translate german jez5_ea09e714:

    # det "And you were nice to me in the past, when we went out for drinks."
    det "Und du warst in der Vergangenheit nett zu mir, als wir zusammen etwas trinken waren."

# game/Scenes/Jez/jez5.rpy:36
translate german jez5_d41d8cd9_3:

    # voice 'voices/jez_5_3.mp3'
    voice 'voices/jez_5_3.mp3'

# game/Scenes/Jez/jez5.rpy:37
translate german jez5_307d2b53:

    # det "And I don't really have anybody else to talk to."
    det "Und ich habe eigentlich niemanden sonst, mit dem ich reden kann."

# game/Scenes/Jez/jez5.rpy:39
translate german jez5_d41d8cd9_4:

    # voice 'voices/jez_5_4.mp3'
    voice 'voices/jez_5_4.mp3'

# game/Scenes/Jez/jez5.rpy:40
translate german jez5_0f2cd5d3:

    # det "So I was wondering if you would want to just talk some?"
    det "Also habe ich mich gefragt, ob du vielleicht einfach ein bisschen reden möchtest?"

# game/Scenes/Jez/jez5.rpy:46
translate german jez5_47059538:

    # det "You're right. This was a mistake, I'm sorry."
    det "Du hast recht. Das war ein Fehler, es tut mir leid."

# game/Scenes/Jez/jez5.rpy:47
translate german jez5_ec16f7c0:

    # det "I won't bother you any more until I have information on your dad."
    det "Ich werde dich nicht mehr belästigen, bis ich Informationen über deinen Vater habe."

# game/Scenes/Jez/jez5.rpy:48
translate german jez5_07fc1b9f:

    # det "Bye, [pcname]."
    det "Tschüss, [pcname]."

# game/Scenes/Jez/jez5.rpy:52
translate german jez5_5429a27f:

    # "She hangs up and I lie down to go to sleep."
    "Sie legt auf und ich lege mich hin, um zu schlafen."

# game/Scenes/Jez/jez5.rpy:53
translate german jez5_ceaf3431:

    # "I can hardly believe that she wants to call me and dump her problems on me. Don't I have enough of my own to deal with?"
    "Ich kann kaum glauben, dass sie mich anrufen und ihre Probleme auf mich abladen will. Habe ich nicht schon genug eigene, mit denen ich mich herumschlagen muss?"

# game/Scenes/Jez/jez5.rpy:54
translate german jez5_0a396100:

    # "I mean, my dad is missing and it doesn't seem like she's doing much of anything to find him."
    "Ich meine, mein Vater wird vermisst und es sieht nicht so aus, als würde sie viel tun, um ihn zu finden."

# game/Scenes/Jez/jez5.rpy:55
translate german jez5_a9441b54:

    # "Maybe I was a little harsh with her, but she needs to do her damn job."
    "Vielleicht war ich etwas zu hart zu ihr, aber sie muss ihren verdammten Job machen."

# game/Scenes/Jez/jez5.rpy:56
translate german jez5_437235da:

    # "I fall asleep, still upset about the whole thing."
    "Ich schlafe ein, immer noch verärgert über die ganze Sache."

# game/Scenes/Jez/jez5.rpy:62
translate german jez5_9f04dd80:

    # det "My Chief is yelling at me all the time because I haven't been able to track down this meth manufacturer."
    det "Mein Chef schimpft ständig mit mir, weil ich diesen Meth-Hersteller nicht aufspüren konnte."

# game/Scenes/Jez/jez5.rpy:63
translate german jez5_2edb985d:

    # det "It's like, I'm trying. There's only so much I can do."
    det "Es ist ja nicht so, als würde ich es nicht versuchen. Aber ich kann nur so viel tun."

# game/Scenes/Jez/jez5.rpy:64
translate german jez5_d637e4b1:

    # det "I spend most of my day on stakeouts watching drug handoffs."
    det "Ich verbringe den Großteil meines Tages mit Überwachungen, um Drogenübergaben zu beobachten."

# game/Scenes/Jez/jez5.rpy:65
translate german jez5_b65d63fc:

    # det "Or interrogating people, trying to push them into telling me something."
    det "Oder damit, Leute zu verhören und zu versuchen, sie dazu zu bringen, mir etwas zu sagen."

# game/Scenes/Jez/jez5.rpy:66
translate german jez5_e4fde77f:

    # det "But nobody's giving anything up and I'm running out of leads."
    det "Aber niemand gibt etwas preis und mir gehen die Spuren aus."

# game/Scenes/Jez/jez5.rpy:67
translate german jez5_45b6d6aa:

    # det "There's only two detectives on this case. A big meth ring and just two of us."
    det "Es gibt nur zwei Ermittler an diesem Fall. Ein riesiger Meth-Ring und nur wir beide."

# game/Scenes/Jez/jez5.rpy:68
translate german jez5_77a9cef6:

    # det "I mean Skyhill is a small town, so I get it, but I need more help here."
    det "Ich meine, Skyhill ist eine Kleinstadt, das verstehe ich schon, aber ich brauche hier mehr Hilfe."

# game/Scenes/Jez/jez5.rpy:69
translate german jez5_72d52a4d:

    # det "I wish we could call in the state police, or the FBI or something, but the Chief won't have it. Says we have to handle this ourselves."
    det "Ich wünschte, wir könnten die Staatspolizei oder das FBI oder so hinzuziehen, aber der Chef will davon nichts wissen. Er sagt, wir müssen das selbst regeln."

# game/Scenes/Jez/jez5.rpy:70
translate german jez5_d8b3de1e:

    # det "But there's only so much I can do. I have other cases too - like your dad's - that I'm having to neglect because of this meth thing."
    det "Aber ich kann nur begrenzt viel tun. Ich habe auch noch andere Fälle – wie den deines Vaters –, die ich wegen dieser Meth-Sache vernachlässigen muss."

# game/Scenes/Jez/jez5.rpy:72
translate german jez5_88d7e875:

    # det "And today I had to raid the house of this methhead."
    det "Und heute musste ich das Haus dieser Meth-Süchtigen stürmen."

# game/Scenes/Jez/jez5.rpy:73
translate german jez5_d5874b9e:

    # det "It was horrible. This woman, her house was disgusting. Her baby, a three-year-old girl, was sitting in the middle of a bunch of filth naked."
    det "Es war schrecklich. Diese Frau, ihr Haus war ekelhaft. Ihr Baby, ein dreijähriges Mädchen, saß nackt mitten in einem Haufen Dreck."

# game/Scenes/Jez/jez5.rpy:74
translate german jez5_2823a872:

    # det "And I had to take this child, who was screaming and crying that she didn't want to leave her mom, and give the child to protective services."
    det "Und ich musste dieses Kind, das schrie und weinte, weil es seine Mama nicht verlassen wollte, mitnehmen und dem Jugendamt übergeben."

# game/Scenes/Jez/jez5.rpy:75
translate german jez5_e5dd6ea8:

    # det "The girl will probably have a better life in foster care than she would have with her mother, but who knows. She could end up with some abusive assholes or something."
    det "Das Mädchen wird in einer Pflegefamilie wahrscheinlich ein besseres Leben haben als bei ihrer Mutter, aber wer weiß. Vielleicht landet sie bei irgendwelchen gewalttätigen Arschlöchern oder so."

# game/Scenes/Jez/jez5.rpy:76
translate german jez5_5e97fe72:

    # det "That little girl's life is messed up no matter what happens now."
    det "Das Leben dieses kleinen Mädchens ist kaputt, egal, was jetzt passiert."

# game/Scenes/Jez/jez5.rpy:77
translate german jez5_a1286de7:

    # det "And it just makes me so sad."
    det "Und das macht mich einfach so traurig."

# game/Scenes/Jez/jez5.rpy:78
translate german jez5_89052a8b:

    # pc "I'm sorry. That's awful."
    pc "Tut mir leid. Das ist schrecklich."

# game/Scenes/Jez/jez5.rpy:80
translate german jez5_97380cd0:

    # det "So I get the woman back to the station and start interrogating her."
    det "Also bringe ich die Frau zurück zur Wache und fange an, sie zu verhören."

# game/Scenes/Jez/jez5.rpy:81
translate german jez5_3e4784a1:

    # det "She's going to jail for at least five years for possession, probably will get a child endangerment charge as well, but she won't give up her dealer."
    det "Sie muss wegen Drogenbesitzes für mindestens fünf Jahre ins Gefängnis, wird wahrscheinlich auch wegen Gefährdung eines Kindes angeklagt, aber sie will ihren Dealer nicht verraten."

# game/Scenes/Jez/jez5.rpy:82
translate german jez5_19e09092:

    # det "I don't fucking get it."
    det "Ich verstehe das verdammt noch mal nicht."

# game/Scenes/Jez/jez5.rpy:83
translate german jez5_59760784:

    # det "She's scared that something will happen to her family if she snitches."
    det "Sie hat Angst, dass ihrer Familie etwas zustoßen könnte, wenn sie petzt."

# game/Scenes/Jez/jez5.rpy:84
translate german jez5_c0f63ffe:

    # det "Spits in my face, calls me a pig. I wanted to beat her fucking head in."
    det "Spuckt mir ins Gesicht, nennt mich ein Schwein. Ich wollte ihr verdammt noch mal den Schädel einschlagen."

# game/Scenes/Jez/jez5.rpy:85
translate german jez5_c36e96d1:

    # det "Then I get chewed out by the Chief because I didn't get anything out of her."
    det "Dann werde ich vom Chef zusammengeschissen, weil ich nichts aus ihr herausbekommen habe."

# game/Scenes/Jez/jez5.rpy:87
translate german jez5_2288ac26:

    # det "And that was my day."
    det "Und das war mein Tag."

# game/Scenes/Jez/jez5.rpy:88
translate german jez5_2074c381:

    # det "I'm just so tired of all of it. I want to find this meth manufacturer and shut that shit down."
    det "Ich habe das alles einfach so satt. Ich will diesen Meth-Hersteller finden und dem Ganzen ein Ende machen."

# game/Scenes/Jez/jez5.rpy:90
translate german jez5_3a7bef84:

    # "I think about telling her about the bunker that Izzy had sent me to."
    "Ich überlege, ihr von dem Bunker zu erzählen, in den Izzy mich geschickt hatte."

# game/Scenes/Jez/jez5.rpy:91
translate german jez5_35c47a4d:

    # "But I'm not sure that is really what she's looking for."
    "Aber ich bin mir nicht sicher, ob das wirklich das ist, wonach sie sucht."

# game/Scenes/Jez/jez5.rpy:92
translate german jez5_7dda6c8a:

    # "Plus, I'm not sure if me and Izzy might get in some serious trouble for our part in whatever they were doing."
    "Außerdem bin ich mir nicht sicher, ob Izzy und ich wegen unserer Beteiligung an dem, was auch immer sie da gemacht haben, in ernsthafte Schwierigkeiten geraten könnten."

# game/Scenes/Jez/jez5.rpy:93
translate german jez5_9fcbf4b8:

    # "I may tell Jez about it later, but for now I stay quiet."
    "Vielleicht erzähle ich Jez später davon, aber vorerst halte ich den Mund."

# game/Scenes/Jez/jez5.rpy:95
translate german jez5_6387c117:

    # "I think about telling her about the bunker that Reba had taken me to."
    "Ich überlege, ihr von dem Bunker zu erzählen, in den Reba mich mitgenommen hatte."

# game/Scenes/Jez/jez5.rpy:96
translate german jez5_35c47a4d_1:

    # "But I'm not sure that is really what she's looking for."
    "Aber ich bin mir nicht sicher, ob das wirklich das ist, wonach sie sucht."

# game/Scenes/Jez/jez5.rpy:97
translate german jez5_306cf091:

    # "Plus, I'm not sure if Reba might get in some serious trouble for our part in whatever they were doing."
    "Außerdem bin ich mir nicht sicher, ob Reba wegen unserer Beteiligung an dem, was auch immer sie da gemacht haben, in ernsthafte Schwierigkeiten geraten könnte."

# game/Scenes/Jez/jez5.rpy:98
translate german jez5_9fcbf4b8_1:

    # "I may tell Jez about it later, but for now I stay quiet."
    "Vielleicht erzähle ich Jez später davon, aber im Moment halte ich mich zurück."

# game/Scenes/Jez/jez5.rpy:99
translate german jez5_a3049ca4:

    # det "Anyway, thanks for listening to me vent."
    det "Jedenfalls danke, dass du mir zugehört hast."

# game/Scenes/Jez/jez5.rpy:100
translate german jez5_732596c5:

    # det "I needed to get all that off my chest."
    det "Ich musste mir das alles von der Seele reden."

# game/Scenes/Jez/jez5.rpy:101
translate german jez5_d957ecb7:

    # pc "You feeling better now?"
    pc "Geht es dir jetzt besser?"

# game/Scenes/Jez/jez5.rpy:103
translate german jez5_880af095:

    # det "A little, yeah."
    det "Ein bisschen, ja."

# game/Scenes/Jez/jez5.rpy:104
translate german jez5_566089d7:

    # det "You're a pretty good listener, [pcname]. Thank you."
    det "Du bist eine ziemlich gute Zuhörerin, [pcname]. Danke."

# game/Scenes/Jez/jez5.rpy:105
translate german jez5_c46a0b54:

    # pc "Any time."
    pc "Jederzeit."

# game/Scenes/Jez/jez5.rpy:107
translate german jez5_1d1792a8:

    # det "I can be a good listener too, if you ever want to chat."
    det "Ich kann auch gut zuhören, falls du mal reden möchtest."

# game/Scenes/Jez/jez5.rpy:108
translate german jez5_d87a672d:

    # det "You could call me at nights and we could just talk or something."
    det "Du könntest mich abends anrufen und wir könnten einfach reden oder so."

# game/Scenes/Jez/jez5.rpy:110
translate german jez5_b7c62ab4:

    # pc "That sounds good. I'll do that."
    pc "Das klingt gut. Das mache ich."

# game/Scenes/Jez/jez5.rpy:112
translate german jez5_fc19b673:

    # det "Good."
    det "Gut."

# game/Scenes/Jez/jez5.rpy:114
translate german jez5_d41d8cd9_5:

    # voice 'voices/jez_5_5.mp3'
    voice 'voices/jez_5_5.mp3'

# game/Scenes/Jez/jez5.rpy:115
translate german jez5_22567fb7:

    # det "Okay, [pcname], I better get to bed. Thanks for listening to me."
    det "Okay, [pcname], ich gehe jetzt besser ins Bett. Danke, dass du mir zugehört hast."

# game/Scenes/Jez/jez5.rpy:117
translate german jez5_d41d8cd9_6:

    # voice 'voices/jez_5_6.mp3'
    voice 'voices/jez_5_6.mp3'

# game/Scenes/Jez/jez5.rpy:118
translate german jez5_22b369a9:

    # det "I'll talk to you later."
    det "Wir sprechen uns später."

# game/Scenes/Jez/jez5.rpy:119
translate german jez5_31e08f47:

    # pc "Okay, good night, Jez."
    pc "Okay, gute Nacht, Jez."

# game/Scenes/Jez/jez5.rpy:121
translate german jez5_d41d8cd9_7:

    # voice 'voices/jez_night.mp3'
    voice 'voices/jez_night.mp3'

# game/Scenes/Jez/jez5.rpy:122
translate german jez5_8669dcbe:

    # det "Night."
    det "Nacht."

# game/Scenes/Jez/jez5.rpy:125
translate german jez5_52d6e3cf:

    # "We hang up and I get ready for bed."
    "Wir legen auf und ich mache mich bettfertig."

# game/Scenes/Jez/jez5.rpy:126
translate german jez5_73bafe8e:

    # "It must be hard having to deal with the things that she deals with, see the things that she sees every day."
    "Es muss schwer sein, mit den Dingen fertig zu werden, mit denen sie fertig werden muss, und die Dinge zu sehen, die sie jeden Tag sieht."

# game/Scenes/Jez/jez5.rpy:127
translate german jez5_63d39c7b:

    # "I like that she is opening up to me though, becoming more friendly."
    "Ich finde es aber gut, dass sie sich mir gegenüber öffnet und freundlicher wird."

# game/Scenes/Jez/jez5.rpy:128
translate german jez5_00f887ed:

    # "I actually really like her."
    "Ich mag sie eigentlich wirklich sehr."

# game/Scenes/Jez/jez5.rpy:129
translate german jez5_c6ddf2e1:

    # "I fall asleep thinking about how I'd like to spend more time with her. Hopefully we'll get a chance soon."
    "Ich schlafe ein und denke darüber nach, wie gerne ich mehr Zeit mit ihr verbringen würde. Hoffentlich ergibt sich bald eine Gelegenheit."

