# game/Scenes/Jez/JezConversation/jezq2.rpy:13
translate german jezq2_7e645245:

    # det "What are you going to do if we find your dad?"
    det "Was wirst du tun, wenn wir deinen Vater finden?"

# game/Scenes/Jez/JezConversation/jezq2.rpy:14
translate german jezq2_b55c740c:

    # pc "I'm going to hug him. Tell him I'm sorry for the things that I said and did."
    pc "Ich werde ihn umarmen. Ihm sagen, dass mir die Dinge leid tun, die ich gesagt und getan habe."

# game/Scenes/Jez/JezConversation/jezq2.rpy:15
translate german jezq2_ab3ff14b:

    # pc "Tell him I love him."
    pc "Ihm sagen, dass ich ihn liebe."

# game/Scenes/Jez/JezConversation/jezq2.rpy:17
translate german jezq2_2e7485fd:

    # det "That's nice."
    det "Das ist schön."

# game/Scenes/Jez/JezConversation/jezq2.rpy:18
translate german jezq2_070ecc32:

    # pc "Then I guess I'll just keep on like I have been. Except I'll try to spend more time with him."
    pc "Dann werde ich wohl einfach so weitermachen wie bisher. Nur dass ich versuchen werde, mehr Zeit mit ihm zu verbringen."

# game/Scenes/Jez/JezConversation/jezq2.rpy:19
translate german jezq2_84c06b07:

    # pc "I have a lot of questions for him."
    pc "Ich habe viele Fragen an ihn."

# game/Scenes/Jez/JezConversation/jezq2.rpy:21
translate german jezq2_c85babbc:

    # det "And what if we find him, but he's... um..."
    det "Und was, wenn wir ihn finden, er aber … ähm …"

# game/Scenes/Jez/JezConversation/jezq2.rpy:22
translate german jezq2_64d707d2:

    # pc "Not alive?"
    pc "Nicht mehr lebt?"

# game/Scenes/Jez/JezConversation/jezq2.rpy:23
translate german jezq2_efaf6eb5:

    # det "Yeah."
    det "Ja."

# game/Scenes/Jez/JezConversation/jezq2.rpy:25
translate german jezq2_820bd703:

    # det "You don't have to answer that. I shouldn't have asked."
    det "Du musst das nicht beantworten. Ich hätte nicht fragen sollen."

# game/Scenes/Jez/JezConversation/jezq2.rpy:26
translate german jezq2_2e4c59d4:

    # det "What a downer. I'm so bad at normal conversation."
    det "Was für ein Stimmungskiller. Ich bin so schlecht in normalen Gesprächen."

# game/Scenes/Jez/JezConversation/jezq2.rpy:28
translate german jezq2_b219d344:

    # pc "It's okay."
    pc "Ist schon okay."

# game/Scenes/Jez/JezConversation/jezq2.rpy:29
translate german jezq2_69298cee:

    # pc "If Dad's not alive, I would be sad, of course."
    pc "Wenn Papa nicht mehr lebt, wäre ich natürlich traurig."

# game/Scenes/Jez/JezConversation/jezq2.rpy:30
translate german jezq2_ec2c3b68:

    # pc "I'd have a lot of regrets that I would have to live with."
    pc "Ich hätte eine Menge Bedauern, mit dem ich leben müsste."

# game/Scenes/Jez/JezConversation/jezq2.rpy:32
translate german jezq2_068843ff:

    # pc "I would just hope that somehow he'd know that I love him and I appreciate everything that he's done for me."
    pc "Ich würde einfach hoffen, dass er irgendwie weiß, dass ich ihn liebe und alles schätze, was er für mich getan hat."

# game/Scenes/Jez/JezConversation/jezq2.rpy:33
translate german jezq2_661a213e:

    # pc "And I'd try to live up to his expectations."
    pc "Und ich würde versuchen, seinen Erwartungen gerecht zu werden."

# game/Scenes/Jez/JezConversation/jezq2.rpy:35
translate german jezq2_29d642c1:

    # det "I'm sure that wherever he is, he knows how you feel."
    det "Ich bin mir sicher, dass er, wo auch immer er ist, weiß, wie du dich fühlst."

# game/Scenes/Jez/JezConversation/jezq2.rpy:36
translate german jezq2_31173ab5:

    # det "But I really hope that you get a chance to tell him."
    det "Aber ich hoffe wirklich, dass du die Gelegenheit bekommst, es ihm zu sagen."

# game/Scenes/Jez/JezConversation/jezq2.rpy:37
translate german jezq2_1f8cc682:

    # pc "Thanks, Jez. So do I."
    pc "Danke, Jez. Das hoffe ich auch."

