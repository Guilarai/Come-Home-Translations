# game/Scenes/Jez/JezConversation/jezs10.rpy:15
translate german jezs10_ba1e8137:

    # det "I feel like there are a lot of things I would enjoy doing."
    det "Ich habe das Gefühl, es gibt viele Dinge, die mir Spaß machen würden."

# game/Scenes/Jez/JezConversation/jezs10.rpy:17
translate german jezs10_f8cb520b:

    # det "Maybe being a teacher. I love kids."
    det "Vielleicht Lehrerin zu werden. Ich liebe Kinder."

# game/Scenes/Jez/JezConversation/jezs10.rpy:19
translate german jezs10_29b39419:

    # det "Who knows? I may switch professions sometime."
    det "Wer weiß? Vielleicht wechsle ich irgendwann den Beruf."

# game/Scenes/Jez/JezConversation/jezs10.rpy:20
translate german jezs10_6f542818:

    # det "I can't keep doing this forever. I feel like it's making me age so fast."
    det "Ich kann das nicht ewig weitermachen. Ich habe das Gefühl, dass es mich so schnell altern lässt."

# game/Scenes/Jez/JezConversation/jezs10.rpy:22
translate german jezs10_fa408b95:

    # det "And I worry that I'm putting myself in danger for no reason."
    det "Und ich mache mir Sorgen, dass ich mich ohne Grund in Gefahr bringe."

# game/Scenes/Jez/JezConversation/jezs10.rpy:24
translate german jezs10_e6884c8d:

    # det "I want to do something that helps people, but I don't want Javi to grow up without a mother."
    det "Ich möchte etwas tun, das Menschen hilft, aber ich möchte nicht, dass Javi ohne Mutter aufwächst."

# game/Scenes/Jez/JezConversation/jezs10.rpy:26
translate german jezs10_adcea374:

    # det "I'm just kind of tired of it. I think there are probably other ways that I can help people."
    det "Ich hab’s einfach irgendwie satt. Ich glaube, es gibt wahrscheinlich andere Wege, wie ich Menschen helfen kann."

# game/Scenes/Jez/JezConversation/jezs10.rpy:28
translate german jezs10_0d01a729:

    # det "Jobs where I'm less likely to be killed."
    det "Jobs, bei denen die Wahrscheinlichkeit geringer ist, dass ich getötet werde."

# game/Scenes/Jez/JezConversation/jezs10.rpy:29
translate german jezs10_5572dffc:

    # det "Jobs where people don't hate me."
    det "Jobs, bei denen mich die Leute nicht hassen."

# game/Scenes/Jez/JezConversation/jezs10.rpy:30
translate german jezs10_5fafd6cc:

    # pc "That must be tough."
    pc "Das muss hart sein."

# game/Scenes/Jez/JezConversation/jezs10.rpy:32
translate german jezs10_f43f730e:

    # det "Yeah. But I'm tough too. I hate giving up. I'm a good cop."
    det "Ja. Aber ich bin auch hart im Nehmen. Ich hasse es, aufzugeben. Ich bin eine gute Polizistin."

# game/Scenes/Jez/JezConversation/jezs10.rpy:34
translate german jezs10_c28ce17f:

    # det "The police force is going to be worse without me."
    det "Ohne mich wird es der Polizei schlechter gehen."

# game/Scenes/Jez/JezConversation/jezs10.rpy:35
translate german jezs10_029765e1:

    # pc "I know that's true."
    pc "Ich weiß, dass das stimmt."

# game/Scenes/Jez/JezConversation/jezs10.rpy:37
translate german jezs10_d2cdcf88:

    # det "But I'd probably be a good teacher too."
    det "Aber ich wäre wahrscheinlich auch ein guter Lehrer."

# game/Scenes/Jez/JezConversation/jezs10.rpy:38
translate german jezs10_5ec40255:

    # pc "I bet you would."
    pc "Da wette ich drauf."

# game/Scenes/Jez/JezConversation/jezs10.rpy:39
translate german jezs10_087cb585:

    # pc "I think the world is just lucky to have you, whatever you do."
    pc "Ich glaube, die Welt kann sich glücklich schätzen, dich zu haben, egal, was du tust."

# game/Scenes/Jez/JezConversation/jezs10.rpy:41
translate german jezs10_bafe5f31:

    # det "Aw come on! Now you're just buttering me up."
    det "Ach komm schon! Jetzt schmeichelst du mir nur."

# game/Scenes/Jez/JezConversation/jezs10.rpy:43
translate german jezs10_52f39fce:

    # det "Keep doing it. I love it."
    det "Mach weiter so. Ich liebe es."

