# game/Scenes/Jez/jez3.rpy:16
translate german jez3_b7d0283a:

    # "Detective Rodriguez picks up the phone after a single ring, as if she had been holding her phone in her hand."
    "Detective Rodriguez nimmt nach einem einzigen Klingeln ab, als hätte sie ihr Telefon schon in der Hand gehalten."

# game/Scenes/Jez/jez3.rpy:18
translate german jez3_d41d8cd9:

    # voice 'voices/jez_answering.mp3'
    voice 'voices/jez_answering.mp3'

# game/Scenes/Jez/jez3.rpy:19
translate german jez3_6673062e:

    # det "Detective Rodriguez."
    det "Detective Rodriguez."

# game/Scenes/Jez/jez3.rpy:20
translate german jez3_416b4b28:

    # pc "Hello, this is [pcname]."
    pc "Hallo, hier ist [pcname]."

# game/Scenes/Jez/jez3.rpy:22
translate german jez3_d41d8cd9_1:

    # voice 'voices/jez_hey.mp3'
    voice 'voices/jez_hey.mp3'

# game/Scenes/Jez/jez3.rpy:23
translate german jez3_5f1522eb:

    # det "Hey, [pcname]. What's up?"
    det "Hey, [pcname]. Was gibt’s?"

# game/Scenes/Jez/jez3.rpy:24
translate german jez3_eb667b3e:

    # pc "I had some new information about my dad's case. I was able to get into his laptop."
    pc "Ich habe neue Informationen zum Fall meines Vaters. Ich habe mich in seinen Laptop einloggen können."

# game/Scenes/Jez/jez3.rpy:25
translate german jez3_a1187622:

    # pc "I found a bunch of e-mails between him and this Whitney person."
    pc "Ich habe eine Menge E-Mails zwischen ihm und dieser Whitney gefunden."

# game/Scenes/Jez/jez3.rpy:26
translate german jez3_d2f98bdb:

    # det "Hey, [pcname]. Hold on a second."
    det "Hey, [pcname]. Warte mal kurz."

# game/Scenes/Jez/jez3.rpy:28
translate german jez3_77774b9f:

    # det "I'll be honest with you. I've had a really bad day and I have a migraine from hell."
    det "Ich will ehrlich zu dir sein. Ich hatte einen wirklich schlechten Tag und habe höllische Migräne."

# game/Scenes/Jez/jez3.rpy:29
translate german jez3_b0a1faa8:

    # det "Your voice on this phone is making my head pound. What do you say we meet up in person."
    det "Deine Stimme am Telefon lässt meinen Kopf pochen. Wie wäre es, wenn wir uns persönlich treffen?"

# game/Scenes/Jez/jez3.rpy:30
translate german jez3_7cfb0b0e:

    # det "Do you know where The Pit is?"
    det "Weißt du, wo „The Pit“ ist?"

# game/Scenes/Jez/jez3.rpy:31
translate german jez3_5a003c29:

    # pc "The bar downtown?"
    pc "Die Bar in der Innenstadt?"

# game/Scenes/Jez/jez3.rpy:32
translate german jez3_c60f38c7:

    # det "That's it. Want to meet me there and have this conversation over drinks?"
    det "Genau die. Willst du mich dort treffen und das Gespräch bei einem Drink führen?"

# game/Scenes/Jez/jez3.rpy:33
translate german jez3_a5c9c049:

    # det "I could really use a drink."
    det "Ich könnte wirklich einen Drink gebrauchen."

# game/Scenes/Jez/jez3.rpy:36
translate german jez3_2ba5f0eb:

    # det "Great, I'll be there in two."
    det "Super, ich bin in zwei Minuten da."

# game/Scenes/Jez/jez3.rpy:38
translate german jez3_cd4d07e3:

    # det "Come on man, give me a break."
    det "Komm schon, Mann, hab doch mal Nachsicht mit mir."

# game/Scenes/Jez/jez3.rpy:39
translate german jez3_84d27d16:

    # det "I just got finished working a 24-hour shift."
    det "Ich habe gerade eine 24-Stunden-Schicht hinter mir."

# game/Scenes/Jez/jez3.rpy:40
translate german jez3_cd598c64:

    # pc "Alright, I'll be there in five minutes."
    pc "Na gut, ich bin in fünf Minuten da."

# game/Scenes/Jez/jez3.rpy:41
translate german jez3_2ba5f0eb_1:

    # det "Great, I'll be there in two."
    det "Super, ich bin in zwei Minuten da."

# game/Scenes/Jez/jez3.rpy:44
translate german jez3_d1ed5b1b:

    # "She hangs up and I quickly get ready and head out to the car."
    "Sie legt auf, und ich mache mich schnell fertig und gehe zum Auto."

# game/Scenes/Jez/jez3.rpy:45
translate german jez3_5ddb21e5:

    # "Only a few minutes later, I park in front of the bar."
    "Nur wenige Minuten später parke ich vor der Bar."

# game/Scenes/Jez/jez3.rpy:47
translate german jez3_23e3b6db:

    # "I walk in and am met with a cloud of cigarette smoke, the dull roar of conversation, and a jukebox playing some rock song I've never heard."
    "Ich gehe hinein und werde von einer Wolke aus Zigarettenrauch, dem dumpfen Gemurmel der Gespräche und einer Jukebox empfangen, die einen Rocksong spielt, den ich noch nie gehört habe."

# game/Scenes/Jez/jez3.rpy:48
translate german jez3_64d6327f:

    # "It takes a few moments for me to notice Detective Rodriguez waving at me from a booth in the back of the bar."
    "Es dauert einen Moment, bis ich Detective Rodriguez bemerke, die mir von einem Tisch im hinteren Teil der Bar zuwinkt."

# game/Scenes/Jez/jez3.rpy:49
translate german jez3_398f4ad8:

    # "I walk over and sit down across from her."
    "Ich gehe hinüber und setze mich ihr gegenüber."

# game/Scenes/Jez/jez3.rpy:53
translate german jez3_71bded69:

    # det "Thanks for meeting me here. I know it's not very professional, but I need a drink real bad and I hate drinking alone."
    det "Danke, dass du dich hier mit mir triffst. Ich weiß, das ist nicht sehr professionell, aber ich brauche dringend einen Drink und ich hasse es, allein zu trinken."

# game/Scenes/Jez/jez3.rpy:54
translate german jez3_ac23b499:

    # det "I ordered you a beer too. You're twenty-one, right?"
    det "Ich habe dir auch ein Bier bestellt. Du bist einundzwanzig, oder?"

# game/Scenes/Jez/jez3.rpy:55
translate german jez3_c2113814:

    # pc "Twenty-two."
    pc "Zweiundzwanzig."

# game/Scenes/Jez/jez3.rpy:56
translate german jez3_da9af380:

    # det "Good. Drink up then."
    det "Gut. Dann trink es."

# game/Scenes/Jez/jez3.rpy:59
translate german jez3_899cb188:

    # "I take a drink of the beer in front of me. It's nice and smooth."
    "Ich nehme einen Schluck von dem Bier vor mir. Es ist schön mild."

# game/Scenes/Jez/jez3.rpy:62
translate german jez3_cfdfe09b:

    # pc "I'm just here to talk."
    pc "Ich bin nur hier, um zu reden."

# game/Scenes/Jez/jez3.rpy:64
translate german jez3_a023156a:

    # det "So I'm just going to be drinking alone anyway. So be it."
    det "Also werde ich doch wieder alleine trinken. Na gut."

# game/Scenes/Jez/jez3.rpy:68
translate german jez3_e5c2530c:

    # det "Okay, so you got into your dad's laptop and found some correspondence?"
    det "Okay, du hast dich also in den Laptop deines Vaters gehackt und Korrespondenz gefunden?"

# game/Scenes/Jez/jez3.rpy:69
translate german jez3_66708b9a:

    # pc "Yeah, and it's crazy."
    pc "Ja, und es ist verrückt."

# game/Scenes/Jez/jez3.rpy:70
translate german jez3_08461fea:

    # det "Give me the summary. You can send the entire thing over to my e-mail later."
    det "Gib mir die Zusammenfassung. Du kannst mir das Ganze später per E-Mail schicken."

# game/Scenes/Jez/jez3.rpy:71
translate german jez3_2af7a240:

    # pc "Well the gist is that he and Whitney were planning a trip."
    pc "Also, im Grunde genommen haben er und Whitney eine Reise geplant."

# game/Scenes/Jez/jez3.rpy:72
translate german jez3_b2a62e0b:

    # det "So he did run off with her?"
    det "Er ist also mit ihr durchgebrannt?"

# game/Scenes/Jez/jez3.rpy:73
translate german jez3_d0c263e4:

    # pc "No, he was the only one going on this trip."
    pc "Nein, er war der Einzige, der diese Reise machen wollte."

# game/Scenes/Jez/jez3.rpy:74
translate german jez3_2908401f:

    # det "Okay, so where did he go?"
    det "Okay, und wo ist er hingefahren?"

# game/Scenes/Jez/jez3.rpy:75
translate german jez3_0a1d6430:

    # pc "I'm not sure, but the strangest part is how he got there."
    pc "Ich bin mir nicht sicher, aber das Seltsamste ist, wie er dorthin gekommen ist."

# game/Scenes/Jez/jez3.rpy:76
translate german jez3_09d6eafc:

    # det "Explain."
    det "Erklär mir das."

# game/Scenes/Jez/jez3.rpy:77
translate german jez3_61000743:

    # pc "He built some sort of device. I found it in the basement. It looks like a hula hoop."
    pc "Er hat eine Art Gerät gebaut. Ich habe es im Keller gefunden. Es sieht aus wie ein Hula-Hoop-Reifen."

# game/Scenes/Jez/jez3.rpy:79
translate german jez3_b0e7f9ea:

    # det "What? You lost me."
    det "Was? Ich kann dir nicht folgen."

# game/Scenes/Jez/jez3.rpy:80
translate german jez3_40d85287:

    # pc "I don't know how to explain it. It looks like a hoop. He and Whitney built it together. When it's activated, it's supposed to transport you somewhere."
    pc "Ich weiß nicht, wie ich es erklären soll. Es sieht aus wie ein Reifen. Er und Whitney haben es zusammen gebaut. Wenn es aktiviert wird, soll es einen irgendwohin transportieren."

# game/Scenes/Jez/jez3.rpy:81
translate german jez3_1f06310c:

    # pc "He needed the diamonds to activate it. That's why he stole them."
    pc "Er brauchte die Diamanten, um es zu aktivieren. Deshalb hat er sie gestohlen."

# game/Scenes/Jez/jez3.rpy:82
translate german jez3_35f3019c:

    # det "And the meth too?"
    det "Und das Meth auch?"

# game/Scenes/Jez/jez3.rpy:83
translate german jez3_ff210007:

    # pc "Right. He used the meth to speed his heart rate up so his heart didn't stop during the transportation."
    pc "Genau. Er hat das Meth genommen, um seinen Puls zu beschleunigen, damit sein Herz während des Transports nicht stehen bleibt."

# game/Scenes/Jez/jez3.rpy:84
translate german jez3_22ea6d6f:

    # det "You know this is the dumbest fucking thing I've ever heard right?"
    det "Du weißt, dass das das Dümmste ist, was ich je gehört habe, oder?"

# game/Scenes/Jez/jez3.rpy:85
translate german jez3_a2fed6c2:

    # pc "I'm just telling you what they were talking about."
    pc "Ich erzähle dir nur, worüber sie gesprochen haben."

# game/Scenes/Jez/jez3.rpy:87
translate german jez3_1b198a7a:

    # det "Well I did look into the diamond theft."
    det "Nun, ich habe den Diamantendiebstahl untersucht."

# game/Scenes/Jez/jez3.rpy:88
translate german jez3_0768d1c5:

    # det "There was a jewelry store over in Whiterock that was broken into only a few days before your dad went missing."
    det "Es gab ein Juweliergeschäft in Whiterock, in das nur wenige Tage vor dem Verschwinden deines Vaters eingebrochen wurde."

# game/Scenes/Jez/jez3.rpy:89
translate german jez3_727a0b8a:

    # det "It was just like you described. The security was disabled for only a minute."
    det "Es war genau so, wie du es beschrieben hast. Die Alarmanlage war nur für eine Minute ausgeschaltet."

# game/Scenes/Jez/jez3.rpy:90
translate german jez3_75b55784:

    # det "The thief entered through the back door, walked in, took two three-carat diamond rings, then walked back out."
    det "Der Dieb kam durch die Hintertür herein, ging hinein, nahm zwei Diamantringe mit je drei Karat und ging dann wieder hinaus."

# game/Scenes/Jez/jez3.rpy:91
translate german jez3_a0cd13f9:

    # det "Security kicked back on. There would have been no trace that anybody was even there, except the rings were gone."
    det "Die Alarmanlage sprang wieder an. Es hätte keine Spur davon gegeben, dass überhaupt jemand da war, außer dass die Ringe weg waren."

# game/Scenes/Jez/jez3.rpy:92
translate german jez3_a595c814:

    # pc "So he did it."
    pc "Also war er es."

# game/Scenes/Jez/jez3.rpy:93
translate german jez3_2cf2afa7:

    # det "It seems that way."
    det "Es sieht ganz danach aus."

# game/Scenes/Jez/jez3.rpy:94
translate german jez3_7b6c844b:

    # pc "Any clue where he got the meth?"
    pc "Irgendeine Ahnung, woher er das Meth hat?"

# game/Scenes/Jez/jez3.rpy:96
translate german jez3_6063143c:

    # det "God, there's no telling. That shit is all over Skyhill."
    det "Gott, das lässt sich nicht sagen. Das Zeug ist überall in Skyhill."

# game/Scenes/Jez/jez3.rpy:97
translate german jez3_399bdc0f:

    # pc "Really?"
    pc "Wirklich?"

# game/Scenes/Jez/jez3.rpy:99
translate german jez3_94032961:

    # det "Yes. That's what I've been working on. That's my primary job."
    det "Ja. Daran arbeite ich gerade. Das ist meine Hauptaufgabe."

# game/Scenes/Jez/jez3.rpy:100
translate german jez3_91bebae5:

    # det "We know a few dealers and we can find people who buy meth."
    det "Wir kennen ein paar Dealer und können Leute finden, die Meth kaufen."

# game/Scenes/Jez/jez3.rpy:101
translate german jez3_ec847758:

    # det "But we can't seem to locate where the shit is coming from. Somebody around here is cooking it, and I don't know where."
    det "Aber wir scheinen nicht herauszufinden, woher das Zeug kommt. Jemand hier in der Gegend kocht es, und ich weiß nicht, wo."

# game/Scenes/Jez/jez3.rpy:102
translate german jez3_ea875425:

    # pc "I had no idea it was that bad around here."
    pc "Ich hatte keine Ahnung, dass es hier so schlimm ist."

# game/Scenes/Jez/jez3.rpy:103
translate german jez3_49c82960:

    # det "Yeah. So I'm not sure exactly where your dad got it at, but I've been questioning people."
    det "Ja. Ich bin mir also nicht sicher, wo genau dein Vater es herhat, aber ich habe Leute befragt."

# game/Scenes/Jez/jez3.rpy:104
translate german jez3_5d188bd8:

    # det "Look [pcname], it sounds to me like your dad was having some sort of psychotic break."
    det "Hör mal [pcname], für mich klingt es so, als hätte dein Vater eine Art psychotischen Zusammenbruch gehabt."

# game/Scenes/Jez/jez3.rpy:105
translate german jez3_7a8cf8a1:

    # det "Teleporting hula-hoops, diamond theft, using meth to speed up your heart rate."
    det "Teleportierende Hula-Hoop-Reifen, Diamantendiebstahl, Meth, um die Herzfrequenz zu beschleunigen."

# game/Scenes/Jez/jez3.rpy:106
translate german jez3_8ebd5686:

    # det "That sounds like a bunch of nonsense to me."
    det "Das klingt für mich nach einem Haufen Unsinn."

# game/Scenes/Jez/jez3.rpy:107
translate german jez3_c417e350:

    # pc "Yeah."
    pc "Ja."

# game/Scenes/Jez/jez3.rpy:108
translate german jez3_4c3ec6a3:

    # det "But the more we dig into it, the more likely we're going to find him."
    det "Aber je mehr wir nachforschen, desto wahrscheinlicher ist es, dass wir ihn finden."

# game/Scenes/Jez/jez3.rpy:109
translate german jez3_e004b1ab:

    # det "So keep digging."
    det "Also forsch weiter."

# game/Scenes/Jez/jez3.rpy:110
translate german jez3_58f0fc2d:

    # det "Send me the info that you found on the laptop and I'll see if I can find this Whitney person."
    det "Schick mir die Infos, die du auf dem Laptop gefunden hast, und ich werde sehen, ob ich diese Whitney finden kann."

# game/Scenes/Jez/jez3.rpy:111
translate german jez3_955d194d:

    # det "Assuming that she's real and not somebody that your dad made up."
    det "Vorausgesetzt, sie existiert wirklich und ist nicht jemand, den sich dein Vater ausgedacht hat."

# game/Scenes/Jez/jez3.rpy:112
translate german jez3_25bfd7d2:

    # pc "It seems like she's real to me, based on the e-mails."
    pc "Aufgrund der E-Mails scheint sie mir echt zu sein."

# game/Scenes/Jez/jez3.rpy:113
translate german jez3_2fc85b75:

    # det "Alright. Well let's find her."
    det "Okay. Dann lass uns sie finden."

# game/Scenes/Jez/jez3.rpy:114
translate german jez3_e70c1658:

    # pc "I could e-mail her from Dad's laptop."
    pc "Ich könnte ihr von Dads Laptop aus eine E-Mail schicken."

# game/Scenes/Jez/jez3.rpy:116
translate german jez3_3997e2c3:

    # det "That's not a bad idea. Give it a shot. Start up a conversation with her, see if you can find out more about her."
    det "Das ist keine schlechte Idee. Versuch es mal. Knüpfe ein Gespräch mit ihr an und schau, ob du mehr über sie herausfinden kannst."

# game/Scenes/Jez/jez3.rpy:117
translate german jez3_4d9bef33:

    # det "And let me know anything you find."
    det "Und lass mich wissen, was du herausfindest."

# game/Scenes/Jez/jez3.rpy:119
translate german jez3_5bc44b07:

    # pc "I will."
    pc "Das werde ich."

# game/Scenes/Jez/jez3.rpy:121
translate german jez3_b734eba7:

    # det "Thanks for meeting me here. I needed this."
    det "Danke, dass du dich hier mit mir getroffen hast. Das habe ich gebraucht."

# game/Scenes/Jez/jez3.rpy:122
translate german jez3_ba520f30:

    # det "Now I have to get home. I haven't seen my kid in two days."
    det "Jetzt muss ich nach Hause. Ich habe mein Kind seit zwei Tagen nicht gesehen."

# game/Scenes/Jez/jez3.rpy:123
translate german jez3_ce82357f:

    # pc "You have a kid?"
    pc "Du hast ein Kind?"

# game/Scenes/Jez/jez3.rpy:125
translate german jez3_71fc0e0c:

    # det "Yeah, Javi. He's seven. My mom's taking care of him right now."
    det "Ja, Javi. Er ist sieben. Meine Mutter passt gerade auf ihn auf."

# game/Scenes/Jez/jez3.rpy:126
translate german jez3_798c23ff:

    # det "You surprised that I have a kid?"
    det "Überrascht es dich, dass ich ein Kind habe?"

# game/Scenes/Jez/jez3.rpy:130
translate german jez3_632e262d:

    # det "Thanks. I had him when I was 17."
    det "Danke. Ich habe ihn bekommen, als ich 17 war."

# game/Scenes/Jez/jez3.rpy:133
translate german jez3_ae370b70:

    # det "I'm not. You don't have to be married to have a kid, you know."
    det "Nein, tut es nicht. Man muss nicht verheiratet sein, um ein Kind zu haben, weißt du."

# game/Scenes/Jez/jez3.rpy:134
translate german jez3_2356fff3:

    # pc "Right, I didn't mean anything by it."
    pc "Stimmt, ich habe nichts damit gemeint."

# game/Scenes/Jez/jez3.rpy:137
translate german jez3_a82f6cf9:

    # det "Oh, I thought you seemed surprised."
    det "Oh, ich dachte, du schienst überrascht zu sein."

# game/Scenes/Jez/jez3.rpy:139
translate german jez3_12633b63:

    # det "Anyway, I better get home."
    det "Wie auch immer, ich gehe besser nach Hause."

# game/Scenes/Jez/jez3.rpy:140
translate german jez3_d0fa7dfb:

    # det "I'll see you later, [pcname]."
    det "Bis später, [pcname]."

# game/Scenes/Jez/jez3.rpy:141
translate german jez3_7b4cad00:

    # pc "Bye Detective Rodriguez."
    pc "Tschüss, Detective Rodriguez."

# game/Scenes/Jez/jez3.rpy:144
translate german jez3_d41d8cd9_2:

    # voice 'voices/jez_3_1.mp3'
    voice 'voices/jez_3_1.mp3'

# game/Scenes/Jez/jez3.rpy:145
translate german jez3_e7adfac5:

    # det "You can call me Jez, okay? That's my first name."
    det "Du kannst mich Jez nennen, okay? Das ist mein Vorname."

# game/Scenes/Jez/jez3.rpy:146
translate german jez3_db79b546:

    # pc "Okay. Bye Jez."
    pc "Okay. Tschüss, Jez."

# game/Scenes/Jez/jez3.rpy:151
translate german jez3_d41d8cd9_3:

    # voice 'voices/jez_goodnight.mp3'
    voice 'voices/jez_goodnight.mp3'

# game/Scenes/Jez/jez3.rpy:152
translate german jez3_2f6a1cc2:

    # det "Good night."
    det "Gute Nacht."

# game/Scenes/Jez/jez3.rpy:155
translate german jez3_40a94195:

    # "She stands up and walks out of the bar. I sit there alone for a few minutes, thinking about our conversation."
    "Sie steht auf und verlässt die Bar. Ich sitze noch ein paar Minuten allein da und denke über unser Gespräch nach."

# game/Scenes/Jez/jez3.rpy:156
translate german jez3_06361269:

    # "She thinks Dad was crazy. I'm not so sure."
    "Sie glaubt, Dad war verrückt. Da bin ich mir nicht so sicher."

# game/Scenes/Jez/jez3.rpy:157
translate german jez3_d8c1ec54:

    # "The things in his notes and in his conversations with Whitney were wild, but there is so much there that seems true."
    "Die Dinge in seinen Notizen und in seinen Gesprächen mit Whitney waren abgedreht, aber vieles davon scheint wahr zu sein."

# game/Scenes/Jez/jez3.rpy:158
translate german jez3_3da12785:

    # "Whitney definitely seems like a real person. I just need to find out who she is."
    "Whitney wirkt definitiv wie eine echte Person. Ich muss nur herausfinden, wer sie ist."

# game/Scenes/Jez/jez3.rpy:159
translate german jez3_8298e18a:

    # "Then maybe I can find out where my dad went."
    "Dann kann ich vielleicht herausfinden, wohin mein Vater gegangen ist."

# game/Scenes/Jez/jez3.rpy:160
translate german jez3_bc8a9774:

    # "Eventually, I stand up and walk out of the bar, then head home for the night."
    "Schließlich stehe ich auf, verlasse die Bar und mache mich auf den Heimweg."

translate german strings:

    # game/Scenes/Jez/jez3.rpy:2
    old "You need to get into your dad's computer. Talk to Adrian about it. She's been at the grocery store trying to find a new game."
    new "Du musst an den Computer deines Vaters herankommen. Sprich mit Adrian darüber. Sie ist im Supermarkt und versucht, ein neues Spiel zu finden."

    # game/Scenes/Jez/jez3.rpy:3
    old "Once you search your dad's laptop, call Detective Rodriguez from your bedroom in the evening."
