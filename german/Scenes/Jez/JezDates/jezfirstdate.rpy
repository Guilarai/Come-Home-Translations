    # det "Aw alright. Well if you change your mind, just give me a call sometime."
    det "Ach so, okay. Wenn du es dir anders überlegst, ruf mich einfach mal an."

# game/Scenes/Jez/JezDates/jezfirstdate.rpy:24
translate german jezfirstdate_39a5e291:

    # det "I should be available most evenings now."
