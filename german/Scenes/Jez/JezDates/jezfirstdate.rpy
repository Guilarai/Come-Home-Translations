# game/Scenes/Jez/JezDates/jezfirstdate.rpy:13
translate german jezfirstdate_f924b941:

    # det "With the meth lab shut down, I actually have a little more free time in the evenings."
    det "Da das Meth-Labor geschlossen wurde, habe ich abends tatsächlich etwas mehr Freizeit."

# game/Scenes/Jez/JezDates/jezfirstdate.rpy:14
translate german jezfirstdate_7f3a988e:

    # det "You feel like hitting the bar with me?"
    det "Hast du Lust, mit mir in die Bar zu gehen?"

# game/Scenes/Jez/JezDates/jezfirstdate.rpy:18
translate german jezfirstdate_de415fd1:

    # det "Great! I'll see you at The Pit in about half an hour, okay?"
    det "Super! Wir sehen uns in etwa einer halben Stunde im „The Pit“, okay?"

# game/Scenes/Jez/JezDates/jezfirstdate.rpy:19
translate german jezfirstdate_b0ab0038:

    # pc "Sounds good. See you there."
    pc "Klingt gut. Wir sehen uns dort."

# game/Scenes/Jez/JezDates/jezfirstdate.rpy:23
