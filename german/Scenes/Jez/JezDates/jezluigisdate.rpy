# game/Scenes/Jez/JezDates/jezluigisdate.rpy:29
translate german jezluigisstartdate_ec0fa6ca:

    # "I meet Jez at Luigi's and we sit and order our meals."
    "Ich treffe Jez bei Luigi’s, wir setzen uns und bestellen unser Essen."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:30
translate german jezluigisstartdate_c57a5228:

    # "Then we chat for a while."
    "Dann unterhalten wir uns eine Weile."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:33
translate german jezluigisstartdate_0875967f:

    # "The server brings our food out, and we continue talking while we eat."
    "Der Kellner bringt unser Essen, und wir reden weiter, während wir essen."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:35
translate german jezluigisstartdate_3c0f7991:

    # "When we're done eating, we just hang around and talk for a while longer."
    "Als wir fertig gegessen haben, bleiben wir noch eine Weile sitzen und unterhalten uns."

# game/Scenes/Jez/JezDates/jezluigisdate.rpy:38
translate german jezluigisstartdate_e9a5d339:

    # "We could probably sit and chat all night, but it's starting to get late."
    "Wir könnten wahrscheinlich die ganze Nacht hier sitzen und reden, aber es wird langsam spät."

