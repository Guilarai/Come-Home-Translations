    # voice 'voices/jez_myplace.mp3'
    voice 'voices/jez_myplace.mp3'

# game/Scenes/Jez/JezDates/jezenddate.rpy:8
translate german jezenddate_687d0176:

    # det "So, do you want to come back to my place for a while?"
    det "Also, willst du für eine Weile mit zu mir kommen?"

# game/Scenes/Jez/JezDates/jezenddate.rpy:9
translate german jezenddate_30d6b817:

    # det "Mamá's got Javi for a bit. We could spend some time together."
    det "Mama passt gerade auf Javi auf. Wir könnten ein bisschen Zeit miteinander verbringen."

# game/Scenes/Jez/JezDates/jezenddate.rpy:12
translate german jezenddate_3ba845d3:

    # det "Good, let's go."
    det "Gut, lass uns gehen."

# game/Scenes/Jez/JezDates/jezenddate.rpy:15
translate german jezenddate_588b9a6e:

    # "We get in our cars and I follow her back to her house, where we quickly make our way inside to her bedroom."
    "Wir steigen in unsere Autos und ich folge ihr zu ihrem Haus, wo wir schnell ins Haus und in ihr Schlafzimmer gehen."

# game/Scenes/Jez/JezDates/jezenddate.rpy:19
translate german jezenddate_77b42da9:

    # det "Oh, alright then. Well I had a nice date anyway. I'll see you later, [pcname]."
    det "Oh, na gut. Na ja, ich hatte trotzdem ein nettes Date. Bis später, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:21
translate german jezenddate_b4d69820:

    # "I lean in and we kiss, my arms wrapped around her."
    "Ich beuge mich vor und wir küssen uns, meine Arme um sie geschlungen."

# game/Scenes/Jez/JezDates/jezenddate.rpy:22
translate german jezenddate_3091dff1:

    # pc "Bye, Jez. See you again soon."
    pc "Tschüss, Jez. Bis bald."

# game/Scenes/Jez/JezDates/jezenddate.rpy:25
translate german jezenddate_f48c2630:

    # "She leaves, and I go back out to my car and drive away."
    "Sie geht, und ich gehe zurück zu meinem Auto und fahre los."

# game/Scenes/Jez/JezDates/jezenddate.rpy:29
translate german jezenddate_716db417:

    # det "I had a really good time. I'm looking forward to doing this again soon."
    det "Ich hatte eine wirklich schöne Zeit. Ich freue mich darauf, das bald wieder zu machen."

# game/Scenes/Jez/JezDates/jezenddate.rpy:30
translate german jezenddate_03eaad50:

    # pc "Me too."
    pc "Ich auch."

# game/Scenes/Jez/JezDates/jezenddate.rpy:33
translate german jezenddate_398aacb4:

    # det "I'd invite you over to my place, but I'm not quite ready for my son to meet you yet."
    det "Ich würde dich gerne zu mir einladen, aber ich bin noch nicht ganz bereit dafür, dass mein Sohn dich kennenlernt."

# game/Scenes/Jez/JezDates/jezenddate.rpy:34
translate german jezenddate_70367ea3:

    # det "I don't want him to get confused by male figures being in his life for only a short time."
    det "Ich möchte nicht, dass er verwirrt ist, weil männliche Bezugspersonen nur für kurze Zeit in seinem Leben sind."

# game/Scenes/Jez/JezDates/jezenddate.rpy:35
translate german jezenddate_6cf8b822:

    # det "I want to make sure that this thing between me and you is real before we do that. I hope you understand."
    det "Ich möchte sichergehen, dass das zwischen uns beiden echt ist, bevor wir das tun. Ich hoffe, du verstehst das."

# game/Scenes/Jez/JezDates/jezenddate.rpy:36
translate german jezenddate_cca20d9e:

    # pc "I do understand."
    pc "Ich verstehe das."

# game/Scenes/Jez/JezDates/jezenddate.rpy:38
translate german jezenddate_3239d4cf:

    # det "Thanks."
    det "Danke."

# game/Scenes/Jez/JezDates/jezenddate.rpy:41
translate german jezenddate_b4d69820_1:

    # "I lean in and we kiss, my arms wrapped around her."
    "Ich beuge mich vor und wir küssen uns, meine Arme um sie geschlungen."

# game/Scenes/Jez/JezDates/jezenddate.rpy:43
translate german jezenddate_ef81804e:

    # det "Wow, that was nice. Making it really hard for me to say goodbye."
    det "Wow, das war schön. Das macht es mir wirklich schwer, mich zu verabschieden."

# game/Scenes/Jez/JezDates/jezenddate.rpy:44
translate german jezenddate_c18fe3a7:

    # det "But I have to. Bye, [pcname]."
    det "Aber ich muss. Tschüss, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:45
translate german jezenddate_3091dff1_1:

    # pc "Bye, Jez. See you again soon."
    pc "Tschüss, Jez. Bis bald."

# game/Scenes/Jez/JezDates/jezenddate.rpy:48
translate german jezenddate_f48c2630_1:

    # "She leaves, and I go back out to my car and drive away."
    "Sie geht, und ich gehe zurück zu meinem Auto und fahre los."

