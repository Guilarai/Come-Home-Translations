    # det "Ay Mamá!"
    det "Ay, Mama!"

# game/Scenes/Jez/jez13.rpy:208
translate german jez13_1da93989:

    # mama "Do you have a job?"
    mama "Hast du einen Job?"

# game/Scenes/Jez/jez13.rpy:210
translate german jez13_748e9a7f:

    # pc "Yes, as an assistant at a law office."
    pc "Ja, als Assistentin in einer Anwaltskanzlei."

# game/Scenes/Jez/jez13.rpy:212
translate german jez13_23a217be:

    # mama "Do you have any children?"
    mama "Hast du Kinder?"

# game/Scenes/Jez/jez13.rpy:214
translate german jez13_4219f3ee:

    # pc "No."
    pc "Nein."

# game/Scenes/Jez/jez13.rpy:216
translate german jez13_5dc9c07e:

    # mama "Do you do drugs?"
    mama "Nimmst du Drogen?"

# game/Scenes/Jez/jez13.rpy:218
translate german jez13_4219f3ee_1:

    # pc "No."
    pc "Nein."

# game/Scenes/Jez/jez13.rpy:220
translate german jez13_af0ca811:

    # mama "Do you live with your parents?"
    mama "Wohnst du bei deinen Eltern?"

# game/Scenes/Jez/jez13.rpy:222
translate german jez13_9af16977:

    # pc "I live with my [mother] at the moment."
    pc "Ich wohne im Moment bei meinem [mother]."

# game/Scenes/Jez/jez13.rpy:224
translate german jez13_6b1ebe90:

    # mama "How many other girlfriends do you have?"
    mama "Wie viele andere Freundinnen hast du?"

# game/Scenes/Jez/jez13.rpy:227
translate german jez13_d41d8cd9_17:

    # voice 'voices/jez_13_17b.mp3'
    voice 'voices/jez_13_17b.mp3'

# game/Scenes/Jez/jez13.rpy:228
translate german jez13_5296d8b8:

    # det "Ay Mamá, be nice!"
    det "Ay, Mama, sei nett!"

# game/Scenes/Jez/jez13.rpy:229
translate german jez13_5faa2282:

    # mama "Que?"
    mama "Was?"

# game/Scenes/Jez/jez13.rpy:230
translate german jez13_fd390a20:

    # mama "Quiero saber acerca de este chico con el que estás saliendo."
    mama "Ich will etwas über diesen Jungen wissen, mit dem du zusammen bist."

# game/Scenes/Jez/jez13.rpy:232
translate german jez13_d41d8cd9_18:

    # voice 'voices/jez_13_18.mp3'
    voice 'voices/jez_13_18.mp3'

# game/Scenes/Jez/jez13.rpy:233
translate german jez13_1e7215a5:

    # det "Ya te hablé de él. Es un buen chico y me gusta. ¿No confías en mi juicio?"
    det "Ich habe dir schon von ihm erzählt. Er ist ein netter Junge und ich mag ihn. Vertraust du meinem Urteilsvermögen nicht?"

# game/Scenes/Jez/jez13.rpy:234
translate german jez13_28dfbcd6:

    # mama "No lo hiciste tan bien la primera vez."
    mama "Beim ersten Mal hast du es nicht so gut gemacht."

# game/Scenes/Jez/jez13.rpy:235
translate german jez13_1847687a:

    # det "Mamá!"
    det "Mama!"

# game/Scenes/Jez/jez13.rpy:237
translate german jez13_a9618f8c:

    # mama "Do you have any brothers or sisters?"
    mama "Hast du Geschwister?"

# game/Scenes/Jez/jez13.rpy:239
translate german jez13_b0e9cb79:

    # pc "Just Suzy, my [sister]."
    pc "Nur Suzy, meine [sister]."

# game/Scenes/Jez/jez13.rpy:241
translate german jez13_0acf000d:

    # mama "What are you going to school for?"
    mama "Was studierst du?"

# game/Scenes/Jez/jez13.rpy:243
translate german jez13_04c35adf:

    # pc "Quantum physics. To be a scientist."
    pc "Quantenphysik. Ich will Wissenschaftler werden."

# game/Scenes/Jez/jez13.rpy:245
translate german jez13_36e29056:

    # det "That's enough, Mamá, the food is getting cold while you're grilling him."
    det "Das reicht jetzt, Mama, das Essen wird kalt, während du ihn ausfragst."

# game/Scenes/Jez/jez13.rpy:246
translate german jez13_9fda17f8:

    # mama "You seem like a good boy, I suppose."
    mama "Du scheinst ein netter Junge zu sein, nehme ich an."

# game/Scenes/Jez/jez13.rpy:247
translate german jez13_45d2cbc0:

    # det "He is. He helped me out a lot last night."
    det "Das ist er. Er hat mir gestern Abend sehr geholfen."

# game/Scenes/Jez/jez13.rpy:248
translate german jez13_f3a75866:

    # mama "I'm sure he did."
    mama "Da bin ich mir sicher."

# game/Scenes/Jez/jez13.rpy:250
translate german jez13_d41d8cd9_19:

    # voice 'voices/jez_13_20.mp3'
    voice 'voices/jez_13_20.mp3'

# game/Scenes/Jez/jez13.rpy:251
translate german jez13_b535f103:

    # det "Mamá! Cuida lo que dices delante de Javi."
    det "Mama! Pass auf, was du vor Javi sagst."

# game/Scenes/Jez/jez13.rpy:252
translate german jez13_c913be1a:

    # mama "No dije nada en absoluto!"
    mama "Ich habe überhaupt nichts gesagt!"

# game/Scenes/Jez/jez13.rpy:255
translate german jez13_c5ef0cc4:

    # mama "If Jesabela likes you enough to introduce you to me, you must be something special."
    mama "Wenn Jesabela dich so sehr mag, dass sie dich mir vorstellt, musst du etwas Besonderes sein."

# game/Scenes/Jez/jez13.rpy:256
translate german jez13_48aa3884:

    # mama "You just be good to her."
    mama "Sei einfach nett zu ihr."

# game/Scenes/Jez/jez13.rpy:257
translate german jez13_f31ca3be:

    # pc "Yes ma'am, I will."
    pc "Ja, Mama, das werde ich."

# game/Scenes/Jez/jez13.rpy:258
translate german jez13_8faa40cf:

    # mama "No ma'am. You call me Mamá, or Ivelisse."
    mama "Nein, Ma'am. Nenn mich Mamá oder Ivelisse."

# game/Scenes/Jez/jez13.rpy:259
translate german jez13_49e790d0:

    # jav "Or Abuelita."
    jav "Oder Abuelita."

# game/Scenes/Jez/jez13.rpy:262
translate german jez13_f9207776:

    # mama "No, mi guapo, you're the only one that gets to call me abuelita."
    mama "Nein, mi guapo, du bist der Einzige, der mich Abuelita nennen darf."

# game/Scenes/Jez/jez13.rpy:263
translate german jez13_8d2fe2d9:

    # jav "Oh okay. Sorry, [pcname], you can't call her that."
    jav "Oh okay. Entschuldigung, [pcname], so darfst du sie nicht nennen."

# game/Scenes/Jez/jez13.rpy:266
translate german jez13_196bac72:

    # "We chit-chat a little more while we eat."
    "Wir plaudern noch ein bisschen, während wir essen."

# game/Scenes/Jez/jez13.rpy:267
translate german jez13_dedcdede:

    # "Ivelisse is a little intimidating, but after a while, she smiles a lot and she seems pretty funny."
    "Ivelisse ist ein bisschen einschüchternd, aber nach einer Weile lächelt sie viel und wirkt ziemlich lustig."

# game/Scenes/Jez/jez13.rpy:268
translate german jez13_0ba3754f:

    # "And I can feel so much love between the three of them."
    "Und ich spüre so viel Liebe zwischen den dreien."

# game/Scenes/Jez/jez13.rpy:271
translate german jez13_81657b80:

    # "Javi talks a lot about school and the base that he and his friends are building in Minecraft."
    "Javi redet viel über die Schule und die Basis, die er und seine Freunde in Minecraft bauen."

# game/Scenes/Jez/jez13.rpy:272
translate german jez13_c3923da8:

    # "Meanwhile, Jez looks at me with a shy smile while her foot rubs against my leg under the table."
    "Währenddessen schaut Jez mich mit einem schüchternen Lächeln an, während ihr Fuß unter dem Tisch an meinem Bein reibt."

# game/Scenes/Jez/jez13.rpy:275
translate german jez13_c332134e:

    # "When we finish eating, I tell Javi and Ivelisse goodbye."
    "Als wir mit dem Essen fertig sind, verabschiede ich mich von Javi und Ivelisse."

# game/Scenes/Jez/jez13.rpy:276
translate german jez13_eac1a598:

    # mama "It was very nice to meet you, [pcname]."
    mama "Es war sehr schön, euch kennenzulernen, [pcname]."

# game/Scenes/Jez/jez13.rpy:277
translate german jez13_a7f3d1fc:

    # pc "Nice to meet you too. Thank you for the amazing breakfast."
    pc "Freut mich auch. Danke für das tolle Frühstück."

# game/Scenes/Jez/jez13.rpy:278
translate german jez13_6ad487d2:

    # jav "Bye, [pcname]!"
    jav "Tschüss, [pcname]!"

# game/Scenes/Jez/jez13.rpy:279
translate german jez13_5f653b3b:

    # pc "Bye, Javi. I'll be back for you to teach me about Minecraft sometime, okay?"
    pc "Tschüss, Javi. Ich komme irgendwann wieder, damit du mir etwas über Minecraft beibringst, okay?"

# game/Scenes/Jez/jez13.rpy:280
translate german jez13_930b665f:

    # jav "Okay!"
    jav "Okay!"

# game/Scenes/Jez/jez13.rpy:283
translate german jez13_12a645a9:

    # pc "Do you think I did okay?"
    pc "Meinst du, ich hab das gut gemacht?"

# game/Scenes/Jez/jez13.rpy:284
translate german jez13_e66be0b3:

    # det "You did wonderful."
    det "Du warst wunderbar."

# game/Scenes/Jez/jez13.rpy:287
translate german jez13_2a95c68b:

    # det "Seriously, [pcname]. Thank you for everything."
    det "Im Ernst, [pcname]. Danke für alles."

# game/Scenes/Jez/jez13.rpy:288
translate german jez13_a05c3ddb:

    # pc "You're welcome. Hope your day is better today."
    pc "Gern geschehen. Hoffentlich wird dein Tag heute besser."

# game/Scenes/Jez/jez13.rpy:289
translate german jez13_37df78b6:

    # det "It will be. I already feel so much better."
    det "Das wird er. Ich fühle mich schon viel besser."

# game/Scenes/Jez/jez13.rpy:290
translate german jez13_95715fb7:

    # det "You have a good day too. Let's spend some more time together soon, okay?"
    det "Ich wünsche dir auch einen schönen Tag. Lass uns bald wieder etwas Zeit miteinander verbringen, okay?"

# game/Scenes/Jez/jez13.rpy:291
translate german jez13_2951ed74:

    # pc "Definitely."
    pc "Auf jeden Fall."

# game/Scenes/Jez/jez13.rpy:294
translate german jez13_01f6f4f8:

    # "I leave her house and go home to change clothes and get my things, then head straight to school, barely getting there in time for my first class."
    "Ich verlasse ihr Haus und gehe nach Hause, um mich umzuziehen und meine Sachen zu holen, dann mache ich mich direkt auf den Weg zur Schule und schaffe es gerade noch rechtzeitig zu meiner ersten Stunde."

# game/Scenes/Jez/jez13.rpy:295
translate german jez13_24a3ded4:

    # "The whole time, I'm thinking about my relationship with Jez."
    "Die ganze Zeit denke ich über meine Beziehung zu Jez nach."

# game/Scenes/Jez/jez13.rpy:296
translate german jez13_b509de35:

    # "She called me her boyfriend."
    "Sie hat mich ihren Freund genannt."

# game/Scenes/Jez/jez13.rpy:297
translate german jez13_b197b664:

    # "It seems like it's starting to get pretty serious. Meeting her kid and her mom like that."
    "Es scheint, als würde es langsam ziemlich ernst werden. So ihr Kind und ihre Mutter kennenzulernen."

# game/Scenes/Jez/jez13.rpy:298
translate german jez13_4e167340:

    # "I have to think about if that's something I really want or not. She's amazing, but am I really ready to commit to something like that?"
    "Ich muss mir überlegen, ob ich das wirklich will oder nicht. Sie ist toll, aber bin ich wirklich bereit, mich auf so etwas einzulassen?"

# game/Scenes/Jez/jez13.rpy:299
translate german jez13_3bf96260:

    # "I'll need to decide soon. I don't want to hurt her."
    "Ich muss mich bald entscheiden. Ich will ihr nicht wehtun."

# game/Scenes/Jez/jez13.rpy:300
translate german jez13_3c440e53:

    # "And I don't want her Mamá to hurt me."
    "Und ich will nicht, dass ihre Mama mir wehtut."

