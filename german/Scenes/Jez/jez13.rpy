    # det "Not right now, mijo. We're having breakfast and then you have to go to school."
    det "Nicht jetzt, mijo. Wir frühstücken gerade und dann musst du zur Schule."

# game/Scenes/Jez/jez13.rpy:193
translate german jez13_bd2f8227:

    # jav "Okay, I'll show you later then."
    jav "Okay, dann zeige ich es dir später."

# game/Scenes/Jez/jez13.rpy:196
translate german jez13_ce637d21:

    # "Jez and her mamá come to the table and Jez puts a plate of food in front of me."
    "Jez und ihre Mama kommen an den Tisch und Jez stellt mir einen Teller mit Essen vor mich hin."

# game/Scenes/Jez/jez13.rpy:197
translate german jez13_e02b004c:

    # "Before I get a chance to even look at it though, Mamá sits across from me and looks me in the eyes, like she's weighing me up."
    "Bevor ich jedoch überhaupt die Gelegenheit habe, ihn anzusehen, setzt sich Mama mir gegenüber und schaut mir in die Augen, als würde sie mich mustern."

# game/Scenes/Jez/jez13.rpy:198
translate german jez13_0711ba82:

    # mama "So, [pcname], how old are you?"
    mama "Also, [pcname], wie alt bist du?"

# game/Scenes/Jez/jez13.rpy:200
translate german jez13_c2113814:

    # pc "Twenty-two."
    pc "Zweiundzwanzig."

# game/Scenes/Jez/jez13.rpy:202
translate german jez13_a6d70d6c:

    # mama "So young. You're younger than Jesabela."
    mama "So jung. Du bist jünger als Jesabela."

# game/Scenes/Jez/jez13.rpy:205
translate german jez13_d41d8cd9_16:

    # voice 'voices/jez_13_17.mp3'
    voice 'voices/jez_13_17.mp3'

# game/Scenes/Jez/jez13.rpy:206
