# game/Scenes/Micha/MichaDates/michaparkdate.rpy:26
translate german michaparkstartdate_7d6d0d91:

    # "Mi-Cha and I walk around the trails, chit-chatting for a while."
    "Mi-Cha und ich spazieren die Wege entlang und unterhalten uns eine Weile."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:34
translate german michaparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "Schließlich erreichen wir die Bank auf halber Strecke."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:40
translate german michaparkstartdate_8d76a79c:

    # "We sit next to each other on the bench for a bit, watching the sky change colors as the sun sets."
    "Wir sitzen eine Weile nebeneinander auf der Bank und beobachten, wie der Himmel beim Sonnenuntergang seine Farben wechselt."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:43
translate german michaparkstartdate_3dfbfe0f:

    # "We make out. She's nervous, I can tell that she wants more."
    "Wir knutschen. Sie ist nervös, ich merke, dass sie mehr will."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:44
translate german michaparkstartdate_af7c35f8:

    # "But we have to head back before it gets too dark."
    "Aber wir müssen zurück, bevor es zu dunkel wird."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:47
translate german michaparkstartdate_6b4912a9:

    # mc "Do you mind taking me back to my dorm?"
    mc "Könntest du mich bitte zu meinem Wohnheim zurückbringen?"

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:48
translate german michaparkstartdate_a248948f:

    # pc "Of course."
    pc "Natürlich."

translate german strings:

    # game/Scenes/Micha/MichaDates/michaparkdate.rpy:2
    old "After you have walked Mi-Cha to her dorm once and wished upon a star, you will be able to take her to the park."
    new "Nachdem du Mi-Cha einmal zu ihrem Wohnheim begleitet und dir etwas von einem Stern gewünscht hast, kannst du sie in den Park mitnehmen."

    # game/Scenes/Micha/MichaDates/michaparkdate.rpy:3
    old "Call her in the evening and ask her to go to the park."
    new "Ruf sie am Abend an und frag sie, ob sie mit in den Park kommen möchte."

