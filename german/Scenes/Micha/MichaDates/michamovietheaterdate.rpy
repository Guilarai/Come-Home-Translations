# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:24
translate german michamovietheaterstartdate_929c1af5:

    # "I head over to the movie theater to meet Mi-Cha."
    "Ich gehe zum Kino, um mich mit Mi-Cha zu treffen."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:27
translate german michamovietheaterstartdate_53aa213e:

    # "I meet Mi-Cha in the movie theater parking lot."
    "Ich treffe Mi-Cha auf dem Parkplatz des Kinos."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:29
translate german michamovietheaterstartdate_1696084c:

    # pc "You look very cute."
    pc "Du siehst sehr süß aus."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:32
translate german michamovietheaterstartdate_d41d8cd9:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:33
translate german michamovietheaterstartdate_bb0eeaf4:

    # mc "Thank you."
    mc "Danke."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:34
translate german michamovietheaterstartdate_17670cf3:

    # mc "You look nice also."
    mc "Du siehst auch gut aus."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:37
translate german michamovietheaterstartdate_88edd4ad:

    # "Then we go inside and sit in the back."
    "Dann gehen wir rein und setzen uns ganz nach hinten."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:39
translate german michamovietheaterstartdate_90b2b501:

    # "She's so quiet. I should try to start up a conversation."
    "Sie ist so still. Ich sollte versuchen, ein Gespräch anzufangen."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:44
translate german michamovietheaterstartdate_56f38f5f:

    # "The movie starts and we go quiet."
    "Der Film beginnt und wir schweigen."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:45
translate german michamovietheaterstartdate_0a855fcc:

    # "Throughout the movie, it feels like she starts to relax some."
    "Im Laufe des Films habe ich das Gefühl, dass sie sich langsam etwas entspannt."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:47
translate german michamovietheaterstartdate_914a9aa2:

    # "It's a fun movie and she's nice company, if a little quiet."
    "Es ist ein unterhaltsamer Film und sie ist eine nette Begleitung, wenn auch ein bisschen still."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:49
translate german michamovietheaterstartdate_0edfdae0:

    # "When it ends, she turns to me."
    "Als er zu Ende ist, dreht sie sich zu mir um."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:51
translate german michamovietheaterstartdate_bab5119d:

    # mc "Did you like the movie?"
    mc "Hat dir der Film gefallen?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:52
translate german michamovietheaterstartdate_f4477343:

    # pc "Yeah I enjoyed it."
    pc "Ja, er hat mir gefallen."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:53
translate german michamovietheaterstartdate_e4993620:

    # mc "Me too. I thought it was very good."
    mc "Mir auch. Ich fand ihn sehr gut."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:54
translate german michamovietheaterstartdate_365db8f9:

    # "We hang out during the credits and chat a little bit more."
    "Wir bleiben während des Abspanns noch da und unterhalten uns ein bisschen weiter."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:59
translate german michamovietheaterstartdate_63e18d0b:

    # "When the credits end, we go outside to the parking lot and stand near her car."
    "Als der Abspann zu Ende ist, gehen wir nach draußen auf den Parkplatz und stellen uns neben ihr Auto."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:60
translate german michamovietheaterstartdate_725fffe9:

    # mc "I had a very good time. Thank you for taking me."
    mc "Ich hatte eine sehr schöne Zeit. Danke, dass du mich mitgenommen hast."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:61
translate german michamovietheaterstartdate_07c9c5ab:

    # pc "You're welcome."
    pc "Gern geschehen."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:65
translate german michamovietheaterstartdate_5f014a7b:

    # "She rushes up to me, leans up and gives me a tiny peck of a kiss on the mouth, our lips barely touching."
    "Sie eilt auf mich zu, beugt sich vor und gibt mir einen winzigen Kuss auf den Mund, unsere Lippen berühren sich kaum."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:67
translate german michamovietheaterstartdate_5ac477c2:

    # "Then she pulls back once again."
    "Dann zieht sie sich wieder zurück."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:68
translate german michamovietheaterstartdate_50afc9a0:

    # mc "Okay goodbye, [pcname]."
    mc "Okay, tschüss, [pcname]."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:70
translate german michamovietheaterstartdate_0488daa1:

    # "And before I can say anything in response, she rushes to her car, starts it up, and drives away."
    "Und bevor ich etwas erwidern kann, eilt sie zu ihrem Auto, startet den Motor und fährt davon."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:72
translate german michamovietheaterstartdate_6cbf222e:

    # "Well, I guess we're making some progress at least?"
    "Na ja, ich schätze, wir machen zumindest ein paar Fortschritte?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:78
translate german michamovietheaterstartdate_2674be8c:

    # mc "Would you mind taking me back to my dorm?"
    mc "Könntest du mich bitte zurück zu meinem Wohnheim bringen?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:79
translate german michamovietheaterstartdate_a274c9a4:

    # pc "Of course not."
    pc "Natürlich."

