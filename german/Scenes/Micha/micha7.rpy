translate german micha7_fa4d4666:

    # pc "What would you like, Mi-Cha? I'll pay. Anything you want."
    pc "Was möchtest du, Mi-Cha? Ich bezahle. Was immer du willst."

# game/Scenes/Micha/micha7.rpy:62
translate german micha7_816eccbd:

    # mc "You first, please."
    mc "Du zuerst, bitte."

# game/Scenes/Micha/micha7.rpy:63
translate german micha7_c24a94ff:

    # pc "Okay. I'll have a hot vanilla latte."
    pc "Okay. Ich nehme einen heißen Vanille-Latte."

# game/Scenes/Micha/micha7.rpy:64
translate german micha7_0515f2bf:

    # mc "I will have the same."
    mc "Ich nehme das Gleiche."

# game/Scenes/Micha/micha7.rpy:65
translate german micha7_a4c27a52:

    # bn "Sure thing. Two hot vanilla lattes coming right up."
