# game/Scenes/Micha/micha13.rpy:10
translate german micha13_66a911ed:

    # "When I get to the counselor's office, I'm surprised to see Gertrude behind the counter instead of Mi-Cha."
    "Als ich im Büro der Beraterin ankomme, bin ich überrascht, Gertrude hinter dem Schalter zu sehen statt Mi-Cha."

# game/Scenes/Micha/micha13.rpy:11
translate german micha13_51f359cb:

    # sc "Good morning, [pcname]. If you're here for a counseling session, I'm sorry. I have to work reception today."
    sc "Guten Morgen, [pcname]. Wenn du wegen einer Beratungssitzung hier bist, tut es mir leid. Ich muss heute an der Rezeption arbeiten."

# game/Scenes/Micha/micha13.rpy:12
translate german micha13_320f7ecc:

    # pc "Where's Mi-Cha?"
    pc "Wo ist Mi-Cha?"

# game/Scenes/Micha/micha13.rpy:13
translate german micha13_f822911c:

    # sc "She called this morning saying she couldn't come in for some reason. She sounded upset."
    sc "Sie hat heute Morgen angerufen und gesagt, sie könne aus irgendeinem Grund nicht kommen. Sie klang aufgebracht."

# game/Scenes/Micha/micha13.rpy:14
translate german micha13_d6ed663d:

    # sc "If you have time, maybe you could go check on her? I know you two have become friends."
    sc "Wenn du Zeit hast, könntest du vielleicht mal nach ihr sehen? Ich weiß, dass ihr beide Freunde geworden seid."

# game/Scenes/Micha/micha13.rpy:15
translate german micha13_477e82cd:

    # pc "Yeah, I think I have a little time before class. I'll go do that."
    pc "Ja, ich glaube, ich habe noch ein bisschen Zeit vor dem Unterricht. Ich werde das machen."

# game/Scenes/Micha/micha13.rpy:18
translate german micha13_cfda0a84:

    # "I leave the counselor's office, walk over to the dorms, and make my way up to Mi-Cha's door."
    "Ich verlasse das Büro der Beraterin, gehe zu den Wohnheimen hinüber und mache mich auf den Weg zu Mi-Chas Tür."

# game/Scenes/Micha/micha13.rpy:22
translate german micha13_90464c94:

    # "She answers after a couple of knocks."
    "Nach ein paar Klopfen öffnet sie."

# game/Scenes/Micha/micha13.rpy:23
translate german micha13_94a711d9:

    # mc "Oh, [pcname]! Why are you here?"
    mc "Oh, [pcname]! Warum bist du hier?"

# game/Scenes/Micha/micha13.rpy:24
translate german micha13_36eedc65:

    # pc "Gertrude asked me to come check on you. She said you called in. Are you sick?"
    pc "Gertrude hat mich gebeten, nach dir zu sehen. Sie sagte, du hättest dich krankgemeldet. Bist du krank?"

# game/Scenes/Micha/micha13.rpy:25
translate german micha13_2e46b23a:

    # mc "No, I'm not sick."
    mc "Nein, ich bin nicht krank."

# game/Scenes/Micha/micha13.rpy:26
translate german micha13_cb45e08c:

    # pc "Well, what's going on?"
    pc "Na, was ist los?"

# game/Scenes/Micha/micha13.rpy:29
translate german micha13_98c909b0:

    # "I follow her inside and we sit on her bed."
    "Ich folge ihr hinein und wir setzen uns auf ihr Bett."

# game/Scenes/Micha/micha13.rpy:30
translate german micha13_2f43efba:

    # mc "I argued with my parents last night. They told me to quit dance class. They say that it interferes with my studies."
    mc "Ich habe mich gestern Abend mit meinen Eltern gestritten. Sie haben mir gesagt, ich solle mit dem Tanzunterricht aufhören. Sie sagen, das beeinträchtige mein Studium."

# game/Scenes/Micha/micha13.rpy:31
translate german micha13_6282a1b7:

    # pc "But you like dancing."
    pc "Aber du tanzt doch gerne."

# game/Scenes/Micha/micha13.rpy:34
translate german micha13_44899e27:

    # mc "I love dancing. And I have a performance soon that I was very much looking forward to."
    mc "Ich liebe das Tanzen. Und ich habe bald einen Auftritt, auf den ich mich sehr gefreut habe."

# game/Scenes/Micha/micha13.rpy:35
translate german micha13_4624f9be:

    # mc "But they say that I have to stop."
    mc "Aber sie sagen, ich muss damit aufhören."

# game/Scenes/Micha/micha13.rpy:36
translate german micha13_ff3c6bab:

    # pc "So what?"
    pc "Na und?"

# game/Scenes/Micha/micha13.rpy:37
translate german micha13_f0ac6ad2:

    # mc "I can't just not do what they say."
    mc "Ich kann mich nicht einfach über ihre Anweisungen hinwegsetzen."

# game/Scenes/Micha/micha13.rpy:40
translate german micha13_23d549c1:

    # pc "But I want you to dance."
    pc "Aber ich möchte, dass du tanzt."

# game/Scenes/Micha/micha13.rpy:41
translate german micha13_81709362:

    # mc "You do?"
    mc "Wirklich?"

# game/Scenes/Micha/micha13.rpy:42
translate german micha13_6dba6230:

    # pc "Yes."
    pc "Ja."

# game/Scenes/Micha/micha13.rpy:43
translate german micha13_27a4c741:

    # mc "Are you telling me to?"
    mc "Sagst du mir das?"

# game/Scenes/Micha/micha13.rpy:44
translate german micha13_f43da382:

    # pc "Yes, Mi-Cha. I'm telling you to dance."
    pc "Ja, Mi-Cha. Ich sage dir, dass du tanzen sollst."

# game/Scenes/Micha/micha13.rpy:49
translate german micha13_d41d8cd9:

    # voice 'voices/micha_yessir.mp3'
    voice 'voices/micha_yessir.mp3'

# game/Scenes/Micha/micha13.rpy:50
translate german micha13_620baac7:

    # mc "Yes, [mcsir]."
    mc "Ja, [mcsir]."

# game/Scenes/Micha/micha13.rpy:51
translate german micha13_929f424d:

    # pc "So you will?"
    pc "Wirst du es also tun?"

# game/Scenes/Micha/micha13.rpy:54
translate german micha13_d41d8cd9_1:

    # voice 'voices/micha_yessir.mp3'
    voice 'voices/micha_yessir.mp3'

# game/Scenes/Micha/micha13.rpy:55
translate german micha13_620baac7_1:

    # mc "Yes, [mcsir]."
    mc "Ja, [mcsir]."

# game/Scenes/Micha/micha13.rpy:56
translate german micha13_536da0ad:

    # mc "I will keep dancing. For you."
    mc "Ich werde weiter tanzen. Für dich."

# game/Scenes/Micha/micha13.rpy:57
translate german micha13_f07574ec:

    # pc "Good."
    pc "Gut."

# game/Scenes/Micha/micha13.rpy:61
translate german micha13_d41d8cd9_2:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

# game/Scenes/Micha/micha13.rpy:62
translate german micha13_5b61e929:

    # mc "Thank you, [pcname]."
    mc "Danke, [pcname]."

# game/Scenes/Micha/micha13.rpy:63
translate german micha13_e3b6df4e:

    # pc "Do you feel better now?"
    pc "Fühlst du dich jetzt besser?"

# game/Scenes/Micha/micha13.rpy:64
translate german micha13_c324b928:

    # mc "Yes. I feel much better now."
    mc "Ja. Ich fühle mich jetzt viel besser."

# game/Scenes/Micha/micha13.rpy:65
translate german micha13_63023601:

    # pc "Okay."
    pc "Okay."

# game/Scenes/Micha/micha13.rpy:66
translate german micha13_c98760d6:

    # mc "I'll get dressed and go to the office."
    mc "Ich ziehe mich an und gehe ins Büro."

# game/Scenes/Micha/micha13.rpy:70
translate german micha13_d41d8cd9_3:

    # voice 'voices/micha_imsorry2.mp3'
    voice 'voices/micha_imsorry2.mp3'

# game/Scenes/Micha/micha13.rpy:71
translate german micha13_5fbcf7dd:

    # mc "I'm sorry you had to see me like this. In my pajamas with no makeup."
    mc "Es tut mir leid, dass du mich so sehen musstest. In meinem Pyjama und ungeschminkt."

# game/Scenes/Micha/micha13.rpy:72
translate german micha13_57c13e1f:

    # pc "Don't be silly. You're gorgeous."
    pc "Sei nicht albern. Du siehst umwerfend aus."

# game/Scenes/Micha/micha13.rpy:75
translate german micha13_d41d8cd9_4:

    # voice 'voices/micha_thankyousir2.mp3'
    voice 'voices/micha_thankyousir2.mp3'

# game/Scenes/Micha/micha13.rpy:76
translate german micha13_b00529b9:

    # mc "Thank you, [mcsir]."
    mc "Danke, [mcsir]."

# game/Scenes/Micha/micha13.rpy:79
translate german micha13_80adb898:

    # "I kiss her goodbye."
    "Ich küsse sie zum Abschied."

# game/Scenes/Micha/micha13.rpy:80
translate german micha13_bed52260:

    # "If I had time, I'd do more."
    "Wenn ich Zeit hätte, würde ich mehr tun."

# game/Scenes/Micha/micha13.rpy:83
translate german micha13_1a383b4b:

    # "But I have to get to class, so we pull apart and I tell her goodbye."
    "Aber ich muss zum Unterricht, also lösen wir uns voneinander und ich verabschiede mich von ihr."

