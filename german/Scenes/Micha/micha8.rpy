# game/Scenes/Micha/micha8.rpy:14
translate german micha8_5f9760c9:

    # "Before I go to Gertrude's office, Mi-Cha stops me in the lobby."
    "Bevor ich zu Gertrudes Büro gehe, hält mich Mi-Cha in der Lobby auf."

# game/Scenes/Micha/micha8.rpy:15
translate german micha8_ed6bde86:

    # mc "Hello, [pcname]."
    mc "Hallo, [pcname]."

# game/Scenes/Micha/micha8.rpy:16
translate german micha8_f481dcaa:

    # pc "Hi, Mi-Cha. How are you?"
    pc "Hallo, Mi-Cha. Wie geht es dir?"

# game/Scenes/Micha/micha8.rpy:17
translate german micha8_72cb11f5:

    # mc "I am good, thank you."
    mc "Mir geht es gut, danke."

# game/Scenes/Micha/micha8.rpy:19
translate german micha8_bdbd1fa8:

    # mc "I want to tell you that I enjoyed our coffee date."
    mc "Ich wollte dir sagen, dass mir unser Kaffeetrinken gefallen hat."

# game/Scenes/Micha/micha8.rpy:20
translate german micha8_8a7120da:

    # mc "I apologize for rushing off early and would like to again another sometime."
    mc "Es tut mir leid, dass ich so früh weg musste, und ich würde mich gerne irgendwann wieder mit dir treffen."

# game/Scenes/Micha/micha8.rpy:21
translate german micha8_3171636b:

    # mc "If you would like to this evening?"
    mc "Wie wäre es heute Abend?"

# game/Scenes/Micha/micha8.rpy:25
translate german micha8_2d186b97:

    # mc "Good. I will meet you in the Skyhill Cafe this evening then."
    mc "Gut. Dann sehen wir uns heute Abend im Skyhill Cafe."

# game/Scenes/Micha/micha8.rpy:29
translate german micha8_2f88594e:

    # mc "Oh. Okay. Yes, I'm sure you're busy."
    mc "Oh. Okay. Ja, ich bin mir sicher, dass du viel zu tun hast."

# game/Scenes/Micha/micha8.rpy:31
translate german micha8_08d0510d:

    # mc "Enjoy your visit with Mrs. Spann."
    mc "Viel Spaß bei deinem Besuch bei Frau Spann."

# game/Scenes/Micha/micha8.rpy:32
translate german micha8_32a03447:

    # pc "Okay. I'll see you later, Mi-Cha."
    pc "Okay. Bis später, Mi-Cha."

