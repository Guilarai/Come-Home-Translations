    pc "Guten Morgen."

# game/Scenes/Bai/bai11.rpy:179
translate german bai11_b61ba038:

    # bai "Oh hey, [pcname]. Good morning. I'm just doing my morning exercises."
    bai "Oh hey, [pcname]. Guten Morgen. Ich mache gerade meine Morgengymnastik."

# game/Scenes/Bai/bai11.rpy:180
translate german bai11_19701553:

    # bai "I didn't wake you did I?"
    bai "Ich habe dich doch nicht geweckt, oder?"

# game/Scenes/Bai/bai11.rpy:181
translate german bai11_deb5296b:

    # pc "No, I never even knew you left the bed."
    pc "Nein, ich habe gar nicht mitbekommen, dass du aufgestanden bist."

# game/Scenes/Bai/bai11.rpy:182
translate german bai11_8ba47b78:

