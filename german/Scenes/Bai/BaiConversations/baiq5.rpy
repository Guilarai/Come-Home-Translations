# game/Scenes/Bai/BaiConversations/baiq5.rpy:16
translate german baiq5_7333138d:

    # bai "Hey, [pcname]. I wanted to talk about something kind of serious..."
    bai "Hey, [pcname]. Ich wollte über etwas ziemlich Ernstes reden..."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:17
translate german baiq5_4f3a730b:

    # pc "Okay. What's up?"
    pc "Okay. Was gibt’s?"

# game/Scenes/Bai/BaiConversations/baiq5.rpy:19
translate german baiq5_15d3e71a:

    # bai "Well, we've been dating for a while now. And I love you. And you say you love me."
    bai "Also, wir sind jetzt schon eine Weile zusammen. Und ich liebe dich. Und du sagst, du liebst mich."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:21
translate german baiq5_4fdaf60d:

    # bai "So, I was wondering if you wanted to move in with me after this semester?"
    bai "Also habe ich mich gefragt, ob du nach diesem Semester bei mir einziehen möchtest?"

# game/Scenes/Bai/BaiConversations/baiq5.rpy:23
translate german baiq5_69b6dffa:

    # bai "We could live together. We could get a little more serious."
    bai "Wir könnten zusammenleben. Wir könnten unsere Beziehung etwas ernster angehen."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:25
translate german baiq5_2e6effe7:

    # bai "Honestly, I don't even mind if you keep seeing other people. As long as you come home to sleep with me."
    bai "Ehrlich gesagt macht es mir nicht mal was aus, wenn du dich weiterhin mit anderen triffst. Solange du nach Hause kommst, um mit mir zu schlafen."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:27
translate german baiq5_2be7425b:

    # bai "I just love being with you so much."
    bai "Ich liebe es einfach so sehr, mit dir zusammen zu sein."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:28
translate german baiq5_b2ea46e5:

    # bai "I want to see each other every day. I want to go to sleep together at night."
    bai "Ich möchte dich jeden Tag sehen. Ich möchte abends mit dir zusammen einschlafen."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:30
translate german baiq5_0bab3ff7:

    # bai "And one day, I want to get married."
    bai "Und eines Tages möchte ich heiraten."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:31
translate german baiq5_d3e6b1a8:

    # bai "I want to be with you forever, [pcname]."
    bai "Ich möchte für immer mit dir zusammen sein, [pcname]."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:33
translate german baiq5_3e39ede2:

    # bai "So... I've put myself out there."
    bai "Also... ich habe mich getraut."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:34
translate german baiq5_14318bc1:

    # "He lets out a deep breath."
    "Er atmet tief aus."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:36
translate german baiq5_99cae703:

    # bai "What do you think?"
    bai "Was denkst du?"

# game/Scenes/Bai/BaiConversations/baiq5.rpy:37
translate german baiq5_328ea626:

    # pc "I think it sounds pretty great. I do love you, Bai."
    pc "Ich finde, das klingt ziemlich toll. Ich liebe dich wirklich, Bai."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:38
translate german baiq5_62c2a508:

    # pc "Give me to the end of the semester to think about it?"
    pc "Gib mir bis zum Ende des Semesters Zeit, darüber nachzudenken?"

# game/Scenes/Bai/BaiConversations/baiq5.rpy:40
translate german baiq5_2e71d4fe:

    # bai "Oh, of course! Sure!"
    bai "Oh, natürlich! Klar!"

# game/Scenes/Bai/BaiConversations/baiq5.rpy:41
translate german baiq5_238a8ac5:

    # pc "Thanks, Bai."
    pc "Danke, Bai."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:43
translate german baiq5_2585f770:

    # bai "No problem! I don't mean to rush you or anything."
    bai "Kein Problem! Ich will dich nicht drängen oder so."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:44
translate german baiq5_d61a3587:

    # bai "I'm just ready, you know?"
    bai "Ich bin einfach bereit, weißt du?"

# game/Scenes/Bai/BaiConversations/baiq5.rpy:46
translate german baiq5_08afcabd:

    # bai "And whatever you decide, I think we'll be friends forever."
    bai "Und egal, wie du dich entscheidest, ich glaube, wir werden für immer Freunde bleiben."

# game/Scenes/Bai/BaiConversations/baiq5.rpy:47
translate german baiq5_6c16cd66:

    # pc "I think so too."
    pc "Das glaube ich auch."

