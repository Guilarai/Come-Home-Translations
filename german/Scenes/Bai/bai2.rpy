# game/Scenes/Bai/bai2.rpy:10
translate german bai2_98ca1a51:

    # "My phone buzzes in my pocket."
    "Mein Handy vibriert in meiner Tasche."

# game/Scenes/Bai/bai2.rpy:14
translate german bai2_a13b13a8:

    # "It's Bai. I guess I have time to chat a bit."
    "Es ist Bai. Ich schätze, ich habe Zeit für ein kurzes Gespräch."

# game/Scenes/Bai/bai2.rpy:17
translate german bai2_c0d6b27a:

    # pc "Hey Bai, what's up?"
    pc "Hey Bai, was geht?"

# game/Scenes/Bai/bai2.rpy:18
translate german bai2_ca2e0cd6:

    # bai "Hey, [pcname]. I was just lying here bored and wondered what you were up to?"
    bai "Hey, [pcname]. Ich lag gerade hier und langweilte mich und habe mich gefragt, was du so machst?"

# game/Scenes/Bai/bai2.rpy:19
translate german bai2_f020dde3:

    # pc "Just getting ready for bed, but I can talk for a while."
    pc "Ich mache mich gerade bettfertig, aber ich kann noch ein bisschen reden."

# game/Scenes/Bai/bai2.rpy:20
translate german bai2_b9768b08:

    # bai "That's cool. I've just been thinking a lot."
    bai "Das ist cool. Ich habe gerade viel nachgedacht."

# game/Scenes/Bai/bai2.rpy:21
translate german bai2_e61255db:

    # pc "About what?"
    pc "Worüber?"

# game/Scenes/Bai/bai2.rpy:23
translate german bai2_67224ed1:

    # bai "Just stuff mostly."
    bai "Einfach so über alles Mögliche."

# game/Scenes/Bai/bai2.rpy:24
translate german bai2_19828c08:

    # pc "You're going to have to be a little more specific than that or this conversation isn't going to go anywhere."
    pc "Da musst du schon etwas genauer werden, sonst führt dieses Gespräch zu nichts."

# game/Scenes/Bai/bai2.rpy:25
translate german bai2_64de84cd:

    # bai "Okay, well."
    bai "Okay, na ja."

# game/Scenes/Bai/bai2.rpy:26
translate german bai2_d7d9d996:

    # bai "I uh... I've only dated girls in the past."
    bai "Ich, äh... Ich war bisher nur mit Mädchen zusammen."

# game/Scenes/Bai/bai2.rpy:27
translate german bai2_36470b3e:

    # bai "I've had sex and stuff. With girls."
    bai "Ich hatte Sex und so. Mit Mädchen."

# game/Scenes/Bai/bai2.rpy:28
translate german bai2_41c2c9e2:

    # bai "But uh... I think I might be into guys too."
    bai "Aber, äh... Ich glaube, ich stehe vielleicht auch auf Jungs."

# game/Scenes/Bai/bai2.rpy:30
translate german bai2_8833a2ab:

    # pc "So, you're bisexual?"
    pc "Du bist also bisexuell?"

# game/Scenes/Bai/bai2.rpy:31
translate german bai2_61b09772:

    # bai "Maybe?"
    bai "Vielleicht?"

# game/Scenes/Bai/bai2.rpy:32
translate german bai2_0e63d7c1:

    # bai "What about you? Are you into guys at all?"
    bai "Und du? Stehst du überhaupt auf Jungs?"

# game/Scenes/Bai/bai2.rpy:36
translate german bai2_bde64ebd:

    # bai "Oh okay. I thought maybe we had a thing. It's okay though."
    bai "Oh, okay. Ich dachte, wir hätten vielleicht was. Ist aber okay."

# game/Scenes/Bai/bai2.rpy:37
translate german bai2_0fe323b5:

    # pc "Sorry, man. Chicks only for me."
    pc "Tut mir leid, Mann. Für mich kommen nur Mädels in Frage."

# game/Scenes/Bai/bai2.rpy:38
translate german bai2_83d8b883:

    # bai "It's cool. I understand."
    bai "Ist cool. Ich verstehe das."

# game/Scenes/Bai/bai2.rpy:40
translate german bai2_ecf05d77:

    # bai "Still friends though?"
    bai "Bleiben wir trotzdem Freunde?"

# game/Scenes/Bai/bai2.rpy:41
translate german bai2_71d4cebe:

    # pc "Sure, we're still friends."
    pc "Klar, wir bleiben Freunde."

# game/Scenes/Bai/bai2.rpy:44
translate german bai2_e26b3f90:

    # bai "Cool."
    bai "Cool."

# game/Scenes/Bai/bai2.rpy:47
translate german bai2_b66cc0ac:

    # bai "Really? I thought maybe we had a thing, but I wasn't sure."
    bai "Wirklich? Ich dachte, wir hätten vielleicht was, war mir aber nicht sicher."

# game/Scenes/Bai/bai2.rpy:49
translate german bai2_f39ae0a2:

    # bai "Are you into me?"
    bai "Stehst du auf mich?"

# game/Scenes/Bai/bai2.rpy:53
translate german bai2_99a03550:

    # bai "That makes me so happy."
    bai "Das macht mich so glücklich."

# game/Scenes/Bai/bai2.rpy:55
translate german bai2_99b1838b:

    # bai "So do you maybe want to actually go on a date sometime?"
    bai "Willst du dich dann vielleicht mal mit mir verabreden?"

# game/Scenes/Bai/bai2.rpy:56
translate german bai2_39757b54:

    # pc "Yeah, let's do it."
    pc "Ja, lass es uns machen."

# game/Scenes/Bai/bai2.rpy:57
translate german bai2_8c98f2da:

    # bai "Okay, just give me a call in the evening sometime then. I'm available almost every day."
    bai "Okay, dann ruf mich einfach mal abends an. Ich hab fast jeden Tag Zeit."

# game/Scenes/Bai/bai2.rpy:58
translate german bai2_58a87bc2:

    # pc "Sounds good. I'm looking forward to it."
    pc "Klingt gut. Ich freu mich drauf."

# game/Scenes/Bai/bai2.rpy:59
translate german bai2_10a70856:

    # bai "Me too. Really."
    bai "Ich auch. Wirklich."

# game/Scenes/Bai/bai2.rpy:60
translate german bai2_4d74a398:

    # bai "This is new territory for me, but I'm really looking forward to exploring it with you."
    bai "Das ist Neuland für mich, aber ich freu mich echt drauf, es mit dir zu erkunden."

# game/Scenes/Bai/bai2.rpy:63
translate german bai2_c0a43543:

    # bai "Oh, so you're into guys, but you're not into me."
    bai "Oh, du stehst also auf Jungs, aber nicht auf mich."

# game/Scenes/Bai/bai2.rpy:64
translate german bai2_27247fe1:

    # bai "Gotta say, that hurts man."
    bai "Muss ich sagen, das tut weh, Mann."

# game/Scenes/Bai/bai2.rpy:65
translate german bai2_c31c7975:

    # pc "Sorry, just being honest."
    pc "Tut mir leid, ich bin nur ehrlich."

# game/Scenes/Bai/bai2.rpy:66
translate german bai2_40a3eff2:

    # bai "Yeah okay. Well that sucks."
    bai "Ja, okay. Na, das ist ja schade."

# game/Scenes/Bai/bai2.rpy:67
translate german bai2_0cce2b18:

    # pc "We can still be friends though."
    pc "Wir können aber trotzdem Freunde bleiben."

# game/Scenes/Bai/bai2.rpy:68
translate german bai2_46106a33:

    # bai "Yeah, okay. I'm going to bed."
    bai "Ja, okay. Ich geh jetzt ins Bett."

# game/Scenes/Bai/bai2.rpy:70
translate german bai2_14a17911:

    # "He hangs up. I guess that didn't go so well."
    "Er legt auf. Ich schätze, das ist nicht so gut gelaufen."

# game/Scenes/Bai/bai2.rpy:71
translate german bai2_a0d6f0f3:

    # "Oh well. He'll get over it. Or not, whatever."
    "Na ja. Er wird darüber hinwegkommen. Oder auch nicht, egal."

# game/Scenes/Bai/bai2.rpy:72
translate german bai2_ef88129a:

    # "I put the phone away and get ready for bed."
    "Ich lege das Handy weg und mache mich bettfertig."

# game/Scenes/Bai/bai2.rpy:75
translate german bai2_17d3424c:

    # "We chat a little longer about our days, until we are both tired."
    "Wir unterhalten uns noch ein bisschen über unseren Tag, bis wir beide müde sind."

# game/Scenes/Bai/bai2.rpy:77
translate german bai2_3898d259:

    # bai "I better get some sleep man."
    bai "Ich sollte besser schlafen gehen, Mann."

# game/Scenes/Bai/bai2.rpy:78
translate german bai2_89c07fc5:

    # bai "I'll talk to you later."
    bai "Wir reden später."

# game/Scenes/Bai/bai2.rpy:79
translate german bai2_d2381b62:

    # pc "Okay. See ya, Bai."
    pc "Okay. Bis dann, Bai."

# game/Scenes/Bai/bai2.rpy:82
translate german bai2_52d6e3cf:

    # "We hang up and I get ready for bed."
    "Wir legen auf und ich mache mich bettfertig."

