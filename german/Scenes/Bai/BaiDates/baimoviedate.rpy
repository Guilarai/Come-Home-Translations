# game/Scenes/Bai/BaiDates/baimoviedate.rpy:25
translate german baimovietheaterstartdate_13ddb197:

    # "We get to the theater and find seats in the back."
    "Wir kommen im Kino an und suchen uns Plätze ganz hinten."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:26
translate german baimovietheaterstartdate_7b36967b:

    # "We chat for a while before the movie starts."
    "Wir unterhalten uns eine Weile, bevor der Film beginnt."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:31
translate german baimovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Endlich fängt der Film an und wir werden still."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:33
translate german baimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Die Trailer dauern etwa fünfzehn Minuten, dann geht es richtig los."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:35
translate german baimovietheaterstartdate_5e17c29c:

    # "It's a pretty good movie and we laugh all the way through it."
    "Es ist ein ziemlich guter Film und wir lachen die ganze Zeit."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:37
translate german baimovietheaterstartdate_a2905b6a:

    # "After the movie ends, we hang out and chat through the credits."
    "Nachdem der Film zu Ende ist, bleiben wir noch da und unterhalten uns während des Abspanns."

# game/Scenes/Bai/BaiDates/baimoviedate.rpy:42
translate german baimovietheaterstartdate_edff30b2:

    # "When the credits end, we walk outside together to my car."
    "Als der Abspann zu Ende ist, gehen wir gemeinsam nach draußen zu meinem Auto."

