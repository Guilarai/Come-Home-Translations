# game/Scenes/Bai/BaiDates/baigrottodate.rpy:19
translate german baigrottodate_d3715341:

    # pc "Do you want to come out to a fancy restaurant with me?"
    pc "Willst du mit mir in ein schickes Restaurant gehen?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:20
translate german baigrottodate_4243d9c3:

    # pc "It's called The Grotto. It's out on the lake."
    pc "Es heißt „Die Grotte“. Es liegt am See."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:23
translate german baigrottodate_4f7f94cb:

    # bai "Is it expensive?"
    bai "Ist es teuer?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:24
translate german baigrottodate_3308b177:

    # pc "Pretty expensive, yeah."
    pc "Ziemlich teuer, ja."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:26
translate german baigrottodate_fb59b9b7:

    # bai "Aw, what the hell. Might as well spend it, right?"
    bai "Ach, was soll’s. Wir können das Geld auch ausgeben, oder?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:27
translate german baigrottodate_f82e580f:

    # bai "I eat cheap every other day, let's get some fancy food!"
    bai "Ich esse jeden zweiten Tag billig, lass uns mal schick essen gehen!"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:28
translate german baigrottodate_5f71dc40:

    # pc "All right! I'll text you the address and meet you out there."
    pc "Alles klar! Ich schick dir die Adresse per SMS und wir treffen uns dort."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:29
translate german baigrottodate_1bda0dbe:

    # bai "Sounds good! See you there."
    bai "Klingt gut! Wir sehen uns dort."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:32
translate german baigrottodate_cf65d098:

    # "I get ready and text Bai the address, then about an hour later we're sitting down to eat at The Grotto."
    "Ich mache mich fertig und schicke Bai die Adresse per SMS, dann sitzen wir etwa eine Stunde später im „The Grotto“ beim Essen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:35
translate german baigrottodate_79872e14:

    # bai "That sounds great. Are we going to get all dressed up in suits and stuff?"
    bai "Das klingt toll. Müssen wir uns da alle schick anziehen, mit Anzug und so?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:36
translate german baigrottodate_a9dc377e:

    # pc "Damn right, we are."
    pc "Verdammt richtig, das müssen wir."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:38
translate german baigrottodate_bfaba4a8:

    # bai "Oh man. I have to find my suit then. I know I have one in the closet somewhere."
    bai "Oh Mann. Dann muss ich meinen Anzug erst mal finden. Ich weiß, dass ich irgendwo im Schrank einen habe."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:39
translate german baigrottodate_b5cc83ae:

    # bai "I'll go find it."
    bai "Ich geh ihn suchen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:40
translate german baigrottodate_ffb27a81:

    # pc "Okay. Send me a text when you're ready and I'll come pick you up, okay?"
    pc "Okay. Schick mir eine SMS, wenn du fertig bist, dann hol ich dich ab, okay?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:42
translate german baigrottodate_9e815b71:

    # bai "Okay! I'm really excited!"
    bai "Okay! Ich freu mich schon total!"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:43
translate german baigrottodate_f07574ec:

    # pc "Good."
    pc "Gut."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:44
translate german baigrottodate_412f6c55:

    # bai "Okay, see you in a bit."
    bai "Okay, bis gleich."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:47
translate german baigrottodate_9bcd7a72:

    # "I get ready to go and wait for Bai's text."
    "Ich mach mich fertig und warte auf Bais SMS."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:48
translate german baigrottodate_9173db50:

    # "About an hour later, he texts me and I go pick him up, then we walk into The Grotto together."
    "Etwa eine Stunde später schreibt er mir und ich hole ihn ab, dann gehen wir gemeinsam ins „The Grotto“."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:51
translate german baigrottodate_9131d6c6:

    # bai "Sounds good! I'll see you there."
    bai "Klingt gut! Wir sehen uns dort."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:52
translate german baigrottodate_5d3d77d3:

    # pc "Cool. See you."
    pc "Cool. Bis dann."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:54
translate german baigrottodate_299409d0:

    # bai "That sounds great! I'll start getting ready. Come get me."
    bai "Das klingt toll! Ich fange an, mich fertig zu machen. Hol mich ab."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:55
translate german baigrottodate_e3948ee8:

    # pc "Alright, I'll be there in a bit."
    pc "Alles klar, ich bin gleich da."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:69
translate german baigrottostartdate_ba211ff8:

    # "We walk in together, holding hands."
    "Wir gehen Hand in Hand hinein."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:70
translate german baigrottostartdate_fb0e2e4f:

    # bai "This feels very public. More public than we usually are."
    bai "Das fühlt sich sehr öffentlich an. Öffentlicher, als wir es normalerweise sind."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:71
translate german baigrottostartdate_a674eec0:

    # pc "Are you okay with that?"
    pc "Ist das okay für dich?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:72
translate german baigrottostartdate_023cf823:

    # bai "Yeah, with you, I think I am."
    bai "Ja, mit dir ist es das, glaube ich."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:73
translate german baigrottostartdate_e39c1441:

    # pc "Good. You look like a fucking stud right now. I'm proud to be here with you."
    pc "Gut. Du siehst gerade verdammt gut aus. Ich bin stolz, hier mit dir zu sein."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:74
translate german baigrottostartdate_bb37df29:

    # bai "Me too."
    bai "Ich auch."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:81
translate german baigrottostartdate_a5785e55:

    # "We sit at a table and begin looking over the menus."
    "Wir setzen uns an einen Tisch und schauen uns die Speisekarten an."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:82
translate german baigrottostartdate_a395082c:

    # "Then a server comes by and takes our order."
    "Dann kommt ein Kellner vorbei und nimmt unsere Bestellung auf."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:91
translate german baigrottostartdate_32733c2f:

    # "After we chat for a while, our food is brought out."
    "Nachdem wir uns eine Weile unterhalten haben, wird unser Essen serviert."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:92
translate german baigrottostartdate_501f942a:

    # bai "Wow, this looks amazing."
    bai "Wow, das sieht fantastisch aus."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:98
translate german baigrottostartdate_28b42b01:

    # "We continue chatting while we eat our meal. Just hanging out and enjoying some good food together."
    "Wir unterhalten uns weiter, während wir essen. Wir hängen einfach nur ab und genießen gemeinsam das gute Essen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:101
translate german baigrottostartdate_7150c85d:

    # "When we're done eating, we split the bill and say our goodbyes."
    "Als wir fertig gegessen haben, teilen wir die Rechnung und verabschieden uns."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:105
translate german baigrottostartdate_25d6d119:

    # bai "That was fun, man. Good food. Thanks for inviting me."
    bai "Das hat Spaß gemacht, Mann. Tolles Essen. Danke, dass du mich eingeladen hast."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:106
translate german baigrottostartdate_0c975e99:

    # pc "No problem. Good to hang out and talk for a while."
    pc "Kein Problem. War schön, ein bisschen abzuhängen und zu quatschen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:107
translate german baigrottostartdate_49b45846:

    # bai "Yeah it was."
    bai "Ja, das war es."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:108
translate german baigrottostartdate_01c7ca57:

    # bai "Alright, well I'll see you later. Take care."
    bai "Okay, dann bis später. Mach’s gut."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:109
translate german baigrottostartdate_22fbafdc:

    # pc "You too. See ya."
    pc "Du auch. Bis dann."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:112
translate german baigrottostartdate_0c8ca28d:

    # "We get in our cars and go our separate directions."
    "Wir steigen in unsere Autos und fahren in verschiedene Richtungen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:120
translate german baigrottostartdate_bfde7d54:

    # "We continue chatting and eating."
    "Wir unterhalten uns weiter und essen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:126
translate german baigrottostartdate_1ef0c0b5:

    # "Bai insists that we split the bill, then we get ready to leave."
    "Bai besteht darauf, dass wir die Rechnung teilen, dann machen wir uns bereit zu gehen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:132
translate german baigrottostartdate_ca01422f:

    # bai "It's so pretty out here, isn't it?"
    bai "Es ist so schön hier draußen, nicht wahr?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:133
translate german baigrottostartdate_44eeaf1a:

    # pc "Yeah it is."
    pc "Ja, das ist es."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:139
translate german baigrottostartdate_7c70709c:

    # "I lean in and kiss him, uncaring about anybody who might be watching us."
    "Ich beuge mich vor und küsse ihn, ohne mich darum zu kümmern, ob uns jemand beobachtet."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:140
translate german baigrottostartdate_61700a7a:

    # "He is surprised at first, but doesn't pull away."
    "Er ist zuerst überrascht, weicht aber nicht zurück."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:143
translate german baigrottostartdate_4a0dd6f7:

    # bai "I can't believe I just did that. Right in front of everybody."
    bai "Ich kann nicht glauben, dass ich das gerade getan habe. Mitten vor allen Leuten."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:144
translate german baigrottostartdate_6e718b73:

    # pc "How did it feel?"
    pc "Wie hat es sich angefühlt?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:145
translate german baigrottostartdate_3696af55:

    # bai "It felt great."
    bai "Es hat sich toll angefühlt."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:150
translate german baigrottostartdate_d90b231d:

    # bai "Want to go back to my apartment now?"
    bai "Willst du jetzt zu mir nach Hause kommen?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:153
translate german baigrottostartdate_4861bda5:

    # bai "Aw, okay. Well it was a good date, anyway. Thanks for bringing me."
    bai "Ach, okay. Na ja, es war jedenfalls ein schönes Date. Danke, dass du mich mitgenommen hast."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:156
translate german baigrottostartdate_29d9625f:

    # "We leave and I drive him to his aparment and say goodbye."
    "Wir gehen, ich fahre ihn zu seiner Wohnung und verabschiede mich."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:157
translate german baigrottostartdate_f1413fe1:

    # "Then I drive away to do something else with my night."
    "Dann fahre ich los, um den Abend anderweitig zu verbringen."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:164
translate german baigrottostartdate_ebdfbc55:

    # "We rush out to the car and drive back to his apartment."
    "Wir eilen zum Auto und fahren zurück zu seiner Wohnung."

