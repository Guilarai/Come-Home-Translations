    bai "Ich freue mich schon darauf, wenn wir das nächste Mal zusammen etwas unternehmen können."

# game/Scenes/Bai/bai1.rpy:257
translate german bai1d_d0ca3261:

    # bai "Hope we can hang out like this again soon."
    bai "Hoffentlich können wir bald wieder so etwas machen."

# game/Scenes/Bai/bai1.rpy:258
translate german bai1d_03eaad50_1:

    # pc "Me too."
    pc "Ich auch."

# game/Scenes/Bai/bai1.rpy:260
translate german bai1d_30423311:

    # bai "Hey before we leave, let me give you my phone number."
    bai "Hey, bevor wir gehen, gib ich dir mal meine Telefonnummer."

# game/Scenes/Bai/bai1.rpy:261
translate german bai1d_0b8345e6:

    # bai "I don't have a lot of friends around here, so I'd love to just chat with you whenever you feel up to it."
    bai "Ich hab hier nicht viele Freunde, also würde ich mich freuen, einfach mal mit dir zu quatschen, wann immer du Lust hast."

# game/Scenes/Bai/bai1.rpy:262
translate german bai1d_465c988e:

    # bai "And maybe we can go out again sometime soon."
    bai "Und vielleicht können wir ja bald mal wieder was unternehmen."

# game/Scenes/Bai/bai1.rpy:263
translate german bai1d_50eb93b7:

    # pc "Okay, sounds good."
    pc "Okay, klingt gut."

# game/Scenes/Bai/bai1.rpy:270
translate german bai1d_0e8a2008:

    # "We finish up our food, he leaves some money on the table, then we head outside."
    "Wir essen auf, er legt etwas Geld auf den Tisch, dann gehen wir nach draußen."

# game/Scenes/Bai/bai1.rpy:271
translate german bai1d_630eae85:

    # bai "Well that was the most fun I've had in a while."
    bai "Das war der größte Spaß, den ich seit Langem hatte."

# game/Scenes/Bai/bai1.rpy:272
translate german bai1d_a96bfd7d:

    # bai "Thanks again for hanging out with me tonight."
    bai "Nochmals danke, dass du heute Abend mit mir unterwegs warst."

# game/Scenes/Bai/bai1.rpy:273
translate german bai1d_fe5246ec:

    # pc "No problem. I had fun too."
    pc "Kein Problem. Mir hat es auch Spaß gemacht."

# game/Scenes/Bai/bai1.rpy:274
translate german bai1d_b6980062:

    # bai "Alright, well I better head home."
    bai "Na gut, ich geh jetzt besser nach Hause."

# game/Scenes/Bai/bai1.rpy:276
translate german bai1d_5d4a4d14:

    # bai "I'll see you later."
    bai "Bis später."

# game/Scenes/Bai/bai1.rpy:277
translate german bai1d_1aff6c8c:

    # pc "See ya, Bai."
    pc "Bis dann, Bai."

# game/Scenes/Bai/bai1.rpy:278
translate german bai1d_ba9439b8:

    # "He goes to his car and drives off and I walk to mine."
    "Er geht zu seinem Auto und fährt los, und ich gehe zu meinem."

