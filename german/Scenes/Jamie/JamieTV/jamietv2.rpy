# TODO: Translation updated at 2026-06-02 13:31

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:13
translate german jamietv2_fd039b16:

    # "I walk up to Jamie's door and knock."
    "gehe ich zu Jamies Tür und klopfe an."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:14
translate german jamietv2_fdad75c4:

    # "I wait a bit for her to answer and after a few moments, I almost walk away thinking that she isn't home or is busy or something."
    "Ich warte ein bisschen, bis sie antwortet, und nach ein paar Augenblicken will ich schon fast weggehen, weil ich denke, dass sie nicht zu Hause ist oder beschäftigt ist oder so."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:19
translate german jamietv2_56b288a0:

    # "Then, just when I am about to leave, she opens the door."
    "Dann, gerade als ich gehen will, öffnet sie die Tür."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:20
translate german jamietv2_348b659c:

    # gnd "Hey sorry, I must have fell asleep on the couch."
    gnd "Hey, tut mir leid, ich muss auf der Couch eingeschlafen sein."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:21
translate german jamietv2_85e15039:

    # pc "Oh I'm sorry, I didn't mean to wake you. Was just wondering if you wanted to hang out?"
    pc "Oh, tut mir leid, ich wollte dich nicht wecken. Ich hab mich nur gefragt, ob du Lust hast, was mit mir zu unternehmen?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:22
translate german jamietv2_8cddc873:

    # gnd "Sure, want to come watch TV with me?"
    gnd "Klar, willst du mit mir fernsehen?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:23
translate german jamietv2_6eafa1e5:

    # pc "Are you sure? You look pretty tired."
    pc "Bist du sicher? Du siehst ziemlich müde aus."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:24
translate german jamietv2_d5f53ad3:

    # gnd "I'm exhausted, but I'd still like to spend some time with you."
    gnd "Ich bin total erschöpft, aber ich würde trotzdem gerne etwas Zeit mit dir verbringen."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:25
translate german jamietv2_35743d5e:

    # pc "Okay then."
    pc "Na gut."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:26
translate german jamietv2_d6443097:

    # "We walk inside and sit down on her couch to watch TV together."
    "Wir gehen rein und setzen uns auf ihr Sofa, um gemeinsam fernzusehen."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:29
translate german jamietv2_4eefcd41:

    # pc "You not been sleeping well?"
    pc "Hast du nicht gut geschlafen?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:30
translate german jamietv2_d3a1e5f8:

    # gnd "I've just been studying a lot. It's been tough."
    gnd "Ich habe einfach viel gelernt. Es war ziemlich anstrengend."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:31
translate german jamietv2_6d7e76b4:

    # pc "Tell me about it."
    pc "Wem sagst du das."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:32
translate german jamietv2_56872787:

    # gnd "But I'm glad to spend some time with you, even if I'm sleepy."
    gnd "Aber ich bin froh, etwas Zeit mit dir zu verbringen, auch wenn ich müde bin."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:37
translate german jamietv2_c7a75159:

    # gnd "Are you implying I'm not cute when I'm not sleepy?"
    gnd "Willst du damit sagen, dass ich nicht süß bin, wenn ich nicht müde bin?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:38
translate german jamietv2_4db958a5:

    # pc "What? No."
    pc "Was? Nein."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:39
translate german jamietv2_cf0825c6:

    # gnd "I'm just kidding. Thanks, you're sweet."
    gnd "Ich mache nur Spaß. Danke, das ist lieb von dir."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:42
translate german jamietv2_175d3768:

    # gnd "What? Are you serious?"
    gnd "Was? Meinst du das ernst?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:43
translate german jamietv2_61f77a4c:

    # pc "Sure."
    pc "Klar."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:44
translate german jamietv2_f3a7bdd3:

    # gnd "That's probably not a good idea. My dad might actually kill you."
    gnd "Das ist wahrscheinlich keine gute Idee. Mein Vater könnte dich tatsächlich umbringen."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:45
translate german jamietv2_796397b3:

    # pc "It might be worth the risk."
    pc "Das Risiko könnte es wert sein."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:46
translate german jamietv2_34f266ea:

    # gnd "You're crazy!"
    gnd "Du bist verrückt!"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:49
translate german jamietv2_d13864ee:

    # gnd "But no, let's just watch TV."
    gnd "Aber nein, lass uns einfach fernsehen."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:52
translate german jamietv2_8105064d:

    # "She smiles at me and we both turn towards the TV and watch the show."
    "Sie lächelt mich an und wir drehen uns beide zum Fernseher und schauen die Sendung."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:55
translate german jamietv2_e4b4fe92:

    # "After the first commercial break, I hear her snoring softly and a moment later, she leans over and lays her head on my shoulder."
    "Nach der ersten Werbepause höre ich sie leise schnarchen und einen Moment später beugt sie sich zu mir herüber und legt ihren Kopf auf meine Schulter."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:56
translate german jamietv2_72d126bc:

    # "I sit there like that, feeling her warm weight against me, smelling the scent of her shampoo. It's nice."
    "Ich sitze so da, spüre ihr warmes Gewicht an mir und rieche den Duft ihres Shampoos. Das ist schön."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:57
translate german jamietv2_a7276863:

    # "I watch the rest of the show, letting her sleep on my shoulder until the credits roll."
    "Ich schaue mir den Rest der Sendung an und lasse sie auf meiner Schulter schlafen, bis der Abspann läuft."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:60
translate german jamietv2_aced7ae5:

    # "The music playing during the credits wakes her and she opens her eyes and looks up at me, putting her hand on my chest."
    "Die Musik während des Abspanns weckt sie, sie öffnet die Augen, schaut zu mir hoch und legt ihre Hand auf meine Brust."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:61
translate german jamietv2_222fe902:

    # gnd "Oh man, I missed the whole thing."
    gnd "Oh Mann, ich habe das Ganze verpasst."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:62
translate german jamietv2_7289beae:

    # pc "Yeah, I'll have to fill you in later."
    pc "Ja, ich muss dir später davon erzählen."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:63
translate german jamietv2_d912edc5:

    # gnd "You could have woke me up."
    gnd "Du hättest mich wecken können."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:66
translate german jamietv2_fd8175bb:

    # gnd "I definitely did."
    gnd "Das habe ich definitiv getan."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:68
translate german jamietv2_7b910158:

    # gnd "You're so silly."
    gnd "Du bist so albern."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:69
translate german jamietv2_d404c590:

    # gnd "Do you really think I'm cute?"
    gnd "Findest du mich wirklich süß?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:70
translate german jamietv2_2951ed74:

    # pc "Definitely."
    pc "Auf jeden Fall."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:71
translate german jamietv2_d2d7ae9c:

    # gnd "I think you're cute too."
    gnd "Ich finde dich auch süß."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:72
translate german jamietv2_e8e9a7f7:

    # "Once again, her dad picks the worst moment to open the door and walk in."
    "Wieder einmal wählt ihr Vater den ungünstigsten Moment, um die Tür zu öffnen und hereinzukommen."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:73
translate german jamietv2_9da07a83:

    # "Jamie leans away from me and stands up."
    "Jamie lehnt sich von mir weg und steht auf."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:79
translate german jamietv2_d41d8cd9:

    # voice "voices/jamie_011.mp3"
    voice "voices/jamie_011.mp3"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:80
translate german jamietv2_25b98dfa:

    # gnd "Hey, Daddy."
    gnd "Hey, Daddy."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:81
translate german jamietv2_20dcad47:

    # jd "Send him home."
    jd "Schick ihn nach Hause."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:82
translate german jamietv2_f2596c67:

    # "Her dad doesn't say anything else and instead walks past us and into the kitchen."
    "Ihr Vater sagt nichts weiter, sondern geht an uns vorbei in die Küche."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:86
translate german jamietv2_84d4365c:

    # gnd "He must have had a bad day."
    gnd "Er muss einen schlechten Tag gehabt haben."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:87
translate german jamietv2_b44cf649:

    # pc "I should probably go."
    pc "Ich sollte wohl gehen."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:88
translate german jamietv2_a6870bf2:

    # gnd "Yeah, I'm sorry."
    gnd "Ja, tut mir leid."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:89
translate german jamietv2_b219d344:

    # pc "It's okay."
    pc "Ist schon okay."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:92
translate german jamietv2_36b8ae4f:

    # gnd "Thanks for coming over tonight. I had a good time."
    gnd "Danke, dass du heute Abend vorbeigekommen bist. Ich hatte eine schöne Zeit."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:93
translate german jamietv2_041dfd87:

    # pc "More like you had a good nap."
    pc "Eher hast du ein schönes Nickerchen gemacht."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:94
translate german jamietv2_b762e00f:

    # gnd "That too. Your shoulder is very comfy."
    gnd "Das auch. Deine Schulter ist sehr bequem."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:98
translate german jamietv2_4bbcc4b9:

    # gnd "I might take you up on that."
    gnd "Das nehme ich dir vielleicht mal ab."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:100
translate german jamietv2_f9097bdf:

    # gnd "I'm sure they'll show re-runs all week."
    gnd "Ich bin mir sicher, dass sie die ganze Woche Wiederholungen zeigen werden."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:101
translate german jamietv2_dfc3c586:

    # pc "Alright, well I better head home."
    pc "Na gut, dann geh ich besser nach Hause."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:103
translate german jamietv2_ecb1e778:

    # gnd "Okay, [pcname]. See you again soon."
    gnd "Okay, [pcname]. Bis bald."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:104
translate german jamietv2_209b1712:

    # pc "See ya."
    pc "Bis dann."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:105
translate german jamietv2_1557defd:

    # "With that, she goes back inside and I walk back over to my house."
    "Damit geht sie wieder rein und ich gehe zurück zu meinem Haus."

translate german strings:

    # game/Scenes/Jamie/JamieTV/jamietv2.rpy:2
