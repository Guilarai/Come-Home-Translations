# game/Scenes/Jamie/rich0.rpy:11
translate german rich0_cfa93e6c:

    # "I walk over to Jamie's house and knock on the door."
    "Ich gehe zu Jamies Haus und klopfe an die Tür."

# game/Scenes/Jamie/rich0.rpy:14
translate german rich0_3517dc2a:

    # "Jamie's dad answers the door and looks at me with a visible snarl."
    "Jamies Vater öffnet die Tür und sieht mich mit einem sichtbaren Knurren an."

# game/Scenes/Jamie/rich0.rpy:15
translate german rich0_f8843cde:

    # pc "Is Jamie home?"
    pc "Ist Jamie zu Hause?"

# game/Scenes/Jamie/rich0.rpy:16
translate german rich0_8dae1bff:

    # jd "Look [pcname], I don't know why you're back and I don't really care, you just leave my Jamie out of it."
    jd "Hör mal [pcname], ich weiß nicht, warum du wieder da bist, und es ist mir auch egal, aber lass meine Jamie einfach aus der Sache raus."

# game/Scenes/Jamie/rich0.rpy:17
translate german rich0_b43e0748:

    # jd "I don't want you talking to her. I don't want you looking at her. I don't want you even thinking about her."
    jd "Ich will nicht, dass du mit ihr redest. Ich will nicht, dass du sie ansiehst. Ich will nicht, dass du überhaupt an sie denkst."

# game/Scenes/Jamie/rich0.rpy:18
translate german rich0_fdac7df1:

    # jd "Now get the hell off my porch and don't come back over here again."
    jd "Jetzt verschwinde von meiner Veranda und komm nie wieder hierher."

# game/Scenes/Jamie/rich0.rpy:20
translate german rich0_0c9032ac:

    # "Before I can even formulate a response, he slams the door in my face."
    "Bevor ich überhaupt eine Antwort formulieren kann, knallt er mir die Tür vor der Nase zu."

# game/Scenes/Jamie/rich0.rpy:21
translate german rich0_b20e176c:

    # "I'm so confused. I have no idea what I did to him that made him hate me so much."
    "Ich bin total verwirrt. Ich habe keine Ahnung, was ich ihm angetan habe, dass er mich so sehr hasst."

# game/Scenes/Jamie/rich0.rpy:22
translate german rich0_849077d5:

    # "I'll just have to talk to Jamie sometime when he's not here."
    "Ich muss einfach irgendwann mit Jamie reden, wenn er nicht da ist."

translate german strings:

    # game/Scenes/Jamie/rich0.rpy:2
    old "After the first time you hang out with Jamie at her house,"
    new "Nachdem du das erste Mal bei Jamie zu Hause warst,"

    # game/Scenes/Jamie/rich0.rpy:3
    old "go to Jamie's house on the weekend or in the morning, when her dad is home."
    new "geh am Wochenende oder morgens zu Jamie, wenn ihr Vater zu Hause ist."

