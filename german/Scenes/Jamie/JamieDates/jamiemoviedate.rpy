    gnd "Oh okay."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:50
translate german jamiemovietheaterstartdate_984d111e:

    # gnd "Just a warning though. I might be grabbing onto you a lot."
    gnd "Nur eine Warnung: Ich werde mich vielleicht ziemlich oft an dich klammern."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:51
translate german jamiemovietheaterstartdate_e17b2a96:

    # gnd "Like a lot a lot."
    gnd "So richtig oft."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:55
translate german jamiemovietheaterstartdate_0ae36cfd:

    # gnd "Oh, I like funny movies."
    gnd "Oh, ich mag lustige Filme."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:56
translate german jamiemovietheaterstartdate_a8e40a21:

    # gnd "I hope it's good."
    gnd "Ich hoffe, er ist gut."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:58
translate german jamiemovietheaterstartdate_a311ea1d:

    # "There's a little time before the movie starts."
    "Es ist noch ein bisschen Zeit, bis der Film anfängt."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:62
translate german jamiemovietheaterstartdate_8da0039f:

    # "We just hang out and chat for a while."
    "Wir hängen einfach rum und quatschen eine Weile."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:65
translate german jamiemovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Endlich fängt der Film an und wir werden still."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:67
translate german jamiemovietheaterstartdate_b58e95c5:

    # "Jamie leans against me."
    "Jamie lehnt sich an mich."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:69
translate german jamiemovietheaterstartdate_d41d8cd9_1:

    # voice "voices/jamie_049.mp3"
    voice "voices/jamie_049.mp3"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:70
translate german jamiemovietheaterstartdate_40bb361a:

    # gnd "Want to mess around some?"
    gnd "Willst du ein bisschen rumalbern?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:88
translate german jamiemovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Sie streckt die Hand aus und hält meine Hand auf der Armlehne."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:91
translate german jamiemovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Die Trailer dauern etwa fünfzehn Minuten, dann geht der Film richtig los."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:95
translate german jamiemovietheaterstartdate_f9b1cbb0:

    # "During the movie, she keeps looking over at me."
    "Während des Films schaut sie immer wieder zu mir rüber."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:96
translate german jamiemovietheaterstartdate_d6b093f3:

    # pc "You like the movie?"
    pc "Gefällt dir der Film?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:97
translate german jamiemovietheaterstartdate_18de1f8c:

    # gnd "Yeah, it's good. I just really want to kiss you right now."
    gnd "Ja, der ist gut. Ich möchte dich jetzt einfach nur küssen."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:99
translate german jamiemovietheaterstartdate_4cdfc044:

    # "I lean in and kiss her."
    "Ich beuge mich vor und küsse sie."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:100
translate german jamiemovietheaterstartdate_22ba9c92:

    # "We hold like that for some time before she finally pulls away."
    "Wir bleiben eine Weile so stehen, bevor sie sich schließlich von mir löst."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:101
translate german jamiemovietheaterstartdate_9e25dd4e:

    # gnd "Okay, that will hold me over."
    gnd "Okay, das reicht mir fürs Erste."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:102
translate german jamiemovietheaterstartdate_3784a641:

    # gnd "Back to the movie."
    gnd "Zurück zum Film."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:105
translate german jamiemovietheaterstartdate_43311053:

    # "During the movie, she keeps looking over at me and smiling."
    "Während des Films schaut sie immer wieder zu mir herüber und lächelt."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:107
translate german jamiemovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Der Film scheint ihr ganz gut zu gefallen."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:110
translate german jamiemovietheaterstartdate_ffcd1a92:

    # "She seems to lose interest in the movie fairly quickly."
    "Sie scheint aber ziemlich schnell das Interesse am Film zu verlieren."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:111
translate german jamiemovietheaterstartdate_5973f780:

    # "I don't know. It's pretty fun to me. I guess she just doesn't like this kind of movie."
    "Ich weiß nicht. Ich finde ihn ziemlich lustig. Ich schätze, sie mag diese Art von Film einfach nicht."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:114
translate german jamiemovietheaterstartdate_4f23a069:

    # "During every scary scene that happens she tenses up and covers her mouth."
    "Bei jeder gruseligen Szene verkrampft sie sich und hält sich die Hand vor den Mund."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:115
translate german jamiemovietheaterstartdate_603a9a9b:

    # "Sometimes she even puts her hands over her eyes."
    "Manchmal legt sie sogar die Hände über die Augen."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:116
translate german jamiemovietheaterstartdate_288b2f3c:

    # "Then the music goes quiet, and I know that a jumpscare is coming."
    "Dann wird die Musik leise, und ich weiß, dass ein Jumpscare kommt."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:119
translate german jamiemovietheaterstartdate_e86e1727:

    # "She grabs my arm and tucks her head down into it."
    "Sie greift nach meinem Arm und vergräbt ihren Kopf darin."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:120
translate german jamiemovietheaterstartdate_6bdb4e54:

    # "Her fingers dig into my arm, grasping it so tight."
    "Ihre Finger graben sich in meinen Arm, sie umklammert ihn so fest."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:122
translate german jamiemovietheaterstartdate_e7200fcd:

    # "For the rest of the movie, I put my arm around her and hold her while we watch."
    "Für den Rest des Films lege ich meinen Arm um sie und halte sie fest, während wir zuschauen."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:125
translate german jamiemovietheaterstartdate_ec13a563:

    # "The movie is funny from pretty much the very beginning."
    "Der Film ist schon von Anfang an ziemlich lustig."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:126
translate german jamiemovietheaterstartdate_4caf9a58:

    # "And we laugh together all the way through it."
    "Und wir lachen die ganze Zeit über gemeinsam."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:127
translate german jamiemovietheaterstartdate_7ad920fe:

    # "Even some of the scenes that aren't as funny, she laughs at."
    "Sogar über einige der Szenen, die nicht so lustig sind, lacht sie."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:128
translate german jamiemovietheaterstartdate_0d1cfe15:

    # "And seeing her laugh just makes me laugh too."
    "Und wenn ich sie lachen sehe, muss ich einfach auch lachen."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:129
translate german jamiemovietheaterstartdate_d855e56b:

    # "Eventually the movie ends and the credits start rolling."
    "Schließlich endet der Film und der Abspann läuft."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:132
translate german jamiemovietheaterstartdate_0bcfb0ae:

    # gnd "That was a really sweet movie. Thanks for taking me."
    gnd "Das war ein wirklich süßer Film. Danke, dass du mich mitgenommen hast."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:133
translate german jamiemovietheaterstartdate_4de625af:

    # pc "Of course you're welcome."
    pc "Gern geschehen."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:136
translate german jamiemovietheaterstartdate_f9724275:

    # gnd "That movie wasn't really my thing, but I hope you liked it."
    gnd "Der Film war nicht so ganz mein Ding, aber ich hoffe, er hat dir gefallen."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:137
translate german jamiemovietheaterstartdate_bfe93711:

    # pc "Yeah I though it was pretty cool."
    pc "Ja, ich fand ihn ziemlich cool."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:138
translate german jamiemovietheaterstartdate_045099e4:

    # gnd "I guess so."
    gnd "Ich schätze schon."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:141
translate german jamiemovietheaterstartdate_6d2df7c7:

    # gnd "That movie was SO scary!"
    gnd "Der Film war SO gruselig!"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:142
translate german jamiemovietheaterstartdate_5fcae4fe:

    # gnd "Thanks for being there for me though."
    gnd "Danke, dass du für mich da warst."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:143
translate german jamiemovietheaterstartdate_737a7b53:

    # gnd "Sorry if I hurt your arm."
    gnd "Tut mir leid, wenn ich dir wehgetan habe."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:144
translate german jamiemovietheaterstartdate_00d236b5:

    # pc "It'll heal... eventually."
    pc "Das heilt schon … irgendwann."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:147
translate german jamiemovietheaterstartdate_cd12116f:

    # gnd "That movie was SO funny!"
    gnd "Der Film war SO lustig!"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:148
translate german jamiemovietheaterstartdate_e1a20436:

    # gnd "My chest hurts from laughing so much."
    gnd "Mein Bauch tut weh, so viel habe ich gelacht."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:149
translate german jamiemovietheaterstartdate_262d3cf7:

    # gnd "I loved it. Thanks for bringing me."
    gnd "Ich fand ihn toll. Danke, dass du mich mitgenommen hast."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:151
translate german jamiemovietheaterend_1a39771f:

    # gnd "Want to just sit and chat through the credits?"
    gnd "Willst du einfach noch sitzen bleiben und während des Abspanns quatschen?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:152
translate german jamiemovietheaterend_61f77a4c:

    # pc "Sure."
    pc "Klar."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:156
translate german jamiemovietheaterend_34bf5b34:

    # "When the credits end, we walk outside together and out to our cars."
    "Als der Abspann zu Ende ist, gehen wir zusammen nach draußen zu unseren Autos."

