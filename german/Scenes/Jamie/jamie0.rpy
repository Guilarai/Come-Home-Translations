    # voice "voices/jamie_005.mp3"
    voice "voices/jamie_005.mp3"

# game/Scenes/Jamie/jamie0.rpy:24
translate german jamie0_5c68d96a:

    # gnd "I'm just watching TV. Want to come inside and hang out?"
    gnd "Ich schaue gerade fern. Willst du reinkommen und ein bisschen abhängen?"

# game/Scenes/Jamie/jamie0.rpy:27
translate german jamie0_61f77a4c:

    # pc "Sure."
    pc "Klar."

# game/Scenes/Jamie/jamie0.rpy:30
translate german jamie0_8530d6f7:

    # pc "Not right now."
    pc "Nicht gerade jetzt."

# game/Scenes/Jamie/jamie0.rpy:35
translate german jamie0_d41d8cd9_2:

    # voice "voices/jamie_009b.mp3"
    voice "voices/jamie_009b.mp3"

# game/Scenes/Jamie/jamie0.rpy:36
translate german jamie0_7761ed77:

    # gnd "I'm sorry, I'm not really feeling up to going anywhere tonight."
    gnd "Tut mir leid, ich habe heute Abend nicht wirklich Lust, irgendwohin zu gehen."

# game/Scenes/Jamie/jamie0.rpy:37
translate german jamie0_e3b9539d:

    # gnd "I'm in the middle of a TV show and already dressed for bed."
    gnd "Ich bin gerade mitten in einer Fernsehsendung und habe mich schon zum Schlafen angezogen."

# game/Scenes/Jamie/jamie0.rpy:39
translate german jamie0_9c09b9dd:

    # gnd "Do you want to come inside and chat a bit though?"
    gnd "Willst du trotzdem reinkommen und ein bisschen quatschen?"

# game/Scenes/Jamie/jamie0.rpy:47
translate german jamie0_4f724fa8:

    # gnd "What?"
    gnd "Was?"

# game/Scenes/Jamie/jamie0.rpy:48
translate german jamie0_209b1712:

    # pc "See ya."
    pc "Bis dann."

# game/Scenes/Jamie/jamie0.rpy:49
translate german jamie0_2c2201d1:

    # gnd "Uh okay, see you later then."
    gnd "Äh, okay, dann bis später."

# game/Scenes/Jamie/jamie0.rpy:51
translate german jamie0_74706d57:

    # "She looks disappointed as she shuts the door and I walk back over to my house."
    "Sie sieht enttäuscht aus, als sie die Tür schließt, und ich gehe zurück zu meinem Haus."

# game/Scenes/Jamie/jamie0.rpy:56
translate german leavejamie_fc2cf32e:

    # gnd "Okay, maybe we can do something some other time?"
    gnd "Okay, vielleicht können wir ein anderes Mal etwas unternehmen?"

# game/Scenes/Jamie/jamie0.rpy:57
translate german leavejamie_61f77a4c:

    # pc "Sure."
    pc "Klar."

# game/Scenes/Jamie/jamie0.rpy:58
translate german leavejamie_60ba3b2f:

    # gnd "Well, I'll see you later then."
    gnd "Na dann, bis später."

# game/Scenes/Jamie/jamie0.rpy:59
translate german leavejamie_209b1712:

    # pc "See ya."
    pc "Bis dann."

# game/Scenes/Jamie/jamie0.rpy:60
translate german leavejamie_74706d57:

    # "She looks disappointed as she shuts the door and I walk back over to my house."
    "Sie sieht enttäuscht aus, als sie die Tür schließt und ich zurück zu meinem Haus gehe."

# game/Scenes/Jamie/jamie0.rpy:68
translate german tvchatwithjamie_b827e096:

    # "She leads me to the living room, where the TV is paused on a show that I don't recognize."
    "Sie führt mich ins Wohnzimmer, wo der Fernseher bei einer Sendung pausiert ist, die ich nicht kenne."

# game/Scenes/Jamie/jamie0.rpy:69
translate german tvchatwithjamie_1410557b:

    # gnd "I was just trying to finish up this series that I've been watching before school starts up again."
    gnd "Ich wollte nur diese Serie zu Ende schauen, die ich mir angesehen habe, bevor die Schule wieder anfängt."

# game/Scenes/Jamie/jamie0.rpy:70
translate german tvchatwithjamie_442eef5c:

    # pc "Cool. I barely watch any TV anymore."
    pc "Cool. Ich schaue kaum noch fern."

# game/Scenes/Jamie/jamie0.rpy:71
translate german tvchatwithjamie_e0203869:

    # gnd "Really? I love TV. I probably watch too much."
    gnd "Wirklich? Ich liebe Fernsehen. Ich schaue wahrscheinlich zu viel."

# game/Scenes/Jamie/jamie0.rpy:73
translate german tvchatwithjamie_5407ea16:

    # "We sit there for a few moments in an awkward silence. There are a couple times when Jamie seems like she wants to say something, but doesn't."
    "Wir sitzen dort einen Moment lang in einer unangenehmen Stille. Ein paar Mal sieht es so aus, als wolle Jamie etwas sagen, tut es aber nicht."

# game/Scenes/Jamie/jamie0.rpy:74
translate german tvchatwithjamie_58b01cd5:

    # "It feels very strange, like she is uncomfortable with me for some reason. Like there is something between us."
    "Es fühlt sich sehr seltsam an, als fühle sie sich aus irgendeinem Grund in meiner Gegenwart unwohl. Als stünde etwas zwischen uns."

# game/Scenes/Jamie/jamie0.rpy:75
translate german tvchatwithjamie_396a0d53:

    # "I have to break this silence with literally any conversation."
    "Ich muss diese Stille einfach mit irgendeinem Gespräch brechen."

# game/Scenes/Jamie/jamie0.rpy:76
translate german tvchatwithjamie_1171aaad:

    # pc "Oh, I have a cell phone now."
    pc "Oh, ich habe jetzt ein Handy."

# game/Scenes/Jamie/jamie0.rpy:78
translate german tvchatwithjamie_5c1dfc7a:

    # gnd "Awesome, what's your number?"
    gnd "Super, wie lautet deine Nummer?"

# game/Scenes/Jamie/jamie0.rpy:79
translate german tvchatwithjamie_53b692f6:

    # "I tell her my new phone number and she puts it into her phone."
    "Ich nenne ihr meine neue Telefonnummer und sie speichert sie in ihrem Handy."

# game/Scenes/Jamie/jamie0.rpy:81
translate german tvchatwithjamie_b9feb81a:

    # "Then she turns her phone around and holds it up to take a picture of herself."
    "Dann dreht sie ihr Handy um und hält es hoch, um ein Selfie zu machen."

# game/Scenes/Jamie/jamie0.rpy:83
translate german tvchatwithjamie_5ad0b0e8:

    # gnd "I sent you a text message, along with a picture of me so you can add me into your contacts, and we can chat whenever."
    gnd "Ich habe dir eine SMS geschickt, zusammen mit einem Foto von mir, damit du mich in deine Kontakte aufnehmen kannst und wir uns jederzeit unterhalten können."

# game/Scenes/Jamie/jamie0.rpy:88
translate german tvchatwithjamie_ea0a9e4e:

    # pc "I got it. I'll just add you to my contacts real quick."
    pc "Verstanden. Ich füge dich gleich schnell zu meinen Kontakten hinzu."

# game/Scenes/Jamie/jamie0.rpy:89
translate german tvchatwithjamie_d7eecc80:

    # pc "And done."
    pc "Und fertig."

# game/Scenes/Jamie/jamie0.rpy:90
translate german tvchatwithjamie_7a48c010:

    # gnd "Awesome."
    gnd "Super."

# game/Scenes/Jamie/jamie0.rpy:93
translate german tvchatwithjamie_a06bb2fa:

    # pc "Great. I'll be sure to add you as soon as I get back home and get the phone set up."
    pc "Toll. Ich füge dich auf jeden Fall hinzu, sobald ich wieder zu Hause bin und das Handy eingerichtet habe."

# game/Scenes/Jamie/jamie0.rpy:95
translate german tvchatwithjamie_570f0e90:

    # "She sits on the couch next to me, leaning back against the arm rest to face me, her bare legs folded underneath her."
    "Sie setzt sich neben mich auf die Couch, lehnt sich gegen die Armlehne, um mir gegenüberzusitzen, und zieht ihre nackten Beine unter sich."

# game/Scenes/Jamie/jamie0.rpy:96
translate german tvchatwithjamie_06525d7f:

    # gnd "Do you want to watch my TV show with me?"
    gnd "Willst du meine Serie mit mir gucken?"

# game/Scenes/Jamie/jamie0.rpy:97
translate german tvchatwithjamie_61f77a4c:

    # pc "Sure."
    pc "Klar."

# game/Scenes/Jamie/jamie0.rpy:98
translate german tvchatwithjamie_49f2ae65:

    # gnd "It's called The Nieces of Callahan. Have you ever watched any of it?"
    gnd "Sie heißt „The Nieces of Callahan“. Hast du schon mal was davon gesehen?"

# game/Scenes/Jamie/jamie0.rpy:99
translate german tvchatwithjamie_c7fa5d68:

    # pc "Nope."
    pc "Nein."

# game/Scenes/Jamie/jamie0.rpy:100
translate german tvchatwithjamie_f8a2b09a:

    # gnd "Well I'm sure you'll be completely lost, but I'll try to catch you up."
    gnd "Na ja, du wirst sicher überhaupt nichts verstehen, aber ich versuche, dich auf den neuesten Stand zu bringen."

# game/Scenes/Jamie/jamie0.rpy:102
translate german tvchatwithjamie_fb6f3632:

    # "She plays the show, but talks pretty much the whole time through it, explaining which character was which, who was sleeping with who, and which characters she liked and hated."
    "Sie schaltet die Serie ein, redet aber fast die ganze Zeit dazu und erklärt, welche Figur welche ist, wer mit wem schläft und welche Figuren sie mag und welche sie hasst."

# game/Scenes/Jamie/jamie0.rpy:103
translate german tvchatwithjamie_8a51ccf8:

    # "The show doesn't interest me too much, but as we sit together, she moves closer and closer, until our sides are touching."
    "Die Serie interessiert mich nicht sonderlich, aber während wir so zusammensitzen, rückt sie immer näher, bis sich unsere Seiten berühren."

# game/Scenes/Jamie/jamie0.rpy:104
translate german tvchatwithjamie_df180490:

    # "I think about putting an arm around her shoulder, but I'm not sure what she would think about it."
    "Ich überlege, einen Arm um ihre Schulter zu legen, bin mir aber nicht sicher, was sie davon halten würde."

# game/Scenes/Jamie/jamie0.rpy:105
translate german tvchatwithjamie_02a91ff8:

    # "Still, being there next to her is nice."
    "Trotzdem ist es schön, so neben ihr zu sitzen."

# game/Scenes/Jamie/jamie0.rpy:106
translate german tvchatwithjamie_7c085331:

    # "Finally, the show ends."
    "Endlich ist die Folge zu Ende."

# game/Scenes/Jamie/jamie0.rpy:108
translate german tvchatwithjamie_616bf526:

    # gnd "Did you like it?"
    gnd "Hat es dir gefallen?"

# game/Scenes/Jamie/jamie0.rpy:109
translate german tvchatwithjamie_28b82c1c:

    # pc "Honestly, I couldn't really follow it, but what I saw was okay."
    pc "Ehrlich gesagt konnte ich nicht wirklich folgen, aber was ich gesehen habe, war okay."

# game/Scenes/Jamie/jamie0.rpy:110
translate german tvchatwithjamie_82d9fc6f:

    # gnd "Yeah, you kind of have to watch it from the beginning."
    gnd "Ja, man muss es sich irgendwie von Anfang an ansehen."

# game/Scenes/Jamie/jamie0.rpy:111
translate german tvchatwithjamie_95fb6df8:

    # gnd "Thanks for sitting through it with me anyways. That was nice."
    gnd "Danke, dass du es trotzdem mit mir durchgesessen hast. Das war nett."

# game/Scenes/Jamie/jamie0.rpy:112
translate german tvchatwithjamie_4eb9bd3a:

    # pc "Yeah it was. I enjoyed it."
    pc "Ja, das war es. Es hat mir Spaß gemacht."

# game/Scenes/Jamie/jamie0.rpy:115
translate german tvchatwithjamie_0bde0b2d:

    # gnd "I'm so glad you're back in town. I know we didn't hang out much before you left, but I've always liked you and thought about you."
    gnd "Ich bin so froh, dass du wieder in der Stadt bist. Ich weiß, wir haben vor deiner Abreise nicht viel zusammen unternommen, aber ich mochte dich schon immer und habe an dich gedacht."

# game/Scenes/Jamie/jamie0.rpy:116
translate german tvchatwithjamie_48b6a79b:

    # pc "Yeah, we had some good times when we were younger."
    pc "Ja, wir hatten eine schöne Zeit, als wir jünger waren."

# game/Scenes/Jamie/jamie0.rpy:117
translate german tvchatwithjamie_234edbbb:

    # gnd "Yeah we did. I wish we would have stayed friends through high school. I made a lot of bad decisions then."
    gnd "Ja, das hatten wir. Ich wünschte, wir wären während der Highschool Freunde geblieben. Ich habe damals viele schlechte Entscheidungen getroffen."

# game/Scenes/Jamie/jamie0.rpy:118
translate german tvchatwithjamie_ce0b88b7:

    # pc "I think we all did."
    pc "Ich glaube, das haben wir alle."

# game/Scenes/Jamie/jamie0.rpy:119
translate german tvchatwithjamie_ec3ba06e:

    # gnd "Ain't that the truth."
    gnd "Das ist wahr."

# game/Scenes/Jamie/jamie0.rpy:121
translate german tvchatwithjamie_68579f4f:

    # "She smiles at me, and we stand awkwardly for a few moments."
    "Sie lächelt mich an, und wir stehen ein paar Momente lang etwas unbeholfen da."

# game/Scenes/Jamie/jamie0.rpy:122
translate german tvchatwithjamie_5a0cac5d:

    # pc "Anyways, I better get home."
    pc "Jedenfalls sollte ich besser nach Hause gehen."

# game/Scenes/Jamie/jamie0.rpy:124
translate german tvchatwithjamie_792d2ec7:

    # gnd "Okay, well thanks for coming to see me. Stop by anytime or send me a text if you want to chat."
    gnd "Okay, danke, dass du mich besucht hast. Komm jederzeit vorbei oder schreib mir eine SMS, wenn du reden möchtest."

# game/Scenes/Jamie/jamie0.rpy:126
translate german tvchatwithjamie_d41d8cd9:

    # voice "voices/jamie_007.mp3"
    voice "voices/jamie_007.mp3"

# game/Scenes/Jamie/jamie0.rpy:127
translate german tvchatwithjamie_598f8960:

    # gnd "See you later."
    gnd "Bis später."

# game/Scenes/Jamie/jamie0.rpy:129
translate german tvchatwithjamie_3608be46:

    # "She smiles and waves as I walk out the door, shutting it behind me, and walk over to my house."
    "Sie lächelt und winkt, als ich zur Tür hinausgehe, sie hinter mir schließe und zu meinem Haus hinübergehe."

