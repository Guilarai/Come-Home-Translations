# game/Scenes/Jamie/jamie8.rpy:13
translate german jamie8_98ca1a51:

    # "My phone buzzes in my pocket."
    "Mein Handy vibriert in meiner Tasche."

# game/Scenes/Jamie/jamie8.rpy:15
translate german jamie8_7a608d10:

    # "It's Jamie. I lie on my bed and answer the phone."
    "Es ist Jamie. Ich liege auf meinem Bett und nehme den Anruf entgegen."

# game/Scenes/Jamie/jamie8.rpy:19
translate german jamie8_80c674d7:

    # pc "Hey, Jamie."
    pc "Hey, Jamie."

# game/Scenes/Jamie/jamie8.rpy:20
translate german jamie8_3d698c03:

    # gnd "Hey. You busy?"
    gnd "Hey. Bist du beschäftigt?"

# game/Scenes/Jamie/jamie8.rpy:21
translate german jamie8_4474e21b:

    # pc "Nah. What's up?"
    pc "Nee. Was gibt’s?"

# game/Scenes/Jamie/jamie8.rpy:22
translate german jamie8_34eb8872:

    # gnd "Nothing really. Just wanted to talk to you. Miss you."
    gnd "Eigentlich nichts. Wollte nur mit dir reden. Ich vermisse dich."

# game/Scenes/Jamie/jamie8.rpy:23
translate german jamie8_71edcec9:

    # pc "Well.. you could come over?"
    pc "Na ja… du könntest doch vorbeikommen?"

# game/Scenes/Jamie/jamie8.rpy:25
translate german jamie8_a38e761a:

    # gnd "You know I can't really do that. My dad would be so mad."
    gnd "Du weißt doch, dass ich das nicht wirklich machen kann. Mein Vater wäre total sauer."

# game/Scenes/Jamie/jamie8.rpy:26
translate german jamie8_9f0961af:

    # pc "Why? You're an adult. Why does he get a say in what you do?"
    pc "Warum? Du bist erwachsen. Warum hat er ein Mitspracherecht bei dem, was du tust?"

# game/Scenes/Jamie/jamie8.rpy:27
translate german jamie8_57cb5e24:

    # gnd "I know. I just don't want him to be mad."
    gnd "Ich weiß. Ich will nur nicht, dass er sauer wird."

# game/Scenes/Jamie/jamie8.rpy:28
translate german jamie8_0833b2b4:

    # gnd "I'll talk to him soon though, I promise."
    gnd "Ich werde aber bald mit ihm reden, das verspreche ich."

# game/Scenes/Jamie/jamie8.rpy:29
translate german jamie8_b1a2e372:

    # gnd "I know I need to. It's just hard, because I know he's not going to like what I have to say."
    gnd "Ich weiß, dass ich das muss. Es ist nur schwer, weil ich weiß, dass ihm nicht gefallen wird, was ich zu sagen habe."

# game/Scenes/Jamie/jamie8.rpy:30
translate german jamie8_6cd88cb3:

    # gnd "And he works so hard, and I love him so much. I just hate to make him upset."
    gnd "Und er arbeitet so hart, und ich liebe ihn so sehr. Ich hasse es einfach, ihn zu verärgern."

# game/Scenes/Jamie/jamie8.rpy:32
translate german jamie8_dbc86daf:

    # gnd "But you mean so much to me. I don't want to have to keep sneaking around, keeping us a secret."
    gnd "Aber du bedeutest mir so viel. Ich will nicht mehr heimlich herumschleichen und unsere Beziehung geheim halten."

# game/Scenes/Jamie/jamie8.rpy:33
translate german jamie8_aa61dfea:

    # gnd "I just need to build up the courage to do it."
    gnd "Ich muss nur den Mut aufbringen, es zu tun."

# game/Scenes/Jamie/jamie8.rpy:37
translate german jamie8_07bcbb36:

    # gnd "Thank you. I'm glad. You've been very patient with me."
    gnd "Danke. Ich bin froh. Du warst sehr geduldig mit mir."

# game/Scenes/Jamie/jamie8.rpy:39
translate german jamie8_a5d0737c:

    # gnd "I'll make it worth it for you, I promise."
    gnd "Ich werde es dir wert sein lassen, das verspreche ich."

# game/Scenes/Jamie/jamie8.rpy:40
translate german jamie8_5de186d8:

    # pc "It's already worth it, Jamie."
    pc "Es ist es schon wert, Jamie."

# game/Scenes/Jamie/jamie8.rpy:43
translate german jamie8_911c62b3:

    # gnd "You're right. I'm sorry."
    gnd "Du hast recht. Es tut mir leid."

# game/Scenes/Jamie/jamie8.rpy:44
translate german jamie8_d5112d06:

    # gnd "You shouldn't have to deal with all of this drama. I know you're dealing with your own things, with your dad missing and all."
    gnd "Du solltest dich nicht mit all diesem Drama herumschlagen müssen. Ich weiß, dass du mit deinen eigenen Problemen zu kämpfen hast, mit dem Verschwinden deines Vaters und allem."

# game/Scenes/Jamie/jamie8.rpy:45
translate german jamie8_5a747778:

    # gnd "I should be there for you more."
    gnd "Ich sollte mehr für dich da sein."

# game/Scenes/Jamie/jamie8.rpy:47
translate german jamie8_9d979554:

    # gnd "And I will be. I promise. I'll tell him soon."
    gnd "Und das werde ich auch. Ich verspreche es. Ich werde es ihm bald sagen."

# game/Scenes/Jamie/jamie8.rpy:49
translate german jamie8_d41d8cd9:

    # voice "voices/jamie_022.mp3"        
    voice "voices/jamie_022.mp3"        

# game/Scenes/Jamie/jamie8.rpy:50
translate german jamie8_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Ich liebe dich, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:56
translate german jamie8_b629d4db:

    # gnd "That feels good to say... and to hear."
    gnd "Das fühlt sich gut an, das zu sagen … und zu hören."

# game/Scenes/Jamie/jamie8.rpy:58
translate german jamie8_4d7bfc98:

    # gnd "I really mean it too."
    gnd "Ich meine es auch wirklich so."

# game/Scenes/Jamie/jamie8.rpy:60
translate german jamie8_d41d8cd9_1:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:61
translate german jamie8_8cee1605:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart is growing bigger and bigger until it's close to bursting."
    gnd "Seit du zurückgekommen bist, spüre ich, wie es in mir wächst, als würde mein Herz immer größer werden, bis es fast zu platzen droht."

# game/Scenes/Jamie/jamie8.rpy:63
translate german jamie8_d41d8cd9_2:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:64
translate german jamie8_55ac6cf8:

    # gnd "I smile every time I think about you, and I find myself thinking about you all the time."
    gnd "Ich lächle jedes Mal, wenn ich an dich denke, und ich merke, dass ich ständig an dich denke."

# game/Scenes/Jamie/jamie8.rpy:67
translate german jamie8_d41d8cd9_3:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:68
translate german jamie8_a90d9888:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Ich bin total in dich verliebt, [pcname]. Ich wollte nur, dass du das weißt."

# game/Scenes/Jamie/jamie8.rpy:69
translate german jamie8_9fc0bac9:

    # pc "I feel the same way, Jamie. You're amazing."
    pc "Mir geht es genauso, Jamie. Du bist unglaublich."

# game/Scenes/Jamie/jamie8.rpy:71
translate german jamie8_ff198159:

    # gnd "I'm so happy."
    gnd "Ich bin so glücklich."

# game/Scenes/Jamie/jamie8.rpy:72
translate german jamie8_69aafc54:

    # "We talk a little longer about other less important things, until we're both practically falling asleep on the phone."
    "Wir reden noch ein bisschen länger über andere, weniger wichtige Dinge, bis wir beide am Telefon fast einschlafen."

# game/Scenes/Jamie/jamie8.rpy:74
translate german jamie8_fcdf2655:

    # gnd "I better get some sleep."
    gnd "Ich sollte besser schlafen gehen."

# game/Scenes/Jamie/jamie8.rpy:75
translate german jamie8_fdc5f0f0:

    # pc "Yeah, me too."
    pc "Ja, ich auch."

# game/Scenes/Jamie/jamie8.rpy:77
translate german jamie8_d41d8cd9_4:

    # voice "voices/jamie_010.mp3"
    voice "voices/jamie_010.mp3"

