translate german jamie8_63e5a3ef:

    # gnd "Good night, [pcname]. Love you."
    gnd "Gute Nacht, [pcname]. Ich liebe dich."

# game/Scenes/Jamie/jamie8.rpy:79
translate german jamie8_727173cd:

    # pc "Love you too, Jamie. Good night."
    pc "Ich liebe dich auch, Jamie. Gute Nacht."

# game/Scenes/Jamie/jamie8.rpy:82
translate german jamie8_a25f5d31:

    # gnd "I mean it."
    gnd "Ich meine es ernst."

