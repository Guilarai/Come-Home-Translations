    # pc "Are you going to stay the night?"
    pc "Bleibst du über Nacht?"

# game/Scenes/Jamie/jamie13.rpy:190
translate german jamie13_d41d8cd9_7:

    # voice "voices/jamie_027.mp3"
    voice "voices/jamie_027.mp3"

# game/Scenes/Jamie/jamie13.rpy:191
translate german jamie13_30ec8f73:

    # gnd "I probably shouldn't. But I don't feel like moving right now."
    gnd "Ich sollte es wahrscheinlich nicht. Aber ich habe gerade keine Lust, mich zu bewegen."

# game/Scenes/Jamie/jamie13.rpy:192
translate german jamie13_f1a6c37e:

    # pc "You should stay."
    pc "Du solltest bleiben."

# game/Scenes/Jamie/jamie13.rpy:193
translate german jamie13_6d9c381a:

    # gnd "Okay. I think I will."
    gnd "Okay. Ich glaube, das werde ich."

# game/Scenes/Jamie/jamie13.rpy:195
translate german jamie13_d41d8cd9_8:

    # voice "voices/jamie_028.mp3"
    voice "voices/jamie_028.mp3"

# game/Scenes/Jamie/jamie13.rpy:196
translate german jamie13_b095ff70:

    # gnd "Like you said. I'm an adult. I can do what I want."
    gnd "Wie du gesagt hast. Ich bin erwachsen. Ich kann tun, was ich will."

# game/Scenes/Jamie/jamie13.rpy:199
translate german jamie13_94cd612d:

    # "She moves to look at me, her eyes locked onto mine."
    "Sie dreht sich zu mir um, ihre Augen fest auf meine gerichtet."

# game/Scenes/Jamie/jamie13.rpy:201
translate german jamie13_d41d8cd9_9:

    # voice "voices/jamie_022.mp3"
    voice "voices/jamie_022.mp3"

# game/Scenes/Jamie/jamie13.rpy:202
translate german jamie13_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Ich liebe dich, [pcname]."

# game/Scenes/Jamie/jamie13.rpy:203
translate german jamie13_5e3e613a:

    # pc "I love you too, Jamie."
    pc "Ich liebe dich auch, Jamie."

# game/Scenes/Jamie/jamie13.rpy:204
translate german jamie13_59e15393:

    # "We lie there like that, sweat cooling on our skin, until I hear her soft snoring."
    "Wir liegen so da, der Schweiß kühlt auf unserer Haut, bis ich ihr leises Schnarchen höre."

# game/Scenes/Jamie/jamie13.rpy:207
translate german jamie13_ae4b475d:

    # "Then I fall asleep shortly after."
    "Dann schlafe ich kurz darauf ein."

# game/Scenes/Jamie/jamie13.rpy:215
translate german jamie13_f6d0406e:

    # "In the morning, I wake up to her face, sleeping next to me."
    "Am Morgen wache ich auf und sehe ihr Gesicht, sie schläft neben mir."

# game/Scenes/Jamie/jamie13.rpy:216
translate german jamie13_fc00fd18:

    # "I softly caress her cheek to wake her up."
    "Ich streichle sanft ihre Wange, um sie zu wecken."

# game/Scenes/Jamie/jamie13.rpy:219
translate german jamie13_a336655c:

    # pc "Hey beautiful."
    pc "Hey, meine Schöne."

# game/Scenes/Jamie/jamie13.rpy:221
translate german jamie13_d41d8cd9_10:

    # voice "voices/jamie_029a.mp3"
    voice "voices/jamie_029a.mp3"

# game/Scenes/Jamie/jamie13.rpy:222
translate german jamie13_c59c4cdd:

    # gnd "Oh geez, what time is it?"
    gnd "Oh Mann, wie spät ist es?"

# game/Scenes/Jamie/jamie13.rpy:224
translate german jamie13_d41d8cd9_11:

    # voice "voices/jamie_029b.mp3"
    voice "voices/jamie_029b.mp3"

# game/Scenes/Jamie/jamie13.rpy:225
translate german jamie13_9a2ed43d:

    # gnd "I have to get home before Dad gets upset."
    gnd "Ich muss nach Hause, bevor Dad sich aufregt."

# game/Scenes/Jamie/jamie13.rpy:227
translate german jamie13_d41d8cd9_12:

    # voice "voices/jamie_029c.mp3"
    voice "voices/jamie_029c.mp3"

# game/Scenes/Jamie/jamie13.rpy:228
translate german jamie13_c042afc8:

    # gnd "I need a shower too. I smell like sex so bad."
    gnd "Ich muss auch duschen. Ich rieche so stark nach Sex."

# game/Scenes/Jamie/jamie13.rpy:231
translate german jamie13_dffd2cad:

    # "She jumps up out of bed, seemingly completely awake now, and starts getting dressed."
    "Sie springt aus dem Bett, jetzt scheinbar ganz wach, und fängt an, sich anzuziehen."

# game/Scenes/Jamie/jamie13.rpy:232
translate german jamie13_8d3da257:

    # gnd "Seriously though, [pcname], last night was amazing."
    gnd "Im Ernst, [pcname], letzte Nacht war unglaublich."

# game/Scenes/Jamie/jamie13.rpy:233
translate german jamie13_ec35244f:

    # gnd "I wish I could sleep with you every night."
    gnd "Ich wünschte, ich könnte jede Nacht mit dir schlafen."

# game/Scenes/Jamie/jamie13.rpy:234
translate german jamie13_ef7afd6d:

    # pc "You could if you wanted."
    pc "Das könntest du, wenn du wolltest."

# game/Scenes/Jamie/jamie13.rpy:235
translate german jamie13_bbd8e0f5:

    # gnd "Maybe one day."
    gnd "Vielleicht eines Tages."

# game/Scenes/Jamie/jamie13.rpy:238
translate german jamie13_b00d8df6:

    # "I put on my pajamas and walk her down the stairs."
    "Ich ziehe meinen Pyjama an und begleite sie die Treppe hinunter."

# game/Scenes/Jamie/jamie13.rpy:239
translate german jamie13_9b857853:

    # "The morning light shining on her from the front windows of the house makes her seem like she's glowing."
    "Das Morgenlicht, das durch die vorderen Fenster des Hauses auf sie fällt, lässt sie fast strahlen."

# game/Scenes/Jamie/jamie13.rpy:242
translate german jamie13_5eb86a54:

    # "We stop at the door, kissing goodbye before we open it."
    "Wir bleiben an der Tür stehen und küssen uns zum Abschied, bevor wir sie öffnen."

# game/Scenes/Jamie/jamie13.rpy:243
translate german jamie13_9cdd394e:

    # gnd "Bye, [pcname]. We'll talk later."
    gnd "Tschüss, [pcname]. Wir reden später."

# game/Scenes/Jamie/jamie13.rpy:244
translate german jamie13_92be29ee:

    # gnd "And hopefully do this again very soon."
    gnd "Und hoffentlich machen wir das sehr bald wieder."

# game/Scenes/Jamie/jamie13.rpy:245
translate german jamie13_72475059:

    # pc "I can't wait."
    pc "Ich kann es kaum erwarten."

# game/Scenes/Jamie/jamie13.rpy:249
translate german jamie13_7660a175:

    # "Then she turns and opens the door and her father is standing on my front porch."
    "Dann dreht sie sich um, öffnet die Tür und ihr Vater steht auf meiner Veranda."

# game/Scenes/Jamie/jamie13.rpy:251
translate german jamie13_d41d8cd9_13:

    # voice "voices/jamie_030.mp3"
    voice "voices/jamie_030.mp3"

# game/Scenes/Jamie/jamie13.rpy:252
translate german jamie13_a60f4c8e:

    # gnd "Oh! Daddy, I just..."
    gnd "Oh! Daddy, ich wollte nur..."

# game/Scenes/Jamie/jamie13.rpy:253
translate german jamie13_d6386a6a:

    # "Jamie's Dad" "Let's go."
    "Jamie's Dad" "Lass uns gehen."

# game/Scenes/Jamie/jamie13.rpy:254
translate german jamie13_64554391:

    # gnd "...okay."
    gnd "...okay."

# game/Scenes/Jamie/jamie13.rpy:257
translate german jamie13_c5786232:

    # "They walk away. I can't see Jamie's face, but I can tell she's crying."
    "Sie gehen weg. Ich kann Jamies Gesicht nicht sehen, aber ich merke, dass sie weint."

# game/Scenes/Jamie/jamie13.rpy:258
translate german jamie13_d519e179:

    # "I don't know what to do, so I just let them go."
    "Ich weiß nicht, was ich tun soll, also lasse ich sie einfach gehen."

# game/Scenes/Jamie/jamie13.rpy:259
translate german jamie13_0833f49b:

    # "He needs to get over this shit. I know I hurt her in the past, but it was so long ago. And she's an adult now. I just wish she would stand up to him."
    "Er muss endlich über diesen Mist hinwegkommen. Ich weiß, dass ich ihr in der Vergangenheit wehgetan habe, aber das ist schon so lange her. Und sie ist jetzt erwachsen. Ich wünschte nur, sie würde sich ihm gegenüber behaupten."

# game/Scenes/Jamie/jamie13.rpy:260
translate german jamie13_fe41f349:

    # "Hopefully, she will talk to him and get this all sorted out."
    "Hoffentlich redet sie mit ihm und klärt das alles."

# game/Scenes/Jamie/jamie13.rpy:263
translate german jamie13_1dc304ca:

    # "I shut the door and go back inside and get ready for my day."
    "Ich schließe die Tür, gehe wieder rein und mache mich für den Tag fertig."

# game/Scenes/Jamie/jamie13.rpy:264
translate german jamie13_6888669d:

    # "I try to focus on the amazing night and not the bad morning."
    "Ich versuche, mich auf die wundervolle Nacht zu konzentrieren und nicht auf den schlechten Morgen."

# game/Scenes/Jamie/jamie13.rpy:266
translate german jamie13_ab079190:

    # "Later that night..."
    "Später am Abend..."

# game/Scenes/Jamie/jamie13.rpy:278
translate german jamie13b_e331f532:

    # "My phone starts buzzing in my pocket. Jamie's calling. I hope she worked out stuff with her dad."
    "Mein Handy fängt an, in meiner Tasche zu vibrieren. Jamie ruft an. Ich hoffe, sie hat die Dinge mit ihrem Vater geklärt."

# game/Scenes/Jamie/jamie13.rpy:282
translate german jamie13b_db1adf95:

    # pc "Hey, baby."
    pc "Hey, Baby."

# game/Scenes/Jamie/jamie13.rpy:284
translate german jamie13b_d41d8cd9:

    # voice "voices/jamie_084.mp3"
    voice "voices/jamie_084.mp3"

# game/Scenes/Jamie/jamie13.rpy:285
translate german jamie13b_db3d91ac:

    # gnd "I need to tell you something, [pcname]."
    gnd "Ich muss dir etwas sagen, [pcname]."

# game/Scenes/Jamie/jamie13.rpy:287
translate german jamie13b_d41d8cd9_1:

    # voice "voices/jamie_085.mp3"
    voice "voices/jamie_085.mp3"

# game/Scenes/Jamie/jamie13.rpy:288
translate german jamie13b_ec3e201c:

    # gnd "I'm sorry, but our relationship is not going to work out."
    gnd "Es tut mir leid, aber unsere Beziehung wird nicht funktionieren."

# game/Scenes/Jamie/jamie13.rpy:289
translate german jamie13b_a2a6fb65:

    # pc "What do you mean?"
    pc "Was meinst du damit?"

# game/Scenes/Jamie/jamie13.rpy:291
translate german jamie13b_d41d8cd9_2:

    # voice "voices/jamie_086.mp3"
    voice "voices/jamie_086.mp3"

# game/Scenes/Jamie/jamie13.rpy:292
translate german jamie13b_cab545aa:

    # gnd "I have to choose between you and my dad. I'm choosing my dad."
    gnd "Ich muss mich zwischen dir und meinem Vater entscheiden. Ich entscheide mich für meinen Vater."

# game/Scenes/Jamie/jamie13.rpy:294
translate german jamie13b_d41d8cd9_3:

    # voice "voices/jamie_087.mp3"
    voice "voices/jamie_087.mp3"

# game/Scenes/Jamie/jamie13.rpy:295
translate german jamie13b_9a5ae475:

    # gnd "I'm sorry. It's over."
    gnd "Es tut mir leid. Es ist vorbei."

# game/Scenes/Jamie/jamie13.rpy:298
translate german jamie13b_d41d8cd9_4:

    # voice "voices/jamie_088.mp3"
    voice "voices/jamie_088.mp3"

# game/Scenes/Jamie/jamie13.rpy:299
translate german jamie13b_77f7fa61:

    # gnd "Good luck with everything. Please don't try to contact me anymore."
    gnd "Viel Glück bei allem. Bitte versuch nicht mehr, mich zu kontaktieren."

# game/Scenes/Jamie/jamie13.rpy:300
translate german jamie13b_33949145:

    # pc "What? Wait..."
    pc "Was? Warte..."

# game/Scenes/Jamie/jamie13.rpy:303
translate german jamie13b_bcbbe2f1:

    # "She hung up."
    "Sie hat aufgelegt."

# game/Scenes/Jamie/jamie13.rpy:304
translate german jamie13b_439a8efe:

    # "What the fuck? What am I supposed to do now?"
    "Was zum Teufel? Was soll ich jetzt machen?"

# game/Scenes/Jamie/jamie13.rpy:305
translate german jamie13b_a1814c52:

    # "I guess if she doesn't want to be with me, and doesn't want me to talk to her, I have to respect her wishes."
    "Ich schätze, wenn sie nicht mit mir zusammen sein will und nicht will, dass ich mit ihr rede, muss ich ihre Wünsche respektieren."

# game/Scenes/Jamie/jamie13.rpy:306
translate german jamie13b_f87ec8ec:

    # "But it's bullshit!"
    "Aber das ist doch Schwachsinn!"

# game/Scenes/Jamie/jamie13.rpy:309
translate german jamie13b_18c2def7:

    # "I feel like screaming. Like punching something."
    "Ich möchte schreien. Irgendetwas zerschlagen."

# game/Scenes/Jamie/jamie13.rpy:310
translate german jamie13b_32c163d2:

    # "But instead, I lie in bed and seethe in anger until I fall asleep."
    "Stattdessen liege ich im Bett und schäume vor Wut, bis ich einschlafe."

