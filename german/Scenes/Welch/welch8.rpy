# game/Scenes/Welch/welch8.rpy:60
translate german welch8date_02521388:

    # sst "Woo! Let's vote!"
    sst "Juhu! Los geht’s zum Wählen!"

# game/Scenes/Welch/welch8.rpy:61
translate german welch8date_0f3cf124:

    # pc "Ha! You're ready for this, huh?"
    pc "Ha! Du bist bereit dafür, was?"

# game/Scenes/Welch/welch8.rpy:62
translate german welch8date_d1363569:

    # sst "Hell yes I am! I look forward to this every year."
    sst "Und ob ich das bin! Ich freue mich jedes Jahr darauf."

# game/Scenes/Welch/welch8.rpy:63
translate german welch8date_2e3ddbf8:

