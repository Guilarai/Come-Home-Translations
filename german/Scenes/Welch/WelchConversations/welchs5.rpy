translate german welchs5_15474dcf:

    # sst "Hah, probably. That sounds like her."
    sst "Hah, wahrscheinlich. Das klingt nach ihr."

# game/Scenes/Welch/WelchConversations/welchs5.rpy:24
translate german welchs5_94c344cc:

    # sst "She's pretty protective of me. And a little jealous too."
    sst "Sie ist ziemlich beschützerisch mir gegenüber. Und auch ein bisschen eifersüchtig."

# game/Scenes/Welch/WelchConversations/welchs5.rpy:26
translate german welchs5_259e5b51:

    # sst "She's in love with me."
    sst "Sie ist in mich verliebt."

# game/Scenes/Welch/WelchConversations/welchs5.rpy:27
translate german welchs5_e89e0515:

    # pc "Oh really?"
    pc "Ach wirklich?"

# game/Scenes/Welch/WelchConversations/welchs5.rpy:28
