# game/Scenes/Welch/WelchConversations/welchq1.rpy:16
translate german welchq1_90a40ec2:

    # sst "So, I was wondering... why are you in freshman classes as a senior?"
    sst "Also, ich habe mich gefragt … warum bist du als Seniorin in Erstsemesterkursen?"

# game/Scenes/Welch/WelchConversations/welchq1.rpy:17
translate german welchq1_b0d4142b:

    # sst "Did you wait to do your basics at the end or something? I didn't think they would even let you do that."
    sst "Hast du gewartet, bis du die Grundlagen am Ende machst, oder so? Ich hätte nicht gedacht, dass sie das überhaupt zulassen würden."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:18
translate german welchq1_2c8e0198:

    # pc "Sort of. I went to school in Brazil for the last three years."
    pc "Sozusagen. Ich war die letzten drei Jahre in Brasilien zur Schule."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:20
translate german welchq1_8add5b68:

    # sst "Brazil? Wow!"
    sst "Brasilien? Wow!"

# game/Scenes/Welch/WelchConversations/welchq1.rpy:21
translate german welchq1_cfd427d3:

    # sst "I've never heard of anybody going to Brazil for college before."
    sst "Ich habe noch nie von jemandem gehört, der zum Studieren nach Brasilien gegangen ist."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:22
translate german welchq1_f1031ec0:

    # sst "Was it fun? Why didn't you finish school there?"
    sst "War es lustig? Warum hast du die Schule dort nicht zu Ende gemacht?"

# game/Scenes/Welch/WelchConversations/welchq1.rpy:24
translate german welchq1_2101f83b:

    # pc "It was okay."
    pc "Es war okay."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:25
translate german welchq1_a8c03e38:

    # pc "I mostly went to get away from my dad."
    pc "Ich bin hauptsächlich hingegangen, um meinem Vater zu entkommen."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:26
translate german welchq1_491bbf21:

    # pc "Then I came back because he went missing."
    pc "Dann bin ich zurückgekommen, weil er verschwunden ist."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:27
translate german welchq1_7d1ce916:

    # sst "Missing? Really?"
    sst "Verschwunden? Wirklich?"

# game/Scenes/Welch/WelchConversations/welchq1.rpy:28
translate german welchq1_90a4fc00:

    # sst "Whoa..."
    sst "Wow..."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:29
translate german welchq1_cd80a08e:

    # pc "Yeah, we're still looking for him."
    pc "Ja, wir suchen immer noch nach ihm."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:30
translate german welchq1_5e522282:

    # sst "Oh shit. I think I've seen posters up of him now that I think about it."
    sst "Oh Scheiße. Ich glaube, ich habe Plakate von ihm gesehen, jetzt wo ich darüber nachdenke."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:31
translate german welchq1_b92afc22:

    # sst "He went missing right before the semester started, right?"
    sst "Er ist kurz vor Semesterbeginn verschwunden, oder?"

# game/Scenes/Welch/WelchConversations/welchq1.rpy:32
translate german welchq1_c417e350:

    # pc "Yeah."
    pc "Ja."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:34
translate german welchq1_99556521:

    # sst "Fuck, I'm sorry honey. That's awful."
    sst "Verdammt, das tut mir leid, Schatz. Das ist schrecklich."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:35
translate german welchq1_795ad0a8:

    # sst "I really hope you find him."
    sst "Ich hoffe wirklich, dass ihr ihn findet."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:36
translate german welchq1_49ac58f6:

    # pc "Thanks, me too."
    pc "Danke, ich auch."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:38
translate german welchq1_d331fa89:

    # sst "If there's ever anything I can do to help, let me know, okay?"
    sst "Wenn ich irgendetwas tun kann, um zu helfen, sag mir Bescheid, okay?"

# game/Scenes/Welch/WelchConversations/welchq1.rpy:39
translate german welchq1_562f2c69:

    # pc "Thanks, Ms. Welch. I will."
    pc "Danke, Frau Welch. Das werde ich."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:40
translate german welchq1_7fdffe26:

    # sst "Nora. Please."
    sst "Nora. Bitte."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:41
translate german welchq1_37d515c7:

    # pc "Oh, right. Sorry."
    pc "Oh, stimmt. Entschuldigung."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:42
translate german welchq1_d46d6d96:

    # sst "It's okay, baby."
    sst "Ist schon okay, Schatz."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:44
translate german welchq1_9023eaec:

    # sst "I mean it though."
    sst "Ich meine es aber ernst."

# game/Scenes/Welch/WelchConversations/welchq1.rpy:45
translate german welchq1_0e77eebd:

    # sst "Anything you need, I'm there."
    sst "Was auch immer du brauchst, ich bin für dich da."

