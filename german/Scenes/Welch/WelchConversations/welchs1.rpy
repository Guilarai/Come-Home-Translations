# game/Scenes/Welch/WelchConversations/welchs1.rpy:16
translate german welchs1_a32046bb:

    # sst "Not really. I mean, I don't keep in touch with them."
    sst "Nicht wirklich. Ich meine, ich halte keinen Kontakt zu ihnen."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:17
translate german welchs1_e9cca3d8:

    # sst "They are very different from me."
    sst "Sie sind ganz anders als ich."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:18
translate german welchs1_90640fc0:

    # sst "But I do still talk to my ex-husband's family pretty often."
    sst "Aber mit der Familie meines Ex-Mannes rede ich immer noch ziemlich oft."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:19
translate german welchs1_b8887ab1:

    # pc "You were married?"
    pc "Du warst verheiratet?"

# game/Scenes/Welch/WelchConversations/welchs1.rpy:24
translate german welchmarried_c27601eb:

    # sst "Oh yeah. Right out of high school. Lasted about two years."
    sst "Oh ja. Direkt nach der Highschool. Hat etwa zwei Jahre gehalten."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:25
translate german welchmarried_d6a910a0:

    # sst "But he was controlling and emotionally abusive..."
    sst "Aber er war kontrollsüchtig und hat mich emotional missbraucht..."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:27
translate german welchmarried_6cf00ff4:

    # sst "So, I left his ass."
    sst "Also hab ich den Kerl verlassen."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:29
translate german welchmarried_5314674d:

    # sst "The whole thing made me stronger though. I don't think I'd be the same person today if I hadn't married that asshole."
    sst "Die ganze Sache hat mich aber stärker gemacht. Ich glaube nicht, dass ich heute dieselbe Person wäre, wenn ich diesen Arsch nicht geheiratet hätte."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:31
translate german welchmarried_a405651c:

    # sst "Plus, I got a pretty sweet house out of the divorce."
    sst "Außerdem hab ich durch die Scheidung ein ziemlich cooles Haus abbekommen."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:32
translate german welchmarried_7acc68d6:

    # pc "Hey, that's cool."
    pc "Hey, das ist cool."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:34
translate german welchmarried_5d0c7d8f:

    # sst "His parents and I always got along."
    sst "Seine Eltern und ich haben uns immer gut verstanden."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:35
translate german welchmarried_c3bfaae0:

    # sst "They helped me a lot when I was leaving him, and we still go out for dinner once a month or so."
    sst "Sie haben mir sehr geholfen, als ich ihn verlassen habe, und wir gehen immer noch etwa einmal im Monat zusammen essen."

# game/Scenes/Welch/WelchConversations/welchs1.rpy:37
translate german welchmarried_9b93bf6c:

    # sst "So, I guess I took his family in the divorce too! Hah!"
    sst "Also habe ich bei der Scheidung wohl auch seine Familie mitbekommen! Hah!"

# game/Scenes/Welch/WelchConversations/welchs1.rpy:38
translate german welchmarried_201d5764:

    # pc "Nice."
    pc "Schön."

