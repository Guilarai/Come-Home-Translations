# game/Scenes/Welch/WelchDates/welchdateend.rpy:12
translate german welchdateend_ddf31383:

    # sst "Well I guess this is goodbye, [pcname]. I enjoyed our completely respectable time together and look forward to seeing you in class."
    sst "Nun, ich schätze, das ist dann der Abschied, [pcname]. Ich habe unsere absolut respektable Zeit zusammen genossen und freue mich darauf, dich im Unterricht zu sehen."

