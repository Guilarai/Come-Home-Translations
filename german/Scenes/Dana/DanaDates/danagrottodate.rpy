# game/Scenes/Dana/DanaDates/danagrottodate.rpy:23
translate german danagrottostartdate_1563db25:

    # "I drive over and pick Dana up. Then we go out to The Grotto together."
    "Ich fahre hinüber und hole Dana ab. Dann gehen wir zusammen ins „The Grotto“."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:28
translate german danagrottostartdate_2095cc55:

    # cw "Wow. This place is amazing."
    cw "Wow. Dieser Ort ist unglaublich."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:29
translate german danagrottostartdate_2ba00ab3:

    # cw "I can't believe I get to go out here. It's so beautiful."
    cw "Ich kann gar nicht glauben, dass ich hierherkommen darf. Es ist so wunderschön."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:30
translate german danagrottostartdate_05526a72:

    # pc "You're beautiful, Dana. You deserve it."
    pc "Du bist wunderschön, Dana. Du hast es verdient."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:31
translate german danagrottostartdate_9c4b6956:

    # cw "Thank you, [pcname]."
    cw "Danke, [pcname]."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:32
translate german danagrottostartdate_37c9d0bf:

    # "We walk in and the host leads us to our seats."
    "Wir gehen hinein und der Gastgeber führt uns zu unseren Plätzen."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:38
translate german danagrottostartdate_80af549c:

    # cw "You can afford this? On what Mrs. Mills pays you?"
    cw "Kannst du dir das leisten? Mit dem, was Mrs. Mills dir bezahlt?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:39
translate german danagrottostartdate_0f30c499:

    # pc "Sure. I mean, not every day or anything, but occasionally. I don't have many bills."
    pc "Klar. Ich meine, nicht jeden Tag oder so, aber ab und zu. Ich habe nicht viele Rechnungen."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:40
translate german danagrottostartdate_a4bd3f4d:

    # pc "Don't worry about it though, Dana. I want you to have a great night."
    pc "Mach dir aber keine Sorgen, Dana. Ich möchte, dass du einen tollen Abend hast."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:42
translate german danagrottostartdate_617347d3:

    # cw "I already am. This is incredible."
    cw "Den habe ich schon. Das ist unglaublich."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:43
translate german danagrottostartdate_ecd9ab22:

    # "The server takes our orders and we chat for a while."
    "Der Kellner nimmt unsere Bestellung auf und wir unterhalten uns eine Weile."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:46
translate german danagrottostartdate_ac38448c:

    # "Then we eat and chat some more."
    "Dann essen wir und unterhalten uns noch ein bisschen."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:52
translate german danagrottostartdate_94d3f64e:

    # "Then we get up and dance a bit to the soft music."
    "Dann stehen wir auf und tanzen ein wenig zu der leisen Musik."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:54
translate german danagrottostartdate_d0b4cddc:

    # cw "You're so amazing. This is the best date I've ever been on."
    cw "Du bist so unglaublich. Das ist das beste Date, das ich je hatte."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:55
translate german danagrottostartdate_1ece43ad:

    # cw "I couldn't want anything more."
    cw "Ich könnte mir nichts mehr wünschen."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:56
translate german danagrottostartdate_f6634f6b:

    # pc "Anything to make you happy, Dana. That's all I want."
    pc "Alles, was dich glücklich macht, Dana. Das ist alles, was ich will."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:60
translate german danagrottostartdate_93db9284:

    # cw "You do make me happy, [pcname]."
    cw "Du machst mich wirklich glücklich, [pcname]."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:61
translate german danagrottostartdate_8b92acc5:

    # cw "I'm so very happy."
    cw "Ich bin so unglaublich glücklich."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:69
translate german danagrottostartdate_c8c4e655:

    # cw "I know a way you can make me even happier though."
    cw "Ich weiß aber, wie du mich noch glücklicher machen kannst."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:70
translate german danagrottostartdate_ae871f39:

    # pc "Oh yeah?"
    pc "Ach ja?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:71
translate german danagrottostartdate_9a5a9a70:

    # cw "Are you ready to take me home?"
    cw "Bist du bereit, mich nach Hause zu bringen?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:72
translate german danagrottostartdate_69a64407:

    # pc "Yes, I think we should."
    pc "Ja, ich finde, das sollten wir."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:76
translate german danagrottostartdate_4097bbec:

    # "Fifteen minutes later we're in her bedroom and she's naked on the bed, practically begging me to ravage her."
    "Fünfzehn Minuten später sind wir in ihrem Schlafzimmer und sie liegt nackt auf dem Bett und fleht mich geradezu an, sie zu nehmen."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:80
translate german danagrottostartdate_ff3293a2:

    # cw "Do you want to continue this back at my place?"
    cw "Willst du das bei mir zu Hause fortsetzen?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:83
translate german danagrottostartdate_92e63c5d:

    # cw "Great. Let's go. I can't wait to get my mouth on you."
    cw "Super. Los geht’s. Ich kann es kaum erwarten, dich mit meinem Mund zu verwöhnen."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:87
translate german danagrottostartdate_4097bbec_1:

    # "Fifteen minutes later we're in her bedroom and she's naked on the bed, practically begging me to ravage her."
    "Fünfzehn Minuten später sind wir in ihrem Schlafzimmer und sie liegt nackt auf dem Bett und fleht mich geradezu an, sie zu nehmen."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:91
translate german danagrottostartdate_627e2bde:

    # cw "Oh, alright."
    cw "Oh, na gut."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:92
translate german danagrottostartdate_0128787c:

    # cw "It was still an incredible date. Thank you."
    cw "Es war trotzdem ein unglaubliches Date. Danke."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:95
translate german danagrottostartdate_e8cbe586:

    # "I drive Dana home and we say our goodbyes, then she goes inside and I drive away to continue my night."
    "Ich fahre Dana nach Hause und wir verabschieden uns, dann geht sie rein und ich fahre los, um meinen Abend fortzusetzen."

