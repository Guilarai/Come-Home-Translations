# game/Scenes/Dana/DanaConversation/danas6.rpy:14
translate german danas6_99a6cbdc:

    # cw "Ugh, this question makes me kind of hate myself."
    cw "Uff, diese Frage bringt mich dazu, mich irgendwie selbst zu hassen."

# game/Scenes/Dana/DanaConversation/danas6.rpy:15
translate german danas6_5685fff8:

    # pc "Why?"
    pc "Warum?"

# game/Scenes/Dana/DanaConversation/danas6.rpy:16
translate german danas6_a787a358:

    # cw "It makes me think of all the things that I haven't done with my life."
    cw "Sie lässt mich an all die Dinge denken, die ich in meinem Leben noch nicht getan habe."

# game/Scenes/Dana/DanaConversation/danas6.rpy:18
translate german danas6_3300cea5:

    # cw "I guess I'm proud of getting my bachelor's degree."
    cw "Ich glaube, ich bin stolz darauf, meinen Bachelor-Abschluss gemacht zu haben."

# game/Scenes/Dana/DanaConversation/danas6.rpy:19
translate german danas6_e9d28f82:

    # cw "I'm the first in my family that has graduated college."
    cw "Ich bin die Erste in meiner Familie, die das College abgeschlossen hat."

# game/Scenes/Dana/DanaConversation/danas6.rpy:20
translate german danas6_17bc9925:

    # pc "That's pretty cool."
    pc "Das ist ziemlich cool."

# game/Scenes/Dana/DanaConversation/danas6.rpy:22
translate german danas6_1e29d5b6:

    # cw "Yeah, I thought so."
    cw "Ja, das dachte ich mir."

# game/Scenes/Dana/DanaConversation/danas6.rpy:24
translate german danas6_d23aaa13:

    # cw "But when you're living in a college town, it's like no big deal. Everybody has a degree."
    cw "Aber wenn man in einer Universitätsstadt lebt, ist das keine große Sache. Jeder hat einen Abschluss."

# game/Scenes/Dana/DanaConversation/danas6.rpy:25
translate german danas6_38ac0463:

    # cw "It's like being proud that I learned how to tie my shoes."
    cw "Das ist so, als wäre ich stolz darauf, dass ich gelernt habe, meine Schuhe zu binden."

# game/Scenes/Dana/DanaConversation/danas6.rpy:26
translate german danas6_37abdbfa:

    # pc "Well I think that you should be proud anyway."
    pc "Nun, ich finde, du solltest trotzdem stolz sein."

# game/Scenes/Dana/DanaConversation/danas6.rpy:27
translate german danas6_9e02f2bc:

    # pc "It's something that you set out to do, you worked really hard to make it happen, and you succeeded."
    pc "Es ist etwas, das du dir vorgenommen hast, du hast wirklich hart dafür gearbeitet, und du hast es geschafft."

# game/Scenes/Dana/DanaConversation/danas6.rpy:28
translate german danas6_4d8257d6:

    # pc "It's a big deal."
    pc "Das ist eine große Sache."

# game/Scenes/Dana/DanaConversation/danas6.rpy:30
translate german danas6_19e18fd7:

    # cw "Thanks, [pcname]. You're right."
    cw "Danke, [pcname]. Du hast recht."

# game/Scenes/Dana/DanaConversation/danas6.rpy:31
translate german danas6_c3de2ed1:

    # cw "I am proud, damn it!"
    cw "Ich bin stolz, verdammt noch mal!"

