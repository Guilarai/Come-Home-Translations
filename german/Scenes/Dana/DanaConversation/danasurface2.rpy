# game/Scenes/Dana/DanaConversation/danasurface2.rpy:13
translate german danasurface2_adb78891:

    # pc "Do you have any pets?"
    pc "Hast du Haustiere?"

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:14
translate german danasurface2_69bf2a77:

    # cw "No, no pets."
    cw "Nein, keine Haustiere."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:16
translate german danasurface2_f1e7f090:

    # cw "I wouldn't mind having a dog - a big one that I could hug and cuddle with."
    cw "Ich hätte nichts gegen einen Hund – einen großen, den ich umarmen und knuddeln könnte."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:17
translate german danasurface2_72be5411:

    # cw "I had a big fluffy Great Pyrenees growing up named Khan. He was my favorite thing."
    cw "Als ich klein war, hatte ich einen großen, flauschigen Pyrenäenberghund namens Khan. Er war mein ganzer Stolz."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:20
translate german danasurface2_0084a7fa:

    # cw "But Terry, my fiancé, is allergic to dogs. And cats. So no pets."
    cw "Aber Terry, mein Verlobter, ist allergisch gegen Hunde. Und gegen Katzen. Also keine Haustiere."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:21
translate german danasurface2_e161b952:

    # pc "Maybe one day."
    pc "Vielleicht eines Tages."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:23
translate german danasurface2_d9e8daa4:

    # cw "Maybe."
    cw "Vielleicht."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:25
translate german danasurface2_4789760b:

    # cw "Although, no, I guess not, since I'm marrying Terry and will be with him forever."
    cw "Obwohl, nein, ich glaube nicht, da ich Terry heirate und für immer mit ihm zusammen sein werde."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:26
translate german danasurface2_b3875e3a:

    # cw "He's always going to be allergic to dogs, so that means no dogs for me."
    cw "Er wird immer allergisch gegen Hunde sein, das heißt also keine Hunde für mich."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:28
translate german danasurface2_5388797f:

    # cw "That's okay though."
    cw "Das ist aber okay."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:29
translate german danasurface2_75ed006d:

    # pc "Maybe a turtle?"
    pc "Vielleicht eine Schildkröte?"

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:31
translate german danasurface2_5cff00b8:

    # cw "Haha, maybe!"
    cw "Haha, vielleicht!"

