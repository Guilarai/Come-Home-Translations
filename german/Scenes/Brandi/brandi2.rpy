    fd "Oh, du willst also Anwältin werden?"

# game/Scenes/Brandi/brandi2.rpy:108
translate german brandi2_afbdac62:

    # pc "Well, no. I'm in school for quantum physics actually."
    pc "Naja, nein. Ich studiere eigentlich Quantenphysik."

# game/Scenes/Brandi/brandi2.rpy:109
translate german brandi2_04c1148e:

    # fd "Wow, that's impressive."
    fd "Wow, das ist beeindruckend."

# game/Scenes/Brandi/brandi2.rpy:110
translate german brandi2_1de87a6b:

    # fd "I dropped out of high school and now I eat food in front of an audience for money."
    fd "Ich habe die Highschool abgebrochen und jetzt esse ich vor Publikum für Geld."

# game/Scenes/Brandi/brandi2.rpy:111
translate german brandi2_037690dc:

    # pc "Hey, whatever pays the bills."
    pc "Hey, Hauptsache, die Rechnungen werden bezahlt."

# game/Scenes/Brandi/brandi2.rpy:112
translate german brandi2_75eca7b6:

