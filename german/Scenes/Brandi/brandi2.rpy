    fd "Da du der Gast bist, darfst du als Erster probieren."

# game/Scenes/Brandi/brandi2.rpy:117
translate german brandi2_350435c4:

    # pc "Okay, sounds good to me."
    pc "Okay, klingt gut für mich."

# game/Scenes/Brandi/brandi2.rpy:118
translate german brandi2_96c0c900:

    # fd "What do you think, [pcname]? Do you like it?"
    fd "Was meinst du, [pcname]? Schmeckt es dir?"

# game/Scenes/Brandi/brandi2.rpy:119
translate german brandi2_efb02d33:

    # pc "Yeah it's pretty damn good."
    pc "Ja, es ist verdammt gut."

# game/Scenes/Brandi/brandi2.rpy:120
translate german brandi2_f2d6f866:

    # fd "See? I love this place."
    fd "Siehst du? Ich liebe diesen Laden."

# game/Scenes/Brandi/brandi2.rpy:123
translate german brandi2_add75b21:

    # fd "Now it's my turn."
    fd "Jetzt bin ich dran."

# game/Scenes/Brandi/brandi2.rpy:124
translate german brandi2_d1a17c3f:

    # fd "I like to start with the balls."
