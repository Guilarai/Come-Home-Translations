# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:28
translate german brandimovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Wir kommen zum Kino und setzen uns ganz nach hinten."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:30
translate german brandimovietheaterstartdate_5de6c24e:

    # fd "Oh man, I love the movie theater. I don't even care what we're watching."
    fd "Oh Mann, ich liebe das Kino. Mir ist es sogar egal, was wir uns ansehen."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:31
translate german brandimovietheaterstartdate_4e350aa8:

    # fd "Just the smell of the popcorn and the glow of the screen and the slightly uncomfortable seats is so nostalgic."
    fd "Allein der Geruch von Popcorn, das Leuchten der Leinwand und die etwas unbequemen Sitze wecken so viel Nostalgie."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:32
translate german brandimovietheaterstartdate_72767dd3:

    # fd "Plus it's just fun to cuddle up in the dark with somebody you like."
    fd "Außerdem macht es einfach Spaß, sich im Dunkeln an jemanden zu kuscheln, den man mag."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:33
translate german brandimovietheaterstartdate_6cc4cd44:

    # "There's a little time to chat before the movie starts."
    "Wir haben noch ein bisschen Zeit zum Quatschen, bevor der Film anfängt."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:37
translate german brandimovietheaterstartdate_e073d5a5:

    # "Then the lights dim and we go silent."
    "Dann wird es dunkel und wir schweigen."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:43
translate german brandimovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Sie streckt die Hand aus und hält meine Hand auf der Armlehne."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:44
translate german brandimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Die Trailer dauern etwa fünfzehn Minuten, dann geht der Film richtig los."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:47
translate german brandimovietheaterstartdate_222a7d5f:

    # "She leans against me and watches the whole movie, never really taking her eyes off the screen."
    "Sie lehnt sich an mich und schaut den ganzen Film, ohne den Blick wirklich von der Leinwand zu nehmen."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:48
translate german brandimovietheaterstartdate_1f099f0a:

    # "She seems to be really enjoying it."
    "Sie scheint es wirklich zu genießen."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:51
translate german brandimovietheaterstartdate_b059763a:

    # "When the movie ends, she sits up and looks at me, smiling."
    "Als der Film endet, setzt sie sich auf und sieht mich lächelnd an."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:52
translate german brandimovietheaterstartdate_3637234b:

    # fd "Wow! That was really good, huh?"
    fd "Wow! Das war wirklich gut, oder?"

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:53
translate german brandimovietheaterstartdate_56a5dea5:

    # "We hang out and chat throughout the credits."
    "Wir sitzen da und unterhalten uns während des Abspanns."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:58
translate german brandimovietheaterstartdate_21c5f05c:

    # "When the credits end, we go out to my car and I drive her home."
    "Als der Abspann zu Ende ist, gehen wir zu meinem Auto und ich fahre sie nach Hause."

