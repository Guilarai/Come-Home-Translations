# game/Scenes/Brandi/BrandiDates/brandilakedate.rpy:79
translate german brandilakestartdate_4ea5a098:

    # "We pack things up and drive back to her apartment."
    "Wir packen unsere Sachen zusammen und fahren zurück zu ihrer Wohnung."

