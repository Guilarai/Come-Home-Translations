# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:17
translate german brandis8_4aed897d:

    # fd "Not really."
    fd "Nicht wirklich."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:19
translate german brandis8_62228593:

    # fd "It's actually something that I struggle with a lot."
    fd "Das ist eigentlich etwas, womit ich sehr zu kämpfen habe."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:21
translate german brandis8_06850c03:

    # fd "I have people that I talk to online."
    fd "Ich habe Leute, mit denen ich online rede."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:22
translate german brandis8_b7bc1e50:

    # fd "I have my family."
    fd "Ich habe meine Familie."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:23
translate german brandis8_5c5a4a76:

    # fd "I have some friends on Facebook that I keep in touch with."
    fd "Ich habe ein paar Freunde auf Facebook, mit denen ich in Kontakt bleibe."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:25
translate german brandis8_c21a1991:

    # fd "And I have you, of course."
    fd "Und ich habe natürlich dich."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:27
translate german brandis8_b8faf66f:

    # fd "But I don't have any girlfriends that I can hang out with and open up to about things and share my feelings with."
    fd "Aber ich habe keine Freundinnen, mit denen ich etwas unternehmen, mich über Dinge auslassen und meine Gefühle teilen kann."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:28
translate german brandis8_305d44ed:

    # fd "I get jealous and sad when I see people who have that."
    fd "Ich werde eifersüchtig und traurig, wenn ich Leute sehe, die das haben."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:30
translate german brandis8_6a821ea4:

    # fd "I just never have."
    fd "Ich hatte das einfach nie."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:32
translate german brandis8_4ea0af15:

    # fd "As a kid, we moved around a lot, so I never had time to make really strong friendships."
    fd "Als Kind sind wir oft umgezogen, deshalb hatte ich nie Zeit, wirklich enge Freundschaften aufzubauen."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:34
translate german brandis8_22f38772:

    # fd "And as an adult..."
    fd "Und als Erwachsene…"

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:36
translate german brandis8_b1a92f8a:

    # fd "Well, it's just hard to meet people and make new friends."
    fd "Nun, es ist einfach schwer, Leute kennenzulernen und neue Freunde zu finden."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:37
translate german brandis8_87c60ffa:

    # pc "Yeah, I get that."
    pc "Ja, das verstehe ich."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:39
translate german brandis8_8be586e2:

    # fd "Really?"
    fd "Wirklich?"

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:40
translate german brandis8_15164318:

    # fd "You seem like you make friends pretty easily."
    fd "Du scheinst ziemlich leicht Freunde zu finden."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:41
translate german brandis8_11138f5a:

    # pc "Sometimes!"
    pc "Manchmal!"

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:42
translate german brandis8_c494d1c0:

    # pc "You probably could too. Just invite strangers over to have burgers with you on camera."
    pc "Das könntest du wahrscheinlich auch. Lade einfach Fremde ein, mit dir vor der Kamera Burger zu essen."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:44
translate german brandis8_82a46137:

    # fd "Hey, if it works, it works!"
    fd "Hey, wenn es klappt, klappt es!"

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:46
translate german brandis8_feb1083e:

    # fd "Seriously though, I've done that a couple of times before you and it didn't develop into anything."
    fd "Aber im Ernst, das habe ich schon ein paar Mal vor dir versucht, und es hat sich nie zu etwas entwickelt."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:48
translate german brandis8_dfb74cda:

    # fd "I'm really glad that it worked with you."
    fd "Ich bin wirklich froh, dass es mit dir geklappt hat."

# game/Scenes/Brandi/BrandiConversations/brandis8.rpy:49
translate german brandis8_e01560e0:

    # pc "I'm glad too."
    pc "Ich bin auch froh."

