# game/Scenes/Adrian/adrian15.rpy:151
translate german adrian15_10475b4e:

    # ath "I know. I'd do the same for you too."
    ath "Ich weiß. Ich würde dasselbe auch für dich tun."

# game/Scenes/Adrian/adrian15.rpy:152
translate german adrian15_db6c9ba9:

    # gg "Do we need to? Go on a Thelma and Louise style cross-country escape?"
    gg "Müssen wir das wirklich? Eine Flucht quer durchs Land à la „Thelma und Louise“?"

# game/Scenes/Adrian/adrian15.rpy:153
translate german adrian15_938aadfc:

    # ath "No, it's okay, Adrian."
    ath "Nein, es ist okay, Adrian."

# game/Scenes/Adrian/adrian15.rpy:156
translate german adrian15_9d14717d:

    # ath "I'll be safe. And I'll be with people I love."
    ath "Ich werde in Sicherheit sein. Und ich werde bei den Menschen sein, die ich liebe."

# game/Scenes/Adrian/adrian15.rpy:157
translate german adrian15_ad669f44:

    # ath "I'll just be... hidden for a while."
    ath "Ich werde nur … eine Weile untertauchen."

# game/Scenes/Adrian/adrian15.rpy:160
translate german adrian15_ab7ecd37:

    # ath "But you don't have to worry about me, I promise."
    ath "Aber du musst dir keine Sorgen um mich machen, das verspreche ich dir."

# game/Scenes/Adrian/adrian15.rpy:161
translate german adrian15_6fc1467e:

    # ath "And as soon as I'm able to, I'll contact you."
    ath "Und sobald ich kann, melde ich mich bei dir."

# game/Scenes/Adrian/adrian15.rpy:162
translate german adrian15_f33637a0:

    # ath "This isn't a goodbye. Just a see you later. Okay?"
    ath "Das ist kein Abschied. Nur ein „Bis bald“. Okay?"

# game/Scenes/Adrian/adrian15.rpy:165
translate german adrian15_97b198b3:

    # gg "It feels like a goodbye."
    gg "Es fühlt sich wie ein Abschied an."

# game/Scenes/Adrian/adrian15.rpy:166
translate german adrian15_1ba8b0dd:

    # ath "Oh don't cry, cuz, please. You'll make me cry too."
    ath "Oh, weine nicht, Kumpel, bitte. Du bringst mich auch zum Weinen."

# game/Scenes/Adrian/adrian15.rpy:169
translate german adrian15_0e2cfb70:

    # gg "I just don't know what I'm going to do without being able to talk to you and play games with you every night."
    gg "Ich weiß einfach nicht, was ich tun soll, wenn ich nicht mehr jeden Abend mit dir reden und Spiele spielen kann."

# game/Scenes/Adrian/adrian15.rpy:170
translate german adrian15_0b0416f8:

    # gg "I'm going to miss you so much."
    gg "Ich werde dich so sehr vermissen."

# game/Scenes/Adrian/adrian15.rpy:171
translate german adrian15_4851e337:

    # ath "I'll miss you too, Adrian."
    ath "Ich werde dich auch vermissen, Adrian."

# game/Scenes/Adrian/adrian15.rpy:172
translate german adrian15_decbe2a6:

    # ath "You'll be okay though. You have friends. You are loved."
    ath "Aber du schaffst das schon. Du hast Freunde. Du wirst geliebt."

# game/Scenes/Adrian/adrian15.rpy:173
translate german adrian15_b994f8f3:

    # ath "And one day I'll call you and we'll hang out and I'll tell you everything."
    ath "Und eines Tages rufe ich dich an, wir treffen uns und ich erzähle dir alles."

# game/Scenes/Adrian/adrian15.rpy:176
translate german adrian15_baad95b7:

    # gg "You better."
    gg "Das solltest du besser."

# game/Scenes/Adrian/adrian15.rpy:177
translate german adrian15_e694fdb2:

    # gg "Or I might come looking for you, and I'll take out anybody in my way."
    gg "Sonst komme ich dich vielleicht suchen und schalte jeden aus, der mir im Weg steht."

# game/Scenes/Adrian/adrian15.rpy:178
translate german adrian15_0cebbbe1:

    # gg "I have a very particular set of skills."
    gg "Ich habe ganz besondere Fähigkeiten."

# game/Scenes/Adrian/adrian15.rpy:179
translate german adrian15_46263ea2:

    # ath "I'm not sure how mob management with ice magic or looking amazing in a tank top is going to help you there."
    ath "Ich bin mir nicht sicher, wie dir Mob-Management mit Eismagie oder ein umwerfendes Aussehen in einem Tanktop dabei helfen sollen."

# game/Scenes/Adrian/adrian15.rpy:180
translate german adrian15_5b9f42ef:

    # gg "Fine. I might need to obtain more skills."
    gg "Na gut. Vielleicht muss ich mir noch mehr Fähigkeiten aneignen."

# game/Scenes/Adrian/adrian15.rpy:183
translate german adrian15_297bbe15:

    # ath "So, my ride is going to be here to pick me up soon. I don't have a lot of time."
    ath "Also, mein Fahrer wird mich bald abholen. Ich habe nicht viel Zeit."

# game/Scenes/Adrian/adrian15.rpy:184
translate german adrian15_083bd235:

    # ath "But I do have some good news for you too."
    ath "Aber ich habe auch gute Nachrichten für dich."

# game/Scenes/Adrian/adrian15.rpy:185
translate german adrian15_5f5f9537:

    # gg "Oh really?"
    gg "Ach wirklich?"

# game/Scenes/Adrian/adrian15.rpy:188
translate german adrian15_c24bc319:

    # ath "I'm not going to need my bike anymore. So it's all yours."
    ath "Ich brauche mein Fahrrad nicht mehr. Also gehört es ganz dir."

# game/Scenes/Adrian/adrian15.rpy:189
translate german adrian15_9e813a25:

    # gg "What!? You're just giving it to me!?"
    gg "Was!? Du schenkst es mir einfach so!?"

# game/Scenes/Adrian/adrian15.rpy:190
translate german adrian15_ca7279be:

    # ath "Sure. You had a blast riding it when you visited me last and I can't take it with me."
    ath "Klar. Du hattest so viel Spaß damit, als du mich das letzte Mal besucht hast, und ich kann es nicht mitnehmen."

# game/Scenes/Adrian/adrian15.rpy:191
translate german adrian15_f0112aa2:

    # ath "So I wanted you to have it."
    ath "Deshalb wollte ich, dass du es bekommst."

# game/Scenes/Adrian/adrian15.rpy:194
translate german adrian15_6fb0514f:

    # gg "You're amazing, Thena. I love you."
    gg "Du bist unglaublich, Thena. Ich liebe dich."

# game/Scenes/Adrian/adrian15.rpy:195
translate german adrian15_a77a6e8c:

    # ath "I love you too, cuz."
    ath "Ich liebe dich auch, Cousine."

# game/Scenes/Adrian/adrian15.rpy:196
translate german adrian15_04259593:

    # ath "Take care of it, okay? And be careful."
    ath "Pass gut darauf auf, okay? Und sei vorsichtig."

# game/Scenes/Adrian/adrian15.rpy:197
translate german adrian15_62a41927:

    # gg "I will, I promise."
    gg "Das werde ich, versprochen."

# game/Scenes/Adrian/adrian15.rpy:198
translate german adrian15_1339b17c:

    # ath "We should probably go downstairs. My ride will be here any minute."
    ath "Wir sollten wohl nach unten gehen. Mein Fahrer wird jeden Moment hier sein."

# game/Scenes/Adrian/adrian15.rpy:201
translate german adrian15_1192b455:

    # ath "Be sure to tell your mom what's going on, okay? I was hoping she'd be here so I could say goodbye to her too."
    ath "Sag deiner Mama unbedingt, was los ist, okay? Ich hatte gehofft, sie wäre hier, damit ich mich auch von ihr verabschieden könnte."

# game/Scenes/Adrian/adrian15.rpy:202
translate german adrian15_e8147df6:

    # gg "I will. She's going to be as confused as I am about it, I'm sure."
    gg "Das werde ich. Sie wird darüber sicher genauso verwirrt sein wie ich."

# game/Scenes/Adrian/adrian15.rpy:203
translate german adrian15_43503f58:

    # ath "Yeah, I'm really sorry that I can't tell you more. It's better to know as little as possible for everybody's safety."
    ath "Ja, es tut mir wirklich leid, dass ich dir nicht mehr erzählen kann. Es ist besser, so wenig wie möglich zu wissen, zu jedermanns Sicherheit."

# game/Scenes/Adrian/adrian15.rpy:206
translate german adrian15_b0be2693:

    # ath "And I'm sorry that we couldn't meet under better circumstances."
    ath "Und es tut mir leid, dass wir uns nicht unter besseren Umständen treffen konnten."

# game/Scenes/Adrian/adrian15.rpy:207
translate german adrian15_488c149e:

    # gg "Yeah, usually when Athena and I are together, it's all laughs and playing games and stuff."
    gg "Ja, normalerweise, wenn Athena und ich zusammen sind, wird nur gelacht und gespielt und so."

# game/Scenes/Adrian/adrian15.rpy:208
translate german adrian15_3dedfad6:

    # gg "It would have been fun to hang out for a while with all three of us and play some Smash or something."
    gg "Es wäre lustig gewesen, wenn wir drei eine Weile zusammen abgehangen hätten und ein bisschen Smash oder so gespielt hätten."

# game/Scenes/Adrian/adrian15.rpy:211
translate german adrian15_a29880ae:

    # ath "Do you still main Kirby? I'd love to kick that little pink ball's ass sometime."
    ath "Spielst du immer noch hauptsächlich mit Kirby? Ich würde diesem kleinen rosa Ball gerne mal ordentlich in den Hintern treten."

# game/Scenes/Adrian/adrian15.rpy:212
translate german adrian15_c75ca3d4:

    # gg "You wish."
    gg "Das hättest du gerne."

# game/Scenes/Adrian/adrian15.rpy:213
translate german adrian15_9882e4ae:

    # ath "We might have time to fit in a quick game, if we hurry. It won't take me long to wipe the floor with you."
    ath "Vielleicht haben wir noch Zeit für eine kurze Partie, wenn wir uns beeilen. Es wird nicht lange dauern, bis ich dich in Grund und Boden spiele."

# game/Scenes/Adrian/adrian15.rpy:214
translate german adrian15_36bb3cc8:

    # gg "Let's go then, bitch!"
    gg "Dann los, du Miststück!"

# game/Scenes/Adrian/adrian15.rpy:217
translate german adrian15_b7c027eb:

    # "Just then, a police car parks in front of the house and a man in a suit steps out, looking grim and official."
    "In diesem Moment hält ein Polizeiauto vor dem Haus und ein Mann im Anzug steigt aus, mit grimmigem und dienstlichem Gesichtsausdruck."

# game/Scenes/Adrian/adrian15.rpy:218
translate german adrian15_b3e6504f:

    # ath "Rain check, I guess. Time to go."
    ath "Ein anderes Mal, schätze ich. Zeit zu gehen."

# game/Scenes/Adrian/adrian15.rpy:221
translate german adrian15_d5f4dd84:

    # ath "I love you, cuz. I'll see you again soon."
    ath "Ich liebe dich, Cousine. Wir sehen uns bald wieder."

# game/Scenes/Adrian/adrian15.rpy:222
translate german adrian15_b13e0d25:

    # gg "I love you too."
    gg "Ich liebe dich auch."

# game/Scenes/Adrian/adrian15.rpy:223
translate german adrian15_96dc14b2:

    # gg "I hate this so much. I don't want to let you go."
    gg "Ich hasse das so sehr. Ich will dich nicht gehen lassen."

# game/Scenes/Adrian/adrian15.rpy:224
translate german adrian15_1edb5510:

    # ath "I know. We'll be okay though."
    ath "Ich weiß. Aber wir schaffen das schon."

# game/Scenes/Adrian/adrian15.rpy:225
translate german adrian15_e2fe510e:

    # ath "And when I see you again, we'll hang out for days, okay?"
    ath "Und wenn ich dich wiedersehe, hängen wir tagelang zusammen ab, okay?"

# game/Scenes/Adrian/adrian15.rpy:226
translate german adrian15_c5cc5eaf:

    # gg "Okay, but if there's anything I can do to help, please call me."
    gg "Okay, aber wenn ich irgendetwas tun kann, um zu helfen, ruf mich bitte an."

# game/Scenes/Adrian/adrian15.rpy:227
translate german adrian15_20fcca99:

    # ath "I will."
    ath "Das werde ich."

# game/Scenes/Adrian/adrian15.rpy:230
translate german adrian15_170b7c68:

    # ath "And [pcname], it was nice to meet you."
    ath "Und [pcname], es war schön, dich kennenzulernen."

# game/Scenes/Adrian/adrian15.rpy:231
translate german adrian15_61906ded:

    # pc "Nice to meet you too, Athena."
    pc "Freut mich auch, Athena."

# game/Scenes/Adrian/adrian15.rpy:235
translate german adrian15_84825cda:

    # "Suddenly, she pulls my hand, yanking me closer, then whispers in my ear."
    "Plötzlich zieht sie an meiner Hand, zieht mich näher zu sich heran und flüstert mir dann ins Ohr."

# game/Scenes/Adrian/adrian15.rpy:236
translate german adrian15_46517656:

    # ath "Be good to her. If you hurt my cousin, I will find you."
    ath "Sei nett zu ihr. Wenn du meiner Cousine wehtust, werde ich dich finden."

# game/Scenes/Adrian/adrian15.rpy:237
translate german adrian15_17a1cb32:

    # pc "Uh, I will."
    pc "Äh, das werde ich."

# game/Scenes/Adrian/adrian15.rpy:240
translate german adrian15_05763882:

    # ath "Bye, Adrian! Love you!"
    ath "Tschüss, Adrian! Ich liebe dich!"

# game/Scenes/Adrian/adrian15.rpy:241
translate german adrian15_11b6245f:

    # gg "Bye! Love you too!"
    gg "Tschüss! Ich liebe dich auch!"

# game/Scenes/Adrian/adrian15.rpy:242
translate german adrian15_fd99ecee:

    # ath "Tell your mom I love her too!"
    ath "Sag deiner Mama, dass ich sie auch liebe!"

# game/Scenes/Adrian/adrian15.rpy:243
translate german adrian15_b909935e:

    # gg "I will!"
    gg "Das werde ich!"

# game/Scenes/Adrian/adrian15.rpy:244
translate german adrian15_124dcc1b:

    # ath "I'll kick your pink Kirby ass real soon!"
    ath "Ich werde dir ganz bald in deinen rosa Kirby-Arsch treten!"

# game/Scenes/Adrian/adrian15.rpy:248
translate german adrian15_4829e0da:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns towards me, tears in her eyes."
    "Sobald Athena im Auto sitzt und es losfährt, dreht sich Adrian zu mir um, Tränen in den Augen."

# game/Scenes/Adrian/adrian15.rpy:249
translate german adrian15_5928d159:

    # gg "Ugh, this fucking sucks."
    gg "Ugh, das ist echt beschissen."

# game/Scenes/Adrian/adrian15.rpy:250
translate german adrian15_72615de3:

    # gg "I'm sorry, [pcname]. I don't much feel like playing games anymore."
    gg "Es tut mir leid, [pcname]. Ich habe keine Lust mehr auf Spielchen."

# game/Scenes/Adrian/adrian15.rpy:251
translate german adrian15_fd83325a:

    # gg "I'll see you later, okay?"
    gg "Wir sehen uns später, okay?"

# game/Scenes/Adrian/adrian15.rpy:252
translate german adrian15_e576c8b5:

    # pc "Are you going to be all right."
    pc "Wird alles gut mit dir?"

# game/Scenes/Adrian/adrian15.rpy:253
translate german adrian15_0da71ea1:

    # gg "Yeah. I'll have to be."
    gg "Ja. Das muss es schon."

# game/Scenes/Adrian/adrian15.rpy:254
translate german adrian15_4004410a:

    # gg "But I need some time alone now."
    gg "Aber ich brauche jetzt etwas Zeit für mich."

# game/Scenes/Adrian/adrian15.rpy:255
translate german adrian15_b21f0baf:

    # pc "No problem. Let me know if I can help. See you later, Adrian."
    pc "Kein Problem. Sag Bescheid, wenn ich helfen kann. Bis später, Adrian."

# game/Scenes/Adrian/adrian15.rpy:256
translate german adrian15_9d092ee2:

    # gg "Thanks, [pcname]. See ya."
    gg "Danke, [pcname]. Bis dann."

# game/Scenes/Adrian/adrian15.rpy:259
translate german adrian15_25d8780e:

    # "I leave Adrian's house, hoping that she'll be okay."
    "Ich verlasse Adrians Haus und hoffe, dass es ihr gut geht."

# game/Scenes/Adrian/adrian15.rpy:267
translate german adrian15_d9f27044:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns and collapses into my arms, crying against my shoulder."
    "Sobald Athena im Auto sitzt und es losfährt, dreht sich Adrian um, bricht in meine Arme zusammen und weint an meiner Schulter."

# game/Scenes/Adrian/adrian15.rpy:268
translate german adrian15_0e12d7d2:

    # gg "This fucking sucks!!!"
    gg "Das ist verdammt beschissen!!!"

# game/Scenes/Adrian/adrian15.rpy:269
translate german adrian15_182f9ad8:

    # "I rub her back and hold her and let her cry it out."
    "Ich streichele ihr den Rücken, halte sie fest und lasse sie sich ausweinen."

# game/Scenes/Adrian/adrian15.rpy:272
translate german adrian15_8bf9515c:

    # "A few minutes later, she sniffs up her tears and looks at me."
    "Ein paar Minuten später schniefst du deine Tränen weg und siehst mich an."

# game/Scenes/Adrian/adrian15.rpy:273
translate german adrian15_3d955406:

    # gg "Okay, feeling slightly better."
    gg "Okay, es geht mir schon etwas besser."

# game/Scenes/Adrian/adrian15.rpy:274
translate german adrian15_58a70a56:

    # gg "I want to go for a ride. Do you want to come with me?"
    gg "Ich möchte eine Runde fahren. Willst du mitkommen?"

# game/Scenes/Adrian/adrian15.rpy:275
translate german adrian15_2b3b24ff:

    # "I think I probably should stay with her, with how upset she is."
    "Ich glaube, ich sollte wohl besser bei dir bleiben, so aufgebracht wie du bist."

# game/Scenes/Adrian/adrian15.rpy:276
translate german adrian15_2d17893f:

    # pc "Sure, let's do it, if you're okay to drive?"
    pc "Klar, machen wir das, wenn du fahren kannst?"

# game/Scenes/Adrian/adrian15.rpy:277
translate german adrian15_28404c62:

    # gg "Yeah, I'm okay."
    gg "Ja, ich kann fahren."

# game/Scenes/Adrian/adrian15.rpy:280
translate german adrian15_58afc396:

    # gg "Here, I found her old helmet in the storage under the seat. You should probably wear it."
    gg "Hier, ich habe ihren alten Helm im Staufach unter dem Sitz gefunden. Du solltest ihn wohl besser aufsetzen."

# game/Scenes/Adrian/adrian15.rpy:281
translate german adrian15_4fb22de7:

    # pc "Dear lord, this thing is huge."
    pc "Meine Güte, das Ding ist riesig."

# game/Scenes/Adrian/adrian15.rpy:282
translate german adrian15_2409eb5c:

    # gg "That's what she... nevermind, let's just go."
    gg "Das ist es, was sie... egal, lass uns einfach losfahren."

# game/Scenes/Adrian/adrian15.rpy:283
translate german adrian15_9b4e9f4c:

    # pc "You know how to ride this thing?"
    pc "Weißt du, wie man das Ding fährt?"

# game/Scenes/Adrian/adrian15.rpy:284
translate german adrian15_12315e04:

    # gg "Yeah, Athena taught me when I visited her last time. We rode all over the place on it."
    gg "Ja, Athena hat es mir beigebracht, als ich sie das letzte Mal besucht habe. Wir sind damit überall herumgefahren."

# game/Scenes/Adrian/adrian15.rpy:285
translate german adrian15_c4bccc9f:

    # gg "I'm the only person she'd ever let drive it."
    gg "Ich bin die einzige Person, die sie jemals damit fahren ließ."

# game/Scenes/Adrian/adrian15.rpy:289
translate german adrian15_65c8468c:

    # "I wrap my arms around her and hold on as she pulls out into the street."
    "Ich schlinge meine Arme um sie und halte mich fest, während sie auf die Straße fährt."

# game/Scenes/Adrian/adrian15.rpy:290
translate german adrian15_a4cc4d56:

    # pc "Where are we going?"
    pc "Wohin fahren wir?"

# game/Scenes/Adrian/adrian15.rpy:291
translate german adrian15_33da7917:

    # gg "I just feel like riding for a while. Clear my head, you know."
    gg "Ich habe einfach Lust, eine Weile herumzufahren. Den Kopf frei zu bekommen, weißt du."

# game/Scenes/Adrian/adrian15.rpy:292
translate german adrian15_61f77a4c:

    # pc "Sure."
    pc "Klar."

# game/Scenes/Adrian/adrian15.rpy:294
translate german adrian15_df03bfba:

    # "It feels like we're riding forever. We leave town and take a rarely used highway out towards the lake."
    "Es kommt mir vor, als würden wir ewig fahren. Wir verlassen die Stadt und nehmen eine selten befahrene Landstraße in Richtung See."

# game/Scenes/Adrian/adrian15.rpy:295
translate german adrian15_ba48df36:

    # "After a while, I'm not even sure where we are anymore. Hopefully Adrian knows. I guess I have GPS on the phone if we get lost."
    "Nach einer Weile bin ich mir nicht einmal mehr sicher, wo wir sind. Hoffentlich weiß Adrian es. Ich glaube, ich habe GPS auf dem Handy, falls wir uns verfahren."

# game/Scenes/Adrian/adrian15.rpy:296
translate german adrian15_0bac7b03:

    # "But I don't say anything. I just hold on and let Adrian clear her mind of everything."
    "Aber ich sage nichts. Ich halte mich einfach fest und lasse Adrian den Kopf frei bekommen."

# game/Scenes/Adrian/adrian15.rpy:297
translate german adrian15_76cd1d73:

    # "She seems calm now, like this is exactly what she needed to get through this."
    "Sie wirkt jetzt ruhig, als wäre das genau das, was sie gebraucht hat, um das durchzustehen."

# game/Scenes/Adrian/adrian15.rpy:298
translate german adrian15_f0b56a2e:

    # "Then, after what must have been at least an hour, she pulls off the highway and drives a little ways up towards the cliffside near the lake."
    "Dann, nach mindestens einer Stunde, biegt sie von der Landstraße ab und fährt ein Stück hinauf in Richtung der Klippe am See."

# game/Scenes/Adrian/adrian15.rpy:301
translate german adrian15_135327af:

    # "We sit and I hold her close, trying to provide whatever comfort I can."
    "Wir sitzen da und ich halte sie fest, um ihr so viel Trost wie möglich zu spenden."

# game/Scenes/Adrian/adrian15.rpy:302
translate german adrian15_fa24fdf7:

    # gg "I'm sorry I'm being such a bummer. This was supposed to be a fun day."
    gg "Es tut mir leid, dass ich so eine Miesepeter bin. Das sollte eigentlich ein lustiger Tag werden."

# game/Scenes/Adrian/adrian15.rpy:303
translate german adrian15_cfd80ee8:

    # pc "It's okay, Adrian. I'm here for you. Whatever you need."
    pc "Ist schon okay, Adrian. Ich bin für dich da. Was auch immer du brauchst."

# game/Scenes/Adrian/adrian15.rpy:304
translate german adrian15_64ee3ae6:

    # gg "Thanks, [pcname]. I just need a friend really."
    gg "Danke, [pcname]. Ich brauche eigentlich nur einen Freund."

# game/Scenes/Adrian/adrian15.rpy:306
translate german adrian15_d41d8cd9:

    # voice 'voices/adrian_whenitransitioned.mp3'
    voice 'voices/adrian_whenitransitioned.mp3'

# game/Scenes/Adrian/adrian15.rpy:307
translate german adrian15_ec81d936:

    # gg "When I transitioned, besides my mom, Athena was the only person who was there for me."
    gg "Als ich meine Geschlechtsangleichung durchgemacht habe, war Athena neben meiner Mutter die einzige Person, die für mich da war."

# game/Scenes/Adrian/adrian15.rpy:309
translate german adrian15_d41d8cd9_1:

    # voice 'voices/adrian_nohesitation.mp3'
    voice 'voices/adrian_nohesitation.mp3'

# game/Scenes/Adrian/adrian15.rpy:310
translate german adrian15_b76e91f4:

    # gg "No hesitation, no questions, just a ton of support and love."
    gg "Kein Zögern, keine Fragen, nur jede Menge Unterstützung und Liebe."

# game/Scenes/Adrian/adrian15.rpy:312
translate german adrian15_d41d8cd9_2:

    # voice 'voices/adrian_shewastheonly.mp3'
    voice 'voices/adrian_shewastheonly.mp3'

# game/Scenes/Adrian/adrian15.rpy:313
translate german adrian15_5be20e3b:

    # gg "She was the only friend I had for a long time."
    gg "Sie war lange Zeit die einzige Freundin, die ich hatte."

# game/Scenes/Adrian/adrian15.rpy:317
translate german adrian15_d41d8cd9_3:

    # voice 'voices/adrian_untilyou.mp3'
    voice 'voices/adrian_untilyou.mp3'

# game/Scenes/Adrian/adrian15.rpy:318
translate german adrian15_b79560a9:

    # gg "Until you."
    gg "Bis zu dir."

# game/Scenes/Adrian/adrian15.rpy:320
translate german adrian15_d41d8cd9_4:

    # voice 'voices/adrian_missherlikecrazy.mp3'
    voice 'voices/adrian_missherlikecrazy.mp3'

# game/Scenes/Adrian/adrian15.rpy:321
translate german adrian15_65372d0d:

    # gg "So, I'm going to miss her like crazy, and I'm going to worry about her until I hear from her again."
    gg "Also werde ich sie wahnsinnig vermissen und mir Sorgen um sie machen, bis ich wieder von ihr höre."

# game/Scenes/Adrian/adrian15.rpy:323
translate german adrian15_d41d8cd9_5:

    # voice 'voices/adrian_butimsoglad.mp3'
    voice 'voices/adrian_butimsoglad.mp3'

# game/Scenes/Adrian/adrian15.rpy:324
translate german adrian15_4de0338c:

    # gg "But I'm so glad that you're here."
    gg "Aber ich bin so froh, dass du hier bist."

# game/Scenes/Adrian/adrian15.rpy:326
translate german adrian15_d41d8cd9_6:

    # voice 'voices/adrian_iloveyou1.mp3'
    voice 'voices/adrian_iloveyou1.mp3'

# game/Scenes/Adrian/adrian15.rpy:327
translate german adrian15_9c8fbba1:

    # gg "I love you, [pcname]."
    gg "Ich liebe dich, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:330
translate german adrian15_456cffdf:

    # pc "I love you too, Adrian."
    pc "Ich liebe dich auch, Adrian."

# game/Scenes/Adrian/adrian15.rpy:333
translate german adrian15_e9e54f9a:

    # "We sit and watch the sun set, holding each other, enjoying the quiet evening."
    "Wir sitzen da und schauen uns den Sonnenuntergang an, halten uns fest und genießen den ruhigen Abend."

# game/Scenes/Adrian/adrian15.rpy:334
translate german adrian15_5a0d166e:

    # "I just want to be whatever she needs now."
    "Ich will einfach nur das sein, was sie jetzt braucht."

# game/Scenes/Adrian/adrian15.rpy:335
translate german adrian15_46b97a11:

    # "I realize how hard I've fallen for her. I'd do anything to make her happy."
    "Mir wird klar, wie sehr ich mich in sie verliebt habe. Ich würde alles tun, um sie glücklich zu machen."

# game/Scenes/Adrian/adrian15.rpy:338
translate german adrian15_7f8ffd28:

    # "After the sun sets, we drive back to her house."
    "Nachdem die Sonne untergegangen ist, fahren wir zurück zu ihrem Haus."

# game/Scenes/Adrian/adrian15.rpy:341
translate german adrian15_78e6be93:

    # gg "It looks like my mom is home now. I'm going to have to explain everything to her."
    gg "Es sieht so aus, als wäre meine Mutter jetzt zu Hause. Ich werde ihr alles erklären müssen."

# game/Scenes/Adrian/adrian15.rpy:342
translate german adrian15_f3610339:

    # gg "This is not going to be fun."
    gg "Das wird kein Spaß werden."

# game/Scenes/Adrian/adrian15.rpy:343
translate german adrian15_20cd9dd9:

    # pc "Want some backup?"
    pc "Brauchst du Unterstützung?"

# game/Scenes/Adrian/adrian15.rpy:344
translate german adrian15_0c91a1a8:

    # gg "No, I think I better do this on my own."
    gg "Nein, ich glaube, ich mache das besser alleine."

# game/Scenes/Adrian/adrian15.rpy:345
translate german adrian15_cf913627:

    # gg "Thanks for everything though, [pcname]. You've been amazing."
    gg "Trotzdem danke für alles, [pcname]. Du warst großartig."

# game/Scenes/Adrian/adrian15.rpy:346
translate german adrian15_c46a0b54:

    # pc "Any time."
    pc "Gern geschehen."

# game/Scenes/Adrian/adrian15.rpy:347
translate german adrian15_ee13ba27:

    # gg "I'll call you soon, okay?"
    gg "Ich rufe dich bald an, okay?"

# game/Scenes/Adrian/adrian15.rpy:350
translate german adrian15_1f2a71e7:

    # pc "Okay. Good night, Adrian."
    pc "Okay. Gute Nacht, Adrian."

# game/Scenes/Adrian/adrian15.rpy:351
translate german adrian15_f27d9018:

    # gg "Good night, [pcname]."
    gg "Gute Nacht, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:352
translate german adrian15_80adb898:

    # "I kiss her goodbye."
    "Ich küsse sie zum Abschied."

# game/Scenes/Adrian/adrian15.rpy:355
translate german adrian15_0cbac92b:

    # "Then I get in my car and drive away, hoping that everything will be okay."
    "Dann steige ich in mein Auto und fahre los, in der Hoffnung, dass alles gut wird."

# game/Scenes/Adrian/adrian15.rpy:356
translate german adrian15_339d053a:

    # "And if she needs me, I'll do anything I can to help her."
    "Und wenn sie mich braucht, werde ich alles tun, um ihr zu helfen."

translate german strings:

    # game/Scenes/Adrian/adrian15.rpy:6
    old "After you have checked out a local arcade with Adrian,"
    new "Nachdem du mit Adrian eine Spielhalle in der Nähe besucht hast,"

    # game/Scenes/Adrian/adrian15.rpy:7
    old "she will call and invite you to hang out in the afternoon on the weekend."
    new "wird sie dich anrufen und dich einladen, am Wochenende nachmittags etwas mit ihr zu unternehmen."

    # game/Scenes/Adrian/adrian15.rpy:28
    old "Oh heck yeah"
    new "Oh ja, klar doch"

