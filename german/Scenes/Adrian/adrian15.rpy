translate german adrian15_6b5e2f35:

    # gg "No, you don't have to go."
    gg "Nein, du musst nicht gehen."

# game/Scenes/Adrian/adrian15.rpy:125
translate german adrian15_ff42571e:

    # gg "Right, Athena? What's going on? Did something happen?"
    gg "Stimmt’s, Athena? Was ist los? Ist etwas passiert?"

# game/Scenes/Adrian/adrian15.rpy:128
translate german adrian15_cd5138a1:

    # ath "Yeah, but I'm not allowed to tell you everything."
    ath "Ja, aber ich darf dir nicht alles erzählen."

# game/Scenes/Adrian/adrian15.rpy:129
translate german adrian15_0937f8ec:

