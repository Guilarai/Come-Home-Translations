    gg "Klar."

# game/Scenes/Adrian/adrian15.rpy:111
translate german adrian15_40382c6b:

    # ath "Oh, who's this?"
    ath "Oh, wer ist das?"

# game/Scenes/Adrian/adrian15.rpy:113
translate german adrian15_f248dcf0:

    # gg "This is my boyfriend, [pcname]. [pcname], this is my cousin, Athena."
    gg "Das ist mein Freund, [pcname]. [pcname], das ist meine Cousine, Athena."

# game/Scenes/Adrian/adrian15.rpy:115
translate german adrian15_2fec0547:

    # gg "This is my friend, [pcname]. [pcname], this is my cousin, Athena."
    gg "Das ist mein Freund, [pcname]. [pcname], das ist meine Cousine Athena."

# game/Scenes/Adrian/adrian15.rpy:116
translate german adrian15_bc87a0d4:

    # pc "Nice to meet you."
    pc "Freut mich, dich kennenzulernen."

# game/Scenes/Adrian/adrian15.rpy:117
translate german adrian15_15faa5ea:

    # ath "Yeah, you too."
    ath "Ja, mich auch."

# game/Scenes/Adrian/adrian15.rpy:122
translate german adrian15_7ac147ee:

    # "We go in and go upstairs and sit in the bedroom and the tone immediately changes to something more somber and uncomfortable."
    "Wir gehen rein, gehen nach oben und setzen uns ins Schlafzimmer, und die Stimmung wird sofort ernster und unangenehmer."

# game/Scenes/Adrian/adrian15.rpy:123
translate german adrian15_da185fde:

    # pc "Should I go? Do you two need to talk?"
    pc "Soll ich gehen? Müssen ihr beiden reden?"

