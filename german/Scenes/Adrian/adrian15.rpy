    # ath "I don't know."
    ath "Ich weiß es nicht."

# game/Scenes/Adrian/adrian15.rpy:147
translate german adrian15_024a8128:

    # gg "Are you in danger?"
    gg "Bist du in Gefahr?"

# game/Scenes/Adrian/adrian15.rpy:148
translate german adrian15_619b8851:

    # gg "Because you know I would burn the whole world down for you."
