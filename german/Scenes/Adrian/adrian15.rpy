translate german adrian15_dc747734:

    # ath "Not for a while."
    ath "Eine Weile lang nicht."

# game/Scenes/Adrian/adrian15.rpy:145
translate german adrian15_49c637e0:

    # gg "How long?"
    gg "Wie lange?"

