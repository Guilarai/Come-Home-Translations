    # gg "What do you mean you have to leave?"
    gg "Was meinst du damit, du musst weg?"

# game/Scenes/Adrian/adrian15.rpy:139
translate german adrian15_666954cc:

    # ath "I have to cut contact with everybody. Witness protection."
    ath "Ich muss den Kontakt zu allen abbrechen. Zeugenschutz."

