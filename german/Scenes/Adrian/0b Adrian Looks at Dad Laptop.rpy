translate german adrian0b_1a83f3a4:

    # gg "Sure, I'm just playing a game. I can pause it."
    gg "Klar, ich spiele nur gerade ein Spiel. Ich kann es pausieren."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:14
translate german adrian0b_51cba8b4:

    # gg "Text me your address and I'll head over right now."
    gg "Schick mir deine Adresse per SMS, dann komme ich sofort vorbei."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:15
translate german adrian0b_08551511:

    # pc "You got it."
    pc "Klar."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:16
translate german adrian0b_fc3a8142:

    # gg "Alrighty, see you when I get there."
    gg "Alles klar, wir sehen uns, wenn ich da bin."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:17
translate german adrian0b_dee54724:

    # pc "Okay, see you."
    pc "Okay, bis dann."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:18
translate german adrian0b_172caee2:

    # "We hang up and I text her the address, then go downstairs where I'll see when she pulls in."
    "Wir legen auf und ich schicke ihr die Adresse per SMS, dann gehe ich nach unten, wo ich sehen werde, wenn sie vorfährt."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:21
translate german adrian0b_a362738f:

    # "It only takes about five minutes before she pulls her car up in front of the house and walks up to the front door."
    "Es dauert nur etwa fünf Minuten, bis sie ihr Auto vor dem Haus parkt und zur Haustür kommt."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:25
translate german adrian0b_e7f63749:

    # pc "Hey there."
    pc "Hey."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:26
translate german adrian0b_c876ef37:

    # gg "Hey. Nice house. You live here all by yourself?"
    gg "Hey. Schönes Haus. Wohnst du hier ganz allein?"

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:27
translate german adrian0b_b37f8bf7:

    # pc "No, my [mother] and [sister] live here too."
    pc "Nein, meine [mother] und [sister] wohnen auch hier."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:28
translate german adrian0b_17acd33b:

    # gg "Oh cool. Well let's see this laptop."
    gg "Oh cool. Na dann, zeig mir mal den Laptop."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:29
translate german adrian0b_432db327:

    # pc "Okay, it's down in the basement."
    pc "Okay, er steht unten im Keller."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:33
translate german adrian0b_478d3e60:

    # gg "It's a little creepy down here."
    gg "Es ist ein bisschen unheimlich hier unten."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:34
translate german adrian0b_e7fde663:

    # gg "You're not planning on killing me or anything are you?"
    gg "Du hast doch nicht vor, mich umzubringen oder so, oder?"

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:35
translate german adrian0b_60860dd1:

    # pc "What? No!"
    pc "Was? Nein!"

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:37
translate german adrian0b_6980cd20:

    # gg "Chill! I'm just kidding."
    gg "Entspann dich! Ich mach nur Spaß."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:38
translate german adrian0b_9ad7d2ff:

    # gg "Sorry, I have kind of a dark sense of humor."
    gg "Entschuldigung, ich hab so einen etwas schwarzen Humor."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:40
translate german adrian0b_5783bb83:

    # gg "Alright, let's look at this laptop."
    gg "Okay, schauen wir uns den Laptop mal an."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:43
translate german adrian0b_21801633:

    # "We sit down in front of the laptop and Adrian gets to work."
    "Wir setzen uns vor den Laptop und Adrian macht sich an die Arbeit."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:44
translate german adrian0b_dd61ffb9:

    # "I'm a pretty fast typist, but her hands move so rapidly over the keys that even I'm impressed."
    "Ich tippe ziemlich schnell, aber ihre Hände fliegen so rasend schnell über die Tasten, dass sogar ich beeindruckt bin."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:45
translate german adrian0b_051ad291:

    # "She does something that causes the laptop to boot into a command line."
    "Sie macht irgendwas, wodurch der Laptop in eine Befehlszeile bootet."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:46
translate german adrian0b_73f7e237:

    # "Then she starts typing code that I can't even follow."
    "Dann fängt sie an, Code einzutippen, dem ich nicht einmal folgen kann."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:49
translate german adrian0b_2e32e5c5:

    # pc "Getting anywhere?"
    pc "Kommst du weiter?"

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:50
translate german adrian0b_0dfb0eef:

    # gg "Hold on."
    gg "Warte kurz."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:53
translate german adrian0b_d6166a8c:

    # "She continues digging further into the file system, opening up some things and modifying others."
    "Sie gräbt sich weiter ins Dateisystem ein, öffnet einige Dinge und ändert andere."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:55
translate german adrian0b_d41d8cd9:

    # voice 'voices/adrian_justhavetochange.mp3'
    voice 'voices/adrian_justhavetochange.mp3'

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:56
translate german adrian0b_c81f714e:

    # gg "Just have to change this registry key."
    gg "Ich muss nur diesen Registrierungsschlüssel ändern."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:58
translate german adrian0b_d41d8cd9_1:

    # voice 'voices/adrian_removethepassword.mp3'
    voice 'voices/adrian_removethepassword.mp3'

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:59
translate german adrian0b_3ce63d82:

    # gg "This should let me remove the password."
    gg "Das sollte es mir ermöglichen, das Passwort zu entfernen."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:61
translate german adrian0b_d41d8cd9_2:

    # voice 'voices/adrian_restartthecomputer.mp3'
    voice 'voices/adrian_restartthecomputer.mp3'

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:62
translate german adrian0b_b0e950f4:

    # gg "And restart the computer. Crossing fingers that it boots into the OS now."
    gg "Und den Computer neu zu starten. Ich drücke die Daumen, dass er jetzt ins Betriebssystem bootet."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:66
translate german adrian0b_d41d8cd9_3:

    # voice 'voices/adrian_boom.mp3'
    voice 'voices/adrian_boom.mp3'

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:67
translate german adrian0b_05c66f0d:

    # gg "And BOOM goes the dynamite!"
    gg "Und BUMM, da geht die Bombe!"

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:68
translate german adrian0b_76aeaa20:

    # pc "You did it!"
    pc "Du hast es geschafft!"

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:69
translate german adrian0b_87368b21:

    # gg "Yeah I did."
    gg "Ja, habe ich."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:72
translate german adrian0b_0f8b8b53:

    # pc "You're amazing."
    pc "Du bist unglaublich."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:73
translate german adrian0b_7af8b448:

    # gg "Yeah I am."
    gg "Ja, bin ich."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:74
translate german adrian0b_56e1b85b:

    # gg "Now you can snoop through all your dad's stuff."
    gg "Jetzt kannst du alle Sachen deines Vaters durchstöbern."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:75
translate german adrian0b_caf0b222:

    # pc "Thanks. You've been a huge help."
    pc "Danke. Du warst mir eine riesige Hilfe."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:76
translate german adrian0b_1c09e775:

    # gg "I really hope you find something that leads you to your dad."
    gg "Ich hoffe wirklich, dass du etwas findest, das dich zu deinem Vater führt."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:77
translate german adrian0b_c576a124:

    # pc "Thank you. Me too."
    pc "Danke. Ich auch."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:78
translate german adrian0b_5fb4161e:

    # gg "Alrighty, well I'm going to head home and get out of your way then."
    gg "Na gut, dann mache ich mich auf den Heimweg und gehe dir aus dem Weg."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:79
translate german adrian0b_c2eac1f0:

    # gg "Looks like you have a lot of stuff to look through."
    gg "Sieht so aus, als hättest du eine Menge Material durchzugehen."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:80
translate german adrian0b_f95cb652:

    # pc "Okay. Thanks again, Adrian. Seriously."
    pc "Okay. Nochmals danke, Adrian. Im Ernst."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:81
translate german adrian0b_89ee1f12:

    # gg "No problem."
    gg "Kein Problem."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:85
translate german adrian0b_ffc439c3:

    # gg "I'll let myself out. I know the way. See you later, [pcname]."
    gg "Ich finde den Weg schon. Bis später, [pcname]."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:86
translate german adrian0b_918b9abb:

    # pc "Okay, Adrian. See ya."
    pc "Okay, Adrian. Bis dann."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:89
translate german adrian0b_2bb769a9:

    # "She walks back upstairs and I hear her leave through the front door."
    "Sie geht wieder nach oben und ich höre, wie sie durch die Haustür hinausgeht."

# game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:90
translate german adrian0b_9971aff4:

    # "Then I look down at the laptop, now completely open. There's going to be a lot to dig through on there."
    "Dann schaue ich auf den Laptop hinunter, der nun vollständig geöffnet ist. Da gibt es eine Menge zu durchforsten."

translate german strings:

    # game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:2
    old "After you talk to Adrian at the supermarket,"
    new "Nachdem du im Supermarkt mit Adrian gesprochen hast,"

    # game/Scenes/Adrian/0b Adrian Looks at Dad Laptop.rpy:3
    old "call her and ask her to come over to help with your dad's laptop in the evening or on weekends before night."
    new "ruf sie an und bitte sie, am Abend oder am Wochenende vor Einbruch der Dunkelheit vorbeizukommen, um dir mit dem Laptop deines Vaters zu helfen."

