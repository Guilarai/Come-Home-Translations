# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:25
translate german adrianmovietheaterstartdate_13ddb197:

    # "We get to the theater and find seats in the back."
    "Wir kommen im Kino an und suchen uns Plätze ganz hinten."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:26
translate german adrianmovietheaterstartdate_6cc4cd44:

    # "There's a little time to chat before the movie starts."
    "Wir haben noch ein bisschen Zeit zum Quatschen, bevor der Film anfängt."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:34
translate german adrianmovietheaterstartdate_c6fd13bc:

    # "Finally lights dim and she leans over against me while we watch the movie."
    "Endlich wird es dunkel und sie lehnt sich an mich, während wir den Film anschauen."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:35
translate german adrianmovietheaterstartdate_d2fbe7b2:

    # "It's pretty good and it's nice just being there with her."
    "Er ist ziemlich gut, und es ist schön, einfach nur mit ihr dort zu sein."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:38
translate german adrianmovietheaterstartdate_9dc3692e:

    # "Finally the lights dim and the movie starts. It's not bad."
    "Endlich wird es dunkel und der Film beginnt. Er ist nicht schlecht."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:40
translate german adrianmovietheaterstartdate_9b19c90f:

    # gg "That was pretty good, huh?"
    gg "Das war ziemlich gut, oder?"

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:41
translate german adrianmovietheaterstartdate_a57bb1cd:

    # "We chat a little through the credits."
    "Wir unterhalten uns ein wenig während des Abspanns."

# game/Scenes/Adrian/AdrianDates/adrianmovietheaterdate.rpy:46
translate german adrianmovietheaterstartdate_cb13127e:

    # "Afterwards, I drive her home and walk her up to her door."
    "Danach fahre ich sie nach Hause und begleite sie bis zu ihrer Haustür."

translate german strings:

