# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:30
translate german adriangokartstartdate_26c8bd29:

    # gg "Man, I haven't gone go-karting in a LONG time!"
    gg "Mann, ich war schon sooo lange nicht mehr Go-Kart fahren!"

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:31
translate german adriangokartstartdate_425c7596:

    # gg "I'm looking forward to this."
    gg "Ich freu mich schon drauf."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:32
translate german adriangokartstartdate_c3947180:

    # "While we wait for our turn to drive, we have some time to chat."
    "Während wir darauf warten, dass wir an der Reihe sind, haben wir etwas Zeit zum Quatschen."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:40
translate german adriangokartstartdate_dba2e530:

    # "Finally, it's our turn."
    "Endlich sind wir dran."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:46
translate german adriangokartstartdate_8f9b8839:

    # "We line up and get ready to take off."
    "Wir stellen uns auf und machen uns startklar."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:48
translate german adriangokartstartdate_18ef0fb8:

    # gg "Hope you're ready to eat my dust."
    gg "Hoffentlich bist du bereit, meinen Staub zu schlucken."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:49
translate german adriangokartstartdate_53dbc1f5:

    # pc "Yeah right. You're going down."
    pc "Ja klar. Du wirst untergehen."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:50
translate german adriangokartstartdate_800a9087:

    # gg "No, you!"
    gg "Nein, du!"

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:57
translate german adriangokartstartdate_26aa19ac:

    # "When the light comes on and the buzzer sounds, she pulls in front very quickly. My kart is not accelerating as fast as hers, no matter how much I mash on the gas."
    "Als das Licht aufleuchtet und der Summer ertönt, zieht sie sehr schnell an mir vorbei. Mein Kart beschleunigt nicht so schnell wie ihres, egal wie sehr ich aufs Gaspedal trete."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:64
translate german adriangokartstartdate_1ec15e0c:

    # "As much as I try to catch up, she's just too fast. She takes the corners perfectly, barely letting off the accelerator."
    "So sehr ich auch versuche, aufzuholen, sie ist einfach zu schnell. Sie nimmt die Kurven perfekt und nimmt kaum vom Gas."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:70
translate german adriangokartstartdate_d3f8613e:

    # "By the end of our time, she is well in the lead, leaving me far behind."
    "Am Ende unserer Zeit liegt sie deutlich in Führung und lässt mich weit hinter sich."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:77
translate german adriangokartstartdate_855b783c:

    # "But once I'm able to get the kart up to top speed, I start catching up with her."
    "Aber sobald ich das Kart auf Höchstgeschwindigkeit bringe, hole ich auf."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:83
translate german adriangokartstartdate_349acc4b:

    # "Then, on the final lap, I'm barely able to slip past her just before we cross the finish line."
    "Dann, in der letzten Runde, schaffe ich es gerade noch, kurz vor der Ziellinie an ihr vorbeizuziehen."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:87
translate german adriangokartstartdate_96accbe9:

    # gg "That was fun!"
    gg "Das hat Spaß gemacht!"

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:89
translate german adriangokartstartdate_3f94ba4d:

    # pc "Yeah it was. You kicked my ass."
    pc "Ja, das hat es. Du hast mich fertiggemacht."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:90
translate german adriangokartstartdate_1a12d8de:

    # gg "Lots of Mario Kart practice."
    gg "Viel Mario-Kart-Training."

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:92
translate german adriangokartstartdate_45c6ecca:

    # gg "I can't believe you caught up to me!"
    gg "Ich kann nicht glauben, dass du mich eingeholt hast!"

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:93
translate german adriangokartstartdate_778b032e:

    # gg "You're a damn good driver!"
    gg "Du bist ein verdammt guter Fahrer!"

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:94
translate german adriangokartstartdate_c6880d17:

    # pc "Thanks!"
    pc "Danke!"

# game/Scenes/Adrian/AdrianDates/adriangokartdate.rpy:97
translate german adriangokartstartdate_9f35c8f5:

    # "When we're ready, I drive her home and walk her up to her front door."
    "Als wir fertig sind, fahre ich sie nach Hause und begleite sie bis zu ihrer Haustür."

