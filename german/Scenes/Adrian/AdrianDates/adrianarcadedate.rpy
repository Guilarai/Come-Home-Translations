# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:23
translate german adrianarcadestartdate_93cbf6b1:

    # "I drive over to Adrian's house to pick her up, then she gives me directions to get to this arcade she wants to visit."
    "Ich fahre zu Adrians Haus, um sie abzuholen, dann gibt sie mir eine Wegbeschreibung zu dieser Spielhalle, die sie besuchen möchte."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:25
translate german adrianarcadestartdate_ef349499:

    # "I drive over to Adrian's house and pick her up, then we head out to the arcade."
    "Ich fahre zu Adrians Haus und hole sie ab, dann machen wir uns auf den Weg zur Spielhalle."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:30
translate german adrianarcadestartdate_049af941:

    # gg "Wow, look at this place! It's so retro and trashy."
    gg "Wow, schau dir diesen Laden an! Er ist so retro und schäbig."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:31
translate german adrianarcadestartdate_ca89a42d:

    # gg "I love it!"
    gg "Ich liebe es!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:32
translate german adrianarcadestartdate_1b8393bf:

    # pc "Is this like the business you want to start?"
    pc "Ist das so ähnlich wie das Geschäft, das du aufmachen willst?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:33
translate german adrianarcadestartdate_cb319d99:

    # gg "Hm, not really. I'm looking to appeal to a younger crowd, with newer games and private playing areas."
    gg "Hm, nicht wirklich. Ich möchte eher ein jüngeres Publikum ansprechen, mit neueren Spielen und privaten Spielbereichen."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:34
translate german adrianarcadestartdate_1dc6627f:

    # gg "These are all old machines, pretty beat up too. I love them, but I doubt their business is booming here."
    gg "Das sind alles alte Automaten, und ziemlich ramponiert dazu. Ich liebe sie, aber ich bezweifle, dass das Geschäft hier boomt."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:35
translate german adrianarcadestartdate_b342ddbc:

    # gg "Anyway..."
    gg "Wie auch immer..."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:36
translate german adrianarcadestartdate_ce26e6ca:

    # gg "Let's go play some games!"
    gg "Lass uns ein paar Spiele spielen!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:37
translate german adrianarcadestartdate_5d89bf80:

    # "We head over to the machines."
    "Wir gehen zu den Automaten."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:44
translate german adrianarcadestartdate_fcc66601:

    # "We chat while we play games together."
    "Wir unterhalten uns, während wir zusammen spielen."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:51
translate german adrianarcadestartdate_aa98635a:

    # "It's fun just to hang out with her. She obviously loves this stuff."
    "Es macht einfach Spaß, mit ihr abzuhängen. Sie liebt dieses Zeug offensichtlich."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:60
translate german adrianarcadestartdate_b0953d82:

    # gg "That was fun. You're pretty good at these old games."
    gg "Das hat Spaß gemacht. Du bist ziemlich gut in diesen alten Spielen."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:61
translate german adrianarcadestartdate_98d42c74:

    # pc "Thanks! I used to play these types of games with my dad as a kid all the time."
    pc "Danke! Als Kind habe ich solche Spiele ständig mit meinem Vater gespielt."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:62
translate german adrianarcadestartdate_fb8d8dab:

    # "After we get our fill, playing most of the games in the place several times, we're both ready to leave."
    "Nachdem wir uns sattgespielt und die meisten Spiele hier mehrmals durchgespielt haben, sind wir beide bereit zu gehen."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:66
translate german adrianarcadestartdate_96accbe9:

    # gg "That was fun!"
    gg "Das hat Spaß gemacht!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:68
translate german adrianarcadestartdate_1e0d4722:

    # pc "Did you get the research you need?"
    pc "Hast du die Informationen bekommen, die du brauchst?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:69
translate german adrianarcadestartdate_d081eccb:

    # gg "Yeah, I think so."
    gg "Ja, ich glaube schon."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:72
translate german adrianarcadestartdate_57656827:

    # gg "Want to take me home and research me now?"
    gg "Willst du mich jetzt mit nach Hause nehmen und mich recherchieren?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:73
translate german adrianarcadestartdate_82ba066c:

    # pc "That sounds fantastic."
    pc "Das klingt fantastisch."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:79
translate german adrianarcadestartdate_05218083:

    # "We leave the arcade, then I drive her home and walk her up to her front door."
    "Wir verlassen die Spielhalle, dann fahre ich sie nach Hause und begleite sie bis zu ihrer Haustür."

