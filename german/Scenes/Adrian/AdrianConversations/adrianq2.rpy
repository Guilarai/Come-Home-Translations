# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:11
translate german adrianq2_008003ca:

    # gg "Do you have a job in mind when you graduate?"
    gg "Hast du schon eine Vorstellung davon, welchen Job du nach deinem Abschluss machen willst?"

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:12
translate german adrianq2_9f00d552:

    # pc "Yeah, I guess so."
    pc "Ja, ich glaube schon."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:14
translate german adrianq2_2badad5a:

    # pc "I'm getting a degree in quantum physics and figured I would get a job at the lab where my dad works."
    pc "Ich mache meinen Abschluss in Quantenphysik und dachte mir, ich würde einen Job in dem Labor bekommen, in dem mein Vater arbeitet."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:15
translate german adrianq2_d3547599:

    # gg "Oh, that's cool."
    gg "Oh, das ist cool."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:16
translate german adrianq2_b1ac4484:

    # pc "I've kinda been having mixed feelings about it lately though."
    pc "Ich habe in letzter Zeit allerdings gemischte Gefühle deswegen."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:18
translate german adrianq2_e1b99333:

    # gg "Really?"
    gg "Wirklich?"

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:19
translate german adrianq2_7d02499a:

    # pc "Yeah. I'm not sure if I even want to do the whole quantum physics thing. It's all kind of boring."
    pc "Ja. Ich bin mir nicht sicher, ob ich das mit der Quantenphysik überhaupt machen will. Es ist irgendwie alles ziemlich langweilig."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:21
translate german adrianq2_854e732b:

    # gg "I understand that. I'm in pretty much the same situation."
    gg "Das verstehe ich. Ich bin in einer ziemlich ähnlichen Situation."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:22
translate german adrianq2_150e3c9e:

    # gg "I'm majoring in computer programming, but I'm not sure that's what I want to do either."
    gg "Ich studiere Computerprogrammierung, aber ich bin mir auch nicht sicher, ob das das ist, was ich machen will."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:23
translate german adrianq2_d970da1e:

    # gg "I'm only one year in, so I could just change my major if I wanted..."
    gg "Ich bin erst im ersten Jahr, also könnte ich einfach mein Hauptfach wechseln, wenn ich wollte..."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:24
translate german adrianq2_88c4cd80:

    # gg "... but I'm not sure college is for me at all."
    gg "... aber ich bin mir überhaupt nicht sicher, ob das Studium das Richtige für mich ist."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:25
translate german adrianq2_aabb72ee:

    # pc "You want to drop out? What would you do?"
    pc "Willst du abbrechen? Was würdest du dann machen?"

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:27
translate german adrianq2_b7f3960a:

    # gg "I'm not sure. I have some ideas, but I haven't thought them all through quite yet."
    gg "Ich bin mir nicht sicher. Ich habe ein paar Ideen, aber ich habe sie noch nicht ganz durchdacht."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:28
translate german adrianq2_f6c28ccc:

    # pc "Well, if I can help just let me know."
    pc "Nun, wenn ich helfen kann, sag einfach Bescheid."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:30
translate german adrianq2_45ad41a9:

    # gg "Thanks, [pcname]. I'm not going to do anything drastic. At least not until the end of the year."
    gg "Danke, [pcname]. Ich werde nichts Drastisches unternehmen. Zumindest nicht bis zum Ende des Jahres."

# game/Scenes/Adrian/AdrianConversations/adrianq2.rpy:31
translate german adrianq2_d26df279:

    # gg "I appreciate you being here for me though."
    gg "Ich weiß es aber zu schätzen, dass du für mich da bist."

