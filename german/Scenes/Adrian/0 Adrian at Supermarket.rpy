# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:10
translate german adrian0_0ce1ef2b:

    # "I go inside and take a look around."
    "Ich gehe hinein und schaue mich um."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:13
translate german adrian0_7849354b:

    # "Then I turn into an aisle and spot Adrian standing in front of a glass case looking at the video games."
    "Dann biege ich in einen Gang ein und entdecke Adrian, der vor einer Vitrine steht und sich die Videospiele ansieht."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:14
translate german adrian0_4f07aa53:

    # pc "Hey, Adrian."
    pc "Hey, Adrian."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:17
translate german adrian0_b4e517f7:

    # gg "What?"
    gg "Was?"

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:19
translate german adrian0_649f6f3d:

    # gg "Oh hi, [pcname]. How are you doing?"
    gg "Oh hi, [pcname]. Wie geht’s dir?"

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:20
translate german adrian0_0dd51ecf:

    # pc "I'm okay."
    pc "Mir geht’s gut."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:24
translate german adrian0_ed6af726:

    # gg "Oh yeah, there's a new game out I'm here to buy."
    gg "Oh ja, es ist ein neues Spiel rausgekommen, das ich mir hier kaufen will."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:25
translate german adrian0_25d3d4da:

    # gg "Just waiting on the clerk to come unlock the dang case for me."
    gg "Ich warte nur darauf, dass der Verkäufer kommt und die verdammte Vitrine für mich aufschließt."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:28
translate german adrian0_286df3e0:

    # gg "Yeah, man. They're my favorite thing in the world."
    gg "Ja, Mann. Das ist mein absolutes Lieblingsding auf der Welt."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:29
translate german adrian0_39b08e78:

    # gg "I'm just waiting on the clerk to come unlock the dang case now so I can pick up a new one."
    gg "Ich warte gerade darauf, dass der Verkäufer kommt und die verdammte Vitrine aufschließt, damit ich mir ein neues holen kann."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:32
translate german adrian0_6907ba6c:

    # gg "Oh, okay then. See ya."
    gg "Oh, okay, dann. Bis später."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:33
translate german adrian0_7dc169c2:

    # "I walk away and continue shopping."
    "Ich gehe weg und kaufe weiter ein."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:39
translate german adrian0_37a2469c:

    # pc "Say, you wouldn't happen to know anything about computers, would you?"
    pc "Sag mal, du weißt nicht zufällig etwas über Computer, oder?"

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:41
translate german adrian0_789dfbd6:

    # gg "Know about computers? You sound like an old man."
    gg "Etwas über Computer wissen? Du klingst wie ein alter Mann."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:42
translate german adrian0_e350929a:

    # pc "Well, I know a little bit, but I'm no expert."
    pc "Na ja, ich weiß ein bisschen was, aber ich bin kein Experte."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:44
translate german adrian0_6e24121c:

    # gg "I wouldn't say I'm an expert either, but I know quite a bit."
    gg "Ich würde auch nicht sagen, dass ich ein Experte bin, aber ich weiß ziemlich viel."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:45
translate german adrian0_b6cc961f:

    # gg "Why, you have a computer problem?"
    gg "Warum, hast du ein Computerproblem?"

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:46
translate german adrian0_cec999ba:

    # "I tell her all about how my dad is missing and about finding his laptop in the basement."
    "Ich erzähle ihr alles darüber, dass mein Vater verschwunden ist und dass ich seinen Laptop im Keller gefunden habe."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:47
translate german adrian0_9892f205:

    # "She listens attentively the entire time."
    "Sie hört die ganze Zeit aufmerksam zu."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:48
translate german adrian0_18330a53:

    # gg "So you want me to hack into your dad's laptop to see what we can find on it?"
    gg "Du willst also, dass ich mich in den Laptop deines Vaters hacke, um zu sehen, was wir darauf finden können?"

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:49
translate german adrian0_f8fc980f:

    # pc "Yeah, something like that."
    pc "Ja, so in etwa."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:51
translate german adrian0_521f7e38:

    # gg "I might be able to do it."
    gg "Das könnte ich vielleicht machen."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:52
translate german adrian0_2d9575be:

    # gg "I could come by your house sometime and take a look."
    gg "Ich könnte mal bei dir vorbeikommen und mir das ansehen."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:53
translate german adrian0_4cb6a107:

    # pc "That would be awesome."
    pc "Das wäre super."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:55
translate german adrian0_c93436d0:

    # gg "Peachy! I'm available in the evenings and pretty much any time on the weekends."
    gg "Super! Ich habe abends Zeit und am Wochenende eigentlich immer."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:56
translate german adrian0_74405267:

    # gg "Here, I'll give you my phone number and you can just call me when you want me to come over."
    gg "Hier, ich gebe dir meine Telefonnummer, dann ruf mich einfach an, wenn ich vorbeikommen soll."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:57
translate german adrian0_b6ecd7e5:

    # pc "Sounds good. I'll do that."
    pc "Klingt gut. Das mache ich."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:58
translate german adrian0_4b274f74:

    # "You add Adrian's number to your phone."
    "Du speicherst Adrians Nummer in deinem Handy."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:60
translate german adrian0_a42401cd:

    # pc "Well I better get going. I'll see you later."
    pc "So, ich muss jetzt los. Bis später."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:62
translate german adrian0_d4558b5f:

    # gg "Alrighty. Bye, [pcname]. See you soon."
    gg "Alles klar. Tschüss, [pcname]. Bis bald."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:63
translate german adrian0_9b7b8449:

    # gg "If you happen to see somebody who works here, could you tell them I've been waiting for them to open this case for like half an hour now?"
    gg "Falls du zufällig jemanden siehst, der hier arbeitet, könntest du ihm sagen, dass ich schon seit etwa einer halben Stunde darauf warte, dass er diese Vitrine öffnet?"

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:64
translate german adrian0_1df08797:

    # pc "Will do."
    pc "Mache ich."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:65
translate german adrian0_1249f117:

    # "With that, I walk away and continue shopping."
    "Damit gehe ich weg und setze meinen Einkauf fort."

