# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:9
translate german adrianphone_26914501:

    # "Adrian picks up after a couple of rings."
    "Adrian nimmt nach ein paar Klingelzeichen ab."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:10
translate german adrianphone_481fac95:

    # gg "Hey, [pcname]. What's up?"
    gg "Hey, [pcname]. Was gibt’s?"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:12
translate german adrianphone_9e6d7a2e:

    # pc "I was just wondering if you were free to come over and help with my dad's laptop."
    pc "Ich habe mich nur gefragt, ob du Zeit hast, vorbeizukommen und mir mit dem Laptop meines Vaters zu helfen."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:15
translate german adrianphone_1f602bfd:

    # gg "It's a little late right now. Could we do it sometime earlier in the day?"
    gg "Es ist gerade schon etwas spät. Könnten wir das vielleicht früher am Tag machen?"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:16
translate german adrianphone_325243c6:

    # pc "Sure, you're right. Okay, I'll call you some other day when it's earlier."
    pc "Klar, du hast recht. Okay, ich rufe dich an einem anderen Tag an, wenn es früher ist."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:17
translate german adrianphone_5e17d929:

    # gg "Okay, sorry, [pcname]. I'll talk to you later, okay?"
    gg "Okay, tut mir leid, [pcname]. Wir sprechen uns später, okay?"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:21
translate german adrianphone_5a61ec4b:

    # gg "I don't really have time to do it before school."
    gg "Ich habe vor der Schule nicht wirklich Zeit dafür."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:22
translate german adrianphone_8ec59c74:

    # gg "Could you give me a call after school maybe?"
    gg "Könntest du mich vielleicht nach der Schule anrufen?"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:23
translate german adrianphone_55b46fe0:

    # pc "Oh sure, you're right."
    pc "Oh klar, du hast recht."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:24
translate german adrianphone_71abeb5f:

    # gg "Sorry, [pcname]. I'll talk to you later, okay?"
    gg "Entschuldige, [pcname]. Wir sprechen uns später, okay?"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:31
translate german adrianchat_33d3bb38:

    # pc "I just thought we could chat some."
    pc "Ich dachte nur, wir könnten ein bisschen quatschen."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:32
translate german adrianchat_47047af2:

    # gg "Sure, what do you want to chat about?"
    gg "Klar, worüber willst du quatschen?"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:34
translate german adrianchat_b6985f40:

    # "We finish talking and eventually hang up."
    "Wir beenden das Gespräch und legen schließlich auf."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:40
translate german adrianchat_b7c4dd6f:

    # "Then I start getting ready for bed."
    "Dann mache ich mich bettfertig."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:43
translate german adrianchat_451955f4:

    # "Then I rush off to school."
    "Dann eile ich zur Schule."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:50
translate german adrianhangout_daa77548:

    # gg "Sure, where do you want to go?"
    gg "Klar, wo willst du hin?"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:58
translate german adrianhangout_cd2a26fb:

    # gg "Do you want to invite Kendra? That could be fun."
    gg "Willst du Kendra einladen? Das könnte Spaß machen."

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:61
translate german adrianhangout_484982cf:

    # gg "Awesome!"
    gg "Super!"

# game/Scenes/Adrian/AdrianPhone/adrianphone.rpy:64
translate german adrianhangout_a78c8e3d:

    # gg "Sounds good to me."
    gg "Klingt gut für mich."

