# game/Scenes/Gertrude/gertrude1.rpy:12
translate german gertrude1_b8ab60df:

    # sc "I had a kind of personal question for you today."
    sc "Ich hatte heute eine eher persönliche Frage an dich."

# game/Scenes/Gertrude/gertrude1.rpy:13
translate german gertrude1_46f5a669:

    # pc "Okay, go ahead."
    pc "Okay, schieß los."

# game/Scenes/Gertrude/gertrude1.rpy:14
translate german gertrude1_f61c5e45:

    # sc "If you don't want to answer it, you don't have to."
    sc "Wenn du nicht antworten willst, musst du nicht."

# game/Scenes/Gertrude/gertrude1.rpy:15
translate german gertrude1_e2305d2c:

    # pc "Just ask."
    pc "Frag einfach."

# game/Scenes/Gertrude/gertrude1.rpy:16
translate german gertrude1_0cd2dbde:

    # sc "Are you sexually active?"
    sc "Bist du sexuell aktiv?"

# game/Scenes/Gertrude/gertrude1.rpy:20
translate german gertrude1_7b5b8bbb:

    # sc "I think that most people would say that."
    sc "Ich glaube, das würden die meisten Leute sagen."

# game/Scenes/Gertrude/gertrude1.rpy:23
translate german gertrude1_ebf7eccb:

    # sc "Good, I'm glad."
    sc "Gut, das freut mich."

# game/Scenes/Gertrude/gertrude1.rpy:26
translate german gertrude1_13162311:

    # sc "I'm sorry, I'm not trying to get involved in your personal life."
    sc "Es tut mir leid, ich will mich nicht in dein Privatleben einmischen."

# game/Scenes/Gertrude/gertrude1.rpy:27
translate german gertrude1_dda22b21:

    # sc "But I do think that it is healthy to be sexually active at your age."
    sc "Aber ich finde es gesund, in deinem Alter sexuell aktiv zu sein."

# game/Scenes/Gertrude/gertrude1.rpy:29
translate german gertrude1_5a649775:

    # sc "College is the perfect opportunity to experiment."
    sc "Das Studium ist die perfekte Gelegenheit zum Experimentieren."

# game/Scenes/Gertrude/gertrude1.rpy:30
translate german gertrude1_b8b829eb:

    # sc "To figure out what you like and don't like."
    sc "Um herauszufinden, was du magst und was nicht."

# game/Scenes/Gertrude/gertrude1.rpy:32
translate german gertrude1_8594ced1:

    # sc "You don't want to look back later in life and wonder about the things you missed out on."
    sc "Du willst später im Leben doch nicht zurückblicken und dich fragen, was du alles verpasst hast."

# game/Scenes/Gertrude/gertrude1.rpy:36
translate german gertrude1_639c8f25:

    # sc "Good."
    sc "Gut."

# game/Scenes/Gertrude/gertrude1.rpy:39
translate german gertrude1_070c7224:

    # sc "As long as you're safe about it, yes."
    sc "Solange du dabei auf Sicherheit achtest, ja."

# game/Scenes/Gertrude/gertrude1.rpy:40
translate german gertrude1_9fc07896:

    # sc "I think that you should have lots of sex with a variety of people."
    sc "Ich finde, du solltest viel Sex mit verschiedenen Leuten haben."

# game/Scenes/Gertrude/gertrude1.rpy:41
translate german gertrude1_6bec941c:

    # sc "I believe that it gives you a healthier mindset when you're older, like me."
    sc "Ich glaube, das sorgt für eine gesündere Einstellung, wenn du älter bist, so wie ich."

# game/Scenes/Gertrude/gertrude1.rpy:43
translate german gertrude1_a0193afd:

    # sc "Anyway, that is enough of this talk."
    sc "Wie auch immer, genug von diesem Thema."

# game/Scenes/Gertrude/gertrude1.rpy:44
translate german gertrude1_e11ba8d0:

    # sc "You should get to class, right?"
    sc "Du solltest zum Unterricht gehen, oder?"

# game/Scenes/Gertrude/gertrude1.rpy:46
translate german gertrude1_9f00d552:

    # pc "Yeah, I guess so."
    pc "Ja, ich schätze schon."

# game/Scenes/Gertrude/gertrude1.rpy:47
translate german gertrude1_8f9b25a7:

    # sc "Okay, well I'll see you next time, [pcname]."
    sc "Okay, dann bis zum nächsten Mal, [pcname]."

# game/Scenes/Gertrude/gertrude1.rpy:48
translate german gertrude1_850ead77:

    # pc "Okay. Bye, Gertrude."
    pc "Okay. Tschüss, Gertrude."

