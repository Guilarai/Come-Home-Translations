# game/Scenes/Reba/reba8.rpy:79
translate german reba8mudding_611dcce8:

    # rb "Hey, [pcname]."
    rb "Hey, [pcname]."

# game/Scenes/Reba/reba8.rpy:80
translate german reba8mudding_ee516682:

