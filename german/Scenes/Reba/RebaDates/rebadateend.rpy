translate german rebadateend_4407114d:

    # rb "That was fun, I had a really good time."
    rb "Das hat Spaß gemacht, ich hatte eine wirklich schöne Zeit."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:10
translate german rebadateend_86e2c035:

    # "I step up and pull her into a kiss, which she returns enthusiastically."
    "Ich trete einen Schritt vor und ziehe sie zu mir heran, um sie zu küssen, was sie begeistert erwidert."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:11
translate german rebadateend_39c7b3ca:

    # rb "Wow, I wish I could do more of that, but I gotta get home and make some supper for Mama."
    rb "Wow, ich wünschte, ich könnte das öfter machen, aber ich muss nach Hause und Mama das Abendessen kochen."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:13
translate german rebadateend_895c572b:

    # rb "I hope we can do this again soon. And maybe more. I want so much more."
    rb "Ich hoffe, wir können das bald wiederholen. Und vielleicht noch mehr. Ich will so viel mehr."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:16
translate german rebadateend_744ec225:

    # "I step up and pull her into a hug. She wraps her arms around me and squeezes me close."
    "Ich trete einen Schritt vor und ziehe sie in eine Umarmung. Sie schlingt ihre Arme um mich und drückt mich fest an sich."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:17
translate german rebadateend_91433507:

    # rb "Thanks for taking me out. I hope we can do this again soon."
    rb "Danke, dass du mit mir ausgegangen bist. Ich hoffe, wir können das bald wiederholen."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:18
translate german rebadateend_4f8314b3:

    # rb "But I better get home. Gotta make supper for Mama."
    rb "Aber ich muss besser nach Hause. Ich muss Mama das Abendessen machen."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:21
translate german rebadateend_24de817d:

    # pc "Do you want to come back to my house for a while?"
    pc "Willst du für eine Weile mit zu mir kommen?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:23
translate german rebadateend_c8f7ca44:

    # rb "You want a little hanky-panky?"
    rb "Hast du Lust auf ein bisschen Spaß?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:24
translate german rebadateend_f4be2d3d:

    # rb "Good, because I {i}really{/i} do too. Let's go."
    rb "Gut, denn ich {i}wirklich{/i} auch. Lass uns gehen."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:28
translate german rebadateend_ed307571:

    # "We drive back to my house and go up to my bedroom, where things quickly lead to us being naked on the bed."
    "Wir fahren zu mir nach Hause und gehen hoch in mein Schlafzimmer, wo es schnell dazu kommt, dass wir nackt auf dem Bett liegen."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:32
translate german rebadateend_52303b0f:

    # pc "Yeah, it was good. I'll see you later Reba."
    pc "Ja, das war gut. Bis später, Reba."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:33
translate german rebadateend_7657b93c:

    # rb "Uh, okay."
    rb "Äh, okay."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:34
translate german rebadateend_46d8c374:

    # rb "I'll see you later, [pcname]."
    rb "Bis später, [pcname]."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:35
translate german rebadateend_2fd019a4:

    # "She waves goodbye and gets into her truck and drives away."
    "Sie winkt zum Abschied, steigt in ihren Truck und fährt davon."

