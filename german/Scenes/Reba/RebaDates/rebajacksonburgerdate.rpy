# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:26
translate german rebajacksonburgerstartdate_65a4a9d8:

    # "I meet Reba in front of Jackson Burger and we walk in together."
    "Ich treffe Reba vor dem Jackson Burger und wir gehen zusammen rein."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:29
translate german rebajacksonburgerstartdate_aee9ac2a:

    # "We sit in the back in my usual booth."
    "Wir setzen uns hinten an meinen üblichen Tisch."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:31
translate german rebajacksonburgerstartdate_3f6c7563:

    # rb "I love this place. I don't get to come here very often, but it's so good when I do."
    rb "Ich liebe diesen Ort. Ich komme nicht sehr oft hierher, aber es ist so schön, wenn ich es tue."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:34
translate german rebajacksonburgerstartdate_e0d8209b:

    # "A few moments after we sit down, Mari walks up to take our order."
    "Kurz nachdem wir uns hingesetzt haben, kommt Mari herbei, um unsere Bestellung aufzunehmen."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:36
translate german rebajacksonburgerstartdate_32aad169:

    # fr "Hey, [pcname]. Who's your date?"
    fr "Hey, [pcname]. Wer ist deine Begleitung?"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:37
translate german rebajacksonburgerstartdate_293f257d:

    # pc "This is Reba. We met a little while back and have started dating a bit."
    pc "Das ist Reba. Wir haben uns vor einiger Zeit kennengelernt und sind seit kurzem zusammen."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:38
translate german rebajacksonburgerstartdate_50370da8:

    # fr "Hi, Reba. Nice to meet you."
    fr "Hallo, Reba. Schön, dich kennenzulernen."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:41
translate german rebajacksonburgerstartdate_b8319afc:

    # "Reba stands up and throws her arms around Mari, pulling her into a tight hug."
    "Reba steht auf, wirft ihre Arme um Mari und zieht sie in eine feste Umarmung."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:42
translate german rebajacksonburgerstartdate_fb8c8e3b:

    # rb "Aw girl, it's nice to meet you too."
    rb "Ach Mädchen, es ist auch schön, dich kennenzulernen."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:43
translate german rebajacksonburgerstartdate_9ab5b8d9:

    # rb "I guess you're another one of [pcname]'s friends?"
    rb "Ich nehme an, du bist auch eine von [pcname]s Freundinnen?"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:45
translate german rebajacksonburgerstartdate_8a01148f:

    # fr "Yep, that I am."
    fr "Ja, das bin ich."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:47
translate german rebajacksonburgerstartdate_eedef566:

    # fr "Yeah we're friends. Hopefully more eventually."
    fr "Ja, wir sind Freunde. Hoffentlich irgendwann mehr."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:49
translate german rebajacksonburgerstartdate_c260d345:

    # fr "Yeah, we're friends."
    fr "Ja, wir sind Freunde."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:52
translate german rebajacksonburgerstartdate_d628d3cf:

    # rb "Well he sure knows how to pick them, huh?"
    rb "Na, er weiß ja, wie man sie aussucht, was?"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:53
translate german rebajacksonburgerstartdate_32597348:

    # rb "You're just adorable."
    rb "Du bist einfach bezaubernd."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:54
translate german rebajacksonburgerstartdate_39dfd60b:

    # fr "Thanks! You're quite the cutie yourself."
    fr "Danke! Du bist selbst auch ganz schön süß."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:57
translate german rebajacksonburgerstartdate_a33dd63e:

    # fr "Well, I hope you two have a great date. I'll go get your food ready."
    fr "Na dann, ich hoffe, ihr zwei habt ein tolles Date. Ich bereite euer Essen vor."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:58
translate german rebajacksonburgerstartdate_099fcc61:

    # fr "Let me know if you need anything else."
