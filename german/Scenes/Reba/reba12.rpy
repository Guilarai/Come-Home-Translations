    # rb "Geez, you're going to make me cry with this stuff. It's too dang sweet."
    rb "Mensch, du bringst mich mit dem Zeug noch zum Weinen. Das ist viel zu süß."

# game/Scenes/Reba/reba12.rpy:156
translate german reba12_aa9ed4cf:

    # rb "Let's go watch the sunset."
    rb "Lass uns den Sonnenuntergang anschauen."

# game/Scenes/Reba/reba12.rpy:159
