    pc "Ich konnte sie zwischen ihnen sehen, als wäre sie etwas Echtes, Sichtbares, verstehst du?"

# game/Scenes/Reba/reba12.rpy:154
translate german reba12_8476930d:

    # rb "Yeah. I know what you mean."
    rb "Ja. Ich weiß, was du meinst."

# game/Scenes/Reba/reba12.rpy:155
