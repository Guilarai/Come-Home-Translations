# game/Scenes/Lisa/lisabreakfast.rpy:4
translate german lisabreakfast_b90ab6dc:

    # "Lisa must have gone to work early. She didn't cook any breakfast. I guess she's still upset."
    "Lisa muss wohl früh zur Arbeit gegangen sein. Sie hat kein Frühstück gemacht. Ich schätze, sie ist immer noch sauer."

# game/Scenes/Lisa/lisabreakfast.rpy:12
translate german lisabreakfast_5ba2cbf3:

    # "Lisa stands in the kitchen, cooking some eggs in a pan on the stove."
    "Lisa steht in der Küche und brät Eier in einer Pfanne auf dem Herd."

# game/Scenes/Lisa/lisabreakfast.rpy:19
translate german lisabreakfast_d41d8cd9:

    # voice 'voices/lisa_goodmorning.wav'
    voice 'voices/lisa_goodmorning.wav'

# game/Scenes/Lisa/lisabreakfast.rpy:20
translate german lisabreakfast_09b21b2a:

    # sp "Good morning honey. Want some breakfast?"
    sp "Guten Morgen, Schatz. Möchtest du etwas zum Frühstück?"

# game/Scenes/Lisa/lisabreakfast.rpy:35
translate german nottodaymom_d0417e78:

    # sp "Okay honey, let me know if you change your mind."
    sp "Okay, Schatz, sag mir Bescheid, wenn du es dir anders überlegst."

# game/Scenes/Lisa/lisabreakfast.rpy:45
translate german lisabreakfastconvo_c299cac3:

    # sp "I'll cook you some eggs and bacon."
    sp "Ich mache dir Eier und Speck."

# game/Scenes/Lisa/lisabreakfast.rpy:46
translate german lisabreakfastconvo_e45e3b16:

    # "She returns to the stove and cooks us both breakfast."
    "Sie geht zurück zum Herd und kocht uns beiden Frühstück."

# game/Scenes/Lisa/lisabreakfast.rpy:49
translate german lisabreakfastconvo_2ccb9eb9:

    # "Then we sit down together and have a nice conversation while eating breakfast."
    "Dann setzen wir uns zusammen und unterhalten uns nett, während wir frühstücken."

# game/Scenes/Lisa/lisabreakfast.rpy:51
translate german lisabreakfastconvo_280140a3:

    # "Afterwards, she cleans up the plates and I head upstairs and get dressed for the day."
    "Danach räumt sie den Abwasch weg und ich gehe nach oben, um mich für den Tag anzuziehen."

