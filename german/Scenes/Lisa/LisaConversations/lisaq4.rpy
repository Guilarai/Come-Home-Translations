translate german lisaq4_a2f529d8:

    # sp "And I'm pretty sure you're sleeping with Tammy too."
    sp "Und ich bin mir ziemlich sicher, dass du auch mit Tammy schläfst."

# game/Scenes/Lisa/LisaConversations/lisaq4.rpy:38
translate german lisaq4_0415136b:

    # sp "But it doesn't matter who else you're sleeping with."
    sp "Aber es spielt keine Rolle, mit wem du sonst noch schläfst."

# game/Scenes/Lisa/LisaConversations/lisaq4.rpy:39
translate german lisaq4_944339c0:

    # sp "I wouldn't want you to only be with me anyway."
    sp "Ich würde sowieso nicht wollen, dass du nur mit mir zusammen bist."

# game/Scenes/Lisa/LisaConversations/lisaq4.rpy:42
translate german lisaq4_96e9445f:

