# game/Scenes/Lisa/LisaConversations/lisas5.rpy:13
translate german lisas5_1bd10091:

    # sp "That's easy. Suzy of course."
    sp "Das ist einfach. Suzy natürlich."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:14
translate german lisas5_092a2938:

    # sp "That girl means everything to me."
    sp "Dieses Mädchen bedeutet mir alles."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:16
translate german lisas5_52473454:

    # sp "She has an attitude sometimes. She gets that from me. But she can be so sweet and she's so smart."
    sp "Manchmal hat sie eine ganz eigene Art. Das hat sie von mir. Aber sie kann so lieb sein und sie ist so klug."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:17
translate german lisas5_34f51681:

    # sp "I can't wait to see what she does with her life."
    sp "Ich kann es kaum erwarten zu sehen, was sie aus ihrem Leben macht."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:18
translate german lisas5_d0ef84f3:

    # sp "She's going to do so much more than I have."
    sp "Sie wird so viel mehr erreichen als ich."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:20
translate german lisas5_dcb5444e:

    # sp "I'm proud of you too of course, but I can't take credit for you. We barely had a year together before you left for Brazil."
    sp "Ich bin natürlich auch stolz auf dich, aber ich kann mir das nicht als Verdienst anrechnen. Wir hatten kaum ein Jahr zusammen, bevor du nach Brasilien gegangen bist."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:21
translate german lisas5_a3c1befd:

    # sp "I know your father was proud of you too though. Just as proud as I am of my Suzy."
    sp "Ich weiß aber, dass dein Vater auch stolz auf dich war. Genauso stolz, wie ich auf meine Suzy bin."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:22
translate german lisas5_cda2f52e:

    # pc "Thanks, [mom]."
    pc "Danke, [mom]."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:24
translate german lisas5_015a459b:

    # sp "You're welcome. Love you, [pcname]."
    sp "Gern geschehen. Ich liebe dich, [pcname]."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:25
translate german lisas5_f785b72d:

    # sp "Love you too, [mom]."
    sp "Ich liebe dich auch, [mom]."

