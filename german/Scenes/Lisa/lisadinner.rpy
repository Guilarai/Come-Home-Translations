# game/Scenes/Lisa/lisadinner.rpy:3
translate german lisadinner_e20dd2c0:

    # "Usually Lisa would be cooking dinner here on the weekend, but she's not here."
    "Normalerweise würde Lisa hier am Wochenende das Abendessen kochen, aber sie ist nicht da."

# game/Scenes/Lisa/lisadinner.rpy:4
translate german lisadinner_7b04e990:

    # "I wonder if she's still upset about before?"
    "Ich frage mich, ob sie wegen vorhin immer noch sauer ist?"

# game/Scenes/Lisa/lisadinner.rpy:5
translate german lisadinner_6a8bd90c:

    # "I guess she just needs some more time."
    "Ich schätze, sie braucht einfach noch etwas Zeit."

# game/Scenes/Lisa/lisadinner.rpy:8
translate german lisadinner_17ebb7b6:

    # "Lisa stands in the kitchen, cooking dinner at the stove."
    "Lisa steht in der Küche und kocht am Herd das Abendessen."

# game/Scenes/Lisa/lisadinner.rpy:9
translate german lisadinner_622e58a4:

    # "She looks tired, but still turns towards me with a smile."
    "Sie sieht müde aus, dreht sich aber trotzdem mit einem Lächeln zu mir um."

# game/Scenes/Lisa/lisadinner.rpy:12
translate german lisadinner_dbdf9d75:

    # sp "Hey honey. You joining me for dinner?"
    sp "Hey Schatz. Isst du mit mir zu Abend?"

# game/Scenes/Lisa/lisadinner.rpy:21
translate german lisadinner_d0417e78:

    # sp "Okay honey, let me know if you change your mind."
    sp "Okay Schatz, sag mir Bescheid, wenn du es dir anders überlegst."

# game/Scenes/Lisa/lisadinner.rpy:67
translate german lisadinnerconversation_18c6396f:

    # sp "I'm glad. It gets lonely eating by myself."
    sp "Das freut mich. Es ist einsam, alleine zu essen."

# game/Scenes/Lisa/lisadinner.rpy:69
translate german lisadinnerconversation_f7385cce:

    # "She returns to the stove and cooks us both dinner."
    "Sie geht zurück zum Herd und kocht uns beiden das Abendessen."

# game/Scenes/Lisa/lisadinner.rpy:73
translate german lisadinnerconversation_2aba8403:

    # "Then we sit together in the dining room and have a nice conversation while eating."
    "Dann sitzen wir zusammen im Esszimmer und unterhalten uns nett beim Essen."

# game/Scenes/Lisa/lisadinner.rpy:76
translate german lisadinnerconversation_ac9094b5:

    # "Afterwards, we go to the kitchen and I help with the dishes."
    "Danach gehen wir in die Küche und ich helfe beim Abwasch."

# game/Scenes/Lisa/lisadinner.rpy:77
translate german lisadinnerconversation_74aec54b:

    # sp "Thanks for having dinner with me honey. I really enjoyed it."
    sp "Danke, dass du mit mir zu Abend gegessen hast, Schatz. Es hat mir wirklich gut gefallen."

# game/Scenes/Lisa/lisadinner.rpy:78
translate german lisadinnerconversation_6ecfecf0:

    # pc "Any time, [mom]."
    pc "Gern geschehen, [mom]."

# game/Scenes/Lisa/lisadinner.rpy:80
translate german lisadinnerconversation_79c86a4f:

    # sp "Love you, baby."
    sp "Ich liebe dich, Baby."

# game/Scenes/Lisa/lisadinner.rpy:81
translate german lisadinnerconversation_ce2ae2bf:

    # pc "Love you too."
    pc "Ich liebe dich auch."

# game/Scenes/Lisa/lisadinner.rpy:82
translate german lisadinnerconversation_db14aa5a:

    # "We finish up and Lisa goes to her bedroom for the night."
    "Wir sind fertig und Lisa geht in ihr Schlafzimmer, um sich für die Nacht zurückzuziehen."

