translate german connie15_4fb3d9c8:

    # con "Do you want a smoke?"
    con "Willst du auch eine rauchen?"

# game/Scenes/Connie/connie15.rpy:208
translate german connie15_cdac1b0a:

    # pc "No thanks, I don't smoke cigarettes."
    pc "Nein danke, ich rauche keine Zigaretten."

# game/Scenes/Connie/connie15.rpy:209
translate german connie15_7d74ff93:

    # con "I don't really either. I think I've had this pack for a year or so."
    con "Ich eigentlich auch nicht. Ich glaube, ich habe diese Packung schon seit etwa einem Jahr."

# game/Scenes/Connie/connie15.rpy:212
translate german connie15_98da17ed:

    # con "Right now, after that, a cigarette hits just right."
    con "Gerade jetzt, nach dem, tut eine Zigarette richtig gut."

# game/Scenes/Connie/connie15.rpy:213
translate german connie15_596c0f44:

    # con "You know, besides my husband, you're the first man I've had sex with in fifty years."
    con "Weißt du, abgesehen von meinem Mann bist du der erste Mann, mit dem ich seit fünfzig Jahren Sex hatte."

# game/Scenes/Connie/connie15.rpy:214
translate german connie15_6a75940e:

    # pc "Really? You and Jackson never had anything?"
    pc "Wirklich? Du und Jackson hattet nie etwas?"

# game/Scenes/Connie/connie15.rpy:215
translate german connie15_03c8c55b:

    # con "Naw, he's like a brother to me. He's never looked at me like that."
    con "Nee, er ist wie ein Bruder für mich. Er hat mich nie so angesehen."

# game/Scenes/Connie/connie15.rpy:216
translate german connie15_42e3bab3:

    # con "Nobody ever really looks at me like that."
    con "Niemand sieht mich jemals wirklich so an."

# game/Scenes/Connie/connie15.rpy:219
translate german connie15_bab07018:

    # pc "I don't see why not. You're a good looking woman."
    pc "Ich verstehe nicht, warum nicht. Du bist eine gut aussehende Frau."

# game/Scenes/Connie/connie15.rpy:220
translate german connie15_2a7d9ea2:

    # con "I try, but nobody is interested in an old lady."
    con "Ich versuche es, aber niemand interessiert sich für eine alte Dame."

# game/Scenes/Connie/connie15.rpy:221
translate german connie15_f0f40b8d:

    # con "You got to use it while you're young, you know? Else you end up stuck in an old body, all alone."
    con "Man muss es nutzen, solange man jung ist, weißt du? Sonst landet man in einem alten Körper, ganz allein."

# game/Scenes/Connie/connie15.rpy:222
translate german connie15_007fbff2:

    # pc "You have regrets?"
    pc "Hast du etwas zu bereuen?"

# game/Scenes/Connie/connie15.rpy:223
translate german connie15_79491ffd:

    # con "Oh, no. Not really."
    con "Oh, nein. Nicht wirklich."

# game/Scenes/Connie/connie15.rpy:224
translate german connie15_bf42fbfd:

    # con "My husband was good to me. We had a lot of really good years."
    con "Mein Mann war gut zu mir. Wir hatten viele wirklich schöne Jahre."

# game/Scenes/Connie/connie15.rpy:227
translate german connie15_8fb15acf:

    # con "And that man was just as gifted as you are in bed."
    con "Und dieser Mann war im Bett genauso begabt wie du."

# game/Scenes/Connie/connie15.rpy:228
translate german connie15_acf7a854:

    # con "God, I miss him."
    con "Gott, ich vermisse ihn."

# game/Scenes/Connie/connie15.rpy:231
translate german connie15_25ac1736:

    # pc "Did you have any children?"
    pc "Hattest du Kinder?"

# game/Scenes/Connie/connie15.rpy:232
translate german connie15_4575dead:

    # con "One. A boy. Chase."
    con "Eines. Einen Jungen. Chase."

# game/Scenes/Connie/connie15.rpy:233
translate german connie15_5b0fb844:

    # con "He died over in Afghanistan."
    con "Er ist in Afghanistan gefallen."

# game/Scenes/Connie/connie15.rpy:234
translate german connie15_6c6d9416_1:

    # pc "Oh, I'm sorry."
    pc "Oh, das tut mir leid."

# game/Scenes/Connie/connie15.rpy:237
translate german connie15_0fa6aba4_1:

    # con "It's okay."
    con "Ist schon gut."

# game/Scenes/Connie/connie15.rpy:238
translate german connie15_d075efd8:

    # con "Sometimes I feel like I died too..."
    con "Manchmal fühle ich mich, als wäre ich auch gestorben …"

# game/Scenes/Connie/connie15.rpy:239
translate german connie15_454cba6d:

    # con "... and I'm just stuck here, waiting for my turn to go meet them."
    con "… und ich sitze einfach hier fest und warte darauf, dass ich an der Reihe bin, zu ihnen zu gehen."

# game/Scenes/Connie/connie15.rpy:242
translate german connie15_19979052:

    # con "Thank you for making me feel alive for a little while."
    con "Danke, dass du mir das Gefühl gegeben hast, für eine Weile lebendig zu sein."

# game/Scenes/Connie/connie15.rpy:243
translate german connie15_2911487b:

    # con "You're a good kid."
    con "Du bist ein guter Junge."

# game/Scenes/Connie/connie15.rpy:246
translate german connie15_109a5d63:

    # con "I think you and Brandi make a very nice couple."
    con "Ich finde, du und Brandi seid ein sehr hübsches Paar."

# game/Scenes/Connie/connie15.rpy:247
translate german connie15_68f01008:

    # con "You should consider settling down with her."
    con "Du solltest darüber nachdenken, dich mit ihr niederzulassen."

# game/Scenes/Connie/connie15.rpy:248
translate german connie15_19e05b84:

    # con "I see you coming into Jackson's with different girls."
    con "Ich sehe dich immer mit verschiedenen Mädchen bei Jackson’s hereinkommen."

# game/Scenes/Connie/connie15.rpy:249
translate german connie15_fedfc4a9:

    # con "You're young. That's a good thing. Experiment."
    con "Du bist jung. Das ist gut so. Probier dich aus."

# game/Scenes/Connie/connie15.rpy:250
translate german connie15_ec119d97:

    # con "But eventually, I hope you'll pick a girl and start a life and a family with her."
    con "Aber irgendwann hoffe ich, dass du dir ein Mädchen aussuchst und mit ihr ein Leben und eine Familie gründest."

# game/Scenes/Connie/connie15.rpy:251
translate german connie15_1dc28a58:

    # con "And I hope you'll make each other very happy."
    con "Und ich hoffe, ihr werdet euch gegenseitig sehr glücklich machen."

# game/Scenes/Connie/connie15.rpy:252
translate german connie15_a40b7cd5:

    # pc "Thanks, Connie."
    pc "Danke, Connie."

# game/Scenes/Connie/connie15.rpy:253
translate german connie15_0fd31492:

    # con "All right, that's enough reminiscing. Time to get dressed."
    con "So, genug der Erinnerungen. Zeit, sich anzuziehen."

# game/Scenes/Connie/connie15.rpy:256
translate german connie15_2f1120e6:

    # "Before I leave, she hands me a tin full of chocolate chip cookies."
    "Bevor ich gehe, reicht sie mir eine Dose voller Schokoladenkekse."

# game/Scenes/Connie/connie15.rpy:257
translate german connie15_189fa119:

    # con "I made these for Jackson, but he can have the next batch. You enjoy. You earned them."
    con "Die habe ich für Jackson gebacken, aber die nächste Ladung kann er haben. Genieß sie. Du hast sie dir verdient."

# game/Scenes/Connie/connie15.rpy:258
translate german connie15_25e0f073:

    # con "Thanks again for making my day."
    con "Nochmals danke, dass du mir den Tag versüßt hast."

# game/Scenes/Connie/connie15.rpy:259
translate german connie15_a351accf:

    # con "I don't think we'll do this again, but I'm glad to have spent some time with you."
    con "Ich glaube nicht, dass wir das noch einmal machen werden, aber ich bin froh, etwas Zeit mit dir verbracht zu haben."

# game/Scenes/Connie/connie15.rpy:260
translate german connie15_a9da76fd:

    # pc "Me too, Connie."
    pc "Ich auch, Connie."

# game/Scenes/Connie/connie15.rpy:261
translate german connie15_c6512378:

    # con "You take care."
    con "Pass auf dich auf."

# game/Scenes/Connie/connie15.rpy:264
translate german connie15_18c0b69c:

    # "I leave Connie's house and drive away."
    "Ich verlasse Connies Haus und fahre los."

# game/Scenes/Connie/connie15.rpy:265
translate german connie15_313c822e:

    # "I hope she'll be okay. She's a sweet lady."
    "Ich hoffe, es geht ihr gut. Sie ist eine süße Dame."

# game/Scenes/Connie/connie15.rpy:266
translate german connie15_f74a794a:

    # "And she gives a killer gummer."
    "Und sie gibt einen hammermäßigen Zungenkuss."

