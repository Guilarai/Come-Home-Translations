# game/Scenes/Update20/u20n.rpy:2
translate german u20n_0157cb27:

    # "For now, I should go see Bai."
    "Jetzt sollte ich erst mal zu Bai gehen."

# game/Scenes/Update20/u20n.rpy:5
translate german u20n_5e377e6b:

    # "I drive to Bai's apartment and knock on the door."
    "Ich fahre zu Bais Wohnung und klopfe an die Tür."

# game/Scenes/Update20/u20n.rpy:6
translate german u20n_cd826cbc:

    # "It's late, but I have to see him."
    "Es ist spät, aber ich muss ihn sehen."

# game/Scenes/Update20/u20n.rpy:10
translate german u20n_435415c3:

    # "After a few moments, Bai opens the door."
    "Nach ein paar Augenblicken öffnet Bai die Tür."

# game/Scenes/Update20/u20n.rpy:11
translate german u20n_fce568f9:

    # bai "Holy shit, [pcname]! You're back!"
    bai "Heilige Scheiße, [pcname]! Du bist zurück!"

# game/Scenes/Update20/u20n.rpy:14
translate german u20n_7e7c2a33:

    # "I wrap my arms around Bai, pulling him in tight."
    "Ich schlinge meine Arme um Bai und ziehe ihn fest an mich."

# game/Scenes/Update20/u20n.rpy:15
translate german u20n_e660f3f5:

    # bai "I thought that machine killed you!"
    bai "Ich dachte, diese Maschine hätte dich umgebracht!"

# game/Scenes/Update20/u20n.rpy:16
translate german u20n_52e92c2d:

    # bai "I thought I might never see you again."
    bai "Ich dachte, ich würde dich nie wieder sehen."

# game/Scenes/Update20/u20n.rpy:19
translate german u20n_e99c4913:

    # bai "So what happened? Did you really go to another universe?"
    bai "Was ist denn passiert? Bist du wirklich in ein anderes Universum gereist?"

# game/Scenes/Update20/u20n.rpy:20
translate german u20n_4859fa2f:

    # pc "Yeah, I did. I saw my dad."
    pc "Ja, das bin ich. Ich habe meinen Vater gesehen."

# game/Scenes/Update20/u20n.rpy:21
translate german u20n_d8ec5a44:

    # bai "Wow. Are you okay?"
    bai "Wow. Geht es dir gut?"

# game/Scenes/Update20/u20n.rpy:22
translate german u20n_3c3fa8e3:

    # pc "Yeah, I'm great. I'll tell you everything tomorrow, I promise."
    pc "Ja, mir geht es super. Ich erzähle dir morgen alles, versprochen."

# game/Scenes/Update20/u20n.rpy:25
translate german u20n_feac206a:

    # bai "I'm just glad you're back."
    bai "Ich bin einfach nur froh, dass du zurück bist."

# game/Scenes/Update20/u20n.rpy:26
translate german u20n_03eaad50:

    # pc "Me too."
    pc "Ich auch."

# game/Scenes/Update20/u20n.rpy:29
translate german u20n_61ae245c:

    # "He leans in and kisses me softly."
    "Er beugt sich vor und küsst mich sanft."

# game/Scenes/Update20/u20n.rpy:30
translate german u20n_8466d1ae:

    # bai "Whoo, damn, you smell pretty bad though."
    bai "Puh, verdammt, du riechst allerdings ziemlich übel."

# game/Scenes/Update20/u20n.rpy:31
translate german u20n_dfccd340:

    # bai "Let's take a shower and go to bed."
    bai "Lass uns duschen und ins Bett gehen."

