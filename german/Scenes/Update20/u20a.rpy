    # pc "THIRTY!?"
    pc "DREISSIG!?"

# game/Scenes/Update20/u20a.rpy:23
translate german u20a_d92a0cb0:

    # wt "Yes. It's been a difficult time for me as well."
    wt "Ja. Es war auch für mich eine schwere Zeit."

# game/Scenes/Update20/u20a.rpy:27
translate german u20a_c77aa2a4:

    # wt "Lisa has been very persistent and is nearing her breaking point. I suspect she may involve the police soon."
    wt "Lisa war sehr hartnäckig und steht kurz vor dem Zusammenbruch. Ich vermute, sie wird bald die Polizei einschalten."

# game/Scenes/Update20/u20a.rpy:28
translate german u20a_c1e86e55:

    # wt "She thinks I killed both you and your dad."
    wt "Sie glaubt, ich hätte dich und deinen Vater umgebracht."

# game/Scenes/Update20/u20a.rpy:32
translate german u20a_9a9b3000:

    # wt "Suzy and Tammy have been after me every day. I don't think I could hold them off from calling the police for much longer."
    wt "Suzy und Tammy haben mich jeden Tag verfolgt. Ich glaube nicht, dass ich sie noch viel länger davon abhalten kann, die Polizei zu rufen."

# game/Scenes/Update20/u20a.rpy:33
translate german u20a_24d0649b:

