# game/Scenes/Update20/u20a.rpy:120
translate german u20a_b931c84d:

    # wt "Your car and your cell phone are still here. I hid them out back."
    wt "Dein Auto und dein Handy sind noch hier. Ich habe sie hinten versteckt."

# game/Scenes/Update20/u20a.rpy:121
translate german u20a_167b4558:

    # wt "You should go home and notify everyone that you are safe."
    wt "Du solltest nach Hause gehen und allen Bescheid geben, dass es dir gut geht."

# game/Scenes/Update20/u20a.rpy:122
