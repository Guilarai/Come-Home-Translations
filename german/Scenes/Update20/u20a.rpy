# game/Scenes/Update20/u20a.rpy:14
translate german u20a_45da60e7:

    # wt "Finally, you're back. Took you long enough."
    wt "Endlich bist du zurück. Das hat aber lange gedauert."

# game/Scenes/Update20/u20a.rpy:15
translate german u20a_fd9e8f88:

    # wt "I really thought I might be going to jail!"
    wt "Ich dachte wirklich, ich würde ins Gefängnis kommen!"

# game/Scenes/Update20/u20a.rpy:18
translate german u20a_a33db221:

    # pc "How long have I been gone?"
    pc "Wie lange war ich weg?"

# game/Scenes/Update20/u20a.rpy:19
translate german u20a_e000eef8:

    # wt "Thirty days."
    wt "Dreißig Tage."

# game/Scenes/Update20/u20a.rpy:22
