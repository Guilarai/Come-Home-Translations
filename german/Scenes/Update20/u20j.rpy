# game/Scenes/Update20/u20j.rpy:2
translate german u20j_be7d1e50:

    # "For now, I should go see Adrian."
    "Jetzt sollte ich erst mal zu Adrian fahren."

# game/Scenes/Update20/u20j.rpy:5
translate german u20j_33260fe1:

    # "I drive over to Adrian's house and ring the doorbell."
    "Ich fahre zu Adrians Haus und klingele."

# game/Scenes/Update20/u20j.rpy:6
translate german u20j_4fc89239:

    # "It's late and I hate to wake her, but I need to see her."
    "Es ist spät und ich will sie ungern wecken, aber ich muss sie sehen."

# game/Scenes/Update20/u20j.rpy:9
translate german u20j_494a3331:

    # "Adrian's Mom" "Hello? Do you know how late it is?"
    "Adrian's Mom" "Hallo? Weißt du, wie spät es ist?"

# game/Scenes/Update20/u20j.rpy:10
translate german u20j_7d43c485:

    # pc "I'm sorry, I know. I'm a friend of Adrian's."
    pc "Tut mir leid, ich weiß. Ich bin ein Freund von Adrian."

# game/Scenes/Update20/u20j.rpy:11
translate german u20j_87309e2a:

    # pc "Could I talk to her, please?"
    pc "Könnte ich bitte mit ihr sprechen?"

# game/Scenes/Update20/u20j.rpy:12
translate german u20j_ad012933:

    # "Adrian's Mom" "Oh, are you [pcname]? She's been worried about you for weeks."
    "Adrian's Mom" "Oh, sind Sie das [pcname]? Sie macht sich schon seit Wochen Sorgen um Sie."

# game/Scenes/Update20/u20j.rpy:13
translate german u20j_332de7e5:

    # pc "Yes, I'm sorry. That's me."
    pc "Ja, tut mir leid. Das bin ich."

# game/Scenes/Update20/u20j.rpy:16
translate german u20j_1a0d366a:

    # "Adrian's Mom" "She's going to be really happy to see you."
    "Adrian's Mom" "Sie wird sich riesig freuen, Sie zu sehen."

# game/Scenes/Update20/u20j.rpy:17
translate german u20j_1108c1b8:

    # "Adrian's Mom" "You can go up and see her, just keep things PG, okay?"
    "Adrian's Mom" "Sie können hochgehen und sie besuchen, aber bitte benehmen Sie sich anständig, okay?"

# game/Scenes/Update20/u20j.rpy:18
translate german u20j_e170ff6c:

    # pc "Yes, ma'am. Thank you."
    pc "Ja, Ma'am. Danke."

# game/Scenes/Update20/u20j.rpy:22
translate german u20j_f5638052:

    # "I walk quietly up the stairs and into Adrian's room. She's in bed, sleeping."
    "Ich gehe leise die Treppe hinauf und in Adrians Zimmer. Sie liegt im Bett und schläft."

# game/Scenes/Update20/u20j.rpy:25
translate german u20j_cbba5bfa:

    # "Trying not to wake her immediately, I lie next to her and wrap my arms around her."
    "Um sie nicht sofort zu wecken, lege ich mich neben sie und lege meine Arme um sie."

# game/Scenes/Update20/u20j.rpy:28
translate german u20j_c981bd85:

    # "She jolts awake and looks at me, shocked."
    "Sie schreckt hoch und sieht mich erschrocken an."

# game/Scenes/Update20/u20j.rpy:29
translate german u20j_a857ee55:

    # gg "What the fuck? [pcname]?"
    gg "Was zum Teufel? [pcname]?"

# game/Scenes/Update20/u20j.rpy:32
translate german u20j_0f0952fe:

    # "I don't answer. I just pull her close and kiss her deeply."
    "Ich antworte nicht. Ich ziehe sie einfach an mich und küsse sie innig."

# game/Scenes/Update20/u20j.rpy:33
translate german u20j_09b23034:

    # gg "Fuck, I was so worried about you. I thought you weren't ever coming back."
    gg "Verdammt, ich habe mir solche Sorgen um dich gemacht. Ich dachte, du kommst nie wieder zurück."

# game/Scenes/Update20/u20j.rpy:36
translate german u20j_b1adfb65:

    # gg "So you went to another world, for real?"
    gg "Du warst also wirklich in einer anderen Welt?"

# game/Scenes/Update20/u20j.rpy:37
translate german u20j_e5f2498c:

    # pc "Yeah, I did."
    pc "Ja, das war ich."

# game/Scenes/Update20/u20j.rpy:38
translate german u20j_29a8b357:

    # gg "And you saw your dad?"
    gg "Und du hast deinen Vater gesehen?"

# game/Scenes/Update20/u20j.rpy:39
translate german u20j_c417e350:

    # pc "Yeah."
    pc "Ja."

# game/Scenes/Update20/u20j.rpy:40
translate german u20j_fa6e7016:

    # gg "You have to tell me everything."
    gg "Du musst mir alles erzählen."

# game/Scenes/Update20/u20j.rpy:41
translate german u20j_0bb899f2:

    # pc "I will, I promise. Tomorrow."
    pc "Das werde ich, versprochen. Morgen."

# game/Scenes/Update20/u20j.rpy:44
translate german u20j_92c42e64:

    # gg "Right. Tomorrow. I'm just glad you're back!"
    gg "Genau. Morgen. Ich bin einfach nur froh, dass du zurück bist!"

# game/Scenes/Update20/u20j.rpy:45
translate german u20j_d2639c3b:

    # gg "I can't believe you're back."
    gg "Ich kann nicht glauben, dass du zurück bist."

# game/Scenes/Update20/u20j.rpy:46
translate german u20j_c01c395d:

    # gg "I'm so happy, I can't stand it."
    gg "Ich bin so glücklich, ich halte es kaum aus."

# game/Scenes/Update20/u20j.rpy:49
translate german u20j_f432b969:

    # "I pull her close and kiss her again, feeling her warmth."
    "Ich ziehe sie an mich und küsse sie erneut, spüre ihre Wärme."

# game/Scenes/Update20/u20j.rpy:50
translate german u20j_bf4f63bf:

    # gg "Good idea. Shut me up with your mouth."
    gg "Gute Idee. Bring mich mit deinem Mund zum Schweigen."

# game/Scenes/Update20/u20j.rpy:51
translate german u20j_1530bf0e:

    # gg "I just missed you so much."
    gg "Ich habe dich einfach so sehr vermisst."

# game/Scenes/Update20/u20j.rpy:52
translate german u20j_9c24a5ca:

    # pc "I missed you too, Adrian."
    pc "Ich habe dich auch vermisst, Adrian."

