    voice 'voices/mari_heythere.mp3'

# game/Scenes/Mari/mari3.rpy:13
translate german mari3_5fec8fcf:

    # fr "Hey there, [pcname]. How are you today?"
    fr "Hey, [pcname]. Wie geht es dir heute?"

# game/Scenes/Mari/mari3.rpy:14
translate german mari3_b835b9eb:

    # pc "I'm doing great, how's my favorite waitress?"
    pc "Mir geht es super, wie geht es meiner Lieblingskellnerin?"

# game/Scenes/Mari/mari3.rpy:15
translate german mari3_334e62bd:

    # fr "Much better now that her favorite customer is here."
    fr "Viel besser, jetzt wo ihr Lieblingsgast da ist."

# game/Scenes/Mari/mari3.rpy:20
translate german mari3_747e36cd:

    # pc "Mari, there was something I wanted to ask you."
    pc "Mari, ich wollte dich etwas fragen."

# game/Scenes/Mari/mari3.rpy:21
translate german mari3_96d48818:

    # fr "Ask away."
    fr "Frag ruhig."

# game/Scenes/Mari/mari3.rpy:22
translate german mari3_05be9386:

    # pc "Would you want to go out on a date with me sometime?"
    pc "Möchtest du mal mit mir ausgehen?"

# game/Scenes/Mari/mari3.rpy:25
translate german mari3_d41d8cd9_1:

    # voice 'voices/mari_idloveto.mp3'
    voice 'voices/mari_idloveto.mp3'

# game/Scenes/Mari/mari3.rpy:26
translate german mari3_ad1c3ebd:

    # fr "Really? I'd love to."
    fr "Wirklich? Das würde ich sehr gerne."

# game/Scenes/Mari/mari3.rpy:27
translate german mari3_1da24e01:

    # pc "Awesome."
    pc "Super."

# game/Scenes/Mari/mari3.rpy:29
translate german mari3_008e9d39:

    # fr "I don't get to go out on dates very often, and I do really like you."
    fr "Ich gehe nicht oft aus, und ich mag dich wirklich sehr."

# game/Scenes/Mari/mari3.rpy:30
translate german mari3_098a6e78:

    # fr "I'm busy a lot, but I'll give you my phone number and maybe we could go out in the evening on a weekend sometime?"
    fr "Ich habe viel zu tun, aber ich gebe dir meine Telefonnummer, und vielleicht könnten wir mal an einem Wochenende abends ausgehen?"

# game/Scenes/Mari/mari3.rpy:31
translate german mari3_d2954fc0:

    # pc "That sounds great."
    pc "Das klingt toll."

# game/Scenes/Mari/mari3.rpy:32
translate german mari3_52d8f6ae:

    # fr "Oh I'm so excited."
    fr "Oh, ich bin so aufgeregt."

# game/Scenes/Mari/mari3.rpy:34
translate german mari3_e7685f1d:

    # fr "Here's my phone number."
    fr "Hier ist meine Telefonnummer."

# game/Scenes/Mari/mari3.rpy:36
translate german mari3_639d3c6f:

    # fr "You can call me any time, but I won't be able to talk while I'm working, and I work a lot!"
    fr "Du kannst mich jederzeit anrufen, aber während der Arbeit kann ich nicht telefonieren, und ich arbeite viel!"

# game/Scenes/Mari/mari3.rpy:37
translate german mari3_73bf0030:

    # pc "I'll definitely give you a call sometime."
    pc "Ich werde dich auf jeden Fall mal anrufen."

# game/Scenes/Mari/mari3.rpy:38
translate german mari3_c2bff929:

    # fr "Good, I can't wait!"
    fr "Gut, ich kann es kaum erwarten!"

# game/Scenes/Mari/mari3.rpy:39
translate german mari3_910292d4:

    # fr "I better go get your food."
    fr "Ich hole dir besser dein Essen."

# game/Scenes/Mari/mari3.rpy:40
translate german mari3_63023601:

    # pc "Okay."
    pc "Okay."

# game/Scenes/Mari/mari3.rpy:42
translate german mari3_0aa5dfbc:

    # "She starts to walk away, then looks back at me."
    "Sie geht los, dreht sich dann aber noch einmal zu mir um."

# game/Scenes/Mari/mari3.rpy:43
translate german mari3_8f6f1358:

    # fr "Thanks for asking me out. I'm really looking forward to our date."
    fr "Danke, dass du mich gefragt hast. Ich freue mich schon sehr auf unser Date."

# game/Scenes/Mari/mari3.rpy:44
translate german mari3_03eaad50:

    # pc "Me too."
    pc "Ich mich auch."

# game/Scenes/Mari/mari3.rpy:45
translate german mari3_7553af6a:

    # "With that, she smiles and leaves to get my food."
    "Damit lächelt sie und geht, um mein Essen zu holen."

# game/Scenes/Mari/mari3.rpy:47
translate german mari3_43045d37:

    # "We don't talk much more while I eat and she has to help other customers, but every time she looks at me, she's smiling."
    "Wir reden nicht mehr viel, während ich esse und sie anderen Kunden helfen muss, aber jedes Mal, wenn sie mich ansieht, lächelt sie."

# game/Scenes/Mari/mari3.rpy:48
translate german mari3_2d44a908:

    # "The smile is different than usual. More sincere almost."
    "Das Lächeln ist anders als sonst. Fast aufrichtiger."

# game/Scenes/Mari/mari3.rpy:51
translate german maritip3_474b8780:

    # "I leave 10 dollars on the table."
    "Ich lasse 10 Dollar auf dem Tisch liegen."

# game/Scenes/Mari/mari3.rpy:53
translate german maritip3_bbc6048f:

    # "No need to leave money, I'll give her something better later."
    "Du musst kein Geld da lassen, ich werde ihr später etwas Besseres geben."

# game/Scenes/Mari/mari3.rpy:55
translate german maritip3_c56febff:

    # "Then I start to walk out towards my car."
    "Dann gehe ich hinaus zu meinem Auto."

# game/Scenes/Mari/mari3.rpy:58
translate german maritip3_e3c07fca:

    # "Mari stops me though, wrapping her arms around me and pulling me into a hug."
    "Mari hält mich jedoch auf, legt ihre Arme um mich und zieht mich in eine Umarmung."

# game/Scenes/Mari/mari3.rpy:59
translate german maritip3_7db5e01d:

    # fr "I can't wait to see you again."
    fr "Ich kann es kaum erwarten, dich wiederzusehen."

# game/Scenes/Mari/mari3.rpy:60
translate german maritip3_98e7787f:

    # fr "Be sure you call me."
    fr "Ruf mich unbedingt an."

# game/Scenes/Mari/mari3.rpy:61
translate german maritip3_5bc44b07:

    # pc "I will."
    pc "Das werde ich."

# game/Scenes/Mari/mari3.rpy:62
translate german maritip3_2e512b95:

    # fr "Okay, take care."
    fr "Okay, pass auf dich auf."

# game/Scenes/Mari/mari3.rpy:65
translate german maritip3_5794a059:

    # "She releases me and I go outside. She's really excited about our date it seems."
    "Sie lässt mich los und ich gehe nach draußen. Sie scheint sich wirklich auf unser Date zu freuen."

# game/Scenes/Mari/mari3.rpy:66
translate german maritip3_f0d4672c:

    # "I'm excited too. It should be fun."
    "Ich freue mich auch. Das wird bestimmt lustig."

