# game/Scenes/Mari/mari0.rpy:13
translate german mari0_268d9953:

    # "After about five minutes, a young woman with beautiful curly hair and an even prettier smile walks up with my order."
    "Nach etwa fünf Minuten kommt eine junge Frau mit wunderschönen Locken und einem noch schöneren Lächeln mit meiner Bestellung herbei."

# game/Scenes/Mari/mari0.rpy:14
translate german mari0_61ae3800:

    # fr "Hey there. This must be yours."
    fr "Hallo. Das muss für dich sein."

# game/Scenes/Mari/mari0.rpy:16
translate german mari0_d41d8cd9:

    # voice 'voices/mari_immariwaitress.mp3'
    voice 'voices/mari_immariwaitress.mp3'

# game/Scenes/Mari/mari0.rpy:17
translate german mari0_83cd92ec:

    # fr "I'm Mari. I'll be your waitress today."
    fr "Ich bin Mari. Ich bin heute deine Kellnerin."

# game/Scenes/Mari/mari0.rpy:18
translate german mari0_0a82c299:

    # fr "You just let me know if you need anything else."
    fr "Sag mir einfach Bescheid, wenn du noch etwas brauchst."

# game/Scenes/Mari/mari0.rpy:19
translate german mari0_f711eed2:

    # "She gives me a smile and puts the food down on the table."
    "Sie lächelt mich an und stellt das Essen auf den Tisch."

# game/Scenes/Mari/mari0.rpy:23
translate german mari0_84e54e6e:

    # "She blushes a bit and playfully slaps my shoulder."
    "Sie errötet ein wenig und klopft mir spielerisch auf die Schulter."

# game/Scenes/Mari/mari0.rpy:24
translate german mari0_967f0281:

    # fr "You're just a charmer, aren't you?"
    fr "Du bist ein echter Charmeur, nicht wahr?"

# game/Scenes/Mari/mari0.rpy:27
translate german mari0_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:28
translate german mari0_9af4e82f:

    # fr "Sure thing!"
    fr "Klar doch!"

# game/Scenes/Mari/mari0.rpy:31
translate german mari0_d41d8cd9_2:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:32
translate german mari0_22159de4:

    # fr "Sure thing! I'll bring it right out."
    fr "Klar doch! Ich bringe es dir sofort."

# game/Scenes/Mari/mari0.rpy:33
translate german mari0_55ee1584:

    # "She runs to the back and gets the ketchup, then quickly returns with it."
    "Sie rennt nach hinten, holt den Ketchup und kommt schnell damit zurück."

# game/Scenes/Mari/mari0.rpy:34
translate german mari0_fe5173b6:

    # fr "Just give me a holler if I can do anything else for you."
    fr "Sag einfach Bescheid, wenn ich noch etwas für dich tun kann."

# game/Scenes/Mari/mari0.rpy:37
translate german mari0_d0ec727b:

    # "She walks over to a nearby table, pulls out a rag, and starts wiping it down, bending over just enough to give me a good view of her ass."
    "Sie geht zu einem Tisch in der Nähe, holt ein Tuch hervor und beginnt, ihn abzuwischen, wobei sie sich gerade so weit vorbeugt, dass ich einen guten Blick auf ihren Hintern habe."

# game/Scenes/Mari/mari0.rpy:40
translate german mari0_8458142b:

    # "And damn, that's a nice ass."
    "Und verdammt, das ist ein schöner Hintern."

# game/Scenes/Mari/mari0.rpy:43
translate german mari0_a58a4782:

    # "I eat my food and Mari returns a couple more times to give me a refill on my drink."
    "Ich esse mein Essen und Mari kommt noch ein paar Mal zurück, um mir mein Getränk nachzufüllen."

# game/Scenes/Mari/mari0.rpy:46
translate german mari0_cc46d500:

    # "Then when I'm finished, I stand up and give her a smile and a wave."
    "Als ich fertig bin, stehe ich auf, lächle ihr zu und winke."

# game/Scenes/Mari/mari0.rpy:49
translate german mari0_d41d8cd9_3:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari0.rpy:50
translate german mari0_8fafd7cf:

    # fr "Thanks for coming in. You have a good night."
    fr "Danke, dass du vorbeigekommen bist. Hab noch einen schönen Abend."

# game/Scenes/Mari/mari0.rpy:53
translate german marifirsttip_1c31faa0:

    # "I place $5 on the table before I leave."
    "Ich lege 5 Dollar auf den Tisch, bevor ich gehe."

# game/Scenes/Mari/mari0.rpy:55
translate german marifirsttip_01e672c5:

    # "I head back out to the car."
    "Ich gehe zurück zum Auto."

