# game/Scenes/Mari/MariConversations/maris7.rpy:13
translate german maris7_aa9452c3:

    # fr "Anything outdoors really."
    fr "Eigentlich alles, was draußen stattfindet."

# game/Scenes/Mari/MariConversations/maris7.rpy:14
translate german maris7_23bbfe65:

    # fr "I love walking in the park with you."
    fr "Ich liebe es, mit dir im Park spazieren zu gehen."

# game/Scenes/Mari/MariConversations/maris7.rpy:15
translate german maris7_ebffc98a:

    # fr "I'd love to go to a big garden somewhere. Or just the lake or something."
    fr "Ich würde gerne mal in einen großen Garten irgendwo gehen. Oder einfach an den See oder so."

# game/Scenes/Mari/MariConversations/maris7.rpy:16
translate german maris7_7c02732c:

    # fr "Anywhere that's green and alive and has fresh air and birds and breeze."
    fr "Irgendwohin, wo es grün und lebendig ist und wo es frische Luft, Vögel und eine leichte Brise gibt."

# game/Scenes/Mari/MariConversations/maris7.rpy:17
translate german maris7_008c825e:

    # pc "That all sounds wonderful, but what would be the perfect date?"
    pc "Das klingt alles wunderbar, aber wie würde das perfekte Date aussehen?"

# game/Scenes/Mari/MariConversations/maris7.rpy:19
translate german maris7_fb3aa226:

    # fr "Hmm… I guess I'd like to go to a beautiful garden with colorful flowers. I think there's one up in Whiterock that I've heard of."
    fr "Hmm… Ich glaube, ich würde gerne in einen schönen Garten mit bunten Blumen gehen. Ich glaube, es gibt einen oben in Whiterock, von dem ich gehört habe."

# game/Scenes/Mari/MariConversations/maris7.rpy:20
translate german maris7_15fa15b9:

    # fr "We'd spend the day there, just exploring the place and talking."
    fr "Wir würden den Tag dort verbringen, einfach den Ort erkunden und reden."

# game/Scenes/Mari/MariConversations/maris7.rpy:21
translate german maris7_768a7b04:

    # fr "Then we'd get something delicious to eat. Something fresh and green."
    fr "Dann würden wir uns etwas Leckeres zu essen holen. Etwas Frisches und Grünes."

# game/Scenes/Mari/MariConversations/maris7.rpy:23
translate german maris7_0412d35d:

    # fr "Then we'd go back to the farm. I'd do my evening chores…"
    fr "Dann würden wir zurück zur Farm fahren. Ich würde meine abendlichen Aufgaben erledigen…"

# game/Scenes/Mari/MariConversations/maris7.rpy:24
translate german maris7_4dc951ac:

    # pc "Your ideal date involves chores?"
    pc "Dein ideales Date beinhaltet Hausarbeit?"

# game/Scenes/Mari/MariConversations/maris7.rpy:26
translate german maris7_236034e4:

    # fr "Well somebody has to do them."
    fr "Na ja, irgendjemand muss sie ja machen."

# game/Scenes/Mari/MariConversations/maris7.rpy:28
translate german maris7_9a5fc24f:

    # fr "Anyway, then we'd go inside, take a shower…"
    fr "Jedenfalls würden wir dann reingehen, duschen…"

# game/Scenes/Mari/MariConversations/maris7.rpy:30
translate german maris7_d7effb83:

    # fr "… and do stuff."
    fr "… und Sachen machen."

# game/Scenes/Mari/MariConversations/maris7.rpy:31
translate german maris7_97fb7052:

    # pc "Stuff?"
    pc "Sachen?"

# game/Scenes/Mari/MariConversations/maris7.rpy:32
translate german maris7_30de1bd2:

    # fr "Yeah. Stuff."
    fr "Ja. Sachen."

# game/Scenes/Mari/MariConversations/maris7.rpy:34
translate german maris7_f18990d4:

    # fr "All night."
    fr "Die ganze Nacht."

# game/Scenes/Mari/MariConversations/maris7.rpy:35
translate german maris7_2fab7edc:

    # pc "Sounds nice."
    pc "Klingt schön."

# game/Scenes/Mari/MariConversations/maris7.rpy:37
translate german maris7_c6174cde:

    # fr "Yeah, it would be."
    fr "Ja, das wäre es."

