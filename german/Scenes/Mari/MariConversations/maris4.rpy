# game/Scenes/Mari/MariConversations/maris4.rpy:33
translate german maris4_7b389c9e:

    # fr "That's cool. I don't expect us to both like the exact same things, you know?"
    fr "Das ist cool. Ich erwarte nicht, dass wir beide genau die gleichen Dinge mögen, weißt du?"

# game/Scenes/Mari/MariConversations/maris4.rpy:34
translate german maris4_b1a6e571:

    # fr "What would be the fun in that?"
    fr "Was wäre daran schon spannend?"

# game/Scenes/Mari/MariConversations/maris4.rpy:35
translate german maris4_f6fc400b:

    # fr "You introduce me to some new stuff and I'll introduce you to some new stuff too."
    fr "Du zeigst mir ein paar neue Sachen und ich zeige dir auch ein paar neue Sachen."

# game/Scenes/Mari/MariConversations/maris4.rpy:36
translate german maris4_b35da6a1:

    # fr "Then we both become better people."
    fr "Dann werden wir beide bessere Menschen."

# game/Scenes/Mari/MariConversations/maris4.rpy:37
