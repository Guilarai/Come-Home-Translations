# game/Scenes/Mari/MariConversations/maris4.rpy:43
translate german maris4_11334516:

    # fr "They make a lot of people happy though, so who am I to put them down?"
    fr "Er macht aber viele Menschen glücklich, also wer bin ich, dass ich ihn schlechtmachen könnte?"

