# game/Scenes/Mari/MariConversations/marip4.rpy:13
translate german marip4_396c4a27:

    # fr "Not really."
    fr "Nicht wirklich."

# game/Scenes/Mari/MariConversations/marip4.rpy:14
translate german marip4_a3a6e94e:

    # fr "I talk to some people online and we meet occasionally."
    fr "Ich unterhalte mich online mit einigen Leuten und wir treffen uns gelegentlich."

# game/Scenes/Mari/MariConversations/marip4.rpy:15
translate german marip4_bb06b846:

    # fr "Then there is Jackson and Connie at work, a couple of people that I chat with at the vet clinic."
    fr "Dann sind da noch Jackson und Connie bei der Arbeit, ein paar Leute, mit denen ich in der Tierklinik plaudere."

# game/Scenes/Mari/MariConversations/marip4.rpy:17
translate german marip4_f4e0d40e:

    # fr "And you, of course."
    fr "Und du natürlich."

# game/Scenes/Mari/MariConversations/marip4.rpy:18
translate german marip4_aefff0dc:

    # fr "I wouldn't say any of those relationships are close."
    fr "Ich würde nicht sagen, dass diese Beziehungen eng sind."

# game/Scenes/Mari/MariConversations/marip4.rpy:19
translate german marip4_3c863e30:

    # fr "At least not yet."
    fr "Zumindest noch nicht."

# game/Scenes/Mari/MariConversations/marip4.rpy:24
translate german marip4_36d8c862:

    # fr "Not as close as I would like to be."
    fr "Nicht so eng, wie ich es gerne hätte."

# game/Scenes/Mari/MariConversations/marip4.rpy:26
translate german marip4_a14f7e23:

    # fr "Still though, thank you for saying so."
    fr "Trotzdem danke ich dir für diese Worte."

# game/Scenes/Mari/MariConversations/marip4.rpy:30
translate german marip4_4b65bcb5:

    # fr "It definitely is!"
    fr "Das ist es definitiv!"

# game/Scenes/Mari/MariConversations/marip4.rpy:31
translate german marip4_93b501c6:

    # fr "Everybody is always so busy with their own things, it's hard to keep up with everything going on in other people's lives."
    fr "Jeder ist immer so mit seinen eigenen Sachen beschäftigt, dass es schwer ist, den Überblick über alles zu behalten, was im Leben der anderen so los ist."

# game/Scenes/Mari/MariConversations/marip4.rpy:32
translate german marip4_0dd5ba27:

    # pc "Very true."
    pc "Das stimmt."

# game/Scenes/Mari/MariConversations/marip4.rpy:34
translate german marip4_5292c0c6:

    # fr "But I do wish that I had a couple of close friends that I could confide in."
    fr "Aber ich wünschte mir schon, ich hätte ein paar enge Freunde, denen ich mich anvertrauen könnte."

# game/Scenes/Mari/MariConversations/marip4.rpy:36
translate german marip4_7199f799:

    # fr "Maybe some day."
    fr "Vielleicht irgendwann mal."

# game/Scenes/Mari/MariConversations/marip4.rpy:39
translate german marip4_7567a5a5:

    # fr "Yeah, I guess so."
    fr "Ja, ich schätze schon."

# game/Scenes/Mari/MariConversations/marip4.rpy:40
translate german marip4_fe109b44:

    # fr "What a loser huh?"
    fr "Was für ein Loser, oder?"

# game/Scenes/Mari/MariConversations/marip4.rpy:42
translate german marip4_ea2dcc2a:

    # fr "I will eventually. It's just hard to find nice people who share your interests."
    fr "Irgendwann werde ich das schon. Es ist nur schwer, nette Leute zu finden, die deine Interessen teilen."

# game/Scenes/Mari/MariConversations/marip4.rpy:44
translate german marip4_0b4501cf:

    # fr "Anyways. Let's talk about something else."
    fr "Wie auch immer. Lass uns über etwas anderes reden."

translate german strings:

    # game/Scenes/Mari/MariConversations/marip4.rpy:21
    old "I think we're pretty close"
    new "Ich glaube, wir stehen uns ziemlich nah."

    # game/Scenes/Mari/MariConversations/marip4.rpy:27
    old "It's hard to stay close to your friends"
    new "Es ist schwer, mit seinen Freunden in Kontakt zu bleiben."

    # game/Scenes/Mari/MariConversations/marip4.rpy:37
    old "Maybe you should make more friends?"
    new "Vielleicht solltest du dir mehr Freunde suchen?"

