# game/Scenes/Mari/MariDates/maribeach.rpy:13
translate german maribeachdate_a63d5d5c:

    # fr "The beach sounds amazing! I'll go get in my swimsuit! Come get me."
    fr "Der Strand klingt toll! Ich zieh mir schnell meinen Badeanzug an! Komm und hol mich ab."

# game/Scenes/Mari/MariDates/maribeach.rpy:14
translate german maribeachdate_8caa4a9c:

    # pc "On my way."
    pc "Bin schon unterwegs."

# game/Scenes/Mari/MariDates/maribeach.rpy:21
translate german maribeachdate_40c18b34:

    # "I pick Mari up and we drive out towards the beach."
    "Ich hole Mari ab und wir fahren zum Strand."

# game/Scenes/Mari/MariDates/maribeach.rpy:23
translate german maribeachdate_427f3be4:

    # fr "I haven't been to the beach in forever."
    fr "Ich war schon ewig nicht mehr am Strand."

# game/Scenes/Mari/MariDates/maribeach.rpy:24
translate german maribeachdate_e5624fc2:

    # fr "This is going to be so fun."
    fr "Das wird so ein Spaß."

# game/Scenes/Mari/MariDates/maribeach.rpy:29
translate german maribeachdate_b9c9e980:

    # pc "You look incredible."
    pc "Du siehst umwerfend aus."

# game/Scenes/Mari/MariDates/maribeach.rpy:30
translate german maribeachdate_8a5a041f:

    # fr "Thanks, honey. The water is so pretty. Let's get in."
    fr "Danke, Schatz. Das Wasser ist so schön. Lass uns reingehen."

# game/Scenes/Mari/MariDates/maribeach.rpy:33
translate german maribeachdate_93419ef3:

    # "We spend some time swimming around and chatting."
    "Wir verbringen einige Zeit damit, herumzuschwimmen und zu plaudern."

# game/Scenes/Mari/MariDates/maribeach.rpy:36
translate german maribeachdate_0e1a2c64:

    # "We spend a little longer making out, our bodies pressed against each other underwater."
    "Wir verbringen noch ein bisschen länger damit, uns zu küssen, unsere Körper unter Wasser aneinandergepresst."

# game/Scenes/Mari/MariDates/maribeach.rpy:39
translate german maribeachdate_c4765999:

    # "After a while, we're both tired from swimming and the sun is starting to set, so we lie on the beach and dry off."
    "Nach einer Weile sind wir beide vom Schwimmen müde und die Sonne beginnt unterzugehen, also legen wir uns an den Strand und trocknen uns ab."

# game/Scenes/Mari/MariDates/maribeach.rpy:40
translate german maribeachdate_3d2f7709:

    # "We lean back and talk for a while about whatever comes to mind."
    "Wir lehnen uns zurück und unterhalten uns eine Weile über alles, was uns gerade in den Sinn kommt."

# game/Scenes/Mari/MariDates/maribeach.rpy:50
translate german maribeachdate_67f91a9e:

    # "When the sun starts to dip below the horizon, we take a moment to watch it together."
    "Als die Sonne beginnt, hinter dem Horizont zu versinken, nehmen wir uns einen Moment Zeit, um sie gemeinsam zu beobachten."

# game/Scenes/Mari/MariDates/maribeach.rpy:52
translate german maribeachdate_0b6982cc:

    # fr "It's so beautiful."
    fr "Es ist so wunderschön."

# game/Scenes/Mari/MariDates/maribeach.rpy:53
translate german maribeachdate_91de8c28:

    # fr "Thanks for bringing me here."
    fr "Danke, dass du mich hierher mitgenommen hast."

# game/Scenes/Mari/MariDates/maribeach.rpy:58
translate german maribeachdate_e10b5f4e:

    # "We kiss and it's like lightning between our lips. It warms me from my heart outward."
    "Wir küssen uns und es ist wie ein Blitz zwischen unseren Lippen. Es wärmt mich von innen heraus."

# game/Scenes/Mari/MariDates/maribeach.rpy:63
translate german maribeachdate_4462906b:

    # fr "Are you ready to go back to my place?"
    fr "Bist du bereit, zu mir zu kommen?"

# game/Scenes/Mari/MariDates/maribeach.rpy:64
translate german maribeachdate_61f77a4c:

    # pc "Sure."
    pc "Klar."

# game/Scenes/Mari/MariDates/maribeach.rpy:65
translate german maribeachdate_63a75f93:

    # fr "Good, because I'm ready to get out of this swimsuit. And to get you out of yours."
    fr "Gut, denn ich bin bereit, diesen Badeanzug auszuziehen. Und dich aus deinem."

# game/Scenes/Mari/MariDates/maribeach.rpy:69
translate german maribeachdate_69da3812:

    # "When the sun sets, I drive us back to her house."
    "Als die Sonne untergeht, fahre ich uns zurück zu ihrem Haus."

# game/Scenes/Mari/MariDates/maribeach.rpy:70
translate german maribeachdate_e3551ef8:

    # fr "So... are you coming inside?"
    fr "Also… kommst du mit rein?"

# game/Scenes/Mari/MariDates/maribeach.rpy:73
translate german maribeachdate_b1aed98f:

    # fr "Good. Let's go."
    fr "Gut. Los geht’s."

# game/Scenes/Mari/MariDates/maribeach.rpy:80
translate german maribeachdate_b1aed98f_1:

    # fr "Good. Let's go."
    fr "Gut. Los geht’s."

# game/Scenes/Mari/MariDates/maribeach.rpy:88
translate german maribeachdate_92c16c18:

    # fr "Dang, really? Too busy for little ol' me tonight?"
    fr "Mist, echt? Zu beschäftigt für mich heute Abend?"

# game/Scenes/Mari/MariDates/maribeach.rpy:89
translate german maribeachdate_ea7c5dae:

    # fr "Fine. Good night then."
    fr "Na gut. Dann gute Nacht."

# game/Scenes/Mari/MariDates/maribeach.rpy:92
translate german maribeachdate_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "Ich warte, bis sie ausgestiegen ist und ins Haus geht, bevor ich wegfahre."

translate german strings:

    # game/Scenes/Mari/MariDates/maribeach.rpy:3
    old "When you are able to ask Mari out on a date, and you have unlocked the beach through Suzy's path, invite Mari to the beach."
    new "Wenn du Mari um ein Date bitten kannst und den Strand über Suzys Weg freigeschaltet hast, lade Mari an den Strand ein."

    # game/Scenes/Mari/MariDates/maribeach.rpy:4
    old "She is available to date any time before night on the weekends."
    new "Sie ist an Wochenenden jederzeit vor Einbruch der Nacht für ein Date verfügbar."

