# game/Scenes/Mari/MariDates/mariluigisdate.rpy:28
translate german mariluigisstartdate_1ee44fe2:

    # "Mari and I sit next to each other at one of the booths at Luigi's."
    "Mari und ich sitzen nebeneinander an einem der Tische bei Luigi’s."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:29
translate german mariluigisstartdate_0d18b373:

    # "We are chatting the whole time about this and that."
    "Wir unterhalten uns die ganze Zeit über dies und das."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:30
translate german mariluigisstartdate_5bdbd1f6:

    # "The waitress comes by and takes our order, we continue talking."
    "Die Kellnerin kommt vorbei und nimmt unsere Bestellung auf, wir reden weiter."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:34
translate german mariluigisstartdate_f9e372f9:

    # "After a short time, the waitress brings our food out to us and we continue talking while we eat."
    "Nach kurzer Zeit bringt die Kellnerin uns unser Essen und wir unterhalten uns weiter, während wir essen."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:37
translate german mariluigisstartdate_54f7ac2e:

    # "We take our time eating while we talk, just enjoying one another's company."
    "Wir lassen uns beim Essen Zeit, während wir reden, und genießen einfach die Gesellschaft des anderen."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:40
translate german mariluigisstartdate_764eafa0:

    # fr "Good salad, but the service here isn't great huh?"
    fr "Guter Salat, aber der Service hier ist nicht so toll, oder?"

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:41
translate german mariluigisstartdate_407731d1:

    # fr "Waiter didn't even face the dang silverware the correct way."
    fr "Der Kellner hat nicht mal das verdammte Besteck richtig hingelegt."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:42
translate german mariluigisstartdate_c54b50c7:

    # pc "Well they can't all be as good as you."
    pc "Na ja, die können ja nicht alle so gut sein wie du."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:44
translate german mariluigisstartdate_a4da275d:

    # fr "Aww..."
    fr "Ach..."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:48
translate german mariluigisstartdate_360f4aaa:

    # "When we're done with the meal, I pay the waitress and Mari and I walk out to the car together and start back towards her house."
    "Als wir mit dem Essen fertig sind, bezahle ich die Kellnerin, und Mari und ich gehen zusammen zum Auto und machen uns auf den Weg zurück zu ihrem Haus."

