# game/Scenes/Mari/MariDates/marimoviedate.rpy:26
translate german marimovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Wir kommen zum Kino und setzen uns ganz nach hinten."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:27
translate german marimovietheaterstartdate_d03e5a70:

    # fr "So what are we watching anyway?"
    fr "Was schauen wir uns denn überhaupt an?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:31
translate german marimovietheaterstartdate_346436bf:

    # fr "Oh yeah?"
    fr "Ach ja?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:32
translate german marimovietheaterstartdate_3aed9093:

    # fr "I love romance movies. As long as they're not too corny."
    fr "Ich liebe Liebesfilme. Solange sie nicht zu kitschig sind."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:35
translate german marimovietheaterstartdate_337ed84d:

    # fr "Hrm, okay well that sounds fun."
    fr "Hm, okay, das klingt nach Spaß."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:36
translate german marimovietheaterstartdate_7a1524b8:

    # fr "As long as it isn't just two buff guys slapping their meat together."
    fr "Solange es nicht nur zwei muskelbepackte Typen sind, die ihre Muskeln gegeneinander schlagen."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:38
translate german marimovietheaterstartdate_d3cf7e4e:

    # fr "Actually, that sounds pretty fun too."
    fr "Eigentlich klingt das auch ziemlich lustig."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:43
translate german marimovietheaterstartdate_d41d8cd9:

    # voice 'voices/mari_really.mp3'
    voice 'voices/mari_really.mp3'

# game/Scenes/Mari/MariDates/marimoviedate.rpy:44
translate german marimovietheaterstartdate_67fd9cd9:

    # fr "Really?"
    fr "Wirklich?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:45
translate german marimovietheaterstartdate_8b77409f:

    # fr "I don't really do scary movies very well."
    fr "Ich komme mit Horrorfilmen nicht so gut klar."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:46
translate german marimovietheaterstartdate_cb84ad92:

    # fr "I might just have my eyes closed and be holding you through the whole thing."
    fr "Ich werde vielleicht einfach die Augen schließen und dich die ganze Zeit festhalten."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:51
translate german marimovietheaterstartdate_321fa232:

    # fr "Oh good, I need a good laugh."
    fr "Oh gut, ich brauche mal was zum Lachen."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:52
translate german marimovietheaterstartdate_76b9da8b:

    # fr "As long as it's not one of those gross-out sex comedies. I'm not really into those."
    fr "Solange es keine dieser ekelhaften Sexkomödien ist. Die mag ich nicht so."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:56
translate german marimovietheaterstartdate_f3087137:

    # fr "Oh good! You know what I like."
    fr "Oh gut! Du weißt ja, was ich mag."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:57
translate german marimovietheaterstartdate_3224e393:

    # fr "I love animated stuff. Especially when it's about talking animals."
    fr "Ich liebe Animationsfilme. Vor allem, wenn es um sprechende Tiere geht."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:60
translate german marimovietheaterstartdate_f45af0c0:

    # "There's a little time before the movie starts for us to chat."
    "Wir haben noch ein bisschen Zeit, bevor der Film anfängt, um zu quatschen."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:64
translate german marimovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Endlich fängt der Film an und wir werden still."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:66
translate german marimovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Sie streckt die Hand aus und hält meine Hand auf der Armlehne."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:67
translate german marimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Die Trailer dauern etwa fünfzehn Minuten, dann geht der Film richtig los."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:71
translate german marimovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Während des Films lehnt sie sich an meine Schulter und taucht ganz in die Geschichte ein."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:73
translate german marimovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Dann, während einer besonders romantischen Szene, hebt sie den Kopf und legt ihre Lippen auf meine."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:74
translate german marimovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "Den Rest des Films sehen wir uns nicht wirklich an, sondern konzentrieren uns stattdessen darauf, rumzumachen."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:77
translate german marimovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Während des Films lehnt sie sich an meine Schulter und taucht ganz in die Geschichte ein."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:80
translate german marimovietheaterstartdate_284094da:

    # "Mari watches the movie, but I'm not really sure how much she likes it."
    "Mari schaut sich den Film an, aber ich bin mir nicht wirklich sicher, wie sehr er ihr gefällt."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:83
translate german marimovietheaterstartdate_26b74708:

    # "Eventually, she turns towards me and whispers."
    "Schließlich dreht sie sich zu mir um und flüstert."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:84
translate german marimovietheaterstartdate_5aa661f3:

    # fr "I'm not really into this movie. Want to just make out?"
    fr "Der Film gefällt mir nicht so richtig. Wollen wir uns nicht einfach nur küssen?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:86
translate german marimovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Ich beuge mich zu ihr hin und küsse sie, und wir schauen uns den Rest des Films kaum noch an, sondern konzentrieren uns stattdessen aufeinander."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:89
translate german marimovietheaterstartdate_ae5e6aa0:

    # "To give her some credit, she tries to watch a little bit of the movie."
    "Man muss ihr zugutehalten, dass sie versucht, ein bisschen vom Film zu sehen."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:90
translate german marimovietheaterstartdate_c601de66:

    # "But by the time the scary parts start, she is pretty much done."
    "Aber als die gruseligen Stellen anfangen, hat sie so ziemlich genug."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:92
translate german marimovietheaterstartdate_fafc8629:

    # "She tucks her head down against me and hides the movie from her sight."
    "Sie drückt ihren Kopf an mich und verbirgt den Film vor ihren Augen."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:93
translate german marimovietheaterstartdate_324b6470:

    # "She stays right there, not watching anything for the rest of the movie."
    "Sie bleibt genau dort und schaut für den Rest des Films nichts mehr."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:96
translate german marimovietheaterstartdate_b27a7e4c:

    # "Mari's eyes are focused on the movie throughout the whole thing."
    "Maris Augen sind die ganze Zeit auf den Film gerichtet."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:97
translate german marimovietheaterstartdate_125a0ff3:

    # "She laughs, she cries, she taps her foot along with the music."
    "Sie lacht, sie weint, sie wippt mit dem Fuß im Takt der Musik."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:98
translate german marimovietheaterstartdate_e4a43b4e:

    # "We have a great time."
    "Wir haben eine tolle Zeit."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:101
translate german marimovietheaterstartdate_8f27901e:

    # "The movie is pretty funny all the way through and Mari and I laugh a lot."
    "Der Film ist durchweg ziemlich lustig und Mari und ich lachen viel."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:104
translate german marimovietheaterstartdate_abcf9a29:

    # "Then somehow that turns into us making out."
    "Dann führt das irgendwie dazu, dass wir rummachen."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:105
translate german marimovietheaterstartdate_46b84a07:

    # "We don't really watch much of the movie after that."
    "Danach sehen wir nicht mehr wirklich viel vom Film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:106
translate german marimovietheaterstartdate_d855e56b:

    # "Eventually the movie ends and the credits start rolling."
    "Schließlich endet der Film und der Abspann läuft."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:109
translate german marimovietheaterstartdate_f176d1eb:

    # fr "That was a cute movie."
    fr "Das war ein süßer Film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:111
translate german marimovietheaterstartdate_b1836b04:

    # fr "What little I saw of it anyway."
    fr "Das Wenige, das ich davon gesehen habe jedenfalls."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:112
translate german marimovietheaterstartdate_91db2110:

    # fr "I like what we did even more than the movie."
    fr "Was wir gemacht haben, gefällt mir sogar noch besser als der Film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:113
translate german marimovietheaterstartdate_e25ed9ba:

    # fr "Thanks for taking me."
    fr "Danke, dass du mich mitgenommen hast."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:116
translate german marimovietheaterstartdate_eb286352:

    # fr "Well the movie wasn't really my thing."
    fr "Also, der Film war nicht so mein Ding."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:118
translate german marimovietheaterstartdate_8fc45fba:

    # fr "But seeing it with you made it a lot better."
    fr "Aber ihn mit dir zu sehen, hat ihn viel besser gemacht."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:121
translate german marimovietheaterstartdate_c58b0ecd:

    # fr "I'm a big baby, I know."
    fr "Ich bin ein großes Baby, ich weiß."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:122
translate german marimovietheaterstartdate_acdb9025:

    # fr "But I hated that. Even when I stopped watching it, the noises were still scary."
    fr "Aber ich habe das gehasst. Selbst als ich aufgehört habe, ihn anzuschauen, waren die Geräusche immer noch beängstigend."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:123
translate german marimovietheaterstartdate_26d0b7c9:

    # pc "I'm sorry, I didn't realize that you disliked horror movies so much."
    pc "Es tut mir leid, ich wusste nicht, dass du Horrorfilme so sehr hasst."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:124
translate german marimovietheaterstartdate_30078caa:

    # fr "They just bring back bad memories and make me think about sad things."
    fr "Sie wecken einfach schlechte Erinnerungen und lassen mich an traurige Dinge denken."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:127
translate german marimovietheaterstartdate_c3aec289:

    # fr "That movie was so cute! I loved it!"
    fr "Der Film war so süß! Ich fand ihn toll!"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:128
translate german marimovietheaterstartdate_070969bf:

    # fr "Thanks so much for bringing me."
    fr "Vielen Dank, dass du mich mitgenommen hast."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:131
translate german marimovietheaterstartdate_4549f151:

    # fr "That was a fun movie."
    fr "Das war ein lustiger Film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:133
translate german marimovietheaterstartdate_b1836b04_1:

    # fr "What little I saw of it anyway."
    fr "Das Wenige, das ich davon gesehen habe jedenfalls."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:134
translate german marimovietheaterstartdate_91db2110_1:

    # fr "I like what we did even more than the movie."
    fr "Was wir gemacht haben, gefällt mir sogar noch besser als der Film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:135
translate german marimovietheaterstartdate_233f5bf6:

    # "When the credits start rolling, we hang out and chat through them."
    "Wenn der Abspann läuft, hängen wir ab und quatschen uns durch."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:139
translate german marimovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Wenn der Abspann zu Ende ist, gehen wir zusammen nach draußen und zu meinem Auto."

