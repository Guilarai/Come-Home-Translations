translate german mari1_d41d8cd9:

    # voice 'voices/mari_heysweetie.mp3'
    voice 'voices/mari_heysweetie.mp3'

# game/Scenes/Mari/mari1.rpy:16
translate german mari1_64c354b8:

    # fr "Hey there sweetie, good to see you. How are you doing today?"
    fr "Hey, Süße, schön, dich zu sehen. Wie geht es dir heute?"

# game/Scenes/Mari/mari1.rpy:19
translate german mari1_223b1496:

    # fr "Good, I'm glad. It's nice to see you in here again, let me know if I can get you anything."
    fr "Gut, das freut mich. Schön, dich wieder hier zu sehen. Sag mir Bescheid, wenn ich dir etwas bringen kann."

# game/Scenes/Mari/mari1.rpy:22
translate german mari1_fe03e5ca:

    # fr "You're such a charmer. Keep going, I like it."
    fr "Du bist so ein Charmeur. Mach weiter so, das gefällt mir."

# game/Scenes/Mari/mari1.rpy:23
translate german mari1_4d51f194:

    # pc "I mean, the burgers here are great, but I'm really here just to chat with you."
    pc "Ich meine, die Burger hier sind toll, aber eigentlich bin ich nur hier, um mit dir zu plaudern."

# game/Scenes/Mari/mari1.rpy:25
translate german mari1_67fd9cd9:

    # fr "Really?"
    fr "Wirklich?"

# game/Scenes/Mari/mari1.rpy:26
translate german mari1_18128c18:

    # pc "Really."
    pc "Wirklich."

# game/Scenes/Mari/mari1.rpy:28
translate german mari1_8aa0b3f4:

    # fr "You're so sweet. Thanks for the compliments, but I better get back to work. Let me know if I can get you anything."
    fr "Du bist so süß. Danke für die Komplimente, aber ich muss lieber wieder an die Arbeit. Sag mir Bescheid, wenn ich dir etwas bringen kann."

# game/Scenes/Mari/mari1.rpy:29
translate german mari1_c0bafa60:

    # pc "Can I get a straw for my drink?"
    pc "Kann ich einen Strohhalm für mein Getränk haben?"

# game/Scenes/Mari/mari1.rpy:31
translate german mari1_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari1.rpy:32
translate german mari1_f2433589:

    # fr "Sure thing, honey."
    fr "Klar, Schatz."

# game/Scenes/Mari/mari1.rpy:33
translate german mari1_ab35ef2d:

    # "She reaches into her pocket to pull out one of the straws and a dozen more pop out and fall onto the floor, scattering around."
    "Sie greift in ihre Tasche, um einen der Strohhalme herauszuziehen, und ein Dutzend weitere springen heraus und fallen auf den Boden, wo sie sich verstreuen."

# game/Scenes/Mari/mari1.rpy:36
translate german mari1_d41d8cd9_2:

    # voice 'voices/mari_shoot2.mp3'
    voice 'voices/mari_shoot2.mp3'

# game/Scenes/Mari/mari1.rpy:37
translate german mari1_aaf7d6fa:

    # fr "Ah shoot, sorry about that."
    fr "Ach Mist, tut mir leid."

# game/Scenes/Mari/mari1.rpy:38
translate german mari1_76e2166e:

    # fr "Just a second, let me get these."
    fr "Einen Moment, ich hebe die schnell auf."

# game/Scenes/Mari/mari1.rpy:40
translate german mari1_29517e2b:

    # "She kneels down and gets on hands and knees on the floor, picking up the straws that had scattered around."
    "Sie kniet sich hin und geht auf allen vieren auf den Boden, um die Strohhalme aufzuheben, die überall verstreut waren."

# game/Scenes/Mari/mari1.rpy:41
translate german mari1_fa53362f:

    # fr "I'm so sorry."
    fr "Es tut mir so leid."

# game/Scenes/Mari/mari1.rpy:44
translate german mari1_6ce37599:

    # fr "I'm so clumsy sometimes."
    fr "Ich bin manchmal so ungeschickt."

# game/Scenes/Mari/mari1.rpy:45
translate german mari1_bdb852f0:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Sie sammelt schnell die restlichen Strohhalme ein und steht wieder auf."

# game/Scenes/Mari/mari1.rpy:48
translate german mari1_c84cc9f0:

    # fr "What?"
    fr "Was?"

# game/Scenes/Mari/mari1.rpy:50
translate german mari1_d41d8cd9_3:

    # voice 'voices/mari_youlikethat.mp3'
    voice 'voices/mari_youlikethat.mp3'

# game/Scenes/Mari/mari1.rpy:51
translate german mari1_50b1ddec:

    # fr "Oh. You like that do you?"
    fr "Oh. Das gefällt dir, oder?"

# game/Scenes/Mari/mari1.rpy:53
translate german mari1_7fbd7f76:

    # fr "What about this? You like this?"
    fr "Wie wäre es damit? Gefällt dir das?"

# game/Scenes/Mari/mari1.rpy:54
translate german mari1_9bf0a886:

    # pc "I definitely do."
    pc "Das gefällt mir auf jeden Fall."

# game/Scenes/Mari/mari1.rpy:55
translate german mari1_bdb852f0_1:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Sie sammelt schnell die restlichen Strohhalme ein und steht wieder auf."

# game/Scenes/Mari/mari1.rpy:57
translate german mari1_2771e6a1:

    # fr "I hope that was worth a little bit more of a tip?"
    fr "Ich hoffe, das war ein bisschen mehr Trinkgeld wert?"

# game/Scenes/Mari/mari1.rpy:58
translate german mari1_81450635:

    # pc "Oh I could give you more than the tip."
    pc "Oh, ich könnte dir mehr als nur das Trinkgeld geben."

# game/Scenes/Mari/mari1.rpy:60
translate german mari1_053e79a0:

    # fr "You're so bad!"
    fr "Du bist so frech!"

# game/Scenes/Mari/mari1.rpy:63
translate german mari1_bab66bf3:

    # fr "I'll be right back with a straw that hasn't been on the floor."
    fr "Ich bin gleich wieder da mit einem Strohhalm, der nicht auf dem Boden gelegen hat."

# game/Scenes/Mari/mari1.rpy:64
translate german mari1_c8cd6f6b:

    # "She comes back with my straw and then my food shortly after that."
    "Sie kommt mit meinem Strohhalm zurück und kurz darauf auch mit meinem Essen."

# game/Scenes/Mari/mari1.rpy:65
translate german mari1_2e5f61be:

    # "We don't talk much more, but she gives me a beautiful smile every time I look up at her."
    "Wir reden nicht mehr viel, aber sie schenkt mir jedes Mal ein wunderschönes Lächeln, wenn ich zu ihr aufschaue."

# game/Scenes/Mari/mari1.rpy:69
translate german mari1_e88fc8e1:

    # "When I finish and it's time to leave, she waves at me."
    "Als ich fertig bin und es Zeit ist zu gehen, winkt sie mir nach."

# game/Scenes/Mari/mari1.rpy:71
translate german mari1_d41d8cd9_4:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari1.rpy:72
translate german mari1_7949c609:

    # fr "Thanks for coming in! You have a good night!"
    fr "Danke, dass du hier warst! Hab einen schönen Abend!"

# game/Scenes/Mari/mari1.rpy:75
translate german maritip2_1ce16e45:

    # "I walk up to her and put a ten-dollar bill into her hand."
    "Ich gehe auf sie zu und drücke ihr einen Zehn-Dollar-Schein in die Hand."

# game/Scenes/Mari/mari1.rpy:78
translate german maritip2_d41d8cd9:

    # voice 'voices/mari_thankyousomuch.mp3'
    voice 'voices/mari_thankyousomuch.mp3'

# game/Scenes/Mari/mari1.rpy:79
translate german maritip2_1e720979:

    # fr "Thanks so much, you're the best."
    fr "Vielen Dank, du bist die Beste."

# game/Scenes/Mari/mari1.rpy:81
translate german maritip2_890abf2a:

    # "Without warning, she lunges forward and wraps her arms around me, pulling me into a close hug."
    "Ohne Vorwarnung stürzt sie sich auf mich, schlingt ihre Arme um mich und zieht mich in eine innige Umarmung."

# game/Scenes/Mari/mari1.rpy:82
translate german maritip2_9ba61eed:

    # "She's so warm and soft."
    "Sie ist so warm und weich."

# game/Scenes/Mari/mari1.rpy:83
translate german maritip2_23314f60:

    # "And bonus - she smells like burgers."
    "Und als Bonus – sie riecht nach Burgern."

# game/Scenes/Mari/mari1.rpy:84
translate german maritip2_c96f83e2:

    # pc "Well you're a great waitress."
    pc "Nun, du bist eine tolle Kellnerin."

# game/Scenes/Mari/mari1.rpy:85
translate german maritip2_d1889969:

    # fr "It's easy when the customers are as nice as you are."
    fr "Das ist einfach, wenn die Gäste so nett sind wie du."

# game/Scenes/Mari/mari1.rpy:86
translate german maritip2_9bc4e48c:

    # fr "Come back and see me again soon, okay?"
    fr "Komm bald wieder vorbei und besuch mich, okay?"

# game/Scenes/Mari/mari1.rpy:87
translate german maritip2_9782867b:

    # pc "Oh I'm sure I will."
    pc "Oh, das werde ich sicher."

# game/Scenes/Mari/mari1.rpy:89
translate german maritip2_fb1fac0d:

    # fr "Have a good night, sweetie."
    fr "Hab einen schönen Abend, Schatz."

# game/Scenes/Mari/mari1.rpy:90
translate german maritip2_eb61ef6e:

    # pc "You too."
    pc "Du auch."

# game/Scenes/Mari/mari1.rpy:92
translate german maritip2_3cb27537:

    # "I give her a wave."
    "Ich winke ihr zu."

# game/Scenes/Mari/mari1.rpy:93
translate german maritip2_739d2b0c:

    # "With that, I go back outside and head to my car."
    "Damit gehe ich wieder nach draußen und steuere mein Auto an."

