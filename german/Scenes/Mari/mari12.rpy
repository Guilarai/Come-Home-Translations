    fr "Das war toll. Zeit mit dir zu verbringen. Dinge zu tun wie ein Paar."

# game/Scenes/Mari/mari12.rpy:197
translate german mari12b_ffc4a85b:

    # pc "Yeah, it's been fun."
    pc "Ja, es hat Spaß gemacht."

# game/Scenes/Mari/mari12.rpy:199
