    # fr "Please, make love to me, [pcname]."
    fr "Bitte, schlaf mit mir, [pcname]."

# game/Scenes/Mari/mari12.rpy:241
translate german mari12b_47510abd:

    # "We kiss as I sink into her."
    "Wir küssen uns, während ich in sie eindringe."

# game/Scenes/Mari/mari12.rpy:242
translate german mari12b_1becc9d2:

    # "Then we move together, every part of us connected."
    "Dann bewegen wir uns gemeinsam, jeder Teil von uns ist miteinander verbunden."

# game/Scenes/Mari/mari12.rpy:243
translate german mari12b_f4010c57:

    # "It's the closest I've ever felt to her."
    "Ich habe mich ihr noch nie so nah gefühlt."

# game/Scenes/Mari/mari12.rpy:247
translate german mari12b_e219a86e:

    # "And when we cum together, I feel everything that she feels."
    "Und als wir gemeinsam kommen, spüre ich alles, was sie fühlt."

# game/Scenes/Mari/mari12.rpy:248
translate german mari12b_e721ecdf:

    # "We hold each other close as I empty myself into her."
    "Wir halten uns fest, während ich mich in ihr entleere."

# game/Scenes/Mari/mari12.rpy:251
translate german mari12b_743db198:

    # "Afterwards, we continue holding each other."
    "Danach halten wir uns weiterhin fest."

# game/Scenes/Mari/mari12.rpy:252
translate german mari12b_2a4dc283:

    # "No words are needed. We both know what the other is thinking."
    "Es sind keine Worte nötig. Wir wissen beide, was der andere denkt."

# game/Scenes/Mari/mari12.rpy:253
translate german mari12b_b73d7100:

    # "Our minds and hearts and bodies are all one."
    "Unsere Gedanken, Herzen und Körper sind eins."

# game/Scenes/Mari/mari12.rpy:256
translate german mari12b_3e0dbf15:

    # "And in the comfort of each other, we fall asleep."
    "Und in der Geborgenheit des anderen schlafen wir ein."

# game/Scenes/Mari/mari12.rpy:259
translate german mari12b_a10928f0:

    # "The next day, she has to go to work, so we say goodbye early."
    "Am nächsten Tag muss sie zur Arbeit, also verabschieden wir uns früh."

# game/Scenes/Mari/mari12.rpy:260
translate german mari12b_ceb21b0a:

    # "But our lips linger on each other."
    "Aber unsere Lippen verweilen noch aneinander."

