# game/Scenes/Izzy/izzy4.rpy:14
translate german izzy4_4024ac17:

    # "I hang out with Izzy and her gang for a while."
    "Ich hänge eine Weile mit Izzy und ihrer Clique ab."

# game/Scenes/Izzy/izzy4.rpy:15
translate german izzy4_13ec06b7:

    # gl "You know, Twig, I like you."
    gl "Weißt du, Twig, ich mag dich."

# game/Scenes/Izzy/izzy4.rpy:18
translate german izzy4_6eac563e:

    # gl "You start coming around here even though you don't quite fit in and you just force your way into my group."
    gl "Du fängst an, hierherzukommen, obwohl du nicht so richtig reinpasst, und drängst dich einfach in meine Gruppe."

# game/Scenes/Izzy/izzy4.rpy:19
translate german izzy4_587e3e94:

    # gl "I like that tenacity. It's pretty hot actually."
    gl "Ich mag diese Hartnäckigkeit. Das ist eigentlich ziemlich heiß."

# game/Scenes/Izzy/izzy4.rpy:20
translate german izzy4_5997026a:

    # gl "Anyway, here's my phone number."
    gl "Jedenfalls, hier ist meine Telefonnummer."

# game/Scenes/Izzy/izzy4.rpy:21
translate german izzy4_9efb5f7a:

    # gl "So we can talk sometime without these knuckle-heads hanging around."
    gl "Damit wir uns mal unterhalten können, ohne dass diese Trottel dabei sind."

# game/Scenes/Izzy/izzy4.rpy:22
translate german izzy4_ef3bfa78:

    # pc "What about Devon? Isn't he your boyfriend?"
    pc "Was ist mit Devon? Ist er nicht dein Freund?"

# game/Scenes/Izzy/izzy4.rpy:23
translate german izzy4_ae3aabd6:

    # gl "I told you. I do what I want."
    gl "Ich hab’s dir doch gesagt. Ich mach, was ich will."

# game/Scenes/Izzy/izzy4.rpy:24
translate german izzy4_3cb128b8:

    # gl "And I want to talk to you solo sometime."
    gl "Und ich will mich mal mit dir unter vier Augen unterhalten."

# game/Scenes/Izzy/izzy4.rpy:25
translate german izzy4_136391eb:

    # gl "That okay?"
    gl "Ist das okay?"

# game/Scenes/Izzy/izzy4.rpy:26
translate german izzy4_4f1735dd:

    # pc "Sounds good to me."
    pc "Klingt gut für mich."

# game/Scenes/Izzy/izzy4.rpy:27
translate german izzy4_74f6beab:

    # gl "Good. Call me sometime."
    gl "Gut. Ruf mich mal an."

# game/Scenes/Izzy/izzy4.rpy:28
translate german izzy4_08551511:

    # pc "You got it."
    pc "Klar."

# game/Scenes/Izzy/izzy4.rpy:32
translate german izzy4_41084d43:

    # "I add Izzy's phone number into my contacts list."
    "Ich speichere Izzys Telefonnummer in meinen Kontakten."

# game/Scenes/Izzy/izzy4.rpy:34
translate german izzy4_ade661fa:

    # "We hang out a little longer, smoking and dancing."
    "Wir bleiben noch ein bisschen länger, rauchen und tanzen."

# game/Scenes/Izzy/izzy4.rpy:36
translate german izzy4_2c51ee8c:

    # "We hang out a little longer, just chatting and dancing."
    "Wir bleiben noch ein bisschen länger, quatschen einfach und tanzen."

# game/Scenes/Izzy/izzy4.rpy:37
translate german izzy4_a42d0c9d:

    # "The cops don't even show up tonight. They must be busy working some actual crimes."
    "Die Bullen tauchen heute Abend gar nicht auf. Die müssen wohl mit echten Verbrechen beschäftigt sein."

# game/Scenes/Izzy/izzy4.rpy:38
translate german izzy4_fce6a84a:

    # "It's a good time."
    "Es ist eine schöne Zeit."

# game/Scenes/Izzy/izzy4.rpy:39
translate german izzy4_efe3ccf0:

    # "Then when it's time to leave, everybody goes their separate ways and I head back to the car and drive off."
    "Als es dann Zeit ist zu gehen, gehen alle ihrer Wege, und ich gehe zurück zum Auto und fahre los."

