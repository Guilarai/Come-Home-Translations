    # gl "Oh yeah?"
    gl "Ach ja?"

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:16
translate german izzyp4_c02c2521:

    # pc "Yeah, one of my friends is having to leave her job at Jackson Burger. They're looking for a new waitress."
    pc "Ja, eine meiner Freundinnen muss ihren Job bei Jackson Burger aufgeben. Die suchen eine neue Kellnerin."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:18
translate german izzyp4_0b7b081b:

    # gl "A waitress job? Man, that's not really my thing."
    gl "Ein Job als Kellnerin? Mann, das ist nicht so mein Ding."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:20
translate german izzyp4_98a7524a:

    # gl "But at this point, I'll take what I can get."
    gl "Aber im Moment nehme ich, was ich kriegen kann."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:21
translate german izzyp4_9a7e05b5:

    # gl "Did she like the job? Why is she leaving?"
    gl "Hat ihr der Job gefallen? Warum hört sie auf?"

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:22
translate german izzyp4_56c9f3fd:

    # pc "She's starting at a veterinary job soon. She liked the job though, yeah. She said the owner is a really nice guy."
    pc "Sie fängt bald bei einem Tierarzt an. Der Job hat ihr aber gefallen, ja. Sie hat gesagt, der Besitzer ist ein echt netter Typ."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:23
translate german izzyp4_3d91189b:

    # gl "Alright, I'll try for it."
    gl "Okay, ich versuch’s mal."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:24
translate german izzyp4_5573e1d8:

    # pc "Here, I'll give you Mari's number. She'll probably be able to help you."
    pc "Hier, ich geb dir Maris Nummer. Sie kann dir wahrscheinlich helfen."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:25
translate german izzyp4_3dff977c:

    # gl "Cool."
    gl "Cool."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:26
translate german izzyp4_c56ff175:

    # "I give her Mari's phone number and she puts it in her phone contacts."
    "Ich geb ihr Maris Telefonnummer und sie speichert sie in ihren Kontakten."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:28
translate german izzyp4_ef7a6e14:

    # gl "Thanks, Twig. I appreciate your help. Really."
    gl "Danke, Twig. Ich weiß deine Hilfe echt zu schätzen. Wirklich."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:29
translate german izzyp4_c5692f98:

    # pc "No problem. I hope you get the job."
    pc "Kein Problem. Ich hoffe, du bekommst den Job."

# game/Scenes/Izzy/izzyconversations/izzyp4.rpy:30
translate german izzyp4_e1bc7428:

    # gl "Me too. I'm really starting to struggle for money."
    gl "Ich auch. Ich habe langsam echt Geldsorgen."

translate german strings:

