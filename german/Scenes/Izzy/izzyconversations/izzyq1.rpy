# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:16
translate german izzyq1_d0eb45b5:

    # gl "I don't think so. If we have, I don't remember."
    gl "Ich glaube nicht. Falls doch, erinnere ich mich nicht daran."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:18
translate german izzyq1_9dfac34c:

    # gl "Honestly, I wasn't interested in anything above your belt until recently."
    gl "Ehrlich gesagt, hat mich bis vor kurzem nichts oberhalb deiner Gürtellinie interessiert."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:19
translate german izzyq1_b5ea135c:

    # pc "That's fair."
    pc "Das ist fair."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:21
translate german izzyq1_e15068c6:

    # pc "Well, I go to college, and I have a job as an assistant at a law firm."
    pc "Also, ich gehe aufs College und arbeite als Assistent in einer Anwaltskanzlei."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:23
translate german izzyq1_93e6458a:

    # gl "You're a fucking lawyer? For real?"
    gl "Du bist ein verdammter Anwalt? Im Ernst?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:25
translate german izzyq1_4a320e48:

    # pc "No, no, I'm just an assistant."
    pc "Nein, nein, ich bin nur ein Assistent."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:26
translate german izzyq1_c5a8953c:

    # pc "Like, I clean the office and deal with phones and paperwork and stuff."
    pc "Ich putze das Büro und kümmere mich um Telefonate, Papierkram und so."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:28
translate german izzyq1_f32b0f5a:

    # gl "Like a secretary plus janitor?"
    gl "So wie eine Mischung aus Sekretär und Hausmeister?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:29
translate german izzyq1_ef8bda5d:

    # pc "Sort of."
    pc "So in etwa."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:31
translate german izzyq1_df5aa9d8:

    # gl "Hell, I could do that! And they pay you good, plus give you a car to drive?"
    gl "Verdammt, das könnte ich auch! Und sie bezahlen dich gut und geben dir noch ein Auto?"

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:33
translate german izzyq1_9f00d552:

    # pc "Yeah, I guess so."
    pc "Ja, ich glaub schon."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:35
translate german izzyq1_b429ca1b:

    # gl "I need to get me one of them jobs."
    gl "So einen Job muss ich mir auch besorgen."

# game/Scenes/Izzy/izzyconversations/izzyq1.rpy:36
translate german izzyq1_4017ea2a:

    # pc "It ain't bad."
    pc "Ist gar nicht schlecht."

