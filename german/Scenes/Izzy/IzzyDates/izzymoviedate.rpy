# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:34
translate german izzymoviedatestart_01687529:

    # gl "What's up, Twig. Let's go see this movie."
    gl "Was geht, Twig. Lass uns den Film anschauen."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:38
translate german izzymoviedatestart_00bfd309:

    # gl "This is kinda fun actually. Been a while since I've gone to the movies."
    gl "Das macht eigentlich ganz Spaß. Ist schon eine Weile her, dass ich im Kino war."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:39
translate german izzymoviedatestart_3746eb4d:

    # gl "Except taking my brothers to see Shrek and shit."
    gl "Abgesehen davon, dass ich meine Brüder mit zu „Shrek“ und so genommen hab."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:40
translate german izzymoviedatestart_fefe72bc:

    # gl "Not on a date or anything, anyways."
    gl "Jedenfalls nicht auf einem Date oder so."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:41
translate german izzymoviedatestart_a14fd1a7:

    # pc "So it is a date?"
    pc "Also ist es ein Date?"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:43
translate german izzymoviedatestart_92636968:

    # gl "You want to date me? Like, seriously?"
    gl "Du willst mit mir ausgehen? Im Ernst?"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:46
translate german izzymoviedatestart_4e0b05f2:

    # gl "You know I'm not into the whole monogamy thing though, right?"
    gl "Du weißt aber, dass ich nicht so auf diese Monogamie-Sache stehe, oder?"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:47
translate german izzymoviedatestart_e9418800:

    # pc "I'm not really either."
    pc "Ich auch nicht wirklich."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:48
translate german izzymoviedatestart_4dabe89e:

    # gl "So you keep fucking who you want and I keep fucking who I want, but we also go on dates and fuck each other?"
    gl "Also fickst du weiter, wen du willst, und ich ficke weiter, wen ich will, aber wir gehen auch auf Dates und ficken miteinander?"

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:49
translate german izzymoviedatestart_0aa625bf:

    # pc "I mean, that sounds cool to me."
    pc "Ich meine, das klingt für mich cool."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:51
translate german izzymoviedatestart_0933ffde:

    # gl "Me too. Let's just keep it simple. As long as you're not trying to chain me down, I'm happy with the situation."
    gl "Für mich auch. Lass es uns einfach halten. Solange du nicht versuchst, mich an dich zu binden, bin ich mit der Situation zufrieden."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:52
translate german izzymoviedatestart_2843a332:

    # gl "The moment you tell me I can't do what I want to do, we'll have problems."
    gl "In dem Moment, in dem du mir sagst, ich darf nicht tun, was ich will, gibt es Probleme."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:53
translate german izzymoviedatestart_0d652c29:

    # pc "I wouldn't do that."
    pc "Das würde ich nicht tun."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:55
translate german izzymoviedatestart_2e09af75:

    # gl "Cool. We can date then. We're dating."
    gl "Cool. Dann können wir uns verabreden. Wir sind zusammen."

# game/Scenes/Izzy/IzzyDates/izzymoviedate.rpy:56
translate german izzymoviedatestart_9900eca8:

