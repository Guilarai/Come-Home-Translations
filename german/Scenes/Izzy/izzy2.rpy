translate german izzy2_45725a14:

    # gl "And tall, dark and skinny behind me is Devon. He don't talk much."
    gl "Und der große, dunkle und dünne Typ hinter mir ist Devon. Er redet nicht viel."

# game/Scenes/Izzy/izzy2.rpy:49
translate german izzy2_dc8cb990:

    # "Devon nods his head slightly at me."
    "Devon nickt mir leicht zu."

# game/Scenes/Izzy/izzy2.rpy:50
translate german izzy2_522e1448:

    # gl "And that's the gang. Except now there's you - Twig."
    gl "Und das ist die Clique. Außer dass jetzt du dabei bist – Twig."

# game/Scenes/Izzy/izzy2.rpy:51
