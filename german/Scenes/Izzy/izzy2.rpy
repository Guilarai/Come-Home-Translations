    "Er knallt hart auf den Boden und liegt stöhnend da."

# game/Scenes/Izzy/izzy2.rpy:21
translate german izzy2_7575cb2e:

    # "Izzy and the others burst into laughter, pointing at him."
    "Izzy und die anderen brechen in Gelächter aus und zeigen auf ihn."

