translate german izzy2_b51311fa:

    # "I'm not going to run though. I'm confident in myself."
    "Ich werde aber nicht weglaufen. Ich bin mir meiner Sache sicher."

# game/Scenes/Izzy/izzy2.rpy:14
translate german izzy2_a9a2f7bf:

    # "Maybe he'll kick my ass, but I'm not running."
