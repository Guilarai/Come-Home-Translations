# game/Scenes/Izzy/izzy16.rpy:137
translate german izzy16_c63a510c:

    # gl "Man, he told you about this at the beginning. The person who has the longest road gets that card and gets 2 points."
    gl "Mann, er hat dir das doch am Anfang erklärt. Wer die längste Straße hat, bekommt diese Karte und zwei Punkte."

