# game/Scenes/Izzy/izzy16.rpy:103
translate german izzy16_51e89ffe:

    # mal "Are we seriously going to play this? It's like the nerdiest thing I've ever seen."
    mal "Wollen wir das jetzt ernsthaft spielen? Das ist das nerdigste Ding, das ich je gesehen habe."

# game/Scenes/Izzy/izzy16.rpy:104
translate german izzy16_2245c52c:

    # moose "It looks fun to me. You ever play Trouble? Man, I fucking love Trouble."
    moose "Ich finde es lustig. Hast du schon mal „Trouble“ gespielt? Mann, ich liebe „Trouble“ verdammt noch mal."

# game/Scenes/Izzy/izzy16.rpy:105
