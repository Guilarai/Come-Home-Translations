translate german kendraq2_03fd43c1:

    # pc "My dad went missing. I came home to help find him."
    pc "Mein Vater ist verschwunden. Ich bin nach Hause gekommen, um bei der Suche nach ihm zu helfen."

# game/Scenes/Kendra/KendraConversations/kendraq2.rpy:26
translate german kendraq2_3f912939:

    # sg "Did you find him?"
    sg "Hast du ihn gefunden?"

# game/Scenes/Kendra/KendraConversations/kendraq2.rpy:27
translate german kendraq2_0b7558fc:

    # pc "Not yet."
    pc "Noch nicht."

# game/Scenes/Kendra/KendraConversations/kendraq2.rpy:29
translate german kendraq2_23ae1b3d:

    # sg "Aw that sucks. Sorry, man."
    sg "Oh, das ist echt schade. Tut mir leid, Mann."

# game/Scenes/Kendra/KendraConversations/kendraq2.rpy:30
translate german kendraq2_44963082:

    # sg "Back to Brazil though. That place seems so cool. I'd love to go there some day."
    sg "Aber zurück zu Brasilien. Der Ort scheint so cool zu sein. Ich würde gerne mal dorthin fahren."

# game/Scenes/Kendra/KendraConversations/kendraq2.rpy:31
