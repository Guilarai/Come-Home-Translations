translate german kendras4_f972c97b:

    # sg "Eh, I get by. I don't need much."
    sg "Ach, ich komme klar. Ich brauche nicht viel."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:21
translate german kendras4_45cb15cf:

    # sg "I just value my time much more than anybody could pay me."
    sg "Ich schätze meine Zeit einfach viel mehr, als mir irgendjemand bezahlen könnte."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:22
translate german kendras4_484e8cb5:

    # pc "I guess that makes sense, but I worry about what's going to happen in the future."
    pc "Das leuchtet mir ein, aber ich mache mir Sorgen darüber, was in der Zukunft passieren wird."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:23
translate german kendras4_c26abf81:

    # sg "Not me. No point."
    sg "Ich nicht. Hat keinen Sinn."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:24
translate german kendras4_a2a6fb65:

    # pc "What do you mean?"
    pc "Was meinst du damit?"

