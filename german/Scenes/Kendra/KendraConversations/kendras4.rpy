# game/Scenes/Kendra/KendraConversations/kendras4.rpy:16
translate german kendras4_3bdab488:

    # sg "Don't need it."
    sg "Brauche ich nicht."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:17
translate german kendras4_1ea5be82:

    # sg "Why the hell would I need money?"
