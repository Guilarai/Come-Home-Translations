# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:15
translate german suzys8_1446ff69:

    # ss "I'm not sure I've ever even seen those keys."
    ss "Ich bin mir nicht sicher, ob ich diese Schlüssel überhaupt je gesehen habe."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:16
translate german suzys8_569338fe:

    # pc "You've never ridden in the car with him?"
    pc "Du bist noch nie mit ihm im Auto mitgefahren?"

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:18
translate german suzys8_1d0237b1:

    # ss "Never. If we went somewhere together it was always in Mom's car."
    ss "Nie. Wenn wir zusammen irgendwo hingefahren sind, war es immer in Mamas Auto."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:19
translate german suzys8_c1971cf2:

    # ss "He almost never left the house in the last, like, year or so though."
    ss "Er hat das Haus im letzten Jahr oder so aber fast nie verlassen."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:20
translate german suzys8_c7effbef:

    # pc "Dang. It's so weird that I can't find his keys anywhere."
    pc "Mist. Es ist so seltsam, dass ich seine Schlüssel nirgendwo finden kann."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:22
translate german suzys8_7f01995f:

    # ss "Why do you want that car so bad?"
    ss "Warum willst du das Auto so unbedingt haben?"

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:23
translate german suzys8_b0004592:

    # pc "I'd like to drive the car! You've seen what I've been driving."
    pc "Ich würde gerne damit fahren! Du hast doch gesehen, was ich bisher gefahren bin."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:25
translate german suzys8_0e2b81f6:

    # ss "What? I think the Beetle is cute!"
    ss "Was? Ich finde den Beetle süß!"

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:26
translate german suzys8_345a6dbf:

    # pc "Cute, yeah, but Dad's car is badass."
    pc "Süß, ja, aber Dads Auto ist der Hammer."

# game/Scenes/Suzy/SuzyConversations/suzys8.rpy:28
translate german suzys8_f1ccabba:

    # "She snorts."
