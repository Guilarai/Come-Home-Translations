# game/Scenes/Suzy/suzy1.rpy:13
translate german suzy1_b52dca5a:

    # "I go to the kitchen and make a plate with what's left, then sit down across from her at the table."
    "Ich gehe in die Küche und mache mir einen Teller mit den Resten, dann setze ich mich ihr gegenüber an den Tisch."

# game/Scenes/Suzy/suzy1.rpy:14
translate german suzy1_c4e96a72:

    # "She puts her phone away and looks up at me."
    "Sie steckt ihr Handy weg und schaut zu mir hoch."

# game/Scenes/Suzy/suzy1.rpy:17
translate german suzy1_43f2e75d:

    # ss "So how's it been going [bro]?"
    ss "Und, wie läuft’s so [bro]?"

# game/Scenes/Suzy/suzy1.rpy:18
translate german suzy1_d48b3188:

    # pc "Pretty good, I guess."
    pc "Ziemlich gut, schätze ich."

# game/Scenes/Suzy/suzy1.rpy:19
translate german suzy1_c84b49b4:

    # ss "Have you found out anything about Dad?"
    ss "Hast du irgendwas über Papa herausgefunden?"

# game/Scenes/Suzy/suzy1.rpy:20
translate german suzy1_0b7558fc:

    # pc "Not yet."
    pc "Noch nicht."

# game/Scenes/Suzy/suzy1.rpy:22
translate german suzy1_e47fa0f8:

    # ss "I miss him."
    ss "Ich vermisse ihn."

# game/Scenes/Suzy/suzy1.rpy:23
translate german suzy1_0b941cef:

    # pc "You got along with him well?"
    pc "Hast du dich gut mit ihm verstanden?"

# game/Scenes/Suzy/suzy1.rpy:24
translate german suzy1_0442c0e0:

    # ss "Yeah."
    ss "Ja."

# game/Scenes/Suzy/suzy1.rpy:25
translate german suzy1_d244b907:

    # ss "I mean, we didn't spend a lot of time together. He was down in that basement a lot."
    ss "Ich meine, wir haben nicht viel Zeit miteinander verbracht. Er war oft unten im Keller."

# game/Scenes/Suzy/suzy1.rpy:26
translate german suzy1_34edb007:

    # ss "But he would have breakfast with me every morning before school. He was funny. He'd make me laugh every day."
    ss "Aber er hat jeden Morgen vor der Schule mit mir gefrühstückt. Er war lustig. Er hat mich jeden Tag zum Lachen gebracht."

# game/Scenes/Suzy/suzy1.rpy:27
translate german suzy1_85af114e:

    # pc "Kind of like this, huh?"
    pc "So in etwa, was?"

# game/Scenes/Suzy/suzy1.rpy:29
translate german suzy1_226f4904:

    # ss "I said he was funny, not obnoxious. Plus, he wore pants. Why are you walking around in your boxers?"
    ss "Ich hab gesagt, er war lustig, nicht nervig. Außerdem hat er Hosen getragen. Warum läufst du hier in Boxershorts rum?"

# game/Scenes/Suzy/suzy1.rpy:30
translate german suzy1_4cc016bf:

    # pc "It's morning, I don't want to get dressed yet. You can eat breakfast in your underwear if you want."
    pc "Es ist morgens, ich will mich noch nicht anziehen. Du kannst in Unterwäsche frühstücken, wenn du willst."

# game/Scenes/Suzy/suzy1.rpy:31
translate german suzy1_bd01965a:

    # ss "Yeah, I bet you'd like that. You'd just stare at me the whole time."
    ss "Ja, das fändest du bestimmt toll. Du würdest mich die ganze Zeit nur anstarren."

# game/Scenes/Suzy/suzy1.rpy:35
translate german suzy1_d7a0aba4:

    # ss "You're such a perv."
    ss "Du bist so ein Perverser."

# game/Scenes/Suzy/suzy1.rpy:38
translate german suzy1_0ca3339d:

    # ss "You're such a jerk."
    ss "Du bist so ein Idiot."

# game/Scenes/Suzy/suzy1.rpy:39
translate german suzy1_a976ce63:

    # pc "Besides, you act like you don't stare at me when I'm in my boxers."
    pc "Außerdem tust du so, als würdest du mich nicht anstarren, wenn ich in Boxershorts bin."

# game/Scenes/Suzy/suzy1.rpy:40
translate german suzy1_23992985:

    # ss "What!? I do not!"
    ss "Was!? Das tue ich nicht!"

# game/Scenes/Suzy/suzy1.rpy:41
translate german suzy1_25e7a80f:

    # pc "Come on now [sis], I've seen you."
    pc "Komm schon [sis], ich habe dich gesehen."

# game/Scenes/Suzy/suzy1.rpy:43
translate german suzy1_873662ce:

    # ss "You're out of your mind. I've never stared at you. Like you have anything to stare at anyways."
    ss "Du bist verrückt. Ich habe dich nie angestarrt. Als ob du überhaupt etwas hättest, das man anstarren könnte."

# game/Scenes/Suzy/suzy1.rpy:44
translate german suzy1_6e7bc529:

    # pc "Oh I don't have anything to stare at?"
    pc "Oh, ich habe nichts, was man anstarren könnte?"

# game/Scenes/Suzy/suzy1.rpy:45
translate german suzy1_ec7a8238:

    # ss "Nope."
    ss "Nö."

# game/Scenes/Suzy/suzy1.rpy:48
translate german suzy1_7745b76d:

    # ss "Yeah, whatever."
    ss "Ja, wie auch immer."

# game/Scenes/Suzy/suzy1.rpy:51
translate german suzy1_24166e5d:

    # ss "No! I don't want to see!"
    ss "Nein! Ich will das nicht sehen!"

# game/Scenes/Suzy/suzy1.rpy:52
translate german suzy1_483160a9:

    # ss "Sit down. Stop playing around."
    ss "Setz dich hin. Hör auf, rumzualbern."

# game/Scenes/Suzy/suzy1.rpy:53
translate german suzy1_ce7899d2:

    # pc "I'm not playing. I'll show you."
    pc "Ich albere nicht. Ich zeig’s dir."

# game/Scenes/Suzy/suzy1.rpy:54
translate german suzy1_626bbd17:

    # ss "I don't want to see it. I believe you have something there, but I don't want to see it."
    ss "Ich will das nicht sehen. Ich glaube, du hast da was, aber ich will es nicht sehen."

# game/Scenes/Suzy/suzy1.rpy:55
translate german suzy1_c1226f21:

    # ss "Put it away, sit down."
    ss "Steck’s weg, setz dich hin."

# game/Scenes/Suzy/suzy1.rpy:56
translate german suzy1_02b8ec2b:

    # pc "Alright, I'm sitting."
    pc "Na gut, ich setz mich hin."

# game/Scenes/Suzy/suzy1.rpy:58
translate german suzy1_c7580a8a:

    # ss "You're such a weirdo."
    ss "Du bist so ein Spinner."

# game/Scenes/Suzy/suzy1.rpy:59
translate german suzy1_086a625f:

    # "We spend the rest of the breakfast talking about school and work and joking around."
    "Den Rest des Frühstücks verbringen wir damit, über Schule und Arbeit zu reden und herumzualbern."

# game/Scenes/Suzy/suzy1.rpy:60
translate german suzy1_74d7aff9:

    # "Then we finish eating and it's time to go to school."
    "Dann sind wir fertig mit Essen und es ist Zeit, zur Schule zu gehen."

# game/Scenes/Suzy/suzy1.rpy:65
translate german suzy1_74b357a7:

    # ss "Have a good day [bro]. See you later."
    ss "Hab einen schönen Tag [bro]. Bis später."

# game/Scenes/Suzy/suzy1.rpy:66
translate german suzy1_7dee10c4:

    # pc "Bye [sis]."
    pc "Tschüss [sis]."

# game/Scenes/Suzy/suzy1.rpy:71
translate german suzy1_015cad61:

    # "She leaves for school and I follow right after her."
    "Sie geht zur Schule und ich folge ihr direkt hinterher."

