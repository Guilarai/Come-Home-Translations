translate german suzy8_ef42fa9f:

    # ss "Leave me alone! Get out of my room!"
    ss "Lass mich in Ruhe! Raus aus meinem Zimmer!"

# game/Scenes/Suzy/suzy8.rpy:41
translate german suzy8_c77c201a:

    # pc "I just heard you crying and..."
    pc "Ich habe dich gerade weinen gehört und..."

# game/Scenes/Suzy/suzy8.rpy:43
translate german suzy8_d41d8cd9_2:

    # voice 'voices/suzy_8_3.mp3'
    voice 'voices/suzy_8_3.mp3'

