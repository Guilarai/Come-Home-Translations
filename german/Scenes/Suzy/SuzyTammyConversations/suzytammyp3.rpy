# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:13
translate german suzytammyp3_0505d446:

    # tm "Okay, first of all, it's my mom and step-dad. I would never refer to him as my parent."
    tm "Okay, erst mal: Es sind meine Mutter und mein Stiefvater. Ich würde ihn niemals als meinen Elternteil bezeichnen."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:14
translate german suzytammyp3_b1360d78:

    # tm "But yeah, of course. I hate living there. I'd love to get out. I'm working on it."
    tm "Aber ja, natürlich. Ich hasse es, dort zu wohnen. Ich würde gerne ausziehen. Ich arbeite daran."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:16
translate german suzytammyp3_22e72086:

    # ss "I keep telling her to come live with us. I'm sure Mom wouldn't mind. Then she wouldn't have to pay rent."
    ss "Ich sage ihr ständig, sie soll bei uns wohnen. Ich bin mir sicher, dass Mama nichts dagegen hätte. Dann müsste sie keine Miete zahlen."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:18
translate german suzytammyp3_c572f59f:

    # pc "Wait, they make you pay rent?"
    pc "Moment, die verlangen von dir Miete?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:19
translate german suzytammyp3_d9787c7f:

    # tm "Yeah, as soon as I hit 18. On my birthday."
    tm "Ja, sobald ich 18 werde. An meinem Geburtstag."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:21
translate german suzytammyp3_fc215764:

    # ss "They're assholes."
    ss "Das sind Arschlöcher."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:23
translate german suzytammyp3_299b912c:

    # tm "It's mostly my step-dad."
    tm "Hauptsächlich mein Stiefvater."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:24
translate german suzytammyp3_331cc0dc:

    # pc "So why not move out?"
    pc "Warum ziehst du dann nicht aus?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:25
translate german suzytammyp3_dfcc6985:

    # tm "Money. They're charging me rent, but it's not as much as I would have to pay if I lived in an apartment or something."
    tm "Geld. Sie verlangen zwar Miete von mir, aber es ist nicht so viel, wie ich zahlen müsste, wenn ich in einer Wohnung oder so wohnen würde."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:26
translate german suzytammyp3_e79f4cf2:

    # tm "Even with a roomate or two, I couldn't afford it."
    tm "Selbst mit ein oder zwei Mitbewohnern könnte ich mir das nicht leisten."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:28
translate german suzytammyp3_f08e627e:

    # ss "Unless you moved in with me at my house, like I keep saying!"
    ss "Es sei denn, du würdest bei mir einziehen, wie ich dir schon immer sage!"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:29
translate german suzytammyp3_087a9e71:

    # ss "I bet Mom wouldn't even make you pay rent. You could save all that money up for stuff you really want to do."
    ss "Ich wette, Mama würde dir nicht mal Miete abverlangen. Du könntest das ganze Geld für Dinge sparen, die du wirklich tun willst."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:31
translate german suzytammyp3_79902487:

    # tm "I don't want to be a burden."
    tm "Ich will keine Last sein."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:33
translate german suzytammyp3_3b096adf:

    # ss "You're not a burden!"
    ss "Du bist keine Last!"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:35
translate german suzytammyp3_45c8dbab:

    # pc "She's right. I'm sure Lisa wouldn't mind."
    pc "Sie hat recht. Ich bin mir sicher, Lisa hätte nichts dagegen."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:37
translate german suzytammyp3_a1b868ba:

    # ss "She loves you."
    ss "Sie liebt dich."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:39
translate german suzytammyp3_5a6e2370:

    # tm "She's already got so much going on right now."
    tm "Sie hat im Moment schon so viel um die Ohren."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:40
translate german suzytammyp3_afc19c8b:

    # tm "I'll be okay. I think I'm pretty close to having enough to move out on my own. I just need to save up a little more."
    tm "Mir geht es gut. Ich glaube, ich habe schon fast genug zusammen, um auf eigene Faust auszuziehen. Ich muss nur noch ein bisschen mehr sparen."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:42
translate german suzytammyp3_d7ffdf92:

    # ss "I don't understand why you don't want to live with me."
    ss "Ich verstehe nicht, warum du nicht mit mir zusammenwohnen willst."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:44
translate german suzytammyp3_dac14472:

    # tm "It's not you, baby."
    tm "Es liegt nicht an dir, Schatz."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:45
translate german suzytammyp3_364f2b72:

    # tm "I'm just worried... what if it doesn't work out? What if I'm an annoying roommate and I make you mad at me?"
    tm "Ich mache mir nur Sorgen … was, wenn es nicht klappt? Was, wenn ich eine nervige Mitbewohnerin bin und du dich über mich ärgerst?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:46
translate german suzytammyp3_bd5ca9c1:

    # tm "I don't want you to stop being friends with me."
    tm "Ich will nicht, dass du aufhörst, mit mir befreundet zu sein."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:48
translate german suzytammyp3_bb7f9080:

    # ss "I'm never going to stop being friends with you, dummy."
    ss "Ich werde nie aufhören, mit dir befreundet zu sein, Dummkopf."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:49
translate german suzytammyp3_feacebdb:

    # ss "Even if you leave your dirty clothes everywhere, eat all my stuff out of the fridge, and snore and fart all night long."
    ss "Selbst wenn du deine schmutzigen Klamotten überall liegen lässt, alles aus meinem Kühlschrank isst und die ganze Nacht lang schnarchst und furzt."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:50
translate german suzytammyp3_36eb3f4f:

    # ss "You're always going to be my best friend."
    ss "Du wirst immer meine beste Freundin sein."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:52
translate german suzytammyp3_5db2443b:

    # tm "That's the sweetest thing that anybody has ever said to me."
    tm "Das ist das Netteste, was mir je jemand gesagt hat."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:54
translate german suzytammyp3_b9deba89:

    # ss "You could save all of that rent money. Plus, we could all three spend the nights together."
    ss "Du könntest dir die ganze Miete sparen. Außerdem könnten wir drei die Nächte zusammen verbringen."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:55
translate german suzytammyp3_4f1735dd:

    # pc "Sounds good to me."
    pc "Klingt gut für mich."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:57
translate german suzytammyp3_8cfcea81:

    # tm "It does sound nice."
    tm "Das klingt wirklich schön."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:59
translate german suzytammyp3_e96854ea:

    # tm "I'll think about it, okay?"
    tm "Ich werde darüber nachdenken, okay?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:61
translate german suzytammyp3_fb39f07c:

    # ss "Please."
    ss "Bitte."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:62
translate german suzytammyp3_db331038:

    # ss "I don't like you living with that asshole."
    ss "Ich mag es nicht, dass du mit diesem Arschloch zusammenlebst."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyp3.rpy:64
translate german suzytammyp3_89c60a44:

    # tm "You and me both, baby."
    tm "Das geht mir genauso, Baby."

