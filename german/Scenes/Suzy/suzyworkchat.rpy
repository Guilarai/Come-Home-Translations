translate german suzyworkchat_59e438d3:

    # ss "I'm not interested in talking to you right now, [bro]."
    ss "Ich habe gerade keine Lust, mit dir zu reden, [bro]."

# game/Scenes/Suzy/suzyworkchat.rpy:5
translate german suzyworkchat_9b09fef9:

    # ss "Just leave me alone."
    ss "Lass mich einfach in Ruhe."

# game/Scenes/Suzy/suzyworkchat.rpy:6
translate german suzyworkchat_350e21a3:

    # pc "Okay, sorry."
    pc "Okay, tut mir leid."

# game/Scenes/Suzy/suzyworkchat.rpy:7
translate german suzyworkchat_c5cf0c4b:

    # "I leave the cafe. Hopefully she gets over her anger soon. I'm not really sure what I can do about it."
    "Ich verlasse das Café. Hoffentlich legt sie ihren Ärger bald ab. Ich bin mir nicht wirklich sicher, was ich dagegen tun kann."

# game/Scenes/Suzy/suzyworkchat.rpy:11
translate german suzyworkchat_41b9410d:

    # "Suzy is working, but she just looks at me angrily when I start to approach the counter."
    "Suzy arbeitet, aber sie schaut mich nur wütend an, als ich mich der Theke nähere."

# game/Scenes/Suzy/suzyworkchat.rpy:12
translate german suzyworkchat_75c50bfb:

    # "She's obviously still mad at me. I should try to talk to her at home sometime to see if we can patch things up."
    "Sie ist offensichtlich immer noch sauer auf mich. Ich sollte versuchen, irgendwann zu Hause mit ihr zu reden, um zu sehen, ob wir uns wieder vertragen können."

# game/Scenes/Suzy/suzyworkchat.rpy:13
translate german suzyworkchat_2ad9f9e9:

    # "For now, I'll just leave."
    "Fürs Erste gehe ich einfach."

# game/Scenes/Suzy/suzyworkchat.rpy:18
translate german suzyworkchat_155b6f0a:

    # "I chat with Suzy for a little bit."
    "Ich unterhalte mich ein bisschen mit Suzy."

# game/Scenes/Suzy/suzyworkchat.rpy:22
translate german suzyworkchat_e5844f44:

    # "Then it's time to get to school."
    "Dann ist es Zeit, zur Schule zu gehen."

