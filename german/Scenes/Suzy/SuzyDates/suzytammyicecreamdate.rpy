# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:18
translate german suzytammyicecreamdate_4ffc27b3:

    # "When Suzy is ready, we leave and meet Tammy at the ice cream parlor."
    "Wenn Suzy bereit ist, gehen wir und treffen Tammy in der Eisdiele."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:21
translate german suzytammyicecreamdate_52a33e67:

    # ss "Oh my God, they have coconut. I want that please."
    ss "Oh mein Gott, die haben Kokosnuss. Das möchte ich bitte."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:22
translate german suzytammyicecreamdate_26a56ba4:

    # tm "I'll get the cappuccino chocolate chunk frozen yogurt."
    tm "Ich nehme den Cappuccino-Schokoladenstückchen-Frozen-Yogurt."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:23
translate german suzytammyicecreamdate_4dc17a69:

    # ss "Don't you get enough coffee at work? I kinda hate the smell of it now."
    ss "Bekommst du nicht genug Kaffee bei der Arbeit? Ich hasse den Geruch mittlerweile irgendwie."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:24
translate german suzytammyicecreamdate_d1ff38f6:

    # tm "I think I'm the opposite. I love it. The smell, the taste, everything."
    tm "Ich glaube, bei mir ist es genau umgekehrt. Ich liebe ihn. Den Geruch, den Geschmack, einfach alles."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:25
translate german suzytammyicecreamdate_10f4b187:

    # ss "Blech!"
    ss "Igitt!"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:31
translate german suzytammyicecreamdate_a716a63e:

    # "We sit down and enjoy our ice cream and chat for a while."
    "Wir setzen uns hin, genießen unser Eis und unterhalten uns eine Weile."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:39
translate german suzytammyicecreamdate_d478079d:

    # "When the ice cream is gone, our conversation slows down."
    "Als das Eis aufgegessen ist, verstummt unser Gespräch allmählich."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:41
translate german suzytammyicecreamdate_76de8536:

    # tm "Well, it's getting late. I better head home."
    tm "Tja, es wird langsam spät. Ich sollte besser nach Hause gehen."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:43
translate german suzytammyicecreamdate_6e8b8aa4:

    # ss "Aw, you don't want to come back to the house with us?"
    ss "Ach, willst du nicht mit uns nach Hause kommen?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:44
translate german suzytammyicecreamdate_a1afa737:

    # tm "I can't, baby. Sorry."
    tm "Das geht nicht, Schatz. Tut mir leid."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:49
translate german suzytammyicecreamdate_7661b3c0:

    # tm "I had fun though. Love you both. Have a good night without me."
    tm "Ich hatte aber Spaß. Ich liebe euch beide. Habt eine schöne Nacht ohne mich."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:52
translate german suzytammyicecreamdate_38516bbc:

    # ss "Oh, we will."
    ss "Oh, das werden wir."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:53
translate german suzytammyicecreamdate_fb8e986c:

    # pc "But not as much fun as if you were there too."
    pc "Aber nicht so viel Spaß, als wenn du auch dabei wärst."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:56
translate german suzytammyicecreamdate_05f57ea7:

    # "Tammy leaves, then Suzy and I drive back home."
    "Tammy geht, dann fahren Suzy und ich nach Hause."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:61
translate german suzytammyicecreamdate_d41d8cd9:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:62
translate german suzytammyicecreamdate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Sieht so aus, als ob Mama schon schläft. Also, willst du das Date hier beenden oder hoch in dein Zimmer gehen und es richtig ausklingen lassen?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:65
translate german suzytammyicecreamdate_b9e9893b:

    # ss "I was hoping you would say that."
    ss "Ich hatte gehofft, dass du das sagen würdest."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:68
translate german suzytammyicecreamdate_60c94072:

    # "We quietly go upstairs together, go into my bedroom, and lock the door."
    "Wir gehen leise zusammen nach oben, gehen in mein Schlafzimmer und schließen die Tür ab."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:71
translate german suzytammyicecreamdate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Okay, nun, ich hatte ein schönes Date, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:72
translate german suzytammyicecreamdate_1fea12f8:

    # ss "Sleep well. I'll see you tomorrow."
    ss "Schlaf gut. Wir sehen uns morgen."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:79
translate german suzytammyicecreamdate_65007bab:

    # tm "I don't know about you two, but I'm ready to head back home."
    tm "Ich weiß nicht, wie es euch beiden geht, aber ich bin bereit, nach Hause zu fahren."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:80
translate german suzytammyicecreamdate_f89287b0:

    # ss "That sounds good to me. You ready to take this date back to the house, [bro]?"
    ss "Das klingt gut für mich. Bist du bereit, dieses Date mit nach Hause zu nehmen, [bro]?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:81
translate german suzytammyicecreamdate_a400a310:

    # pc "Sure, let's go home."
    pc "Klar, lass uns nach Hause fahren."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:86
translate german suzytammyicecreamdate_d41d8cd9_1:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:87
translate german suzytammyicecreamdate_643c2201_1:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Sieht so aus, als ob Mama schon schläft. Also, willst du das Date hier beenden oder hoch in dein Zimmer gehen und es ordentlich zu Ende bringen?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:90
translate german suzytammyicecreamdate_df8719cf:

    # tm "Fuck yes."
    tm "Verdammt ja."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:93
translate german suzytammyicecreamdate_60c94072_1:

    # "We quietly go upstairs together, go into my bedroom, and lock the door."
    "Wir gehen leise zusammen nach oben, gehen in mein Schlafzimmer und schließen die Tür ab."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:97
translate german suzytammyicecreamdate_acfb634b_1:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Okay, na ja, ich hatte ein lustiges Date, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:98
translate german suzytammyicecreamdate_be17834a:

    # tm "Yeah, me too."
    tm "Ja, ich auch."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:99
translate german suzytammyicecreamdate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "Schlaf gut. Bis morgen."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:100
translate german suzytammyicecreamdate_d35669a0:

    # tm "Good night, [pcname]."
    tm "Gute Nacht, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:103
translate german suzytammyicecreamdate_d747330a:

    # "They go up to Suzy's bedroom, leaving me to decide what I want to do with my night."
    "Sie gehen hoch in Suzys Schlafzimmer und überlassen es mir, zu entscheiden, was ich mit meinem Abend anfangen will."

