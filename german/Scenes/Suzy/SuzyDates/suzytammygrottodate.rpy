# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:16
translate german suzytammygrottodate_edef91a3:

    # "We get ready and go out to The Grotto together."
    "Wir machen uns fertig und gehen zusammen ins The Grotto."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:19
translate german suzytammygrottodate_a118cb72:

    # ss "I love this place."
    ss "Ich liebe diesen Ort."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:21
translate german suzytammygrottodate_f556393a:

    # tm "Me too. Thanks for taking us, [pcname]."
    tm "Ich auch. Danke, dass du uns mitnimmst, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:23
translate german suzytammygrottodate_ad1121f0:

    # ss "Yeah, thanks [bro]."
    ss "Ja, danke [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:25
translate german suzytammygrottodate_a91a4522:

    # "We chat while we eat and enjoy the atmosphere."
    "Wir unterhalten uns, während wir essen, und genießen die Atmosphäre."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:33
translate german suzytammygrottodate_a306e385:

    # "After we eat, we dance to a couple of songs."
    "Nach dem Essen tanzen wir zu ein paar Liedern."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:36
translate german suzytammygrottodate_ffb49b98:

    # "Fuck, they're gorgeous. I can't help but to stare at them and wonder how I got to be so lucky."
    "Verdammt, die sind umwerfend. Ich kann nicht anders, als sie anzustarren und mich zu fragen, wie ich so viel Glück haben konnte."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:39
translate german suzytammygrottodate_7909898e:

    # ss "You ready to take us home, [bro]?"
    ss "Bist du bereit, uns nach Hause zu bringen, [bro]?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:40
translate german suzytammygrottodate_3dae9d31:

    # pc "Uh, yeah... we should go."
    pc "Äh, ja... wir sollten gehen."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:46
translate german suzytammygrottodate_d41d8cd9:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:47
translate german suzytammygrottodate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Sieht so aus, als ob Mama schon schläft. Also, willst du das Date hier beenden oder hoch in dein Zimmer gehen und es richtig ausklingen lassen?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:50
translate german suzytammygrottodate_df8719cf:

    # tm "Fuck yes."
    tm "Verdammt ja."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:53
translate german suzytammygrottodate_621e1461:

    # "We quietly walk upstairs together, go into my bedroom, and lock the door."
    "Wir gehen leise zusammen nach oben, gehen in mein Schlafzimmer und schließen die Tür ab."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:58
translate german suzytammygrottodate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Okay, nun, ich hatte ein schönes Date, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:59
translate german suzytammygrottodate_be17834a:

    # tm "Yeah, me too."
    tm "Ja, ich auch."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:60
translate german suzytammygrottodate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "Schlaf gut. Bis morgen."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:61
translate german suzytammygrottodate_d35669a0:

    # tm "Good night, [pcname]."
    tm "Gute Nacht, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:64
translate german suzytammygrottodate_d747330a:

    # "They go up to Suzy's bedroom, leaving me to decide what I want to do with my night."
    "Sie gehen hoch in Suzys Schlafzimmer und überlassen es mir, zu entscheiden, was ich mit meinem Abend anfangen will."

