# game/Scenes/CounselorChats/Conversations/cc9.rpy:14
translate german cc9_03ae4865:

    # sc "I'm sure she'd love to meet you and hang out sometime."
    sc "Ich bin mir sicher, dass sie dich gerne kennenlernen und mal etwas mit dir unternehmen würde."

# game/Scenes/CounselorChats/Conversations/cc9.rpy:15
translate german cc9_02ecdd9f:

    # sc "Would you like me to mention it to her?"
