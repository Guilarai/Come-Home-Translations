# game/Scenes/CafeChats/cafechat1.rpy:6
translate french cafechat1_c5150887:

    # "I hang around the café for a while, looking for anybody who might be up for a chat."
    "Je traîne un moment au café, à la recherche de quelqu’un qui aurait envie de discuter."

# game/Scenes/CafeChats/cafechat1.rpy:8
translate french cafechat1_eb82cee3:

    # "A woman comes in alone and orders a coffee, then sits by herself in the corner."
    "Une femme entre seule, commande un café, puis s’assoit toute seule dans un coin."

# game/Scenes/CafeChats/cafechat1.rpy:9
translate french cafechat1_b6ba1c27:

    # "She's looking at her phone, but then looks up and around the room."
    "Elle regarde son téléphone, puis lève les yeux et balaye la salle du regard."

# game/Scenes/CafeChats/cafechat1.rpy:10
translate french cafechat1_52268ea8:

    # "Our eyes meet momentarily and she smiles at me."
    "Nos regards se croisent un instant et elle me sourit."

# game/Scenes/CafeChats/cafechat1.rpy:11
translate french cafechat1_a276a53c:

    # "I take that as a sign to go over and talk to her."
    "Je prends ça comme un signe pour aller lui parler."

# game/Scenes/CafeChats/cafechat1.rpy:13
translate french cafechat1_7261b066:

    # "Although she smiles at me, when I start walking over towards her, she immediately seems anxious."
    "Même si elle me sourit, quand je commence à marcher vers elle, elle a tout de suite l’air nerveuse."

# game/Scenes/CafeChats/cafechat1.rpy:14
translate french cafechat1_d7a053d7:

    # pc "Hey, I just thought I'd come over and say hi. Can I get you a coffee or anything?"
    pc "Salut, je voulais juste venir te dire bonjour. Je peux t’offrir un café ou autre chose ?"

# game/Scenes/CafeChats/cafechat1.rpy:15
translate french cafechat1_f288acdf:

    # "Woman" "Oh no, I'm sorry, I didn't mean to send you any signals."
    "Woman" "Oh non, désolée, je ne voulais pas te donner de faux espoirs."

# game/Scenes/CafeChats/cafechat1.rpy:16
translate french cafechat1_706c714c:

    # pc "Oh it's okay, I just thought maybe we could chat for a bit."
    pc "Oh ce n’est pas grave, je pensais juste qu’on pourrait peut-être discuter un peu."

# game/Scenes/CafeChats/cafechat1.rpy:17
translate french cafechat1_18e49522:

    # "Woman" "No sorry, I'm not interested."
    "Woman" "Non, désolée, ça ne m’intéresse pas."

# game/Scenes/CafeChats/cafechat1.rpy:18
translate french cafechat1_2974e88a:

    # pc "Not even for just a few minutes."
    pc "Même pas juste pour quelques minutes."

# game/Scenes/CafeChats/cafechat1.rpy:19
translate french cafechat1_448eb64d:

    # "Woman" "I'm actually here with somebody."
    "Woman" "En fait, je suis ici avec quelqu’un."

# game/Scenes/CafeChats/cafechat1.rpy:20
translate french cafechat1_1f34339e:

    # "Other Woman" "Hey babe, is this guy bothering you?"
    "Other Woman" "Salut chérie, ce type t’embête ?"

# game/Scenes/CafeChats/cafechat1.rpy:25
translate french cafechat1_57c300a7:

    # "Another woman comes up to her and they kiss before sitting in the seat next to each other."
    "Une autre femme s’approche d’elle et elles s’embrassent avant de s’asseoir l’une à côté de l’autre."

# game/Scenes/CafeChats/cafechat1.rpy:26
translate french cafechat1_fb2f4ae8:

    # pc "No, sorry to bother you. You ladies have a good day."
    pc "Non, désolé de vous avoir dérangées. Passez une bonne journée, mesdames."

# game/Scenes/CafeChats/cafechat1.rpy:27
translate french cafechat1_c4d76043:

    # "I walk away and leave them to each other."
    "Je m’éloigne et les laisse entre elles."

# game/Scenes/CafeChats/cafechat1.rpy:29
translate french cafechat1_84475cd1:

    # "Struck out again, but at least this one was nicer than the last."
    "Encore un échec, mais au moins celle-là était plus sympa que la précédente."

# game/Scenes/CafeChats/cafechat1.rpy:35
translate french cafechat1_9c8103c3:

    # "I leave the café and head to class."
    "Je quitte le café et me dirige vers la salle de cours."

# game/Scenes/CafeChats/cafechat1.rpy:38
translate french cafechat1_f5c89a33:

    # "I leave the café and head back out to my car."
    "Je quitte le café et retourne à ma voiture."

