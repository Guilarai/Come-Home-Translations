# game/Scenes/Brandi/brandi7.rpy:55
translate french brandi7_972e1133:

    # fd "I just want the banana. I like bananas with ice cream, but I don't like the banana to touch the ice cream."
    fd "Je veux juste la banane. J'aime les bananes avec de la glace, mais je n'aime pas que la banane touche la glace."

# game/Scenes/Brandi/brandi7.rpy:56
