# game/Scenes/Brandi/brandi7.rpy:67
translate french brandi7_d3883cc2:

    # fd "Hello everybody and welcome!"
    fd "Bonjour à tous et bienvenue !"

# game/Scenes/Brandi/brandi7.rpy:68
translate french brandi7_bda69350:

    # fd "[pcname] is here with me again, on our second date. We're at a new ice cream parlor in Skyhill."
    fd "[pcname] est de nouveau avec moi, pour notre deuxième rendez-vous. Nous sommes dans un nouveau glacier à Skyhill."

