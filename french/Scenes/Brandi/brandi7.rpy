# game/Scenes/Brandi/brandi7.rpy:58
translate french brandi7_fea3a917:

    # fd "That's what I like to hear."
    fd "C'est ce que j'aime entendre."

# game/Scenes/Brandi/brandi7.rpy:61
translate french brandi7_d4195078:

    # fd "This looks really good."
    fd "Ça a l'air vraiment bon."

# game/Scenes/Brandi/brandi7.rpy:62
translate french brandi7_af423fc0:

    # pc "Yeah it does."
    pc "Oui, en effet."

# game/Scenes/Brandi/brandi7.rpy:63
