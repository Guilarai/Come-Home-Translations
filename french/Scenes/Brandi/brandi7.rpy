    "Je suis presque sûr qu'elle pense la même chose que moi."

# game/Scenes/Brandi/brandi7.rpy:85
translate french brandi7_32a2e507:

    # fd "Oh yeah, yours tastes really good."
    fd "Oh oui, la tienne est vraiment bonne."

# game/Scenes/Brandi/brandi7.rpy:86
