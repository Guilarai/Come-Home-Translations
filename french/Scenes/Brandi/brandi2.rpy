    # pc "You mean like a date?"
    pc "Tu veux dire, comme un rendez-vous ?"

# game/Scenes/Brandi/brandi2.rpy:24
translate french brandi2_bc08406c:

    # fd "Well, yeah. Exactly like a date."
    fd "Eh bien, oui. Exactement comme un rendez-vous."

# game/Scenes/Brandi/brandi2.rpy:25
translate french brandi2_c14c8905:

    # fd "Except my laptop will be there too and I'll be livestreaming and a few hundred people will be watching us."
    fd "Sauf que mon ordinateur portable sera là aussi et que je ferai un live, et que quelques centaines de personnes nous regarderont."

# game/Scenes/Brandi/brandi2.rpy:29
translate french brandi2_60b83ec3:

    # fd "Great!"
    fd "Super !"

# game/Scenes/Brandi/brandi2.rpy:30
translate french brandi2_fcc3b2b6:

    # fd "You know Luigi's? The new Italian place? Could you meet me there?"
    fd "Tu connais Luigi's ? Le nouveau resto italien ? Tu pourrais m'y retrouver ?"

# game/Scenes/Brandi/brandi2.rpy:31
translate french brandi2_06cea6b3:

    # pc "I'm on my way."
    pc "J'arrive."

# game/Scenes/Brandi/brandi2.rpy:33
translate french brandi2_d41d8cd9_1:

    # voice 'voices/brandi_awesome2.mp3'
    voice 'voices/brandi_awesome2.mp3'

# game/Scenes/Brandi/brandi2.rpy:34
