    bai "D'accord, c'est cool."

# game/Scenes/Bai/bai1.rpy:255
translate french bai1d_681f0b18:

    # bai "Well I'm looking forward to the next time we can hang out then."
    bai "Eh bien, j'ai hâte de la prochaine fois où on pourra se voir alors."

# game/Scenes/Bai/bai1.rpy:257
translate french bai1d_d0ca3261:

    # bai "Hope we can hang out like this again soon."
    bai "J'espère qu'on pourra se revoir comme ça bientôt."

# game/Scenes/Bai/bai1.rpy:258
translate french bai1d_03eaad50_1:

    # pc "Me too."
    pc "Moi aussi."

# game/Scenes/Bai/bai1.rpy:260
translate french bai1d_30423311:

    # bai "Hey before we leave, let me give you my phone number."
    bai "Hé, avant de partir, laisse-moi te donner mon numéro de téléphone."

# game/Scenes/Bai/bai1.rpy:261
translate french bai1d_0b8345e6:

    # bai "I don't have a lot of friends around here, so I'd love to just chat with you whenever you feel up to it."
    bai "Je n'ai pas beaucoup d'amis par ici, alors j'adorerais discuter avec toi quand tu en auras envie."

# game/Scenes/Bai/bai1.rpy:262
translate french bai1d_465c988e:

    # bai "And maybe we can go out again sometime soon."
    bai "Et peut-être qu'on pourra ressortir ensemble bientôt."

# game/Scenes/Bai/bai1.rpy:263
translate french bai1d_50eb93b7:

    # pc "Okay, sounds good."
    pc "D'accord, ça me va."

# game/Scenes/Bai/bai1.rpy:270
translate french bai1d_0e8a2008:

    # "We finish up our food, he leaves some money on the table, then we head outside."
    "On finit notre repas, il laisse un peu d'argent sur la table, puis on sort."

# game/Scenes/Bai/bai1.rpy:271
translate french bai1d_630eae85:

    # bai "Well that was the most fun I've had in a while."
    bai "Eh bien, je ne m'étais pas autant amusé depuis longtemps."

# game/Scenes/Bai/bai1.rpy:272
translate french bai1d_a96bfd7d:

    # bai "Thanks again for hanging out with me tonight."
    bai "Merci encore de m'avoir tenu compagnie ce soir."

# game/Scenes/Bai/bai1.rpy:273
translate french bai1d_fe5246ec:

    # pc "No problem. I had fun too."
    pc "Pas de souci. Je me suis bien amusé moi aussi."

# game/Scenes/Bai/bai1.rpy:274
translate french bai1d_b6980062:

    # bai "Alright, well I better head home."
    bai "Bon, je ferais mieux de rentrer chez moi."

# game/Scenes/Bai/bai1.rpy:276
translate french bai1d_5d4a4d14:

    # bai "I'll see you later."
    bai "À plus tard."

# game/Scenes/Bai/bai1.rpy:277
translate french bai1d_1aff6c8c:

    # pc "See ya, Bai."
    pc "À plus, Bai."

# game/Scenes/Bai/bai1.rpy:278
translate french bai1d_ba9439b8:

    # "He goes to his car and drives off and I walk to mine."
    "Il se dirige vers sa voiture et démarre, et je marche vers la mienne."

