# game/Scenes/Bai/bai2.rpy:10
translate french bai2_98ca1a51:

    # "My phone buzzes in my pocket."
    "Mon téléphone vibre dans ma poche."

# game/Scenes/Bai/bai2.rpy:14
translate french bai2_a13b13a8:

    # "It's Bai. I guess I have time to chat a bit."
    "C'est Bai. Je suppose que j'ai le temps de discuter un peu."

# game/Scenes/Bai/bai2.rpy:17
translate french bai2_c0d6b27a:

    # pc "Hey Bai, what's up?"
    pc "Salut Bai, ça va ?"

# game/Scenes/Bai/bai2.rpy:18
translate french bai2_ca2e0cd6:

    # bai "Hey, [pcname]. I was just lying here bored and wondered what you were up to?"
    bai "Salut, [pcname]. J'étais allongé là, je m'ennuyais, et je me demandais ce que tu faisais ?"

# game/Scenes/Bai/bai2.rpy:19
translate french bai2_f020dde3:

    # pc "Just getting ready for bed, but I can talk for a while."
    pc "Je me prépare juste à aller me coucher, mais je peux parler un moment."

# game/Scenes/Bai/bai2.rpy:20
translate french bai2_b9768b08:

    # bai "That's cool. I've just been thinking a lot."
    bai "C'est cool. Je réfléchissais juste à plein de choses."

# game/Scenes/Bai/bai2.rpy:21
translate french bai2_e61255db:

    # pc "About what?"
    pc "À quoi ?"

# game/Scenes/Bai/bai2.rpy:23
translate french bai2_67224ed1:

    # bai "Just stuff mostly."
    bai "Juste à des trucs, surtout."

# game/Scenes/Bai/bai2.rpy:24
translate french bai2_19828c08:

    # pc "You're going to have to be a little more specific than that or this conversation isn't going to go anywhere."
    pc "Tu vas devoir être un peu plus précis que ça, sinon cette conversation ne mènera nulle part."

# game/Scenes/Bai/bai2.rpy:25
translate french bai2_64de84cd:

    # bai "Okay, well."
    bai "D'accord, bon."

# game/Scenes/Bai/bai2.rpy:26
translate french bai2_d7d9d996:

    # bai "I uh... I've only dated girls in the past."
    bai "Je... euh... Je ne suis sorti qu'avec des filles jusqu'à présent."

# game/Scenes/Bai/bai2.rpy:27
translate french bai2_36470b3e:

    # bai "I've had sex and stuff. With girls."
    bai "J'ai couché avec des filles et tout ça."

# game/Scenes/Bai/bai2.rpy:28
translate french bai2_41c2c9e2:

    # bai "But uh... I think I might be into guys too."
    bai "Mais euh... Je crois que je pourrais aussi être attiré par les mecs."

# game/Scenes/Bai/bai2.rpy:30
translate french bai2_8833a2ab:

    # pc "So, you're bisexual?"
    pc "Alors, tu es bisexuel ?"

# game/Scenes/Bai/bai2.rpy:31
translate french bai2_61b09772:

    # bai "Maybe?"
    bai "Peut-être ?"

# game/Scenes/Bai/bai2.rpy:32
translate french bai2_0e63d7c1:

    # bai "What about you? Are you into guys at all?"
    bai "Et toi ? Tu es attiré par les mecs ?"

# game/Scenes/Bai/bai2.rpy:36
translate french bai2_bde64ebd:

    # bai "Oh okay. I thought maybe we had a thing. It's okay though."
    bai "Oh, d'accord. Je pensais qu'il y avait peut-être quelque chose entre nous. Mais ça va."

# game/Scenes/Bai/bai2.rpy:37
translate french bai2_0fe323b5:

    # pc "Sorry, man. Chicks only for me."
    pc "Désolé, mec. Je ne m'intéresse qu'aux filles."

# game/Scenes/Bai/bai2.rpy:38
translate french bai2_83d8b883:

    # bai "It's cool. I understand."
    bai "C'est cool. Je comprends."

# game/Scenes/Bai/bai2.rpy:40
translate french bai2_ecf05d77:

    # bai "Still friends though?"
    bai "On reste amis quand même ?"

# game/Scenes/Bai/bai2.rpy:41
translate french bai2_71d4cebe:

    # pc "Sure, we're still friends."
    pc "Bien sûr, on reste amis."

# game/Scenes/Bai/bai2.rpy:44
translate french bai2_e26b3f90:

    # bai "Cool."
    bai "Cool."

# game/Scenes/Bai/bai2.rpy:47
translate french bai2_b66cc0ac:

    # bai "Really? I thought maybe we had a thing, but I wasn't sure."
    bai "Vraiment ? Je pensais qu'il y avait peut-être quelque chose entre nous, mais je n'étais pas sûr."

# game/Scenes/Bai/bai2.rpy:49
translate french bai2_f39ae0a2:

    # bai "Are you into me?"
    bai "Tu es attiré par moi ?"

# game/Scenes/Bai/bai2.rpy:53
translate french bai2_99a03550:

    # bai "That makes me so happy."
    bai "Ça me rend tellement heureux."

# game/Scenes/Bai/bai2.rpy:55
translate french bai2_99b1838b:

    # bai "So do you maybe want to actually go on a date sometime?"
    bai "Alors, tu veux peut-être qu'on se voie un de ces jours ?"

# game/Scenes/Bai/bai2.rpy:56
translate french bai2_39757b54:

    # pc "Yeah, let's do it."
    pc "Ouais, allons-y."

# game/Scenes/Bai/bai2.rpy:57
translate french bai2_8c98f2da:

    # bai "Okay, just give me a call in the evening sometime then. I'm available almost every day."
    bai "OK, appelle-moi un soir alors. Je suis dispo presque tous les jours."

# game/Scenes/Bai/bai2.rpy:58
translate french bai2_58a87bc2:

    # pc "Sounds good. I'm looking forward to it."
    pc "Ça me va. J'ai hâte."

# game/Scenes/Bai/bai2.rpy:59
translate french bai2_10a70856:

    # bai "Me too. Really."
    bai "Moi aussi. Vraiment."

# game/Scenes/Bai/bai2.rpy:60
translate french bai2_4d74a398:

    # bai "This is new territory for me, but I'm really looking forward to exploring it with you."
    bai "C'est un nouveau terrain pour moi, mais j'ai vraiment hâte de l'explorer avec toi."

# game/Scenes/Bai/bai2.rpy:63
translate french bai2_c0a43543:

    # bai "Oh, so you're into guys, but you're not into me."
    bai "Oh, donc tu aimes les mecs, mais tu ne m'aimes pas."

# game/Scenes/Bai/bai2.rpy:64
translate french bai2_27247fe1:

    # bai "Gotta say, that hurts man."
    bai "Faut dire que ça fait mal, mec."

# game/Scenes/Bai/bai2.rpy:65
translate french bai2_c31c7975:

    # pc "Sorry, just being honest."
    pc "Désolé, je suis juste honnête."

# game/Scenes/Bai/bai2.rpy:66
translate french bai2_40a3eff2:

    # bai "Yeah okay. Well that sucks."
    bai "Ouais, d'accord. Eh bien, ça craint."

# game/Scenes/Bai/bai2.rpy:67
translate french bai2_0cce2b18:

    # pc "We can still be friends though."
    pc "On peut quand même rester amis."

# game/Scenes/Bai/bai2.rpy:68
translate french bai2_46106a33:

    # bai "Yeah, okay. I'm going to bed."
    bai "Ouais, d'accord. Je vais me coucher."

# game/Scenes/Bai/bai2.rpy:70
translate french bai2_14a17911:

    # "He hangs up. I guess that didn't go so well."
    "Il raccroche. Je suppose que ça ne s'est pas très bien passé."

# game/Scenes/Bai/bai2.rpy:71
translate french bai2_a0d6f0f3:

    # "Oh well. He'll get over it. Or not, whatever."
    "Oh, tant pis. Il s'en remettra. Ou pas, peu importe."

# game/Scenes/Bai/bai2.rpy:72
translate french bai2_ef88129a:

    # "I put the phone away and get ready for bed."
    "Je range mon téléphone et je me prépare à aller me coucher."

# game/Scenes/Bai/bai2.rpy:75
translate french bai2_17d3424c:

    # "We chat a little longer about our days, until we are both tired."
    "On discute encore un peu de notre journée, jusqu'à ce qu'on soit tous les deux fatigués."

# game/Scenes/Bai/bai2.rpy:77
translate french bai2_3898d259:

    # bai "I better get some sleep man."
    bai "Je ferais mieux d'aller dormir, mec."

# game/Scenes/Bai/bai2.rpy:78
translate french bai2_89c07fc5:

    # bai "I'll talk to you later."
    bai "On se parle plus tard."

# game/Scenes/Bai/bai2.rpy:79
translate french bai2_d2381b62:

    # pc "Okay. See ya, Bai."
    pc "D'accord. À plus, Bai."

# game/Scenes/Bai/bai2.rpy:82
translate french bai2_52d6e3cf:

    # "We hang up and I get ready for bed."
    "On raccroche et je me prépare à aller me coucher."

