# game/Scenes/Bai/BaiDates/baibeachdate.rpy:19
translate french baibeachdate_caf334cd:

    # "I pick Bai up and we drive out towards the beach."
    "Je passe prendre Bai et on part en voiture vers la plage."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:21
translate french baibeachdate_8ebfb187:

    # pc "Have you been out here before?"
    pc "Tu es déjà venu ici ?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:22
translate french baibeachdate_64336c0b:

    # bai "Yeah, I sometimes come out here to run in the mornings."
    bai "Ouais, je viens parfois ici pour courir le matin."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:23
translate french baibeachdate_5f0b57d2:

    # bai "But I've never been out here with a cute guy before."
    bai "Mais je ne suis jamais venu ici avec un mec mignon avant."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:29
translate french baibeachdate_e914bd34:

    # "When we get to the beach, Bai pulls his shirt off."
    "Quand on arrive à la plage, Bai enlève son t-shirt."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:30
translate french baibeachdate_835e0f75:

    # "He's already put suntan lotion on and his skin glistens in the light."
    "Il a déjà mis de la crème solaire et sa peau brille à la lumière."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:31
translate french baibeachdate_4cb4deb6:

    # bai "Ready to get in the water?"
    bai "Prêt à aller dans l'eau ?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:32
translate french baibeachdate_39757b54:

    # pc "Yeah, let's do it."
    pc "Ouais, allons-y."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:35
translate french baibeachdate_67fe8962:

    # "We swim around for a while. Bai gets really into it."
    "On nage un moment. Bai s'y met à fond."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:36
translate french baibeachdate_eaa7bafe:

    # "We try racing a bit, but even though I'm a good swimmer, Bai is way too fast for me to keep up with."
    "On essaie de faire une petite course, mais même si je suis un bon nageur, Bai est bien trop rapide pour que je puisse le suivre."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:39
translate french baibeachdate_c4765999:

    # "After a while, we're both tired from swimming and the sun is starting to set, so we lie on the beach and dry off."
    "Au bout d’un moment, on est tous les deux fatigués d’avoir nagé et le soleil commence à se coucher, alors on s’allonge sur la plage pour se sécher."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:40
translate french baibeachdate_3d2f7709:

    # "We lean back and talk for a while about whatever comes to mind."
    "On se penche en arrière et on discute un moment de tout ce qui nous passe par la tête."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:47
translate french baibeachdate_fb5239af:

    # bai "Well, I guess we should head back."
    bai "Bon, je crois qu’on devrait rentrer."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:48
translate french baibeachdate_e0511e98:

    # bai "This was fun though, man. Maybe next time there will be more girls out here, you know?"
    bai "C'était sympa quand même, mec. Peut-être qu'il y aura plus de filles ici la prochaine fois, tu vois ?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:51
translate french baibeachdate_9291d328:

    # "I drive Bai back to his apartment, then leave to go on with the rest of my day."
    "Je ramène Bai à son appartement, puis je pars vaquer à mes occupations."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:62
translate french baibeachdate_67f91a9e:

    # "When the sun starts to dip below the horizon, we take a moment to watch it together."
    "Quand le soleil commence à plonger sous l'horizon, on prend un moment pour l'admirer ensemble."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:64
translate french baibeachdate_c710bd77:

    # bai "This is so beautiful."
    bai "C'est tellement beau."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:65
translate french baibeachdate_409aa835:

    # "I can see his eyes tear up a bit."
    "Je vois ses yeux s'embuer un peu."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:66
translate french baibeachdate_7a029997:

    # bai "You make me feel so safe."
    bai "Tu me fais me sentir tellement en sécurité."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:67
translate french baibeachdate_fe07fc02:

    # pc "You're always safe with me."
    pc "Tu es toujours en sécurité avec moi."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:72
translate french baibeachdate_e1672a1f:

    # bai "I'm so happy that we found each other."
    bai "Je suis tellement heureuse qu’on se soit trouvés."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:73
translate french baibeachdate_afdaf298:

    # bai "I can't wait to get you back to my place."
    bai "J’ai hâte de te ramener chez moi."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:78
translate french baibeachdate_123df4e4:

    # bai "After the sun sets though."
    bai "Mais après le coucher du soleil."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:79
translate french baibeachdate_63409295:

    # bai "I'm really enjoying this moment."
    bai "J’apprécie vraiment ce moment."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:83
translate french baibeachdate_67ce83d2:

    # "After the sun sets, I drive us back to his apartment."
    "Une fois le soleil couché, je nous ramène à son appartement."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:84
translate french baibeachdate_64712708:

    # bai "Are you coming inside?"
    bai "Tu viens à l’intérieur ?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:89
translate french baibeachdate_0ac06427:

    # bai "Cool. Let's go."
    bai "Cool. Allons-y."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:92
translate french baibeachdate_b7437714:

    # bai "Cool, let's go."
    bai "Cool, allons-y."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:95
translate french baibeachdate_32755ff3:

    # bai "Okay. Well, I had a good time with you anyway."
    bai "D'accord. Bon, j'ai passé un bon moment avec toi de toute façon."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:96
translate french baibeachdate_5d4a4d14:

    # bai "I'll see you later."
    bai "À plus tard."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:97
translate french baibeachdate_1aff6c8c:

    # pc "See ya, Bai."
    pc "À plus, Bai."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:100
translate french baibeachdate_0c0ee20a:

    # "He gets out and walks into his apartment building."
    "Il sort et entre dans son immeuble."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:101
translate french baibeachdate_5b3fbfe7:

    # "Then I drive away."
    "Puis je m'éloigne en voiture."

