# game/Scenes/Bai/BaiDates/baigrottodate.rpy:19
translate french baigrottodate_d3715341:

    # pc "Do you want to come out to a fancy restaurant with me?"
    pc "Tu veux venir dans un restaurant chic avec moi ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:20
translate french baigrottodate_4243d9c3:

    # pc "It's called The Grotto. It's out on the lake."
    pc "Ça s'appelle La Grotte. C'est au bord du lac."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:23
translate french baigrottodate_4f7f94cb:

    # bai "Is it expensive?"
    bai "C'est cher ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:24
translate french baigrottodate_3308b177:

    # pc "Pretty expensive, yeah."
    pc "Plutôt cher, oui."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:26
translate french baigrottodate_fb59b9b7:

    # bai "Aw, what the hell. Might as well spend it, right?"
    bai "Ah, tant pis. Autant se faire plaisir, non ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:27
translate french baigrottodate_f82e580f:

    # bai "I eat cheap every other day, let's get some fancy food!"
    bai "Je mange pas cher un jour sur deux, alors profitons d’un repas chic !"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:28
translate french baigrottodate_5f71dc40:

    # pc "All right! I'll text you the address and meet you out there."
    pc "D’accord ! Je t’envoie l’adresse par SMS et on se retrouve là-bas."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:29
translate french baigrottodate_1bda0dbe:

    # bai "Sounds good! See you there."
    bai "Super ! À tout à l’heure."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:32
translate french baigrottodate_cf65d098:

    # "I get ready and text Bai the address, then about an hour later we're sitting down to eat at The Grotto."
    "Je me prépare et j’envoie l’adresse à Bai par SMS, puis environ une heure plus tard, on est assis à table au Grotto."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:35
translate french baigrottodate_79872e14:

    # bai "That sounds great. Are we going to get all dressed up in suits and stuff?"
    bai "Ça a l’air génial. On va s’habiller en costume et tout ça ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:36
translate french baigrottodate_a9dc377e:

    # pc "Damn right, we are."
    pc "Et comment !"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:38
translate french baigrottodate_bfaba4a8:

    # bai "Oh man. I have to find my suit then. I know I have one in the closet somewhere."
    bai "Oh là là. Il va falloir que je trouve mon costume alors. Je sais que j’en ai un quelque part dans le placard."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:39
translate french baigrottodate_b5cc83ae:

    # bai "I'll go find it."
    bai "Je vais le chercher."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:40
translate french baigrottodate_ffb27a81:

    # pc "Okay. Send me a text when you're ready and I'll come pick you up, okay?"
    pc "D’accord. Envoie-moi un SMS quand tu seras prêt et je viendrai te chercher, d’accord ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:42
translate french baigrottodate_9e815b71:

    # bai "Okay! I'm really excited!"
    bai "D’accord ! J’ai vraiment hâte !"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:43
translate french baigrottodate_f07574ec:

    # pc "Good."
    pc "Bien."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:44
translate french baigrottodate_412f6c55:

    # bai "Okay, see you in a bit."
    bai "D’accord, à tout à l’heure."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:47
translate french baigrottodate_9bcd7a72:

    # "I get ready to go and wait for Bai's text."
    "Je me prépare à partir et j’attends le SMS de Bai."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:48
translate french baigrottodate_9173db50:

    # "About an hour later, he texts me and I go pick him up, then we walk into The Grotto together."
    "Environ une heure plus tard, il m'envoie un SMS et je passe le chercher, puis on entre ensemble au Grotto."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:51
translate french baigrottodate_9131d6c6:

    # bai "Sounds good! I'll see you there."
    bai "Ça me va ! On se voit là-bas."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:52
translate french baigrottodate_5d3d77d3:

    # pc "Cool. See you."
    pc "Cool. À tout à l'heure."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:54
translate french baigrottodate_299409d0:

    # bai "That sounds great! I'll start getting ready. Come get me."
    bai "Ça me va très bien ! Je vais commencer à me préparer. Viens me chercher."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:55
translate french baigrottodate_e3948ee8:

    # pc "Alright, I'll be there in a bit."
    pc "D'accord, j'arrive dans un petit moment."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:69
translate french baigrottostartdate_ba211ff8:

    # "We walk in together, holding hands."
    "On entre ensemble, main dans la main."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:70
translate french baigrottostartdate_fb0e2e4f:

    # bai "This feels very public. More public than we usually are."
    bai "On se sent très exposés. Plus exposés que d'habitude."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:71
translate french baigrottostartdate_a674eec0:

    # pc "Are you okay with that?"
    pc "Ça te dérange pas ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:72
translate french baigrottostartdate_023cf823:

    # bai "Yeah, with you, I think I am."
    bai "Non, avec toi, je crois que ça me va."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:73
translate french baigrottostartdate_e39c1441:

    # pc "Good. You look like a fucking stud right now. I'm proud to be here with you."
    pc "Bien. T'as l'air d'un vrai tombeur là. Je suis fier d'être ici avec toi."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:74
translate french baigrottostartdate_bb37df29:

    # bai "Me too."
    bai "Moi aussi."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:81
translate french baigrottostartdate_a5785e55:

    # "We sit at a table and begin looking over the menus."
    "On s'assoit à une table et on commence à regarder les menus."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:82
translate french baigrottostartdate_a395082c:

    # "Then a server comes by and takes our order."
    "Puis un serveur vient prendre notre commande."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:91
translate french baigrottostartdate_32733c2f:

    # "After we chat for a while, our food is brought out."
    "Après avoir discuté un moment, on nous apporte notre repas."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:92
translate french baigrottostartdate_501f942a:

    # bai "Wow, this looks amazing."
    bai "Waouh, ça a l’air incroyable."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:98
translate french baigrottostartdate_28b42b01:

    # "We continue chatting while we eat our meal. Just hanging out and enjoying some good food together."
    "On continue à discuter pendant qu’on mange. On passe juste un bon moment ensemble à savourer un bon repas."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:101
translate french baigrottostartdate_7150c85d:

    # "When we're done eating, we split the bill and say our goodbyes."
    "Quand on a fini de manger, on partage l’addition et on se dit au revoir."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:105
translate french baigrottostartdate_25d6d119:

    # bai "That was fun, man. Good food. Thanks for inviting me."
    bai "C’était sympa, mec. Bon repas. Merci de m’avoir invité."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:106
translate french baigrottostartdate_0c975e99:

    # pc "No problem. Good to hang out and talk for a while."
    pc "Pas de problème. Ça m’a fait plaisir de passer un moment avec toi et de discuter."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:107
translate french baigrottostartdate_49b45846:

    # bai "Yeah it was."
    bai "Ouais, c’est vrai."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:108
translate french baigrottostartdate_01c7ca57:

    # bai "Alright, well I'll see you later. Take care."
    bai "Bon, eh bien à plus tard. Prends soin de toi."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:109
translate french baigrottostartdate_22fbafdc:

    # pc "You too. See ya."
    pc "Toi aussi. À plus."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:112
translate french baigrottostartdate_0c8ca28d:

    # "We get in our cars and go our separate directions."
    "On monte dans nos voitures et on part chacun de notre côté."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:120
translate french baigrottostartdate_bfde7d54:

    # "We continue chatting and eating."
    "On continue à discuter et à manger."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:126
translate french baigrottostartdate_1ef0c0b5:

    # "Bai insists that we split the bill, then we get ready to leave."
    "Bai insiste pour qu’on partage l’addition, puis on se prépare à partir."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:132
translate french baigrottostartdate_ca01422f:

    # bai "It's so pretty out here, isn't it?"
    bai "C’est tellement joli ici, n’est-ce pas ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:133
translate french baigrottostartdate_44eeaf1a:

    # pc "Yeah it is."
    pc "Oui, c’est vrai."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:139
translate french baigrottostartdate_7c70709c:

    # "I lean in and kiss him, uncaring about anybody who might be watching us."
    "Je me penche vers lui et l’embrasse, sans me soucier de ceux qui pourraient nous regarder."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:140
translate french baigrottostartdate_61700a7a:

    # "He is surprised at first, but doesn't pull away."
    "Il est surpris au début, mais ne se recule pas."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:143
translate french baigrottostartdate_4a0dd6f7:

    # bai "I can't believe I just did that. Right in front of everybody."
    bai "Je n'arrive pas à croire que je viens de faire ça. Devant tout le monde."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:144
translate french baigrottostartdate_6e718b73:

    # pc "How did it feel?"
    pc "Qu'est-ce que ça t'a fait ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:145
translate french baigrottostartdate_3696af55:

    # bai "It felt great."
    bai "C'était génial."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:150
translate french baigrottostartdate_d90b231d:

    # bai "Want to go back to my apartment now?"
    bai "Tu veux aller chez moi maintenant ?"

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:153
translate french baigrottostartdate_4861bda5:

    # bai "Aw, okay. Well it was a good date, anyway. Thanks for bringing me."
    bai "Ah, d'accord. En tout cas, c'était un bon rendez-vous. Merci de m'avoir emmené."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:156
translate french baigrottostartdate_29d9625f:

    # "We leave and I drive him to his aparment and say goodbye."
    "On part, je le conduis chez lui et je lui dis au revoir."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:157
translate french baigrottostartdate_f1413fe1:

    # "Then I drive away to do something else with my night."
    "Puis je pars en voiture pour faire autre chose de ma soirée."

# game/Scenes/Bai/BaiDates/baigrottodate.rpy:164
translate french baigrottostartdate_ebdfbc55:

    # "We rush out to the car and drive back to his apartment."
    "On se précipite vers la voiture et on retourne à son appartement."

translate french strings:

