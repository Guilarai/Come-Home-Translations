translate french danasurface2_adb78891:

    # pc "Do you have any pets?"
    pc "Tu as des animaux de compagnie ?"

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:14
translate french danasurface2_69bf2a77:

    # cw "No, no pets."
    cw "Non, pas d'animaux."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:16
translate french danasurface2_f1e7f090:

    # cw "I wouldn't mind having a dog - a big one that I could hug and cuddle with."
    cw "Ça ne me dérangerait pas d'avoir un chien – un gros chien que je pourrais serrer dans mes bras et câliner."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:17
translate french danasurface2_72be5411:

    # cw "I had a big fluffy Great Pyrenees growing up named Khan. He was my favorite thing."
    cw "Quand j'étais petite, j'avais un gros chien des Pyrénées tout doux qui s'appelait Khan. C'était mon préféré."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:20
translate french danasurface2_0084a7fa:

    # cw "But Terry, my fiancé, is allergic to dogs. And cats. So no pets."
    cw "Mais Terry, mon fiancé, est allergique aux chiens. Et aux chats. Donc pas d’animaux."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:21
translate french danasurface2_e161b952:

    # pc "Maybe one day."
    pc "Peut-être un jour."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:23
translate french danasurface2_d9e8daa4:

    # cw "Maybe."
    cw "Peut-être."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:25
translate french danasurface2_4789760b:

    # cw "Although, no, I guess not, since I'm marrying Terry and will be with him forever."
    cw "Mais non, je ne pense pas, puisque je vais épouser Terry et que je serai avec lui pour toujours."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:26
translate french danasurface2_b3875e3a:

    # cw "He's always going to be allergic to dogs, so that means no dogs for me."
    cw "Il sera toujours allergique aux chiens, donc ça veut dire pas de chiens pour moi."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:28
translate french danasurface2_5388797f:

    # cw "That's okay though."
    cw "Mais ça ne fait rien."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:29
translate french danasurface2_75ed006d:

    # pc "Maybe a turtle?"
    pc "Peut-être une tortue ?"

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:31
translate french danasurface2_5cff00b8:

    # cw "Haha, maybe!"
    cw "Haha, peut-être !"

