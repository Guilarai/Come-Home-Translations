# game/Scenes/Dana/DanaConversation/danas9.rpy:14
translate french danas9_ffefe834:

    # cw "Oh yeah, he doesn't come in often, and usually early in the day while you're at school."
    cw "Ah oui, il ne vient pas souvent, et généralement tôt dans la journée, pendant que tu es à l'école."

# game/Scenes/Dana/DanaConversation/danas9.rpy:15
translate french danas9_d766b79e:

    # cw "He mostly stays at the courthouse all day though. He has an office there as well."
    cw "Mais il reste surtout au palais de justice toute la journée. Il a aussi un bureau là-bas."

# game/Scenes/Dana/DanaConversation/danas9.rpy:16
translate french danas9_9509abf6:

    # pc "Is he nice to work for?"
    pc "C'est quelqu'un de sympa pour qui travailler ?"

# game/Scenes/Dana/DanaConversation/danas9.rpy:18
translate french danas9_958eb612:

    # cw "Yeah, I guess."
    cw "Oui, je suppose."

# game/Scenes/Dana/DanaConversation/danas9.rpy:19
translate french danas9_89c7bce1:

    # cw "I don't really do much for him. I work for this office, which is mostly Mrs. Mills."
    cw "Je ne fais pas grand-chose pour lui. Je travaille pour ce bureau, qui dépend surtout de Mme Mills."

# game/Scenes/Dana/DanaConversation/danas9.rpy:20
translate french danas9_c6f7c0de:

    # cw "Mr. Gonzales actually has another secretary at his courthouse office."
    cw "M. Gonzales a en fait une autre secrétaire à son bureau du palais de justice."

# game/Scenes/Dana/DanaConversation/danas9.rpy:22
translate french danas9_05b4d1ab:

    # cw "But yeah, when I've seen him, he's always been good to me."
    cw "Mais oui, quand je l'ai vu, il a toujours été gentil avec moi."

# game/Scenes/Dana/DanaConversation/danas9.rpy:23
translate french danas9_59b1f9cc:

    # pc "Well that's good to hear, at least."
    pc "Eh bien, c'est déjà ça, au moins."

