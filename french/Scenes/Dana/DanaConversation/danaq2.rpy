# game/Scenes/Dana/DanaConversation/danaq2.rpy:14
translate french danaq2_acbc7e1a:

    # cw "So what are your plans for when the school year finishes?"
    cw "Alors, quels sont tes projets pour la fin de l'année scolaire ?"

# game/Scenes/Dana/DanaConversation/danaq2.rpy:15
translate french danaq2_cd4394ee:

    # pc "I really don't know."
    pc "Je ne sais vraiment pas."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:16
translate french danaq2_c347cf32:

    # pc "I guess I'll probably be looking for a full-time job at a lab somewhere."
    pc "Je pense que je vais probablement chercher un emploi à temps plein dans un laboratoire quelque part."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:18
translate french danaq2_c048a14e:

    # cw "So you'll be moving away from Skyhill?"
    cw "Alors tu vas quitter Skyhill ?"

# game/Scenes/Dana/DanaConversation/danaq2.rpy:19
translate french danaq2_51594db6:

    # pc "Maybe. I don't know."
    pc "Peut-être. Je ne sais pas."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:20
translate french danaq2_55bfad52:

    # pc "I could apply for a job at the lab where my dad works."
    pc "Je pourrais postuler au laboratoire où travaille mon père."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:22
translate french danaq2_43bbf96d:

    # pc "Or, there is another job at a smaller lab that I was offered. I might do that."
    pc "Ou alors, on m'a proposé un poste dans un laboratoire plus petit. Je vais peut-être accepter."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:24
translate french danaq2_fe225afa:

    # cw "That sounds promising."
    cw "Ça a l'air prometteur."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:26
translate french danaq2_a5c10f63:

    # cw "If you leave Skyhill, would you want some company?"
    cw "Si tu quittes Skyhill, tu voudrais de la compagnie ?"

# game/Scenes/Dana/DanaConversation/danaq2.rpy:27
translate french danaq2_be10be8c:

    # pc "You want to come with me?"
    pc "Tu veux venir avec moi ?"

# game/Scenes/Dana/DanaConversation/danaq2.rpy:29
translate french danaq2_61d6ecbb:

    # cw "Yeah, I'd love to get out of Skyhill some day."
    cw "Ouais, j'adorerais partir de Skyhill un jour."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:30
translate french danaq2_0d583ef7:

    # cw "Anywhere else."
    cw "N'importe où ailleurs."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:31
translate french danaq2_a4b32207:

    # pc "Well yeah. You're welcome to come with me, wherever I go."
    pc "Eh bien oui. Tu es la bienvenue si tu veux venir avec moi, où que j'aille."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:33
translate french danaq2_96bdf713:

    # cw "I'm not being too clingy?"
    cw "Je ne suis pas trop collante ?"

# game/Scenes/Dana/DanaConversation/danaq2.rpy:34
translate french danaq2_a71f37d8:

    # pc "Not at all. I like when you cling a little."
    pc "Pas du tout. J'aime bien quand tu es un peu collante."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:36
translate french danaq2_88bcad55:

    # cw "Maybe wherever you go will need a secretary."
    cw "Peut-être que là où tu iras, ils auront besoin d'une secrétaire."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:37
translate french danaq2_756528de:

    # pc "I'm sure we can find a position that you'll fit into."
    pc "Je suis sûre qu’on trouvera un poste qui te conviendra."

# game/Scenes/Dana/DanaConversation/danaq2.rpy:39
translate french danaq2_40ab0283:

    # cw "Probably. I am pretty flexible."
    cw "Probablement. Je suis assez flexible."

