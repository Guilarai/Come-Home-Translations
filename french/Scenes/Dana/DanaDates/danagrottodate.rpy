translate french danagrottostartdate_1563db25:

    # "I drive over and pick Dana up. Then we go out to The Grotto together."
    "Je passe la chercher en voiture. Puis on va ensemble au Grotto."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:28
translate french danagrottostartdate_2095cc55:

    # cw "Wow. This place is amazing."
    cw "Waouh. Cet endroit est incroyable."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:29
translate french danagrottostartdate_2ba00ab3:

    # cw "I can't believe I get to go out here. It's so beautiful."
    cw "Je n'arrive pas à croire que j'ai la chance de venir ici. C'est tellement beau."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:30
translate french danagrottostartdate_05526a72:

    # pc "You're beautiful, Dana. You deserve it."
    pc "Tu es magnifique, Dana. Tu le mérites."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:31
translate french danagrottostartdate_9c4b6956:

    # cw "Thank you, [pcname]."
    cw "Merci, [pcname]."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:32
translate french danagrottostartdate_37c9d0bf:

    # "We walk in and the host leads us to our seats."
    "Nous entrons et l'hôte nous conduit à notre table."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:38
translate french danagrottostartdate_80af549c:

    # cw "You can afford this? On what Mrs. Mills pays you?"
    cw "Tu peux te permettre ça ? Avec ce que Mme Mills te paie ?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:39
translate french danagrottostartdate_0f30c499:

    # pc "Sure. I mean, not every day or anything, but occasionally. I don't have many bills."
    pc "Bien sûr. Je veux dire, pas tous les jours ni rien, mais de temps en temps. Je n'ai pas beaucoup de factures à payer."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:40
translate french danagrottostartdate_a4bd3f4d:

    # pc "Don't worry about it though, Dana. I want you to have a great night."
    pc "Mais ne t'en fais pas, Dana. Je veux que tu passes une excellente soirée."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:42
translate french danagrottostartdate_617347d3:

    # cw "I already am. This is incredible."
    cw "C'est déjà le cas. C'est incroyable."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:43
translate french danagrottostartdate_ecd9ab22:

    # "The server takes our orders and we chat for a while."
    "Le serveur prend notre commande et nous discutons un moment."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:46
translate french danagrottostartdate_ac38448c:

    # "Then we eat and chat some more."
    "Puis nous mangeons et discutons encore un peu."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:52
translate french danagrottostartdate_94d3f64e:

    # "Then we get up and dance a bit to the soft music."
    "Ensuite, nous nous levons et dansons un peu au son d'une musique douce."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:54
translate french danagrottostartdate_d0b4cddc:

    # cw "You're so amazing. This is the best date I've ever been on."
    cw "Tu es tellement génial. C'est le meilleur rendez-vous que j'ai jamais eu."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:55
translate french danagrottostartdate_1ece43ad:

    # cw "I couldn't want anything more."
    cw "Je ne pourrais pas demander mieux."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:56
translate french danagrottostartdate_f6634f6b:

    # pc "Anything to make you happy, Dana. That's all I want."
    pc "Tout ce qui te rend heureuse, Dana. C'est tout ce que je veux."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:60
translate french danagrottostartdate_93db9284:

    # cw "You do make me happy, [pcname]."
    cw "Tu me rends heureuse, [pcname]."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:61
translate french danagrottostartdate_8b92acc5:

    # cw "I'm so very happy."
    cw "Je suis tellement heureuse."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:69
translate french danagrottostartdate_c8c4e655:

    # cw "I know a way you can make me even happier though."
    cw "Mais je connais un moyen de me rendre encore plus heureuse."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:70
translate french danagrottostartdate_ae871f39:

    # pc "Oh yeah?"
    pc "Ah oui ?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:71
translate french danagrottostartdate_9a5a9a70:

    # cw "Are you ready to take me home?"
    cw "Tu es prêt à me ramener chez moi ?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:72
translate french danagrottostartdate_69a64407:

    # pc "Yes, I think we should."
    pc "Oui, je pense qu'on devrait."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:76
translate french danagrottostartdate_4097bbec:

    # "Fifteen minutes later we're in her bedroom and she's naked on the bed, practically begging me to ravage her."
    "Quinze minutes plus tard, on est dans sa chambre et elle est nue sur le lit, me suppliant presque de la dévorer."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:80
translate french danagrottostartdate_ff3293a2:

    # cw "Do you want to continue this back at my place?"
    cw "Tu veux qu'on continue ça chez moi ?"

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:83
translate french danagrottostartdate_92e63c5d:

    # cw "Great. Let's go. I can't wait to get my mouth on you."
    cw "Super. Allons-y. J'ai hâte de te lécher."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:87
translate french danagrottostartdate_4097bbec_1:

    # "Fifteen minutes later we're in her bedroom and she's naked on the bed, practically begging me to ravage her."
    "Quinze minutes plus tard, on est dans sa chambre et elle est nue sur le lit, me suppliant presque de la dévorer."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:91
translate french danagrottostartdate_627e2bde:

    # cw "Oh, alright."
    cw "Oh, d'accord."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:92
translate french danagrottostartdate_0128787c:

    # cw "It was still an incredible date. Thank you."
    cw "C'était quand même un rendez-vous incroyable. Merci."

# game/Scenes/Dana/DanaDates/danagrottodate.rpy:95
translate french danagrottostartdate_e8cbe586:

    # "I drive Dana home and we say our goodbyes, then she goes inside and I drive away to continue my night."
    "Je raccompagne Dana chez elle et on se dit au revoir, puis elle rentre et je pars pour continuer ma soirée."

