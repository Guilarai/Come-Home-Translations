# game/Scenes/MrsMills/mills2.rpy:57
translate french mills2_289f1f92:

    # bs "But I'm your boss and we shouldn't complicate that relationship."
    bs "Mais je suis ta patronne et on ne devrait pas compliquer cette relation."

# game/Scenes/MrsMills/mills2.rpy:58
translate french mills2_fefc9af5:

