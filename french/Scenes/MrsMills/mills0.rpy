translate french mills0_818c6ce6:

    # bs "Thank you, [pcname]."
    bs "Merci, [pcname]."

# game/Scenes/MrsMills/mills0.rpy:86
translate french mills0_b4ece937:

    # bs "Now you can get to cleaning. I'm going to relax here for a few minutes."
    bs "Maintenant, tu peux te mettre au nettoyage. Je vais me détendre ici quelques minutes."

# game/Scenes/MrsMills/mills0.rpy:87
translate french mills0_1ca80c77_2:

    # pc "Yes, ma'am."
    pc "Oui, madame."

# game/Scenes/MrsMills/mills0.rpy:88
translate french mills0_25119040:

    # "I wouldn't mind relaxing and drinking my coffee too, but I pick up the duster and get to work."
    "Ça ne me dérangerait pas de me détendre et de boire mon café moi aussi, mais je prends le plumeau et je me mets au travail."

# game/Scenes/MrsMills/mills0.rpy:91
