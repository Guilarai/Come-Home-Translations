translate french mills0_a8c4ebf9:

    # pc "Maybe? I'm just an assistant to Mrs. Mills over there."
    pc "Peut-être ? Je ne suis qu’une assistante de Mme Mills, là-bas."

# game/Scenes/MrsMills/mills0.rpy:54
translate french mills0_2b4c91e1:

