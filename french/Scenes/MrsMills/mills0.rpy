# game/Scenes/MrsMills/mills0.rpy:66
translate french mills0_4cf794b1:

    # tm "Hrm, well she wanted a guy for some reason."
    tm "Hum, eh bien, elle voulait un homme pour une raison quelconque."

# game/Scenes/MrsMills/mills0.rpy:67
translate french mills0_2b17c9bb:

    # tm "Anyways, I'll get the coffees ready."
    tm "Bref, je vais préparer les cafés."

# game/Scenes/MrsMills/mills0.rpy:68
translate french mills0_a9a2d1b9:

    # pc "Thanks."
    pc "Merci."

# game/Scenes/MrsMills/mills0.rpy:70
translate french mills0_88f20fe1:

    # "I give my order to the barista."
    "Je passe ma commande à la barista."

