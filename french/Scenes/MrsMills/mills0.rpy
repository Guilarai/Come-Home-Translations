    tm "Oui, c'est vrai."

# game/Scenes/MrsMills/mills0.rpy:64
translate french mills0_c600d14b:

    # tm "What do you do for her that a woman can't do, I wonder?"
    tm "Je me demande ce que tu fais pour elle qu'une femme ne peut pas faire ?"

# game/Scenes/MrsMills/mills0.rpy:65
translate french mills0_4385024a:

