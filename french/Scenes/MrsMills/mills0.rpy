    # pc "No ma'am. Just, you're staring at me."
    pc "Non, madame. C'est juste que vous me fixez."

# game/Scenes/MrsMills/mills0.rpy:112
translate french mills0_c0bf0f06:

    # bs "That's true."
    bs "C'est vrai."

# game/Scenes/MrsMills/mills0.rpy:113
