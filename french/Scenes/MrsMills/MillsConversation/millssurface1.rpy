translate french millssurface1_a8706b45:

    # pc "What do you like to do in your free time?"
    pc "Qu'est-ce que tu aimes faire pendant ton temps libre ?"

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:13
translate french millssurface1_7417d927:

    # bs "Oh, the things I like to do are not really appropriate for work talk."
    bs "Oh, les choses que j'aime faire ne sont pas vraiment appropriées pour une conversation au travail."

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:14
translate french millssurface1_e1541568:

    # bs "Maybe I'll get the chance to show you one day."
    bs "Peut-être que j'aurai l'occasion de te le montrer un jour."

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:16
translate french millssurface1_bd3f24d4:

    # bs "For now, just to keep conversation going, I'll say I like to go to the gym."
    bs "Pour l'instant, juste pour entretenir la conversation, je dirai que j'aime aller à la salle de sport."

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:17
translate french millssurface1_65563004:

    # pc "You work out a lot?"
    pc "Tu t'entraînes beaucoup ?"

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:18
translate french millssurface1_ebc6e26d:

    # bs "Every day after work, to clear my mind of all this nonsense and keep this body in tip-top shape."
    bs "Tous les jours après le travail, pour me vider la tête de toutes ces bêtises et garder ce corps en pleine forme."

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:19
translate french millssurface1_283b563c:

    # bs "Then I go home and have a glass of wine, preferably naked with somebody in my hot tub."
    bs "Ensuite, je rentre chez moi et je bois un verre de vin, de préférence nue avec quelqu'un dans mon jacuzzi."

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:21
translate french millssurface1_b6be7836:

    # bs "And enjoy my night."
    bs "Et je profite de ma soirée."

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:22
translate french millssurface1_35743d5e:

    # pc "Okay then."
    pc "D'accord alors."

