# game/Scenes/MrsMills/MillsConversation/millss4.rpy:12
translate french millss4_63ef2d75:

    # bs "Too many women in the workplace can cause issues."
    bs "Trop de femmes sur le lieu de travail, ça peut poser problème."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:13
translate french millss4_8c95432d:

    # bs "Women get too competitive with each other."
    bs "Les femmes deviennent trop compétitives entre elles."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:14
translate french millss4_7206131f:

    # bs "I needed somebody who would cater to everything I told them to do. No questions, no talk-back."
    bs "J’avais besoin de quelqu’un qui ferait tout ce que je lui demandais. Sans poser de questions, sans me contredire."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:16
translate french millss4_ad209de8:

    # bs "I find that men are better for that."
    bs "Je trouve que les hommes sont mieux pour ça."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:17
translate french millss4_d8646ae5:

    # bs "You tell them what to do, and they do it. They have a desire to please me."
    bs "On leur dit quoi faire, et ils le font. Ils ont envie de me faire plaisir."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:18
translate french millss4_c42a912e:

    # bs "And if they don't, they get punished. Which can be…"
    bs "Et s’ils ne le font pas, ils sont punis. Ce qui peut être…"

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:20
translate french millss4_7690c018:

    # bs "… fun."
    bs "… amusant."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:21
translate french millss4_48d4f23f:

    # pc "That sounds a little scary."
    pc "Ça a l’air un peu effrayant."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:23
translate french millss4_c8a6f279:

    # bs "Then keep minding your manners and don't make mistakes."
    bs "Alors continuez à bien vous tenir et ne faites pas d’erreurs."

# game/Scenes/MrsMills/MillsConversation/millss4.rpy:24
translate french millss4_1ca80c77:

    # pc "Yes, ma'am."
    pc "Oui, madame."

