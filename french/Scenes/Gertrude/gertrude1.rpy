# game/Scenes/Gertrude/gertrude1.rpy:12
translate french gertrude1_b8ab60df:

    # sc "I had a kind of personal question for you today."
    sc "J'avais une question un peu personnelle à te poser aujourd'hui."

# game/Scenes/Gertrude/gertrude1.rpy:13
translate french gertrude1_46f5a669:

    # pc "Okay, go ahead."
    pc "D'accord, vas-y."

# game/Scenes/Gertrude/gertrude1.rpy:14
translate french gertrude1_f61c5e45:

    # sc "If you don't want to answer it, you don't have to."
    sc "Si tu ne veux pas y répondre, tu n'es pas obligé."

# game/Scenes/Gertrude/gertrude1.rpy:15
translate french gertrude1_e2305d2c:

    # pc "Just ask."
    pc "Demande-moi."

# game/Scenes/Gertrude/gertrude1.rpy:16
translate french gertrude1_0cd2dbde:

    # sc "Are you sexually active?"
    sc "Es-tu sexuellement actif ?"

# game/Scenes/Gertrude/gertrude1.rpy:20
translate french gertrude1_7b5b8bbb:

    # sc "I think that most people would say that."
    sc "Je pense que la plupart des gens répondraient oui."

# game/Scenes/Gertrude/gertrude1.rpy:23
translate french gertrude1_ebf7eccb:

    # sc "Good, I'm glad."
    sc "Bien, j'en suis ravie."

# game/Scenes/Gertrude/gertrude1.rpy:26
translate french gertrude1_13162311:

    # sc "I'm sorry, I'm not trying to get involved in your personal life."
    sc "Je suis désolée, je ne cherche pas à me mêler de ta vie privée."

# game/Scenes/Gertrude/gertrude1.rpy:27
translate french gertrude1_dda22b21:

    # sc "But I do think that it is healthy to be sexually active at your age."
    sc "Mais je pense vraiment qu'il est sain d'être sexuellement actif à ton âge."

# game/Scenes/Gertrude/gertrude1.rpy:29
translate french gertrude1_5a649775:

    # sc "College is the perfect opportunity to experiment."
    sc "L'université est l'occasion idéale d'expérimenter."

# game/Scenes/Gertrude/gertrude1.rpy:30
translate french gertrude1_b8b829eb:

    # sc "To figure out what you like and don't like."
    sc "Pour découvrir ce que tu aimes et ce que tu n'aimes pas."

# game/Scenes/Gertrude/gertrude1.rpy:32
translate french gertrude1_8594ced1:

    # sc "You don't want to look back later in life and wonder about the things you missed out on."
    sc "Tu ne veux pas, plus tard dans ta vie, regarder en arrière et te demander ce que tu as manqué."

# game/Scenes/Gertrude/gertrude1.rpy:36
translate french gertrude1_639c8f25:

    # sc "Good."
    sc "Bien."

# game/Scenes/Gertrude/gertrude1.rpy:39
translate french gertrude1_070c7224:

    # sc "As long as you're safe about it, yes."
    sc "Tant que tu prends tes précautions, oui."

# game/Scenes/Gertrude/gertrude1.rpy:40
translate french gertrude1_9fc07896:

    # sc "I think that you should have lots of sex with a variety of people."
    sc "Je pense que tu devrais avoir beaucoup de relations sexuelles avec des personnes différentes."

# game/Scenes/Gertrude/gertrude1.rpy:41
translate french gertrude1_6bec941c:

    # sc "I believe that it gives you a healthier mindset when you're older, like me."
    sc "Je crois que ça te donne un état d'esprit plus sain quand tu es plus âgé, comme moi."

# game/Scenes/Gertrude/gertrude1.rpy:43
translate french gertrude1_a0193afd:

    # sc "Anyway, that is enough of this talk."
    sc "Bref, assez parlé de ça."

# game/Scenes/Gertrude/gertrude1.rpy:44
translate french gertrude1_e11ba8d0:

    # sc "You should get to class, right?"
    sc "Tu devrais aller en cours, non ?"

# game/Scenes/Gertrude/gertrude1.rpy:46
translate french gertrude1_9f00d552:

    # pc "Yeah, I guess so."
    pc "Ouais, je suppose."

# game/Scenes/Gertrude/gertrude1.rpy:47
translate french gertrude1_8f9b25a7:

    # sc "Okay, well I'll see you next time, [pcname]."
    sc "D'accord, eh bien à la prochaine, [pcname]."

# game/Scenes/Gertrude/gertrude1.rpy:48
translate french gertrude1_850ead77:

    # pc "Okay. Bye, Gertrude."
    pc "D'accord. Salut, Gertrude."

