# game/Scenes/Izzy/izzyconversations/izzys10.rpy:15
translate french izzys10_17317082:

    # gl "Naw, man."
    gl "Non, mec."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:17
translate french izzys10_6bcba249:

    # gl "None of that shit matters."
    gl "Tout ça, ça compte pas."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:18
translate french izzys10_8985d868:

    # gl "Rich people gonna do what they want, no matter what colors you wear or who you're voting for."
    gl "Les riches font ce qu'ils veulent, peu importe la couleur de tes vêtements ou pour qui tu votes."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:20
translate french izzys10_50958f7d:

    # gl "Us poor folk just gotta hold on and try not to get stomped on too hard."
    gl "Nous, les pauvres, on doit juste tenir bon et essayer de ne pas se faire trop piétiner."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:21
translate french izzys10_26644926:

    # pc "So you don't vote or anything?"
    pc "Alors tu ne votes pas ou quoi ?"

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:23
translate french izzys10_3a619d16:

    # gl "I've voted before. Once."
    gl "J'ai déjà voté. Une fois."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:25
translate french izzys10_fdf652b2:

    # gl "A woman I really believed could have made a difference."
    gl "Pour une femme dont je croyais vraiment qu'elle aurait pu changer les choses."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:27
translate french izzys10_1971388f:

    # gl "So of course she didn't win."
    gl "Alors bien sûr, elle n'a pas gagné."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:28
translate french izzys10_5f496235:

    # gl "They don't let anybody in there that will actually change things."
    gl "Ils ne laissent entrer personne là-dedans qui puisse réellement changer les choses."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:29
translate french izzys10_a217372a:

    # gl "At least I've never seen any change happen."
    gl "En tout cas, je n’ai jamais vu aucun changement se produire."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:31
translate french izzys10_f839dfdc:

    # gl "Although they been legalizing weed all over the place. Here too soon, probably."
    gl "Même s’ils légalisent l’herbe un peu partout. Ici aussi, probablement trop tôt."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:33
translate french izzys10_ee530a04:

    # gl "That's gonna be cool."
    gl "Ça va être cool."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:35
translate french izzys10_265e2718:

    # gl "I mean, I'd rather be in control of my own uterus, but take what you can get, I guess?"
    gl "Je veux dire, je préférerais avoir le contrôle de mon utérus, mais on prend ce qu’on peut, j’imagine ?"

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:37
translate french izzys10_f24052d9:

    # gl "Whatever. That shit's just infuriating."
    gl "Peu importe. Tout ça, c’est juste exaspérant."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:38
translate french izzys10_ba98e918:

    # gl "If I paid too much attention to it, I'd be mad all the damn time."
    gl "Si j’y prêtais trop attention, je serais en colère tout le temps."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:39
translate french izzys10_a4b1068c:

    # gl "I can't do that. I got shit to do, you know?"
    gl "Je peux pas faire ça. J’ai des trucs à faire, tu vois ?"

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:40
translate french izzys10_56fe0d71:

    # gl "Only rich people got time for politics. That's the problem."
    gl "Y a que les riches qui ont le temps de s’intéresser à la politique. C’est ça le problème."

# game/Scenes/Izzy/izzyconversations/izzys10.rpy:41
translate french izzys10_c129c6fe:

    # pc "Can't argue with that."
    pc "Je peux pas contredire ça."

