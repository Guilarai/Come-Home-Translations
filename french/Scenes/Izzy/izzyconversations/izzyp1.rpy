# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:12
translate french izzyp1_ba702b25:

    # gl "I was all they had, really."
    gl "J'étais tout ce qu'ils avaient, en fait."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:13
translate french izzyp1_b95c4fc1:

    # gl "When Mom went to prison, they were put into foster care for a little while."
    gl "Quand maman est allée en prison, ils ont été placés en famille d'accueil pendant un petit moment."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:14
translate french izzyp1_3ffed69b:

    # gl "But they hated it. The place that they ended up was not good."
    gl "Mais ils détestaient ça. L'endroit où ils se sont retrouvés n'était pas terrible."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:15
translate french izzyp1_98fe1afa:

    # gl "So I dropped out of school and got a retail job and as soon as I turned 18, I applied to be their guardian."
    gl "Alors j'ai arrêté l'école, j'ai trouvé un boulot dans le commerce et dès que j'ai eu 18 ans, j'ai demandé à devenir leur tuteur."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:17
translate french izzyp1_bb03637c:

    # gl "I mean I pretty much raised them anyway. Whenever Mom was actually home, she was high."
    gl "Je veux dire, c'est moi qui les ai élevés de toute façon. Chaque fois que maman était à la maison, elle était défoncée."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:19
translate french izzyp1_853f1428:

    # gl "So anyway, I was approved and that was that."
    gl "Bref, ma demande a été acceptée et voilà."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:21
translate french izzyp1_b0499bd6:

    # gl "But I wasn't making enough at my minimum wage job to support the three of us, so I started slinging dope."
    gl "Mais je ne gagnais pas assez avec mon salaire minimum pour subvenir aux besoins de nous trois, alors j’ai commencé à dealer de la drogue."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:22
translate french izzyp1_4f921dcb:

    # pc "What about your aunt? Couldn't they stay with her? They seem to like her."
    pc "Et ta tante ? Ils ne pouvaient pas rester chez elle ? Ils ont l’air de l’aimer bien."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:24
translate french izzyp1_41ba71be:

    # gl "They love her. I do too. But she's not much better off than me."
    gl "Ils l’adorent. Moi aussi. Mais elle n’est pas en bien meilleure posture que moi."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:25
translate french izzyp1_fd624143:

    # gl "She has five kids already."
    gl "Elle a déjà cinq enfants."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:26
translate french izzyp1_f33a41ea:

    # gl "Well, three are hers and two are her girlfriend's."
    gl "En fait, trois sont les siens et deux sont ceux de sa copine."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:28
translate french izzyp1_d9093d47:

    # gl "Both of them have two jobs. Have to work all the damn time."
    gl "Elles ont toutes les deux deux boulots. Elles doivent bosser tout le temps."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:29
translate french izzyp1_ad8b9872:

    # gl "They don't have time or money for Stanley and Paul."
    gl "Elles n’ont ni le temps ni l’argent pour s’occuper de Stanley et Paul."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:30
translate french izzyp1_14bb1b26:

    # pc "Yeah, that sounds pretty rough."
    pc "Ouais, ça a l’air plutôt dur."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:32
translate french izzyp1_698e73e8:

    # gl "It has been, but we'll get through it."
    gl "Ça l’a été, mais on va s’en sortir."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:34
translate french izzyp1_ec0443e3:

    # gl "At least those kids know that they're loved."
    gl "Au moins, ces gamins savent qu’on les aime."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:35
translate french izzyp1_5101b2d7:

    # gl "I hope my brothers know how much I love them."
    gl "J’espère que mes frères savent à quel point je les aime."

# game/Scenes/Izzy/izzyconversations/izzyp1.rpy:36
translate french izzyp1_f3315c79:

    # pc "I'm sure they do, Izzy."
    pc "Je suis sûr qu’ils le savent, Izzy."

