translate french izzy12_f80d8283:

    # "When I get in the car, my phone starts buzzing. Izzy's calling."
    "Quand je monte dans la voiture, mon téléphone se met à vibrer. C'est Izzy qui appelle."

# game/Scenes/Izzy/izzy12.rpy:16
translate french izzy12_bea5e8cb:

    # pc "Hello?"
    pc "Allô ?"

# game/Scenes/Izzy/izzy12.rpy:17
translate french izzy12_ec7ea0db:

    # gl "Hey, Twig. You busy?"
    gl "Salut, Twig. T'es occupé ?"

# game/Scenes/Izzy/izzy12.rpy:18
translate french izzy12_54f66403:

    # pc "Not really, what's up?"
    pc "Pas vraiment, qu'est-ce qu'il y a ?"

# game/Scenes/Izzy/izzy12.rpy:20
translate french izzy12_e79156a7:

    # gl "There's a movie I want to see. Thought maybe you'd want to come with me?"
    gl "Il y a un film que j'aimerais voir. Je me disais que tu voudrais peut-être m'accompagner ?"

# game/Scenes/Izzy/izzy12.rpy:21
translate french izzy12_8ceccd75:

    # pc "You want to go on a date?"
    pc "Tu veux qu'on sorte ensemble ?"

# game/Scenes/Izzy/izzy12.rpy:23
translate french izzy12_ec53909b:

    # gl "I just want to go see a movie. You can call it whatever you want."
    gl "Je veux juste aller voir un film. Tu peux appeler ça comme tu veux."

# game/Scenes/Izzy/izzy12.rpy:24
translate french izzy12_64ec2086:

    # pc "You know you're going to have to wear some clothes right?"
    pc "Tu sais que tu vas devoir t'habiller, n'est-ce pas ?"

# game/Scenes/Izzy/izzy12.rpy:26
translate french izzy12_33a6163c:

    # gl "Funny. Are we going, or what?"
    gl "Très drôle. On y va, ou quoi ?"

# game/Scenes/Izzy/izzy12.rpy:27
translate french izzy12_659d5d45:

    # pc "Yeah, I'll come pick you up."
    pc "Ouais, je passe te chercher."

# game/Scenes/Izzy/izzy12.rpy:28
translate french izzy12_3b30cb95:

    # gl "Cool. See you when you get here."
    gl "Cool. À tout à l'heure."

