    # voice 'voices/izzy_1_1.mp3'
    voice 'voices/izzy_1_1.mp3'

# game/Scenes/Izzy/izzy1.rpy:24
translate french izzy1_d20e163b:

    # gl "Where you going, twig-boy?"
    gl "T'as l'intention d'aller où, petit gringalet ?"

# game/Scenes/Izzy/izzy1.rpy:25
translate french izzy1_7d2401c7:

    # pc "Twig-boy?"
    pc "Petit gringalet ?"

# game/Scenes/Izzy/izzy1.rpy:27
translate french izzy1_d41d8cd9_1:

    # voice 'voices/izzy_1_2.mp3'
    voice 'voices/izzy_1_2.mp3'

# game/Scenes/Izzy/izzy1.rpy:28
translate french izzy1_d093d218:

    # gl "Yeah, cause you about the size of a twig and my guys could snap you in two."
    gl "Ouais, parce que t'es à peu près de la taille d'une brindille et que mes potes pourraient te casser en deux."

# game/Scenes/Izzy/izzy1.rpy:29
translate french izzy1_aec5c4f7:

    # "I look over at them behind her. I almost believe that they could."
    "Je jette un œil à ceux qui se trouvent derrière elle. Je crois presque qu'ils en seraient capables."

# game/Scenes/Izzy/izzy1.rpy:30
translate french izzy1_51076f5a:

    # pc "I just thought I'd come over and say hi. I'm new in town."
    pc "Je voulais juste passer vous dire bonjour. Je suis nouveau en ville."

# game/Scenes/Izzy/izzy1.rpy:32
translate french izzy1_d41d8cd9_2:

    # voice 'voices/izzy_1_3.mp3'
    voice 'voices/izzy_1_3.mp3'

# game/Scenes/Izzy/izzy1.rpy:33
translate french izzy1_f9a04499:

    # gl "And you think we're the welcoming committee? We look like the type that'd invite you over, make you a casserole?"
    gl "Et tu penses qu'on est le comité d'accueil ? On a l'air du genre à t'inviter chez nous et à te préparer un plat mijoté ?"

# game/Scenes/Izzy/izzy1.rpy:35
translate french izzy1_23081509:

    # moose "Haha! A casserole! You so funny, Izzy."
    moose "Haha ! Un plat mijoté ! T'es trop drôle, Izzy."

# game/Scenes/Izzy/izzy1.rpy:37
translate french izzy1_d41d8cd9_3:

    # voice 'voices/izzy_1_4.mp3'
    voice 'voices/izzy_1_4.mp3'

# game/Scenes/Izzy/izzy1.rpy:38
translate french izzy1_c2c19747:

    # gl "Shut the fuck up, Moose."
    gl "Ferme-la, Moose."

# game/Scenes/Izzy/izzy1.rpy:39
translate french izzy1_33e887bb:

    # moose "Sorry, girl. My bad."
    moose "Désolée, ma belle. C'est ma faute."

# game/Scenes/Izzy/izzy1.rpy:42
translate french izzy1_d41d8cd9_4:

    # voice 'voices/izzy_1_5.mp3'
    voice 'voices/izzy_1_5.mp3'

# game/Scenes/Izzy/izzy1.rpy:43
translate french izzy1_f6a69cf1:

    # gl "Anyways, we ain't no city council and we ain't an open forum."
    gl "Bref, on est pas le conseil municipal et on est pas un forum public."

# game/Scenes/Izzy/izzy1.rpy:45
translate french izzy1_d41d8cd9_5:

    # voice 'voices/izzy_1_6.mp3'
    voice 'voices/izzy_1_6.mp3'

# game/Scenes/Izzy/izzy1.rpy:46
translate french izzy1_671e7cca:

    # gl "So you ain't welcome here. Get it, Twig?"
    gl "Donc t'es pas le bienvenu ici. T'as compris, Petite Baguette ?"

# game/Scenes/Izzy/izzy1.rpy:51
translate french izzytwigtalk_bc94c85f:

    # gl "You back, Twig?"
    gl "T'es de retour, Petite Baguette ?"

# game/Scenes/Izzy/izzy1.rpy:52
translate french izzytwigtalk_5e16b4dd:

    # gl "I told you that you ain't welcome here."
    gl "Je t'ai dit que t'étais pas le bienvenu ici."

# game/Scenes/Izzy/izzy1.rpy:56
translate french izzytwigtalk_19da926c:

    # gl "Good. Get the fuck out of here, Twig."
    gl "Bien. Dégage d'ici, Petite Baguette."

# game/Scenes/Izzy/izzy1.rpy:59
translate french izzytwigtalk_03a3489c:

    # "I turn and walk away. After I take a few steps I can hear them all laughing. It's humiliating."
    "Je me retourne et m’éloigne. Après avoir fait quelques pas, je les entends tous rire. C’est humiliant."

# game/Scenes/Izzy/izzy1.rpy:60
translate french izzytwigtalk_6aa25614:

    # "Maybe I'll try again some other time, but for now I just want to get out of here."
    "J’essaierai peut-être à nouveau une autre fois, mais pour l’instant, je veux juste me tirer d’ici."

# game/Scenes/Izzy/izzy1.rpy:70
translate french izzytwigtalk_ea29e717:

    # gl "Oh, is that what you think?"
    gl "Oh, c’est ce que tu crois ?"

# game/Scenes/Izzy/izzy1.rpy:71
translate french izzytwigtalk_4f1631c8:

    # gl "Fine. Moose, grab him."
    gl "Très bien. Moose, attrape-le."

# game/Scenes/Izzy/izzy1.rpy:72
translate french izzytwigtalk_c7045d3c:

    # moose "You got it, girl."
    moose "C’est parti, ma belle."

# game/Scenes/Izzy/izzy1.rpy:75
translate french izzytwigtalk_bfacd7f0:

    # "With unnatural speed for his size, the big man charges towards me, arms out."
    "Avec une rapidité inhabituelle pour sa taille, le colosse se précipite vers moi, les bras tendus."

# game/Scenes/Izzy/izzy1.rpy:77
translate french izzytwigtalk_d623de1c:

    # "Without even thinking about it, I turn and run the other way."
    "Sans même y réfléchir, je fais demi-tour et je pars en courant dans l’autre sens."

# game/Scenes/Izzy/izzy1.rpy:78
translate french izzytwigtalk_c857d906:

    # "He gives chase for a bit, but then gives up and goes back to the others."
    "Il me poursuit un moment, mais finit par abandonner et retourne vers les autres."

# game/Scenes/Izzy/izzy1.rpy:81
translate french izzytwigtalk_2a2c5fa4:

    # "I don't stop though. I just showed how much of a pussy I am by running there and now I can't just go back and face them again."
    "Je ne m’arrête pas pour autant. Je viens de montrer à quel point je suis une mauviette en m’enfuyant, et maintenant je ne peux pas simplement revenir et les affronter à nouveau."

# game/Scenes/Izzy/izzy1.rpy:82
translate french izzytwigtalk_224c9c2b:

    # gl "That's right, keep running, Twig!"
    gl "C’est ça, continue de courir, Twig !"

# game/Scenes/Izzy/izzy1.rpy:83
translate french izzytwigtalk_67906573:

    # "She yells after me, taunting me as I head back towards my car."
    "Elle me crie après, me narguant alors que je retourne vers ma voiture."

# game/Scenes/Izzy/izzy1.rpy:84
translate french izzytwigtalk_45a42840:

    # "Maybe if I was more confident, I could stand my ground, but for now I just want to get out of here."
    "Peut-être que si j’avais plus confiance en moi, je pourrais tenir bon, mais pour l’instant, je veux juste partir d’ici."

# game/Scenes/Izzy/izzy1.rpy:85
translate french izzytwigtalk_9a4f14d6:

    # "I could probably boost my confidence by chatting up random strangers at the school café. That seems like the most obvious way."
    "Je pourrais probablement booster ma confiance en discutant avec des inconnus au café de l’école. Ça semble être la solution la plus évidente."

