# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:30
translate french izzyarcadedatestart_515d2991:

    # gl "What's up, Twig. Let's go play some games."
    gl "Salut, Twig. Allons jouer à des jeux."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:36
translate french izzyarcadedatestart_605a4d9f:

    # gl "Hey, this place is pretty cool. I bet Stanley and Paul would love it."
    gl "Hé, cet endroit est plutôt cool. Je parie que Stanley et Paul adoreraient ça."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:37
translate french izzyarcadedatestart_b1581a15:

    # gl "Maybe we could bring them sometime, when I'm able to."
    gl "On pourrait peut-être les amener un jour, quand je pourrai."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:38
translate french izzyarcadedatestart_8de112f2:

    # pc "Yeah for sure, that sounds fun."
    pc "Ouais, bien sûr, ça a l'air sympa."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:45
translate french izzyarcadedatestart_f9357be7:

    # "We play games and chat for a while."
    "On joue à des jeux et on discute un moment."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:49
translate french izzyarcadedatestart_66506ca5:

    # "We try out a few different games."
    "On essaie plusieurs jeux différents."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:57
translate french izzyarcadedatestart_726fbd6c:

    # "It's all fun and she seems to have a good time."
    "C'est sympa et elle a l'air de bien s'amuser."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:59
translate french izzyarcadedatestart_84d584ed:

    # "When we're done playing, I drive Izzy back to her house."
    "Quand on a fini de jouer, je ramène Izzy chez elle."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:60
translate french izzyarcadedatestart_2a5b6b89:

    # "I pull into her driveway and she turns to look at me."
    "Je m'engage dans son allée et elle se retourne pour me regarder."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:62
translate french izzyarcadedatestart_6dd86d8c:

    # gl "So, do you want to come inside and fuck a little?"
    gl "Alors, tu veux entrer pour baiser un peu ?"

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:69
translate french izzyarcadedatestart_dcbc938c:

    # gl "Cool, let's go."
    gl "Cool, allons-y."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:72
translate french izzyarcadedatestart_dcbc938c_1:

    # gl "Cool, let's go."
    gl "Cool, allons-y."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:75
translate french izzyarcadedatestart_7c186cf5:

    # gl "Damn. Well thanks for hanging out anyway. It was fun."
    gl "Merde. Bon, merci d'être sortie avec moi quand même. C'était sympa."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:76
translate french izzyarcadedatestart_63fc4244:

    # pc "Bye, Izzy."
    pc "Salut, Izzy."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:79
translate french izzyarcadedatestart_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "J'attends qu'elle sorte et entre dans sa maison avant de repartir."

