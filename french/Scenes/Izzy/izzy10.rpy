    # voice 'voices/izzy_10_9.mp3'
    voice 'voices/izzy_10_9.mp3'

# game/Scenes/Izzy/izzy10.rpy:51
translate french izzy10_511de65f:

    # gl "I gotta go. Talk to you later, hopefully."
    gl "Je dois y aller. On se reparle plus tard, j'espère."

# game/Scenes/Izzy/izzy10.rpy:52
translate french izzy10_c363031d:

    # pc "Okay. Bye, Izzy."
    pc "D'accord. Salut, Izzy."

# game/Scenes/Izzy/izzy10.rpy:56
translate french izzy10_d0995620:

    # "I pull back out onto the streets and start driving over towards Izzy's house."
    "Je reprends la route et me dirige vers la maison d'Izzy."

# game/Scenes/Izzy/izzy10.rpy:57
translate french izzy10_541c797d:

    # "Izzy in jail. Man, that sucks. I wonder if I'll ever even see her again?"
    "Izzy en prison. Bon sang, ça craint. Je me demande si je la reverrai un jour ?"

# game/Scenes/Izzy/izzy10.rpy:60
translate french izzy10_0161d2d8:

    # "At her house, I find the door unlocked. I open it and walk inside."
    "Arrivé chez elle, je trouve la porte ouverte. Je l'ouvre et entre."

# game/Scenes/Izzy/izzy10.rpy:61
translate french izzy10_0d5bc151:

    # pc "Hello? Anybody home?"
    pc "Bonjour ? Il y a quelqu'un ?"

# game/Scenes/Izzy/izzy10.rpy:62
translate french izzy10_735aa81f:

    # "I can hear the television playing in the living room."
    "J'entends la télévision dans le salon."

# game/Scenes/Izzy/izzy10.rpy:65
translate french izzy10_48d7389b:

    # "Then two boys who must be Izzy's little brothers rush out."
    "Puis deux garçons, qui doivent être les petits frères d'Izzy, se précipitent vers moi."

# game/Scenes/Izzy/izzy10.rpy:66
translate french izzy10_c3511125:

    # "Older Boy" "Who are you? You better get out of our house!"
    "Older Boy" "Qui êtes-vous ? Vous feriez mieux de sortir de chez nous !"

# game/Scenes/Izzy/izzy10.rpy:67
translate french izzy10_a66a8306:

    # pc "Woah, calm down. I'm one of Izzy's friends. She's going to be uh... late."
    pc "Whoah, calmez-vous. Je suis une amie d'Izzy. Elle va être... en retard."

# game/Scenes/Izzy/izzy10.rpy:68
translate french izzy10_807e3ac4:

    # pc "Your auntie is supposed to be coming, but Izzy wanted me to come sit with you until she gets here."
    pc "Votre tante est censée venir, mais Izzy voulait que je vienne m'asseoir avec vous jusqu'à ce qu'elle arrive."

# game/Scenes/Izzy/izzy10.rpy:71
translate french izzy10_1d52908f:

    # "Younger Boy" "Izzy? Who's that?"
    "Younger Boy" "Izzy ? C'est qui ?"

# game/Scenes/Izzy/izzy10.rpy:72
translate french izzy10_ecf25c52:

    # "Older Boy" "That's sis, dummy. That's what her friends call her."
    "Older Boy" "C'est ma sœur, idiot. C'est comme ça que ses amis l'appellent."

# game/Scenes/Izzy/izzy10.rpy:73
translate french izzy10_9e4c4b50:

    # "Younger Boy" "Oh yeah!"
    "Younger Boy" "Ah oui !"

# game/Scenes/Izzy/izzy10.rpy:74
translate french izzy10_380c7fa4:

    # "Older Boy" "Okay, you can come sit and watch TV with us, but if you try anything, we'll bust you."
    "Older Boy" "Bon, tu peux venir t'asseoir et regarder la télé avec nous, mais si tu essaies quoi que ce soit, on te mettra une raclée."

# game/Scenes/Izzy/izzy10.rpy:75
translate french izzy10_94570d10:

    # pc "All right then."
    pc "D'accord alors."

# game/Scenes/Izzy/izzy10.rpy:78
translate french izzy10_be6441de:

    # "I go in and sit on the couch, while they sit on the floor in front of the coffee table, doing homework and watching cartoons on the television."
    "J'entre et je m'assois sur le canapé, tandis qu'ils s'assoient par terre devant la table basse, faisant leurs devoirs et regardant des dessins animés à la télévision."

# game/Scenes/Izzy/izzy10.rpy:79
translate french izzy10_98c4afdf:

    # "After sitting for a couple minutes in awkward silence, the older boy turns towards me."
    "Après être restés assis quelques minutes dans un silence gêné, le plus grand se tourne vers moi."

# game/Scenes/Izzy/izzy10.rpy:82
translate french izzy10_b0063ead:

    # "Older Boy" "What's your name?"
    "Older Boy" "Comment tu t'appelles ?"

# game/Scenes/Izzy/izzy10.rpy:83
translate french izzy10_784c18d8:

    # pc "[pcname]. What's yours?"
    pc "[pcname]. Et toi ?"

# game/Scenes/Izzy/izzy10.rpy:84
translate french izzy10_ceb1abab:

    # "Older Boy" "I'm Paul. My brother is Stanley."
    "Older Boy" "Je m'appelle Paul. Mon frère, c'est Stanley."

# game/Scenes/Izzy/izzy10.rpy:85
translate french izzy10_70696046:

    # pc "Nice to meet you both."
    pc "Ravi de vous rencontrer tous les deux."

# game/Scenes/Izzy/izzy10.rpy:86
translate french izzy10_3a7290ac:

    # "Paul" "So, are you one of her boyfriends?"
    "Paul" "Alors, t'es l'un de ses copains ?"

# game/Scenes/Izzy/izzy10.rpy:87
translate french izzy10_2d34af9e:

    # "Paul" "Sis has lots of boyfriends, but she usually doesn't let us meet them."
    "Paul" "Ma sœur a plein de copains, mais d'habitude, elle nous laisse pas les rencontrer."

# game/Scenes/Izzy/izzy10.rpy:88
translate french izzy10_fc1855ec:

    # pc "Yeah, I guess I am. We're friends."
    pc "Ouais, je suppose que oui. On est potes."

# game/Scenes/Izzy/izzy10.rpy:89
translate french izzy10_0b6b2f16:

    # "Stanley" "Where is she? Why isn't she at home?"
    "Stanley" "Où est-elle ? Pourquoi n’est-elle pas à la maison ?"

# game/Scenes/Izzy/izzy10.rpy:92
translate french izzy10_e562930a:

    # pc "Well, the police arrested her. She might be going to jail."
    pc "Eh bien, la police l’a arrêtée. Elle risque d’aller en prison."

# game/Scenes/Izzy/izzy10.rpy:93
translate french izzy10_9d4dc068:

    # "Paul" "Oh. Like mom."
    "Paul" "Oh. Comme maman."

# game/Scenes/Izzy/izzy10.rpy:94
translate french izzy10_363102ed:

    # "Stanley" "So we'll never see her again?"
    "Stanley" "Alors on ne la reverra plus jamais ?"

# game/Scenes/Izzy/izzy10.rpy:95
translate french izzy10_05948c06:

    # "Paul" "Right."
    "Paul" "Exactement."

# game/Scenes/Izzy/izzy10.rpy:96
translate french izzy10_db875c8c:

    # pc "I wouldn't say that. We'll just have to wait to see what happens."
    pc "Je ne dirais pas ça. Il va falloir attendre de voir ce qui va se passer."

# game/Scenes/Izzy/izzy10.rpy:97
translate french izzy10_f0cc05be:

    # "Paul" "Yeah, okay."
    "Paul" "Ouais, d’accord."

# game/Scenes/Izzy/izzy10.rpy:98
translate french izzy10_9054da2b:

    # "Stanley" "I don't want sis to go to jail."
    "Stanley" "Je ne veux pas que ma sœur aille en prison."

# game/Scenes/Izzy/izzy10.rpy:100
translate french izzy10_8c26bb19:

    # pc "She just got busy with something, but she'll be home soon."
    pc "Elle a juste été retenue par quelque chose, mais elle sera bientôt de retour à la maison."

# game/Scenes/Izzy/izzy10.rpy:101
translate french izzy10_aed5f95e:

    # "Paul" "Really? She's always here when we get off the bus. What'd she get busy with?"
    "Paul" "Vraiment ? Elle est toujours là quand on descend du bus. Qu'est-ce qui l'a occupée ?"

# game/Scenes/Izzy/izzy10.rpy:102
translate french izzy10_0d6ab269:

    # pc "Just some stuff she had to do."
    pc "Juste des trucs qu'elle devait faire."

# game/Scenes/Izzy/izzy10.rpy:103
translate french izzy10_f0cc05be_1:

    # "Paul" "Yeah, okay."
    "Paul" "Ouais, d'accord."

# game/Scenes/Izzy/izzy10.rpy:104
translate french izzy10_5c971f07:

    # "We go back to awkward silence for a few more minutes."
    "On retombe dans un silence gênant pendant quelques minutes."

# game/Scenes/Izzy/izzy10.rpy:107
translate french izzy10_d9654c38:

    # "Stanley" "Do you know how to do your multiplication tables?"
    "Stanley" "Tu sais faire tes tables de multiplication ?"

# game/Scenes/Izzy/izzy10.rpy:108
translate french izzy10_c0dfc38d:

    # pc "Uh, yeah I do."
    pc "Euh, ouais, je sais."

# game/Scenes/Izzy/izzy10.rpy:109
translate french izzy10_5a2c5982:

    # "Stanley" "Could you help me with my homework then? I don't understand this stuff."
    "Stanley" "Tu pourrais m'aider avec mes devoirs alors ? Je comprends pas ce truc-là."

# game/Scenes/Izzy/izzy10.rpy:110
translate french izzy10_e85ea253:

    # pc "Sure, let me see what you have there."
    pc "Bien sûr, montre-moi ce que t'as là."

# game/Scenes/Izzy/izzy10.rpy:113
translate french izzy10_b17956ae:

    # "Stanley gets up and sits on the couch next to me, putting his worksheet and book on his lap to show me."
    "Stanley se lève et s'assoit sur le canapé à côté de moi, posant sa feuille d'exercices et son livre sur ses genoux pour me les montrer."

# game/Scenes/Izzy/izzy10.rpy:114
translate french izzy10_b975883b:

    # "Stanley" "I know that 8 plus 6 is 14. But this says that 8 times 6 is 48. How the heck does that work?"
    "Stanley" "Je sais que 8 plus 6 font 14. Mais là, c'est écrit que 8 fois 6 font 48. Comment ça marche, ça ?"

# game/Scenes/Izzy/izzy10.rpy:115
translate french izzy10_329fcf1a:

    # pc "So you know how to do addition? 8 plus 8?"
    pc "Alors tu sais faire des additions ? 8 plus 8 ?"

# game/Scenes/Izzy/izzy10.rpy:116
translate french izzy10_04dda5a7:

    # "Stanley" "Yeah."
    "Stanley" "Oui."

# game/Scenes/Izzy/izzy10.rpy:117
translate french izzy10_1c11dbdd:

    # pc "Well think of multiplication like you're doing addition over and over again."
    pc "Eh bien, imagine la multiplication comme si tu faisais des additions encore et encore."

# game/Scenes/Izzy/izzy10.rpy:118
translate french izzy10_b949eaf3:

    # pc "Here, write 8 six times on your paper. Eight six times is eight times six."
    pc "Tiens, écris 8 six fois sur ta feuille. Huit fois six, ça fait huit fois six."

# game/Scenes/Izzy/izzy10.rpy:119
translate french izzy10_b115a24b:

    # "Stanley" "Oh, I get it."
    "Stanley" "Oh, je comprends."

# game/Scenes/Izzy/izzy10.rpy:120
translate french izzy10_8b68d233:

    # pc "Then put a plus between each of those 8's and add them all together."
    pc "Ensuite, mets un signe plus entre chaque 8 et additionne-les tous."

# game/Scenes/Izzy/izzy10.rpy:121
translate french izzy10_e6a0ee82:

    # "He starts adding, writing the number above each of the eights on his page until he reaches the last one that is 48."
    "Il commence à additionner, en écrivant le chiffre au-dessus de chaque 8 sur sa feuille jusqu’à ce qu’il arrive au dernier, qui est 48."

# game/Scenes/Izzy/izzy10.rpy:122
translate french izzy10_7d468f4d:

    # "Stanley" "I get it! Wow, you should be a teacher."
    "Stanley" "J’ai compris ! Waouh, tu devrais être prof."

# game/Scenes/Izzy/izzy10.rpy:125
translate french izzy10_d3d886b1:

    # "I hear the front door open and a woman's voice calls out."
    "J'entends la porte d'entrée s'ouvrir et une voix de femme appeler."

# game/Scenes/Izzy/izzy10.rpy:126
translate french izzy10_e6d98dc8:

    # "Woman" "Boys? Y'all in here?"
    "Woman" "Les garçons ? Vous êtes tous là ?"

# game/Scenes/Izzy/izzy10.rpy:129
translate french izzy10_e3c838b3:

    # "The woman, who must be the boy's auntie, walks around the corner and both of them rush up to hug her."
    "La femme, qui doit être la tante du garçon, arrive au coin du couloir et les deux se précipitent pour la serrer dans leurs bras."

# game/Scenes/Izzy/izzy10.rpy:130
translate french izzy10_ec0adf9c:

    # "Auntie" "Everything okay here?"
    "Auntie" "Tout va bien ici ?"

# game/Scenes/Izzy/izzy10.rpy:131
translate french izzy10_5e4c7b42:

    # "Paul" "Yeah, we're all good."
    "Paul" "Oui, tout va bien."

# game/Scenes/Izzy/izzy10.rpy:132
translate french izzy10_60d1cbf2:

    # "Stanley" "[pcname] was teaching me how to do my times table."
    "Stanley" "[pcname] m'apprenait à faire mes tables de multiplication."

# game/Scenes/Izzy/izzy10.rpy:133
translate french izzy10_ad65d7e3:

    # "Auntie" "That's nice of him."
    "Auntie" "C'est gentil de sa part."

# game/Scenes/Izzy/izzy10.rpy:134
translate french izzy10_31976fc3:

    # "Auntie" "You two go to your room and pack up some clothes. You're going to come stay at my house for a few days, okay?"
    "Auntie" "Vous deux, allez dans votre chambre et préparez quelques vêtements. Vous allez venir chez moi pour quelques jours, d'accord ?"

# game/Scenes/Izzy/izzy10.rpy:135
translate french izzy10_32e2b2bb:

    # "Paul" "Is sis okay?"
    "Paul" "Ma sœur va bien ?"

# game/Scenes/Izzy/izzy10.rpy:136
translate french izzy10_d6e45f9a:

    # "Auntie" "She's okay, but she's going to be gone for a bit."
    "Auntie" "Elle va bien, mais elle va s'absenter un moment."

# game/Scenes/Izzy/izzy10.rpy:137
translate french izzy10_e67935e5:

    # "Stanley" "How long?"
    "Stanley" "Combien de temps ?"

# game/Scenes/Izzy/izzy10.rpy:138
translate french izzy10_1f41c1ac:

    # "Auntie" "I don't know yet honey. Go pack your bags, okay?"
    "Auntie" "Je ne sais pas encore, mon chéri. Va faire tes valises, d'accord ?"

# game/Scenes/Izzy/izzy10.rpy:141
translate french izzy10_3581e151:

    # "The two boys run off towards their rooms, and I stand up to talk to their auntie."
    "Les deux garçons courent vers leurs chambres, et je me lève pour parler à leur tante."

# game/Scenes/Izzy/izzy10.rpy:142
translate french izzy10_f78cee83:

    # "Auntie" "Thanks for coming over and sitting with them for a bit."
    "Auntie" "Merci d’être venue et de t’être occupée d’eux un moment."

# game/Scenes/Izzy/izzy10.rpy:143
translate french izzy10_5301b871:

    # pc "Oh, no problem. They seem like good kids."
    pc "Oh, pas de problème. Ils ont l’air d’être de bons enfants."

# game/Scenes/Izzy/izzy10.rpy:144
translate french izzy10_bd9c1d85:

    # "Auntie" "They are. I wish they didn't have to go through all this. First their mom, now their sister."
    "Auntie" "Ils le sont. J’aimerais qu’ils n’aient pas à traverser tout ça. D’abord leur mère, maintenant leur sœur."

# game/Scenes/Izzy/izzy10.rpy:145
translate french izzy10_8a42d1af:

    # pc "Is she going to be okay?"
    pc "Est-ce qu’elle va s’en sortir ?"

# game/Scenes/Izzy/izzy10.rpy:146
translate french izzy10_74736fd1:

    # "Auntie" "She had a lot of drugs on her when they arrested her and that other boy. She has a couple of priors as well. It doesn't look good."
    "Auntie" "Elle avait beaucoup de drogue sur elle quand ils l’ont arrêtée, elle et cet autre garçon. Elle a aussi quelques antécédents judiciaires. Ça s’annonce mal."

# game/Scenes/Izzy/izzy10.rpy:147
translate french izzy10_139f3015:

    # "Auntie" "I've been trying to get her to drop the drugs for a long time."
    "Auntie" "J'essaie depuis longtemps de la convaincre d'arrêter la drogue."

# game/Scenes/Izzy/izzy10.rpy:148
translate french izzy10_5e1c08a1:

    # "Auntie" "But it's hard to take care of two kids with a minimum wage job. Isabel didn't ask for any of this either."
    "Auntie" "Mais c'est dur de s'occuper de deux enfants avec un salaire minimum. Isabel n'a rien demandé de tout ça non plus."

# game/Scenes/Izzy/izzy10.rpy:149
translate french izzy10_847af3a0:

    # "Auntie" "I don't know how {i}I'm{/i} even going to take care of these boys."
    "Auntie" "Je ne sais même pas comment {i}je vais{/i} m'occuper de ces garçons."

# game/Scenes/Izzy/izzy10.rpy:150
translate french izzy10_45975e4c:

    # "Auntie" "But, I'll figure it out. Got no other choice."
    "Auntie" "Mais je trouverai une solution. Je n'ai pas d'autre choix."

# game/Scenes/Izzy/izzy10.rpy:151
translate french izzy10_527206cb:

    # "Auntie" "Anyways, thanks again. I'll take it from here."
    "Auntie" "Bref, merci encore. Je m'en occupe à partir de là."

# game/Scenes/Izzy/izzy10.rpy:154
translate french izzy10_47574532:

    # "She walks me towards the front door, but before I leave, Paul and Stanley come back out."
    "Elle m'accompagne jusqu'à la porte d'entrée, mais avant que je parte, Paul et Stanley reviennent."

# game/Scenes/Izzy/izzy10.rpy:155
translate french izzy10_82761cf4:

    # "Stanley" "Bye, [pcname]! Thanks for helping me with my math."
    "Stanley" "Salut, [pcname] ! Merci de m'avoir aidée en maths."

# game/Scenes/Izzy/izzy10.rpy:156
translate french izzy10_0438055e:

    # pc "Bye, you two. Be good. Keep studying."
    pc "Salut, vous deux. Soyez sages. Continuez à étudier."

# game/Scenes/Izzy/izzy10.rpy:160
translate french izzy10_85086dcf:

    # "I walk out, get into my car, and drive away."
    "Je sors, je monte dans ma voiture et je pars."

# game/Scenes/Izzy/izzy10.rpy:161
translate french izzy10_70ed6fb0:

    # "Damn, I hope Izzy will be okay. Those boys too. This whole situation just sucks."
    "Mince, j'espère qu'Izzy va s'en sortir. Ces garçons aussi. Toute cette situation est vraiment nulle."

