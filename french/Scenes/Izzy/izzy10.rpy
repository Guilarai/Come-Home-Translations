    gl "Je sais pas ce que je vais faire, [pcname]. Je suis dans le pétrin."

# game/Scenes/Izzy/izzy10.rpy:34
translate french izzy10_4814cea8:

    # pc "Oh shit. I'm sorry, Izzy. What can I do?"
    pc "Oh merde. Je suis désolé, Izzy. Qu'est-ce que je peux faire ?"

# game/Scenes/Izzy/izzy10.rpy:36
