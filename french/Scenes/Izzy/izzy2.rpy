# game/Scenes/Izzy/izzy2.rpy:13
translate french izzy2_b51311fa:

    # "I'm not going to run though. I'm confident in myself."
    "Mais je ne vais pas m’enfuir. J’ai confiance en moi."

# game/Scenes/Izzy/izzy2.rpy:14
translate french izzy2_a9a2f7bf:

    # "Maybe he'll kick my ass, but I'm not running."
    "Il va peut-être me botter le cul, mais je ne m’enfuirai pas."

# game/Scenes/Izzy/izzy2.rpy:17
translate french izzy2_da02f2e6:

    # "When Moose is about to slam into me, I quickly step aside and instead he trips forward, tumbling through the air."
    "Au moment où Moose s’apprête à me percuter, je m’écarte rapidement et c’est lui qui trébuche en avant, faisant une culbute dans les airs."

# game/Scenes/Izzy/izzy2.rpy:20
translate french izzy2_4a1e9586:

    # "He slams hard into the ground and lies there moaning."
    "Il s'écrase violemment au sol et reste allongé là à gémir."

# game/Scenes/Izzy/izzy2.rpy:21
translate french izzy2_7575cb2e:

    # "Izzy and the others burst into laughter, pointing at him."
    "Izzy et les autres éclatent de rire en le montrant du doigt."

# game/Scenes/Izzy/izzy2.rpy:22
translate french izzy2_58f4b0c6:

    # moose "S'not funny, man."
    moose "C'est pas drôle, mec."

# game/Scenes/Izzy/izzy2.rpy:23
translate french izzy2_fa71cc47:

    # mal "I don't know about that."
    mal "J'en doute."

# game/Scenes/Izzy/izzy2.rpy:24
translate french izzy2_0a29e854:

    # gl "Pretty damn funny to me."
    gl "Moi, je trouve ça sacrément drôle."

# game/Scenes/Izzy/izzy2.rpy:28
translate french izzy2_d41d8cd9:

    # voice 'voices/izzy_2_1.mp3'
    voice 'voices/izzy_2_1.mp3'

# game/Scenes/Izzy/izzy2.rpy:29
translate french izzy2_9be7b884:

    # gl "Got to say, I'm impressed, Twig."
    gl "Faut dire que je suis impressionné, Twig."

# game/Scenes/Izzy/izzy2.rpy:31
translate french izzy2_d41d8cd9_1:

    # voice 'voices/izzy_2_2.mp3'
    voice 'voices/izzy_2_2.mp3'

# game/Scenes/Izzy/izzy2.rpy:32
translate french izzy2_6e6d4843:

    # gl "Not many people who have the guts to stand their ground against Moose."
    gl "Y a pas beaucoup de gens qui ont le cran de tenir tête à Moose."

# game/Scenes/Izzy/izzy2.rpy:34
translate french izzy2_d41d8cd9_2:

    # voice 'voices/izzy_2_3.mp3'
    voice 'voices/izzy_2_3.mp3'

# game/Scenes/Izzy/izzy2.rpy:35
translate french izzy2_728d74b7:

    # gl "You're alright. You can hang with us."
    gl "T'es pas mal. Tu peux traîner avec nous."

# game/Scenes/Izzy/izzy2.rpy:37
translate french izzy2_d41d8cd9_3:

    # voice 'voices/izzy_2_4.mp3'
    voice 'voices/izzy_2_4.mp3'

# game/Scenes/Izzy/izzy2.rpy:38
translate french izzy2_e3c5fbdd:

    # gl "I'm Izzy. These guys are my gang."
    gl "Je m'appelle Izzy. Ces gars-là, c'est ma bande."

# game/Scenes/Izzy/izzy2.rpy:39
translate french izzy2_a0189c31:

    # moose "YOUR gang?"
    moose "TA bande ?"

# game/Scenes/Izzy/izzy2.rpy:40
translate french izzy2_f87a2e20:

    # gl "Yeah, Moose. MY gang. You have a problem with that?"
    gl "Ouais, Moose. MA bande. Ça te pose un problème ?"

# game/Scenes/Izzy/izzy2.rpy:41
translate french izzy2_bf630c9b:

    # moose "Naw, sis. No problem."
    moose "Non, ma belle. Pas de problème."

# game/Scenes/Izzy/izzy2.rpy:43
translate french izzy2_d41d8cd9_4:

    # voice 'voices/izzy_2_5.mp3'
    voice 'voices/izzy_2_5.mp3'

# game/Scenes/Izzy/izzy2.rpy:44
translate french izzy2_b260b0b6:

    # gl "You know Moose. The shirtless Bruce Lee-looking boy-toy over there is Mal."
    gl "Tu connais Moose. Le beau gosse torse nu qui ressemble à Bruce Lee, là-bas, c'est Mal."

# game/Scenes/Izzy/izzy2.rpy:45
translate french izzy2_3e106586:

    # mal "Wassup?"
    mal "Ça va ?"

# game/Scenes/Izzy/izzy2.rpy:47
translate french izzy2_d41d8cd9_5:

    # voice 'voices/izzy_2_7.mp3'
    voice 'voices/izzy_2_7.mp3'

# game/Scenes/Izzy/izzy2.rpy:48
translate french izzy2_45725a14:

    # gl "And tall, dark and skinny behind me is Devon. He don't talk much."
    gl "Et le grand, brun et maigre derrière moi, c'est Devon. Il parle pas beaucoup."

# game/Scenes/Izzy/izzy2.rpy:49
translate french izzy2_dc8cb990:

    # "Devon nods his head slightly at me."
    "Devon me fait un petit signe de tête."

# game/Scenes/Izzy/izzy2.rpy:50
translate french izzy2_522e1448:

    # gl "And that's the gang. Except now there's you - Twig."
    gl "Et voilà la bande. Sauf qu’il y a toi maintenant – Twig."

# game/Scenes/Izzy/izzy2.rpy:51
translate french izzy2_8b86df4b:

    # pc "My name is--"
    pc "Je m’appelle…"

# game/Scenes/Izzy/izzy2.rpy:52
translate french izzy2_28bea8fd:

    # "Just then the chirp of a police siren and a flashing light in the distance catches everyone's attention."
    "À ce moment-là, le hurlement d’une sirène de police et un gyrophare au loin attirent l’attention de tout le monde."

# game/Scenes/Izzy/izzy2.rpy:55
translate french izzy2_40384605:

    # mal "Cops!"
    mal "Les flics !"

# game/Scenes/Izzy/izzy2.rpy:56
translate french izzy2_3a4267e8:

    # moose "Oh shit, I gotta get out of here!"
    moose "Oh merde, je dois me tirer d’ici !"

# game/Scenes/Izzy/izzy2.rpy:57
translate french izzy2_db9ea3d3:

    # gl "Damn, gotta split."
    gl "Merde, je dois me casser."

# game/Scenes/Izzy/izzy2.rpy:60
translate french izzy2_84f98777:

    # gl "You come back and hang out with us sometime."
    gl "Reviens nous voir un de ces jours."

# game/Scenes/Izzy/izzy2.rpy:61
translate french izzy2_37f4bf94:

    # gl "We know how to have a good time."
    gl "On sait s’amuser."

# game/Scenes/Izzy/izzy2.rpy:62
translate french izzy2_d2b269a7:

    # gl "See you later, Twig."
    gl "À plus tard, Twig."

# game/Scenes/Izzy/izzy2.rpy:65
translate french izzy2_dbce667a:

    # "With that, she runs off in the same direction as the others."
    "Sur ces mots, elle s'enfuit dans la même direction que les autres."

# game/Scenes/Izzy/izzy2.rpy:66
translate french izzy2_4f647b81:

    # "I turn and walk back to my car."
    "Je me retourne et retourne vers ma voiture."

# game/Scenes/Izzy/izzy2.rpy:67
translate french izzy2_56b73e22:

    # "The police sirens and lights fade away. I'm not even sure they were aware of Izzy and her gang."
    "Les sirènes et les gyrophares s'éloignent. Je ne suis même pas sûr qu'ils aient remarqué Izzy et sa bande."

# game/Scenes/Izzy/izzy2.rpy:68
translate french izzy2_b8cda32c:

    # "I wonder why they are so jumpy?"
    "Je me demande pourquoi ils sont si nerveux ?"

# game/Scenes/Izzy/izzy2.rpy:69
translate french izzy2_b0b60482:

    # "I'll have to come back and hang out with them some other time. For now I get in my car and drive away."
    "Il faudra que je revienne passer du temps avec eux une autre fois. Pour l'instant, je monte dans ma voiture et je m'éloigne."

translate french strings:

    # game/Scenes/Izzy/izzy2.rpy:2
    old "Once you have some confidence,"
    new "Une fois que tu auras pris confiance,"

    # game/Scenes/Izzy/izzy2.rpy:3
