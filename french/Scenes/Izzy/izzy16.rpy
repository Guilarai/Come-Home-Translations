    # gl "Maybe. Just something I was thinking about."
    gl "Peut-être. C'est juste une idée qui m'est venue."

# game/Scenes/Izzy/izzy16.rpy:341
translate french izzy16_fc71e7f9:

    # gl "You staying the night?"
    gl "Tu restes dormir ?"

# game/Scenes/Izzy/izzy16.rpy:342
translate french izzy16_3e51dd6a:

    # pc "Yeah, I'll stay."
    pc "Ouais, je reste."

# game/Scenes/Izzy/izzy16.rpy:346
translate french izzy16_c6a7da14:

    # "We go back to her bed and lie down together."
    "On retourne dans son lit et on s'allonge ensemble."

# game/Scenes/Izzy/izzy16.rpy:349
translate french izzy16_033d9c0c:

    # "It doesn't take long before we're both asleep."
    "On ne tarde pas à s'endormir tous les deux."

# game/Scenes/Izzy/izzy16.rpy:352
translate french izzy16_1cee6238:

    # "I wake up to the sound of my phone alarm in the morning."
    "Je me réveille au son de l'alarme de mon téléphone le matin."

# game/Scenes/Izzy/izzy16.rpy:355
translate french izzy16_bc4ff6d9:

    # pc "Hey, Izzy. I have to go."
    pc "Salut, Izzy. Je dois y aller."

# game/Scenes/Izzy/izzy16.rpy:356
translate french izzy16_4511aa4e:

    # gl "Oh okay, baby."
    gl "Oh d'accord, chéri."

# game/Scenes/Izzy/izzy16.rpy:357
translate french izzy16_475c67d1:

    # gl "Hope you have a good day. Thanks for staying over."
    gl "Passe une bonne journée. Merci d'être resté."

# game/Scenes/Izzy/izzy16.rpy:360
translate french izzy16_f4a8219d:

    # pc "I'll talk to you later."
    pc "On se parle plus tard."

# game/Scenes/Izzy/izzy16.rpy:361
translate french izzy16_923d4965:

    # gl "Okay."
    gl "D'accord."

# game/Scenes/Izzy/izzy16.rpy:364
translate french izzy16_7db1b4d7:

    # "As I'm walking away, I hear her say, almost too low to make out the words..."
    "Alors que je m'éloigne, je l'entends dire, d'une voix presque trop faible pour que je puisse distinguer les mots..."

# game/Scenes/Izzy/izzy16.rpy:365
translate french izzy16_968ee224:

    # gl "Love you, Twig."
    gl "Je t'aime, Twig."

# game/Scenes/Izzy/izzy16.rpy:366
translate french izzy16_5236ef26:

    # "I leave Izzy's house, then head home to change and shower before starting my day."
    "Je quitte la maison d'Izzy, puis je rentre chez moi pour me changer et prendre une douche avant de commencer ma journée."

