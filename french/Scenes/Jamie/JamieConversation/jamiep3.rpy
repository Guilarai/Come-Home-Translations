# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:13
translate french jamiep3_100299e2:

    # gnd "Besides you? Not really."
    gnd "À part toi ? Pas vraiment."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:14
translate french jamiep3_b41de290:

    # gnd "All my high school friends moved away after graduation."
    gnd "Tous mes amis du lycée ont déménagé après le bac."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:15
translate french jamiep3_7df9bda2:

    # gnd "We only really talk online occasionally now."
    gnd "On ne se parle plus vraiment qu’occasionnellement en ligne maintenant."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:16
translate french jamiep3_70c8d02c:

    # gnd "There's a couple of girls in class that I talk to, but we don't really hang out or anything."
    gnd "Il y a deux ou trois filles en classe à qui je parle, mais on ne traîne pas vraiment ensemble ni rien."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:17
translate french jamiep3_a4b86b2a:

    # gnd "It's hard to make friends as an adult - especially when you spend most of your time at home, like I do."
    gnd "C'est dur de se faire des amis quand on est adulte – surtout quand on passe la plupart de son temps à la maison, comme moi."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:18
translate french jamiep3_6a377a93:

    # gnd "That's why I go to Java Lava to have my coffee every morning."
    gnd "C'est pour ça que je vais au Java Lava prendre mon café tous les matins."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:19
translate french jamiep3_b4b2cc87:

    # gnd "I get lonely."
    gnd "Je me sens seule."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:23
translate french jamiep3_ab221d8d:

    # gnd "I know. That's what my dad says too."
    gnd "Je sais. C'est ce que dit mon père aussi."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:24
translate french jamiep3_1912dfae:

    # gnd "But I'm just awkward around new people."
    gnd "Mais je suis juste mal à l'aise avec les nouvelles personnes."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:25
translate french jamiep3_4b11ab85:

    # gnd "I've never been good at talking to people like you are."
    gnd "Je n'ai jamais été douée pour parler aux gens comme tu l'es."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:27
translate french jamiep3_bc820600:

    # gnd "Yeah, at least I have that."
    gnd "Ouais, au moins j'ai ça."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:28
translate french jamiep3_a5543b0a:

    # gnd "Thanks, [pcname]."
    gnd "Merci, [pcname]."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:32
translate french jamiep3_5c7d9750:

    # gnd "That would be great."
    gnd "Ce serait génial."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:33
translate french jamiep3_3bc8548e:

    # gnd "You've always been good at talking to people."
    gnd "Tu as toujours su parler aux gens."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:34
translate french jamiep3_a457b32c:

    # gnd "I'm usually okay once I get to know a person, it's just at the beginning that I have a hard time forming complete sentences."
    gnd "En général, ça va une fois que je connais la personne, c’est juste au début que j’ai du mal à former des phrases complètes."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:35
translate french jamiep3_d3d4a815:

    # pc "I have some friends that you might get along with."
    pc "J’ai quelques amis avec qui tu t’entendrais bien."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:36
translate french jamiep3_fe72798e:

    # gnd "Yeah, we should hang out as a group sometime then."
    gnd "Ouais, on devrait sortir en groupe un de ces jours alors."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:37
translate french jamiep3_2951ed74:

    # pc "Definitely."
    pc "Absolument."

translate french strings:

    # game/Scenes/Jamie/JamieConversation/jamiep3.rpy:21
    old "You just need to get out more"
    new "Tu dois juste sortir plus souvent."

    # game/Scenes/Jamie/JamieConversation/jamiep3.rpy:26
    old "Well you have me"
    new "Eh bien, tu m’as moi."

    # game/Scenes/Jamie/JamieConversation/jamiep3.rpy:29
    old "Maybe I can introduce you to some people"
    new "Je pourrais peut-être te présenter à quelques personnes."

