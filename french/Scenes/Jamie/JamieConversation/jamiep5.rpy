translate french jamiep5_386a9d47:

    # gnd "Hm, getting into the deep questions now?"
    gnd "Hum, on passe aux questions profondes maintenant ?"

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:16
translate french jamiep5_68b7f918:

    # gnd "I guess I want the fairytale dream."
    gnd "Je suppose que je veux vivre un conte de fées."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:17
translate french jamiep5_c161b7d2:

    # gnd "I want a loving relationship."
    gnd "Je veux une relation amoureuse."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:18
translate french jamiep5_84a44c5c:

    # gnd "I want to get married to my soulmate."
    gnd "Je veux me marier avec mon âme sœur."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:19
translate french jamiep5_14b32e30:

    # gnd "I want at least three children."
    gnd "Je veux au moins trois enfants."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:20
translate french jamiep5_70863928:

    # gnd "I want to see them grow up and have their own children."
    gnd "Je veux les voir grandir et avoir leurs propres enfants."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:21
translate french jamiep5_4499c8f0:

    # gnd "I want to spend my life surrounded by people that I love."
    gnd "Je veux passer ma vie entourée des gens que j’aime."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:25
translate french jamiep5_1d72f29a:

    # gnd "Yeah, I think so."
    gnd "Ouais, je crois."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:27
translate french jamiep5_cf38cad8:

    # gnd "Step one is finding that soulmate."
    gnd "La première étape, c’est de trouver cette âme sœur."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:28
translate french jamiep5_9aedfa0b:

    # gnd "I think I'm getting closer."
    gnd "Je crois que je m’en approche."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:29
translate french jamiep5_ae871f39:

    # pc "Oh yeah?"
    pc "Ah oui ?"

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:30
translate french jamiep5_4e948d93:

    # gnd "Yeah."
    gnd "Ouais."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:33
translate french jamiep5_8f56c3e9:

    # gnd "Why?"
    gnd "Pourquoi ?"

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:34
translate french jamiep5_87af0849:

    # pc "Surrounding yourself with people you love is just asking for heartache."
    pc "T'entourer de gens que tu aimes, c'est juste te chercher des chagrins."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:35
translate french jamiep5_40d7d404:

    # pc "People get sick. People die."
    pc "Les gens tombent malades. Les gens meurent."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:36
translate french jamiep5_2b5ce695:

    # pc "The more people you love, the more people who can hurt you."
    pc "Plus tu aimes de gens, plus il y a de gens qui peuvent te faire du mal."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:37
translate french jamiep5_a709efd5:

    # gnd "Wow, that's a pretty sad way to look at things."
    gnd "Ouah, c'est une façon assez triste de voir les choses."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:38
translate french jamiep5_a8099acc:

    # gnd "Yeah people die. Yeah it hurts. But you can't just not love anybody."
    gnd "Ouais, les gens meurent. Ouais, ça fait mal. Mais tu peux pas simplement ne pas aimer personne."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:39
translate french jamiep5_a1226e3d:

    # gnd "My mom died. Your mom died. Would you rather you had never known them? Would that have been better?"
    gnd "Ma mère est morte. Ta mère est morte. Tu aurais préféré ne jamais les avoir connues ? Ça aurait été mieux ?"

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:43
translate french jamiep5_51c8d1d1:

    # gnd "THAT is ridiculous."
    gnd "C'est ridicule."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:44
translate french jamiep5_38f2044e:

    # gnd "I know I'm happy to have been able to spend the time with my mom that I did."
    gnd "Je sais que je suis heureuse d'avoir pu passer tout ce temps avec ma mère."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:45
translate french jamiep5_61004df2:

    # gnd "I'm sad that she's gone now, but I'm so, SO happy for the time we had."
    gnd "Je suis triste qu'elle soit partie maintenant, mais je suis tellement, TELLEMENT heureuse du temps qu'on a passé ensemble."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:46
translate french jamiep5_a11012e3:

    # gnd "I can't believe that you would feel differently about your mom."
    gnd "Je n'arrive pas à croire que tu puisses ressentir autre chose pour ta mère."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:48
translate french jamiep5_d3e8663d:

    # gnd "Right."
    gnd "C'est vrai."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:49
translate french jamiep5_38f2044e_1:

    # gnd "I know I'm happy to have been able to spend the time with my mom that I did."
    gnd "Je sais que je suis heureuse d'avoir pu passer tout ce temps avec ma mère."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:50
translate french jamiep5_61004df2_1:

    # gnd "I'm sad that she's gone now, but I'm so, SO happy for the time we had."
    gnd "Je suis triste qu'elle soit partie maintenant, mais je suis tellement, TELLEMENT heureuse du temps qu'on a passé ensemble."

# game/Scenes/Jamie/JamieConversation/jamiep5.rpy:51
translate french jamiep5_2daa69ee:

    # gnd "Let's talk about something else before I get too upset."
    gnd "Parlons d'autre chose avant que je ne m'énerve trop."

