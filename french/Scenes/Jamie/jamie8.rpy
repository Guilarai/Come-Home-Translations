translate french jamie8_a90d9888_1:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Je suis complètement amoureuse de toi, [pcname]. Je voulais juste que tu le saches."

# game/Scenes/Jamie/jamie8.rpy:92
translate french jamie8_fb4ce796:

    # pc "Oh, okay. Good to know."
    pc "Oh, d’accord. C’est bon à savoir."

# game/Scenes/Jamie/jamie8.rpy:94
translate french jamie8_5b0a7e45:

    # "We talk awkwardly a little bit longer about less important things, then there's just silence between us for a while."
    "On discute un peu plus longtemps, un peu maladroitement, de choses moins importantes, puis il n’y a plus que le silence entre nous pendant un moment."

# game/Scenes/Jamie/jamie8.rpy:95
translate french jamie8_fcdf2655_1:

    # gnd "I better get some sleep."
    gnd "Je ferais mieux d’aller dormir."

# game/Scenes/Jamie/jamie8.rpy:96
translate french jamie8_fdc5f0f0_1:

    # pc "Yeah, me too."
    pc "Ouais, moi aussi."

# game/Scenes/Jamie/jamie8.rpy:97
translate french jamie8_76e2f41b:

    # gnd "Okay. Good night, [pcname]."
    gnd "D'accord. Bonne nuit, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:98
translate french jamie8_6fd39c33:

    # pc "Night!"
    pc "Bonne nuit !"

# game/Scenes/Jamie/jamie8.rpy:99
translate french jamie8_39ca4ede:

    # "I hang up and go to sleep."
    "Je raccroche et je vais me coucher."

