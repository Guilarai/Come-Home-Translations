# game/Scenes/Jamie/jamie8.rpy:13
translate french jamie8_98ca1a51:

    # "My phone buzzes in my pocket."
    "Mon téléphone vibre dans ma poche."

# game/Scenes/Jamie/jamie8.rpy:15
translate french jamie8_7a608d10:

    # "It's Jamie. I lie on my bed and answer the phone."
    "C’est Jamie. Je reste allongé sur mon lit et je réponds au téléphone."

# game/Scenes/Jamie/jamie8.rpy:19
translate french jamie8_80c674d7:

    # pc "Hey, Jamie."
    pc "Salut, Jamie."

# game/Scenes/Jamie/jamie8.rpy:20
translate french jamie8_3d698c03:

    # gnd "Hey. You busy?"
    gnd "Salut. T’es occupé ?"

# game/Scenes/Jamie/jamie8.rpy:21
translate french jamie8_4474e21b:

    # pc "Nah. What's up?"
    pc "Non. Quoi de neuf ?"

# game/Scenes/Jamie/jamie8.rpy:22
translate french jamie8_34eb8872:

    # gnd "Nothing really. Just wanted to talk to you. Miss you."
    gnd "Rien de spécial. Je voulais juste te parler. Tu me manques."

# game/Scenes/Jamie/jamie8.rpy:23
translate french jamie8_71edcec9:

    # pc "Well.. you could come over?"
    pc "Eh bien… tu pourrais passer ?"

# game/Scenes/Jamie/jamie8.rpy:25
translate french jamie8_a38e761a:

    # gnd "You know I can't really do that. My dad would be so mad."
    gnd "Tu sais bien que je peux pas vraiment faire ça. Mon père serait furieux."

# game/Scenes/Jamie/jamie8.rpy:26
translate french jamie8_9f0961af:

    # pc "Why? You're an adult. Why does he get a say in what you do?"
    pc "Pourquoi ? Tu es adulte. Pourquoi a-t-il son mot à dire sur ce que tu fais ?"

# game/Scenes/Jamie/jamie8.rpy:27
translate french jamie8_57cb5e24:

    # gnd "I know. I just don't want him to be mad."
    gnd "Je sais. C'est juste que je ne veux pas qu'il se fâche."

# game/Scenes/Jamie/jamie8.rpy:28
translate french jamie8_0833b2b4:

    # gnd "I'll talk to him soon though, I promise."
    gnd "Mais je vais lui parler bientôt, je te le promets."

# game/Scenes/Jamie/jamie8.rpy:29
translate french jamie8_b1a2e372:

    # gnd "I know I need to. It's just hard, because I know he's not going to like what I have to say."
    gnd "Je sais que je dois le faire. C'est juste difficile, parce que je sais qu'il ne va pas aimer ce que j'ai à lui dire."

# game/Scenes/Jamie/jamie8.rpy:30
translate french jamie8_6cd88cb3:

    # gnd "And he works so hard, and I love him so much. I just hate to make him upset."
    gnd "Et il travaille si dur, et je l'aime tellement. Je déteste juste le contrarier."

# game/Scenes/Jamie/jamie8.rpy:32
translate french jamie8_dbc86daf:

    # gnd "But you mean so much to me. I don't want to have to keep sneaking around, keeping us a secret."
    gnd "Mais tu comptes tellement pour moi. Je ne veux plus avoir à agir en cachette, à garder notre relation secrète."

# game/Scenes/Jamie/jamie8.rpy:33
translate french jamie8_aa61dfea:

    # gnd "I just need to build up the courage to do it."
    gnd "J'ai juste besoin de trouver le courage de le faire."

# game/Scenes/Jamie/jamie8.rpy:37
translate french jamie8_07bcbb36:

    # gnd "Thank you. I'm glad. You've been very patient with me."
    gnd "Merci. Je suis contente. Tu as été très patiente avec moi."

# game/Scenes/Jamie/jamie8.rpy:39
translate french jamie8_a5d0737c:

    # gnd "I'll make it worth it for you, I promise."
    gnd "Je ferai en sorte que ça en vaille la peine pour toi, je te le promets."

# game/Scenes/Jamie/jamie8.rpy:40
translate french jamie8_5de186d8:

    # pc "It's already worth it, Jamie."
    pc "Ça en vaut déjà la peine, Jamie."

# game/Scenes/Jamie/jamie8.rpy:43
translate french jamie8_911c62b3:

    # gnd "You're right. I'm sorry."
    gnd "Tu as raison. Je suis désolée."

# game/Scenes/Jamie/jamie8.rpy:44
translate french jamie8_d5112d06:

    # gnd "You shouldn't have to deal with all of this drama. I know you're dealing with your own things, with your dad missing and all."
    gnd "Tu ne devrais pas avoir à gérer tout ce drame. Je sais que tu as déjà tes propres soucis, avec la disparition de ton père et tout ça."

# game/Scenes/Jamie/jamie8.rpy:45
translate french jamie8_5a747778:

    # gnd "I should be there for you more."
    gnd "Je devrais être plus présente pour toi."

# game/Scenes/Jamie/jamie8.rpy:47
translate french jamie8_9d979554:

    # gnd "And I will be. I promise. I'll tell him soon."
    gnd "Et je le serai. Je te le promets. Je vais lui dire bientôt."

# game/Scenes/Jamie/jamie8.rpy:49
translate french jamie8_d41d8cd9:

    # voice "voices/jamie_022.mp3"        
    voice "voices/jamie_022.mp3"        

# game/Scenes/Jamie/jamie8.rpy:50
translate french jamie8_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Je t'aime, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:56
translate french jamie8_b629d4db:

    # gnd "That feels good to say... and to hear."
    gnd "Ça fait du bien de le dire... et de l'entendre."

# game/Scenes/Jamie/jamie8.rpy:58
translate french jamie8_4d7bfc98:

    # gnd "I really mean it too."
    gnd "Et je le pense vraiment."

# game/Scenes/Jamie/jamie8.rpy:60
translate french jamie8_d41d8cd9_1:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:61
translate french jamie8_8cee1605:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart is growing bigger and bigger until it's close to bursting."
    gnd "Depuis que tu es revenue, je sens ce sentiment grandir, comme si mon cœur devenait de plus en plus gros jusqu’à être sur le point d’éclater."

# game/Scenes/Jamie/jamie8.rpy:63
translate french jamie8_d41d8cd9_2:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:64
translate french jamie8_55ac6cf8:

    # gnd "I smile every time I think about you, and I find myself thinking about you all the time."
    gnd "Je souris chaque fois que je pense à toi, et je me surprends à penser à toi tout le temps."

# game/Scenes/Jamie/jamie8.rpy:67
translate french jamie8_d41d8cd9_3:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:68
translate french jamie8_a90d9888:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Je suis complètement amoureux de toi, [pcname]. Je voulais juste que tu le saches."

# game/Scenes/Jamie/jamie8.rpy:69
translate french jamie8_9fc0bac9:

    # pc "I feel the same way, Jamie. You're amazing."
    pc "Je ressens la même chose, Jamie. Tu es incroyable."

# game/Scenes/Jamie/jamie8.rpy:71
translate french jamie8_ff198159:

    # gnd "I'm so happy."
    gnd "Je suis tellement heureuse."

# game/Scenes/Jamie/jamie8.rpy:72
translate french jamie8_69aafc54:

    # "We talk a little longer about other less important things, until we're both practically falling asleep on the phone."
    "On parle encore un peu de choses moins importantes, jusqu’à ce qu’on s’endorme presque tous les deux au téléphone."

# game/Scenes/Jamie/jamie8.rpy:74
translate french jamie8_fcdf2655:

    # gnd "I better get some sleep."
    gnd "Je ferais mieux d’aller dormir."

# game/Scenes/Jamie/jamie8.rpy:75
translate french jamie8_fdc5f0f0:

    # pc "Yeah, me too."
    pc "Ouais, moi aussi."

# game/Scenes/Jamie/jamie8.rpy:77
translate french jamie8_d41d8cd9_4:

    # voice "voices/jamie_010.mp3"
    voice "voices/jamie_010.mp3"

# game/Scenes/Jamie/jamie8.rpy:78
translate french jamie8_63e5a3ef:

    # gnd "Good night, [pcname]. Love you."
    gnd "Bonne nuit, [pcname]. Je t’aime."

# game/Scenes/Jamie/jamie8.rpy:79
translate french jamie8_727173cd:

    # pc "Love you too, Jamie. Good night."
    pc "Je t’aime aussi, Jamie. Bonne nuit."

# game/Scenes/Jamie/jamie8.rpy:82
translate french jamie8_a25f5d31:

    # gnd "I mean it."
    gnd "Je le pense vraiment."

# game/Scenes/Jamie/jamie8.rpy:84
translate french jamie8_d41d8cd9_5:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:85
translate french jamie8_796c0fbd:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart growing bigger and bigger until it's almost bursting now."
    gnd "Depuis que tu es revenu, je sens que ça monte en moi, comme si mon cœur grossissait de plus en plus jusqu’à être sur le point d’éclater."

# game/Scenes/Jamie/jamie8.rpy:87
translate french jamie8_d41d8cd9_6:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:88
translate french jamie8_0d1296eb:

    # gnd "I smile every time I think about you, and I find myself thinking about you a lot."
    gnd "Je souris chaque fois que je pense à toi, et je me surprends à penser à toi très souvent."

# game/Scenes/Jamie/jamie8.rpy:90
translate french jamie8_d41d8cd9_7:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

