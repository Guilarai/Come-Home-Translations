translate french jamiedate0_c4ab21ae:

    # "My phone starts buzzing in my pocket. I take it out and see Jamie is calling."
    "Mon téléphone se met à vibrer dans ma poche. Je le sors et je vois que c’est Jamie qui m’appelle."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:25
translate french jamiedate0_bea5e8cb:

    # pc "Hello?"
    pc "Allô ?"

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:26
translate french jamiedate0_3cdb8e82:

    # gnd "Hey, [pcname]... about our date for tonight."
    gnd "Salut, [pcname]... à propos de notre rendez-vous de ce soir."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:27
translate french jamiedate0_035b9440:

    # pc "You have to cancel?"
    pc "Tu dois annuler ?"

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:28
translate french jamiedate0_279da3ba:

    # gnd "Oh no, no, not at all! Trust me I want this so much."
    gnd "Oh non, non, pas du tout ! Crois-moi, j'ai vraiment envie de ça."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:29
translate french jamiedate0_f7556ea0:

    # gnd "I was just going to say that if you tell me where you want to go, I'll drive my own car and meet you there."
    gnd "J'allais juste te dire que si tu me dis où tu veux aller, je prendrai ma propre voiture et je te rejoindrai là-bas."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:30
translate french jamiedate0_b51e4bee:

    # gnd "I just don't want my dad coming home and seeing that my car is here and I'm not."
    gnd "Je ne veux juste pas que mon père rentre à la maison et voie que ma voiture est là et que je ne suis pas là."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:31
translate french jamiedate0_1d24979c:

    # gnd "I don't know what I would tell him."
    gnd "Je ne sais pas quoi lui dire."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:34
translate french jamiedate0_b2e041ac:

    # gnd "I know. I'm not ready to do that yet."
    gnd "Je comprends. Je ne suis pas encore prête à faire ça."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:35
translate french jamiedate0_fb759c1e:

    # gnd "He will not like that I'm dating you."
    gnd "Il n'aimera pas que je sorte avec toi."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:36
translate french jamiedate0_3676635a:

    # gnd "Just for now, can we do it like this?"
