translate french jamiemoviedate_811f3c11:

    # gnd "Sure, I'm sure there's something good playing."
    gnd "Bien sûr, je suis sûr qu’il y a un bon film à l’affiche."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:14
translate french jamiemoviedate_ddd48024:

    # gnd "Give me just a few minutes to get ready."
    gnd "Donne-moi juste quelques minutes pour me préparer."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:33
translate french jamiemovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "On arrive au cinéma et on s'assoit tout au fond."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:34
translate french jamiemovietheaterstartdate_c9878d77:

    # gnd "So what are we watching anyway?"
    gnd "Au fait, on va voir quoi ?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:38
translate french jamiemovietheaterstartdate_b4720e01:

    # gnd "Oh, I like it."
    gnd "Oh, j'aime bien."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:39
translate french jamiemovietheaterstartdate_45ba22b9:

    # gnd "Trying to put me in the mood huh?"
    gnd "Tu essaies de me mettre dans l'ambiance, hein ?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:44
translate french jamiemovietheaterstartdate_d41d8cd9:

    # voice "voices/jamie_003.mp3"
    voice "voices/jamie_003.mp3"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:45
translate french jamiemovietheaterstartdate_642253e9:

    # gnd "Oh okay. I guess that's fine."
    gnd "Oh d'accord. Je suppose que ça va."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:49
translate french jamiemovietheaterstartdate_b7b6ccce:

    # gnd "Oh okay."
    gnd "Oh d'accord."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:50
translate french jamiemovietheaterstartdate_984d111e:

    # gnd "Just a warning though. I might be grabbing onto you a lot."
    gnd "Mais je te préviens. Je risque de te serrer très fort."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:51
translate french jamiemovietheaterstartdate_e17b2a96:

    # gnd "Like a lot a lot."
    gnd "Vraiment très fort."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:55
translate french jamiemovietheaterstartdate_0ae36cfd:

    # gnd "Oh, I like funny movies."
    gnd "Oh, j'aime les films drôles."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:56
translate french jamiemovietheaterstartdate_a8e40a21:

    # gnd "I hope it's good."
    gnd "J'espère que c'est bien."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:58
translate french jamiemovietheaterstartdate_a311ea1d:

    # "There's a little time before the movie starts."
    "Il reste un peu de temps avant le début du film."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:62
translate french jamiemovietheaterstartdate_8da0039f:

    # "We just hang out and chat for a while."
    "On traîne et on discute un moment."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:65
translate french jamiemovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Enfin, le film commence et on se tait."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:67
translate french jamiemovietheaterstartdate_b58e95c5:

    # "Jamie leans against me."
    "Jamie se blottit contre moi."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:69
translate french jamiemovietheaterstartdate_d41d8cd9_1:

    # voice "voices/jamie_049.mp3"
    voice "voices/jamie_049.mp3"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:70
translate french jamiemovietheaterstartdate_40bb361a:

    # gnd "Want to mess around some?"
    gnd "Tu veux qu'on s'amuse un peu ?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:88
translate french jamiemovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Elle tend la main et tient la mienne par-dessus l'accoudoir."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:91
translate french jamiemovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Les bandes-annonces durent environ quinze minutes, puis le film commence vraiment."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:95
translate french jamiemovietheaterstartdate_f9b1cbb0:

    # "During the movie, she keeps looking over at me."
    "Pendant le film, elle n'arrête pas de me regarder."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:96
translate french jamiemovietheaterstartdate_d6b093f3:

    # pc "You like the movie?"
    pc "Tu aimes le film ?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:97
translate french jamiemovietheaterstartdate_18de1f8c:

    # gnd "Yeah, it's good. I just really want to kiss you right now."
    gnd "Ouais, c'est bien. J'ai juste très envie de t'embrasser là."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:99
translate french jamiemovietheaterstartdate_4cdfc044:

    # "I lean in and kiss her."
    "Je me penche vers elle et je l'embrasse."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:100
translate french jamiemovietheaterstartdate_22ba9c92:

    # "We hold like that for some time before she finally pulls away."
    "On reste comme ça un moment avant qu'elle ne s'écarte enfin."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:101
translate french jamiemovietheaterstartdate_9e25dd4e:

    # gnd "Okay, that will hold me over."
    gnd "Bon, ça me suffira pour l'instant."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:102
translate french jamiemovietheaterstartdate_3784a641:

    # gnd "Back to the movie."
    gnd "Retour au film."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:105
translate french jamiemovietheaterstartdate_43311053:

    # "During the movie, she keeps looking over at me and smiling."
    "Pendant le film, elle n'arrête pas de me jeter des regards et de me sourire."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:107
translate french jamiemovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "On dirait que le film lui plaît bien."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:110
translate french jamiemovietheaterstartdate_ffcd1a92:

    # "She seems to lose interest in the movie fairly quickly."
    "Elle semble se désintéresser du film assez rapidement."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:111
translate french jamiemovietheaterstartdate_5973f780:

    # "I don't know. It's pretty fun to me. I guess she just doesn't like this kind of movie."
    "Je ne sais pas. Moi, je trouve ça plutôt sympa. Je suppose qu’elle n’aime tout simplement pas ce genre de film."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:114
translate french jamiemovietheaterstartdate_4f23a069:

    # "During every scary scene that happens she tenses up and covers her mouth."
    "À chaque scène effrayante, elle se raidit et se couvre la bouche."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:115
translate french jamiemovietheaterstartdate_603a9a9b:

    # "Sometimes she even puts her hands over her eyes."
    "Parfois, elle se met même les mains sur les yeux."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:116
translate french jamiemovietheaterstartdate_288b2f3c:

    # "Then the music goes quiet, and I know that a jumpscare is coming."
    "Puis la musique s’arrête, et je sais qu’un « jumpscare » va arriver."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:119
translate french jamiemovietheaterstartdate_e86e1727:

    # "She grabs my arm and tucks her head down into it."
    "Elle m’attrape le bras et y enfouit sa tête."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:120
translate french jamiemovietheaterstartdate_6bdb4e54:

    # "Her fingers dig into my arm, grasping it so tight."
    "Ses doigts s’enfoncent dans mon bras, le serrant très fort."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:122
translate french jamiemovietheaterstartdate_e7200fcd:

    # "For the rest of the movie, I put my arm around her and hold her while we watch."
    "Pendant le reste du film, je passe mon bras autour d’elle et je la serre contre moi pendant qu’on regarde."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:125
translate french jamiemovietheaterstartdate_ec13a563:

    # "The movie is funny from pretty much the very beginning."
    "Le film est drôle pratiquement dès le début."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:126
translate french jamiemovietheaterstartdate_4caf9a58:

    # "And we laugh together all the way through it."
    "Et on rit ensemble tout au long du film."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:127
translate french jamiemovietheaterstartdate_7ad920fe:

    # "Even some of the scenes that aren't as funny, she laughs at."
    "Même certaines scènes qui ne sont pas si drôles, elle en rit."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:128
translate french jamiemovietheaterstartdate_0d1cfe15:

    # "And seeing her laugh just makes me laugh too."
    "Et la voir rire me fait rire aussi."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:129
translate french jamiemovietheaterstartdate_d855e56b:

    # "Eventually the movie ends and the credits start rolling."
    "Finalement, le film se termine et le générique commence à défiler."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:132
translate french jamiemovietheaterstartdate_0bcfb0ae:

    # gnd "That was a really sweet movie. Thanks for taking me."
    gnd "C’était un film vraiment sympa. Merci de m’avoir emmenée."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:133
translate french jamiemovietheaterstartdate_4de625af:

    # pc "Of course you're welcome."
    pc "De rien, bien sûr."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:136
translate french jamiemovietheaterstartdate_f9724275:

    # gnd "That movie wasn't really my thing, but I hope you liked it."
    gnd "Ce film n'était pas vraiment mon truc, mais j'espère qu'il t'a plu."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:137
translate french jamiemovietheaterstartdate_bfe93711:

    # pc "Yeah I though it was pretty cool."
    pc "Ouais, je l'ai trouvé plutôt cool."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:138
translate french jamiemovietheaterstartdate_045099e4:

    # gnd "I guess so."
    gnd "Je suppose."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:141
translate french jamiemovietheaterstartdate_6d2df7c7:

    # gnd "That movie was SO scary!"
    gnd "Ce film était TELLEMENT effrayant !"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:142
translate french jamiemovietheaterstartdate_5fcae4fe:

    # gnd "Thanks for being there for me though."
    gnd "Merci d'avoir été là pour moi quand même."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:143
translate french jamiemovietheaterstartdate_737a7b53:

    # gnd "Sorry if I hurt your arm."
    gnd "Désolée si je t'ai fait mal au bras."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:144
translate french jamiemovietheaterstartdate_00d236b5:

    # pc "It'll heal... eventually."
    pc "Ça guérira... un jour."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:147
translate french jamiemovietheaterstartdate_cd12116f:

    # gnd "That movie was SO funny!"
    gnd "Ce film était TELLEMENT drôle !"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:148
translate french jamiemovietheaterstartdate_e1a20436:

    # gnd "My chest hurts from laughing so much."
    gnd "J'ai mal à la poitrine à force de rire."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:149
translate french jamiemovietheaterstartdate_262d3cf7:

    # gnd "I loved it. Thanks for bringing me."
    gnd "J'ai adoré. Merci de m'avoir emmenée."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:151
translate french jamiemovietheaterend_1a39771f:

    # gnd "Want to just sit and chat through the credits?"
    gnd "Tu veux qu'on reste assis à discuter pendant le générique ?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:152
translate french jamiemovietheaterend_61f77a4c:

    # pc "Sure."
    pc "D'accord."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:156
translate french jamiemovietheaterend_34bf5b34:

    # "When the credits end, we walk outside together and out to our cars."
    "Quand le générique se termine, on sort ensemble et on rejoint nos voitures."

