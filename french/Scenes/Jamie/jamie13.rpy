    # voice "voices/jamie_088.mp3"
    voice "voices/jamie_088.mp3"

# game/Scenes/Jamie/jamie13.rpy:299
translate french jamie13b_77f7fa61:

    # gnd "Good luck with everything. Please don't try to contact me anymore."
    gnd "Bonne chance pour tout. S'il te plaît, n'essaie plus de me contacter."

# game/Scenes/Jamie/jamie13.rpy:300
translate french jamie13b_33949145:

    # pc "What? Wait..."
    pc "Quoi ? Attends..."

# game/Scenes/Jamie/jamie13.rpy:303
translate french jamie13b_bcbbe2f1:

    # "She hung up."
    "Elle a raccroché."

# game/Scenes/Jamie/jamie13.rpy:304
translate french jamie13b_439a8efe:

    # "What the fuck? What am I supposed to do now?"
    "C'est quoi ce bordel ? Qu'est-ce que je suis censé faire maintenant ?"

# game/Scenes/Jamie/jamie13.rpy:305
translate french jamie13b_a1814c52:

    # "I guess if she doesn't want to be with me, and doesn't want me to talk to her, I have to respect her wishes."
    "Je suppose que si elle ne veut pas être avec moi et ne veut pas que je lui parle, je dois respecter ses souhaits."

# game/Scenes/Jamie/jamie13.rpy:306
translate french jamie13b_f87ec8ec:

    # "But it's bullshit!"
    "Mais c'est n'importe quoi !"

# game/Scenes/Jamie/jamie13.rpy:309
translate french jamie13b_18c2def7:

    # "I feel like screaming. Like punching something."
    "J'ai envie de hurler. De frapper quelque chose."

# game/Scenes/Jamie/jamie13.rpy:310
translate french jamie13b_32c163d2:

    # "But instead, I lie in bed and seethe in anger until I fall asleep."
    "Mais à la place, je reste allongé dans mon lit et je bouillonne de rage jusqu'à ce que je m'endorme."

