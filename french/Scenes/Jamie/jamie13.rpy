    # pc "You should stay."
    pc "Tu devrais rester."

# game/Scenes/Jamie/jamie13.rpy:193
translate french jamie13_6d9c381a:

    # gnd "Okay. I think I will."
    gnd "D'accord. Je crois que je vais le faire."

# game/Scenes/Jamie/jamie13.rpy:195
translate french jamie13_d41d8cd9_8:

    # voice "voices/jamie_028.mp3"
    voice "voices/jamie_028.mp3"

# game/Scenes/Jamie/jamie13.rpy:196
translate french jamie13_b095ff70:

    # gnd "Like you said. I'm an adult. I can do what I want."
    gnd "Comme tu l'as dit. Je suis adulte. Je peux faire ce que je veux."

# game/Scenes/Jamie/jamie13.rpy:199
translate french jamie13_94cd612d:

    # "She moves to look at me, her eyes locked onto mine."
    "Elle se tourne pour me regarder, ses yeux rivés sur les miens."

# game/Scenes/Jamie/jamie13.rpy:201
translate french jamie13_d41d8cd9_9:

    # voice "voices/jamie_022.mp3"
    voice "voices/jamie_022.mp3"

# game/Scenes/Jamie/jamie13.rpy:202
translate french jamie13_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Je t'aime, [pcname]."

# game/Scenes/Jamie/jamie13.rpy:203
translate french jamie13_5e3e613a:

    # pc "I love you too, Jamie."
    pc "Je t'aime aussi, Jamie."

# game/Scenes/Jamie/jamie13.rpy:204
translate french jamie13_59e15393:

    # "We lie there like that, sweat cooling on our skin, until I hear her soft snoring."
    "On reste allongés comme ça, la sueur qui refroidit sur notre peau, jusqu'à ce que j'entende son doux ronflement."

# game/Scenes/Jamie/jamie13.rpy:207
translate french jamie13_ae4b475d:

    # "Then I fall asleep shortly after."
    "Puis je m'endors peu après."

# game/Scenes/Jamie/jamie13.rpy:215
translate french jamie13_f6d0406e:

    # "In the morning, I wake up to her face, sleeping next to me."
    "Le matin, je me réveille face à elle, endormie à mes côtés."

# game/Scenes/Jamie/jamie13.rpy:216
translate french jamie13_fc00fd18:

    # "I softly caress her cheek to wake her up."
    "Je lui caresse doucement la joue pour la réveiller."

# game/Scenes/Jamie/jamie13.rpy:219
translate french jamie13_a336655c:

    # pc "Hey beautiful."
    pc "Salut ma belle."

# game/Scenes/Jamie/jamie13.rpy:221
translate french jamie13_d41d8cd9_10:

    # voice "voices/jamie_029a.mp3"
    voice "voices/jamie_029a.mp3"

# game/Scenes/Jamie/jamie13.rpy:222
translate french jamie13_c59c4cdd:

    # gnd "Oh geez, what time is it?"
    gnd "Oh mince, quelle heure est-il ?"

# game/Scenes/Jamie/jamie13.rpy:224
translate french jamie13_d41d8cd9_11:

    # voice "voices/jamie_029b.mp3"
    voice "voices/jamie_029b.mp3"

# game/Scenes/Jamie/jamie13.rpy:225
translate french jamie13_9a2ed43d:

    # gnd "I have to get home before Dad gets upset."
    gnd "Je dois rentrer avant que papa ne s’énerve."

# game/Scenes/Jamie/jamie13.rpy:227
translate french jamie13_d41d8cd9_12:

    # voice "voices/jamie_029c.mp3"
    voice "voices/jamie_029c.mp3"

# game/Scenes/Jamie/jamie13.rpy:228
translate french jamie13_c042afc8:

    # gnd "I need a shower too. I smell like sex so bad."
    gnd "J’ai besoin d’une douche aussi. Je sens tellement le sexe."

# game/Scenes/Jamie/jamie13.rpy:231
translate french jamie13_dffd2cad:

    # "She jumps up out of bed, seemingly completely awake now, and starts getting dressed."
    "Elle bondit hors du lit, apparemment complètement réveillée maintenant, et commence à s’habiller."

# game/Scenes/Jamie/jamie13.rpy:232
translate french jamie13_8d3da257:

    # gnd "Seriously though, [pcname], last night was amazing."
    gnd "Sérieusement, [pcname], la nuit dernière était incroyable."

# game/Scenes/Jamie/jamie13.rpy:233
translate french jamie13_ec35244f:

    # gnd "I wish I could sleep with you every night."
    gnd "J'aimerais pouvoir coucher avec toi tous les soirs."

# game/Scenes/Jamie/jamie13.rpy:234
translate french jamie13_ef7afd6d:

    # pc "You could if you wanted."
    pc "Tu pourrais si tu le voulais."

# game/Scenes/Jamie/jamie13.rpy:235
translate french jamie13_bbd8e0f5:

    # gnd "Maybe one day."
    gnd "Peut-être un jour."

# game/Scenes/Jamie/jamie13.rpy:238
translate french jamie13_b00d8df6:

    # "I put on my pajamas and walk her down the stairs."
    "J'enfile mon pyjama et l'accompagne en bas."

# game/Scenes/Jamie/jamie13.rpy:239
translate french jamie13_9b857853:

    # "The morning light shining on her from the front windows of the house makes her seem like she's glowing."
    "La lumière du matin qui l'éclaire depuis les fenêtres de devant de la maison lui donne l'air de rayonner."

# game/Scenes/Jamie/jamie13.rpy:242
translate french jamie13_5eb86a54:

    # "We stop at the door, kissing goodbye before we open it."
    "On s'arrête à la porte, s'embrassant pour se dire au revoir avant de l'ouvrir."

# game/Scenes/Jamie/jamie13.rpy:243
translate french jamie13_9cdd394e:

    # gnd "Bye, [pcname]. We'll talk later."
    gnd "Salut, [pcname]. On se reparle plus tard."

# game/Scenes/Jamie/jamie13.rpy:244
translate french jamie13_92be29ee:

    # gnd "And hopefully do this again very soon."
    gnd "Et j'espère qu'on recommencera très bientôt."

# game/Scenes/Jamie/jamie13.rpy:245
translate french jamie13_72475059:

    # pc "I can't wait."
    pc "J'ai hâte."

# game/Scenes/Jamie/jamie13.rpy:249
translate french jamie13_7660a175:

    # "Then she turns and opens the door and her father is standing on my front porch."
    "Puis elle se retourne et ouvre la porte, et son père se tient sur mon perron."

# game/Scenes/Jamie/jamie13.rpy:251
