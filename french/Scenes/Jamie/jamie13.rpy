    # gnd "I'm sorry, but our relationship is not going to work out."
    gnd "Je suis désolée, mais notre relation ne va pas marcher."

# game/Scenes/Jamie/jamie13.rpy:289
translate french jamie13b_a2a6fb65:

    # pc "What do you mean?"
    pc "Comment ça ?"

# game/Scenes/Jamie/jamie13.rpy:291
