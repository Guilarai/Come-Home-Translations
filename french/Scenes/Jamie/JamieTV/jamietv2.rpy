# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:13
translate french jamietv2_fd039b16:

    # "I walk up to Jamie's door and knock."
    "je me dirige vers la porte de Jamie et je frappe."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:14
translate french jamietv2_fdad75c4:

    # "I wait a bit for her to answer and after a few moments, I almost walk away thinking that she isn't home or is busy or something."
    "J'attends un peu qu'elle réponde et, au bout de quelques instants, je m'apprête presque à partir en pensant qu'elle n'est pas chez elle ou qu'elle est occupée ou quelque chose comme ça."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:19
translate french jamietv2_56b288a0:

    # "Then, just when I am about to leave, she opens the door."
    "Puis, juste au moment où je m'apprête à partir, elle ouvre la porte."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:20
translate french jamietv2_348b659c:

    # gnd "Hey sorry, I must have fell asleep on the couch."
    gnd "Salut, désolée, j'ai dû m'endormir sur le canapé."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:21
translate french jamietv2_85e15039:

    # pc "Oh I'm sorry, I didn't mean to wake you. Was just wondering if you wanted to hang out?"
    pc "Oh, désolé, je ne voulais pas te réveiller. Je me demandais juste si tu voulais passer un peu de temps avec moi ?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:22
translate french jamietv2_8cddc873:

    # gnd "Sure, want to come watch TV with me?"
    gnd "Bien sûr, tu veux venir regarder la télé avec moi ?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:23
translate french jamietv2_6eafa1e5:

    # pc "Are you sure? You look pretty tired."
    pc "Tu es sûr ? Tu as l'air assez fatigué."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:24
translate french jamietv2_d5f53ad3:

    # gnd "I'm exhausted, but I'd still like to spend some time with you."
    gnd "Je suis épuisé, mais j'aimerais quand même passer un peu de temps avec toi."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:25
translate french jamietv2_35743d5e:

    # pc "Okay then."
    pc "D'accord, alors."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:26
translate french jamietv2_d6443097:

    # "We walk inside and sit down on her couch to watch TV together."
    "On entre et on s'assoit sur son canapé pour regarder la télé ensemble."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:29
translate french jamietv2_4eefcd41:

    # pc "You not been sleeping well?"
    pc "Tu dors mal ces derniers temps ?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:30
translate french jamietv2_d3a1e5f8:

    # gnd "I've just been studying a lot. It's been tough."
    gnd "J'ai juste beaucoup étudié. Ça a été dur."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:31
translate french jamietv2_6d7e76b4:

    # pc "Tell me about it."
    pc "Tu m'en diras tant."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:32
translate french jamietv2_56872787:

    # gnd "But I'm glad to spend some time with you, even if I'm sleepy."
    gnd "Mais je suis contente de passer un peu de temps avec toi, même si j'ai sommeil."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:37
translate french jamietv2_c7a75159:

    # gnd "Are you implying I'm not cute when I'm not sleepy?"
    gnd "Tu veux dire que je ne suis pas mignonne quand je n'ai pas sommeil ?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:38
translate french jamietv2_4db958a5:

    # pc "What? No."
    pc "Quoi ? Non."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:39
translate french jamietv2_cf0825c6:

    # gnd "I'm just kidding. Thanks, you're sweet."
    gnd "Je plaisante. Merci, tu es gentil."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:42
translate french jamietv2_175d3768:

    # gnd "What? Are you serious?"
    gnd "Quoi ? Tu es sérieux ?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:43
translate french jamietv2_61f77a4c:

    # pc "Sure."
    pc "Bien sûr."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:44
translate french jamietv2_f3a7bdd3:

    # gnd "That's probably not a good idea. My dad might actually kill you."
    gnd "Ce n'est probablement pas une bonne idée. Mon père pourrait vraiment te tuer."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:45
translate french jamietv2_796397b3:

    # pc "It might be worth the risk."
    pc "Ça vaut peut-être le coup de prendre le risque."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:46
translate french jamietv2_34f266ea:

    # gnd "You're crazy!"
    gnd "Tu es fou !"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:49
translate french jamietv2_d13864ee:

    # gnd "But no, let's just watch TV."
    gnd "Mais non, regardons juste la télé."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:52
translate french jamietv2_8105064d:

    # "She smiles at me and we both turn towards the TV and watch the show."
    "Elle me sourit et on se tourne tous les deux vers la télé pour regarder l’émission."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:55
translate french jamietv2_e4b4fe92:

    # "After the first commercial break, I hear her snoring softly and a moment later, she leans over and lays her head on my shoulder."
    "Après la première pause publicitaire, je l’entends ronfler doucement et, un instant plus tard, elle se penche et pose sa tête sur mon épaule."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:56
translate french jamietv2_72d126bc:

    # "I sit there like that, feeling her warm weight against me, smelling the scent of her shampoo. It's nice."
    "Je reste assis là, sentant son poids chaud contre moi, humant le parfum de son shampoing. C'est agréable."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:57
translate french jamietv2_a7276863:

    # "I watch the rest of the show, letting her sleep on my shoulder until the credits roll."
    "Je regarde le reste de l'émission, la laissant dormir sur mon épaule jusqu'au générique."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:60
translate french jamietv2_aced7ae5:

    # "The music playing during the credits wakes her and she opens her eyes and looks up at me, putting her hand on my chest."
    "La musique qui accompagne le générique la réveille ; elle ouvre les yeux, lève la tête vers moi et pose sa main sur ma poitrine."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:61
translate french jamietv2_222fe902:

    # gnd "Oh man, I missed the whole thing."
    gnd "Oh non, j'ai tout raté."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:62
translate french jamietv2_7289beae:

    # pc "Yeah, I'll have to fill you in later."
    pc "Ouais, je te raconterai tout ça plus tard."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:63
translate french jamietv2_d912edc5:

    # gnd "You could have woke me up."
    gnd "Tu aurais pu me réveiller."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:66
translate french jamietv2_fd8175bb:

    # gnd "I definitely did."
    gnd "Je l'ai fait, c'est sûr."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:68
translate french jamietv2_7b910158:

    # gnd "You're so silly."
    gnd "Tu es tellement bête."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:69
translate french jamietv2_d404c590:

    # gnd "Do you really think I'm cute?"
    gnd "Tu me trouves vraiment mignonne ?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:70
translate french jamietv2_2951ed74:

    # pc "Definitely."
    pc "Absolument."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:71
translate french jamietv2_d2d7ae9c:

    # gnd "I think you're cute too."
    gnd "Je te trouve mignonne aussi."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:72
translate french jamietv2_e8e9a7f7:

    # "Once again, her dad picks the worst moment to open the door and walk in."
    "Une fois de plus, son père choisit le pire moment pour ouvrir la porte et entrer."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:73
translate french jamietv2_9da07a83:

    # "Jamie leans away from me and stands up."
    "Jamie s’éloigne de moi et se lève."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:79
translate french jamietv2_d41d8cd9:

    # voice "voices/jamie_011.mp3"
    voice "voices/jamie_011.mp3"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:80
translate french jamietv2_25b98dfa:

    # gnd "Hey, Daddy."
    gnd "Salut, papa."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:81
translate french jamietv2_20dcad47:

    # jd "Send him home."
    jd "Renvoie-le chez lui."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:82
translate french jamietv2_f2596c67:

    # "Her dad doesn't say anything else and instead walks past us and into the kitchen."
    "Son père ne dit rien d’autre et passe devant nous pour se diriger vers la cuisine."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:86
translate french jamietv2_84d4365c:

    # gnd "He must have had a bad day."
    gnd "Il a dû passer une mauvaise journée."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:87
translate french jamietv2_b44cf649:

    # pc "I should probably go."
    pc "Je devrais probablement y aller."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:88
translate french jamietv2_a6870bf2:

    # gnd "Yeah, I'm sorry."
    gnd "Ouais, désolé."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:89
translate french jamietv2_b219d344:

    # pc "It's okay."
    pc "C'est pas grave."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:92
translate french jamietv2_36b8ae4f:

    # gnd "Thanks for coming over tonight. I had a good time."
    gnd "Merci d'être venu ce soir. J'ai passé un bon moment."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:93
translate french jamietv2_041dfd87:

    # pc "More like you had a good nap."
    pc "On dirait plutôt que tu as fait une bonne sieste."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:94
translate french jamietv2_b762e00f:

    # gnd "That too. Your shoulder is very comfy."
    gnd "Ça aussi. Ton épaule est très confortable."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:98
translate french jamietv2_4bbcc4b9:

    # gnd "I might take you up on that."
    gnd "Je vais peut-être te prendre au mot."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:100
translate french jamietv2_f9097bdf:

    # gnd "I'm sure they'll show re-runs all week."
    gnd "Je suis sûr qu'ils vont rediffuser ça toute la semaine."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:101
translate french jamietv2_dfc3c586:

    # pc "Alright, well I better head home."
    pc "Bon, je ferais mieux de rentrer chez moi."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:103
translate french jamietv2_ecb1e778:

    # gnd "Okay, [pcname]. See you again soon."
    gnd "D'accord, [pcname]. À bientôt."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:104
translate french jamietv2_209b1712:

    # pc "See ya."
    pc "À plus."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:105
translate french jamietv2_1557defd:

    # "With that, she goes back inside and I walk back over to my house."
    "Sur ce, elle rentre chez elle et je retourne chez moi."

