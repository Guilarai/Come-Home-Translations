# game/Scenes/CounselorChats/CounselorChat1.rpy:26
translate french counselorchat1_4f1ac8be:

    # sc "She's such a sweet girl."
    sc "C'est une fille tellement adorable."

# game/Scenes/CounselorChats/CounselorChat1.rpy:27
translate french counselorchat1_78209edd:

    # sc "What brings you in today, [pcname]?"
    sc "Qu'est-ce qui t'amène aujourd'hui, [pcname] ?"

# game/Scenes/CounselorChats/CounselorChat1.rpy:28
translate french counselorchat1_e969080f:

    # pc "I got your note. Thought I'd come in and chat."
    pc "J'ai reçu ton mot. J'ai pensé venir te parler."

# game/Scenes/CounselorChats/CounselorChat1.rpy:29
translate french counselorchat1_19a7f1dc:

    # sc "Oh great. I'd love to help you with whatever you have going on."
    sc "Oh super. Je serais ravie de t'aider, quel que soit ton problème."

# game/Scenes/CounselorChats/CounselorChat1.rpy:30
translate french counselorchat1_65d3a226:

    # sc "Whether you need some advice, or just somebody to listen - school or personal life, I'll be here to help you succeed."
    sc "Que tu aies besoin d'un conseil ou simplement de quelqu'un à qui parler – que ce soit pour l'école ou ta vie personnelle –, je serai là pour t'aider à t'en sortir."

# game/Scenes/CounselorChats/CounselorChat1.rpy:31
translate french counselorchat1_dbac118e:

    # sc "You can come in and visit me any time in the morning before school and talk about whatever is on your mind."
    sc "Tu peux venir me voir à tout moment le matin avant les cours et me parler de tout ce qui te préoccupe."

# game/Scenes/CounselorChats/CounselorChat1.rpy:32
translate french counselorchat1_31735f2d:

    # sc "If you're ready, you can lie down on the couch over there."
    sc "Si tu es prête, tu peux t'allonger sur le canapé là-bas."

