# game/Scenes/CounselorChats/Conversations/cc15.rpy:11
translate french cc15_67b6b093:

    # sc "Outside of work?"
    sc "En dehors du travail ?"

# game/Scenes/CounselorChats/Conversations/cc15.rpy:13
translate french cc15_7e6a5594:

    # sc "Well... I have some friends that I spend time with."
    sc "Eh bien… J’ai quelques amis avec qui je passe du temps."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:14
translate french cc15_89eb652b:

    # sc "We go out for dinner, for drinks."
    sc "On sort dîner, prendre un verre."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:16
translate french cc15_8d7798b4:

    # sc "I also enjoy going hiking sometimes."
    sc "J’aime aussi faire de la randonnée de temps en temps."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:17
translate french cc15_08dbc19e:

    # pc "Really? By yourself or with friends?"
    pc "Vraiment ? Toute seule ou avec des amis ?"

# game/Scenes/CounselorChats/Conversations/cc15.rpy:19
translate french cc15_648addea:

    # sc "Sometimes I'll go out with a friend, but most of the time I hike solo."
    sc "Parfois je sors avec un ami, mais la plupart du temps je randonne en solo."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:20
translate french cc15_4c629c48:

    # sc "It's really nice to get out in the peace and quiet and empty my mind."
    sc "C’est vraiment agréable de sortir dans le calme et la tranquillité et de me vider l’esprit."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:22
translate french cc15_bff7388b:

    # sc "I like the quiet. Sometimes I'll go out to some empty, lonely place and read a book. "
    sc "J'aime le calme. Parfois, je vais dans un endroit désert et isolé pour lire un livre."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:24
translate french cc15_afb39967:

    # sc "I love it."
    sc "J'adore ça."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:26
translate french cc15_4e788207:

    # sc "Aside from hiking, I read a lot."
    sc "À part la randonnée, je lis beaucoup."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:27
translate french cc15_1d053ca8:

    # sc "And I love gardening as well."
    sc "Et j'adore le jardinage aussi."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:29
translate french cc15_e5506e36:

    # sc "I guess that's about it. I don't do a lot outside of work."
    sc "Je crois que c'est à peu près tout. Je ne fais pas grand-chose en dehors du travail."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:30
translate french cc15_0691607a:

    # pc "It sounds like a lot to me."
    pc "Ça me semble déjà beaucoup."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:32
translate french cc15_d8bc3c33:

    # sc "Well I probably spend too much time just sitting around watching TV as well."
    sc "Eh bien, je passe probablement aussi trop de temps à rester assise à regarder la télé."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:33
translate french cc15_9e66a7d7:

    # pc "Nothing wrong with that either."
    pc "Il n'y a rien de mal à ça non plus."

# game/Scenes/CounselorChats/Conversations/cc15.rpy:36
translate french cc15_d2717b24:

    # "When our time is up, I leave her office and go to class."
    "Quand notre temps est écoulé, je quitte son bureau et je vais en cours."

