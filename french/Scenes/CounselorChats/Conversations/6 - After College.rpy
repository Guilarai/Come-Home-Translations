# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:9
translate french cc6_c75dd8a0:

    # pc "I've been thinking a lot about what I'm going to do after college."
    pc "J'ai beaucoup réfléchi à ce que je vais faire après l'université."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:10
translate french cc6_4d3932c7:

    # sc "Oh yeah? And what are your plans?"
    sc "Ah oui ? Et quels sont tes projets ?"

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:11
translate french cc6_e242eb63:

    # pc "That's the thing, I'm not sure."
    pc "C'est justement ça, je ne sais pas trop."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:12
translate french cc6_b24c2eeb:

    # pc "I'm going to college for this degree in quantum physics, but I have no idea where I'm going to work with a degree like that."
    pc "Je fais des études de physique quantique, mais je n'ai aucune idée de l'endroit où je vais pouvoir travailler avec un diplôme comme ça."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:13
translate french cc6_66ab9496:

    # pc "Originally I had planned on moving away and working in a big lab somewhere."
    pc "Au départ, j’avais prévu de partir et de travailler dans un grand laboratoire quelque part."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:14
translate french cc6_bfdd91b2:

    # pc "But now that I'm here in Skyhill, I'm kind of liking this place again."
    pc "Mais maintenant que je suis ici à Skyhill, je commence à aimer cet endroit à nouveau."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:15
translate french cc6_f025e18e:

    # sc "And now you don't want to move away?"
    sc "Et maintenant, tu ne veux plus partir ?"

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:16
translate french cc6_bc1428f9:

    # pc "Not really."
    pc "Pas vraiment."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:17
translate french cc6_fb807b53:

    # pc "Maybe I can get a job with the company my dad works for?"
    pc "Peut-être que je pourrais trouver un emploi dans l’entreprise où travaille mon père ?"

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:18
translate french cc6_070153a2:

    # sc "Maybe."
    sc "Peut-être."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:19
translate french cc6_e256d723:

    # sc "I think it's good that you're happy here."
    sc "Je trouve ça bien que tu sois heureuse ici."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:20
translate french cc6_26be0970:

    # sc "The work will come once you get your degree."
    sc "Le travail viendra tout seul une fois que tu auras ton diplôme."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:21
translate french cc6_7c65efc6:

    # sc "The main thing is that you're happy, wherever you end up."
    sc "L'essentiel, c'est que tu sois heureuse, où que tu finisses par aller."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:22
translate french cc6_4b2732e5:

    # sc "Just keep doing what makes you the most happy."
    sc "Continue simplement à faire ce qui te rend le plus heureuse."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:23
translate french cc6_f3f0b508:

    # pc "I will. Thanks, Gertrude."
    pc "Je le ferai. Merci, Gertrude."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:24
translate french cc6_92ea774c:

    # sc "That's what I'm here for."
    sc "Je suis là pour ça."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:26
translate french cc6_a8f0ee70:

    # pc "I better get to class, I guess."
    pc "Je ferais mieux d'aller en cours, je suppose."

# game/Scenes/CounselorChats/Conversations/6 - After College.rpy:27
translate french cc6_300f3cc2:

    # sc "Okay. See you next time, [pcname]."
    sc "D'accord. À la prochaine, [pcname]."

