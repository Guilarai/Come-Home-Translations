# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:12
translate french adrianq3_cf1f5239:

    # gg "Have you found anything about your dad? You know, since I helped you get into his laptop?"
    gg "Tu as trouvé quelque chose sur ton père ? Tu sais, depuis que je t'ai aidé à accéder à son ordinateur portable ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:13
translate french adrianq3_be1e6f88:

    # pc "I found a woman that he was talking to online."
    pc "J'ai découvert une femme avec qui il discutait en ligne."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:14
translate french adrianq3_35de2cbd:

    # gg "Oh yeah? Think he ran away with her?"
    gg "Ah oui ? Tu crois qu'il s'est enfui avec elle ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:15
translate french adrianq3_e1dcc124:

    # pc "No. I talked to her. It's weirder than that. You're not going to believe me."
    pc "Non. Je lui ai parlé. C'est encore plus bizarre que ça. Tu ne vas pas me croire."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:16
translate french adrianq3_14fcc814:

    # gg "Try me, I might."
    gg "Essaie, je pourrais bien."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:17
translate french adrianq3_fc396cec:

    # pc "Okay. Well, we think my father somehow opened a portal to an alternate universe and is not able to get back."
    pc "D'accord. Eh bien, on pense que mon père a en quelque sorte ouvert un portail vers un univers parallèle et qu'il n'arrive pas à revenir."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:18
translate french adrianq3_fdfdda1c:

    # gg "Uh... are you serious right now?"
    gg "Euh... tu es sérieuse ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:19
translate french adrianq3_89c41931:

    # pc "Afraid so. Told you that you wouldn't believe me."
    pc "J'en ai bien peur. Je t'avais dit que tu ne me croirais pas."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:21
translate french adrianq3_4f27f187:

    # gg "Well, it's kind of a crazy story."
    gg "Eh bien, c'est une histoire un peu folle."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:22
translate french adrianq3_95d7fa4d:

    # pc "Yeah, I know."
    pc "Oui, je sais."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:24
translate french adrianq3_8bbadd96:

    # gg "But you think it's true?"
    gg "Mais tu penses que c'est vrai ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:25
translate french adrianq3_77dc712a:

    # pc "Yeah. I think so."
    pc "Oui. Je le pense."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:26
translate french adrianq3_74ac2eb3:

    # gg "That's wild. What are you going to do?"
    gg "C'est dingue. Qu'est-ce que tu vas faire ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:27
translate french adrianq3_5636d939:

    # pc "The woman who helped him is helping me now. I'm going to follow him."
    pc "La femme qui l’a aidé m’aide maintenant. Je vais le suivre."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:28
translate french adrianq3_e570f2b2:

    # gg "But what if you get stuck there too?"
    gg "Mais et si tu te retrouves coincé là-bas toi aussi ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:29
translate french adrianq3_1c8e0c1e:

    # pc "We're trying to make sure that doesn't happen."
    pc "On essaie de faire en sorte que ça n’arrive pas."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:30
translate french adrianq3_df12f813:

    # gg "Oh, good."
    gg "Oh, tant mieux."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:32
translate french adrianq3_63d2ae71:

    # gg "Assuming all of this is true... can I come with you?"
    gg "En supposant que tout ça soit vrai… je peux venir avec toi ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:33
translate french adrianq3_b2359b7f:

    # pc "What? Really?"
    pc "Quoi ? Vraiment ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:34
translate french adrianq3_a2746834:

    # gg "Yeah. I'd love to go to another world."
    gg "Oui. J’adorerais aller dans un autre monde."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:35
translate french adrianq3_c8275080:

    # pc "But we don't even know what the world he went to is like."
    pc "Mais on ne sait même pas à quoi ressemble le monde où il est allé."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:37
translate french adrianq3_b919ac80:

    # gg "Gotta be better than this one, right?"
    gg "Ça ne peut pas être pire que celui-ci, non ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:38
translate french adrianq3_473c9b39:

    # pc "It's not that bad here, is it? You got me, your mom, your games."
    pc "C'est pas si mal ici, si ? T'as moi, ta mère, tes jeux."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:40
translate french adrianq3_56a36222:

    # gg "You're right. Sorry for being mopey. I just don't like the idea of you leaving me."
    gg "T'as raison. Désolé d'avoir été si morose. C'est juste que j'aime pas l'idée que tu me quittes."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:41
translate french adrianq3_2f3116fc:

    # pc "If everything works out, you won't even know I'm gone."
    pc "Si tout se passe bien, tu ne te rendras même pas compte que je suis parti."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:43
translate french adrianq3_1a7cf30a:

    # gg "I've seen stories like this in countless video games and movies."
    gg "J'ai vu des histoires comme ça dans d'innombrables jeux vidéo et films."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:44
translate french adrianq3_f82c5e71:

    # gg "When does everything work out?"
    gg "Quand est-ce que tout s'arrange ?"

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:45
translate french adrianq3_016ed945:

    # pc "Yeah, I guess so. Hopefully it will this time. Whitney really knows what she's doing."
    pc "Ouais, je suppose. Espérons que ce sera le cas cette fois-ci. Whitney sait vraiment ce qu'elle fait."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:47
translate french adrianq3_34aad1d1:

    # gg "I hope so. I uh... don't want to lose you."
    gg "J'espère. Je... je ne veux pas te perdre."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:48
translate french adrianq3_e3d25ce0:

    # pc "Don't worry. I don't want to lose you either."
    pc "Ne t'inquiète pas. Je ne veux pas te perdre non plus."

# game/Scenes/Adrian/AdrianConversations/adrianq3.rpy:50
translate french adrianq3_338b4311:

    # gg "Right. Let's move on to a happier conversation."
    gg "D'accord. Passons à une conversation plus joyeuse."

