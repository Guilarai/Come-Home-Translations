# game/Scenes/Lisa/lisadinner.rpy:3
translate french lisadinner_e20dd2c0:

    # "Usually Lisa would be cooking dinner here on the weekend, but she's not here."
    "D’habitude, Lisa prépare le dîner ici le week-end, mais elle n’est pas là."

# game/Scenes/Lisa/lisadinner.rpy:4
translate french lisadinner_7b04e990:

    # "I wonder if she's still upset about before?"
    "Je me demande si elle est toujours fâchée à cause de tout à l’heure ?"

# game/Scenes/Lisa/lisadinner.rpy:5
translate french lisadinner_6a8bd90c:

    # "I guess she just needs some more time."
    "Je suppose qu’elle a juste besoin d’un peu plus de temps."

# game/Scenes/Lisa/lisadinner.rpy:8
translate french lisadinner_17ebb7b6:

    # "Lisa stands in the kitchen, cooking dinner at the stove."
    "Lisa est debout dans la cuisine, en train de préparer le dîner devant la cuisinière."

# game/Scenes/Lisa/lisadinner.rpy:9
translate french lisadinner_622e58a4:

    # "She looks tired, but still turns towards me with a smile."
    "Elle a l’air fatiguée, mais elle se tourne quand même vers moi avec un sourire."

# game/Scenes/Lisa/lisadinner.rpy:12
translate french lisadinner_dbdf9d75:

    # sp "Hey honey. You joining me for dinner?"
    sp "Salut chéri. Tu te joins à moi pour le dîner ?"

# game/Scenes/Lisa/lisadinner.rpy:21
translate french lisadinner_d0417e78:

    # sp "Okay honey, let me know if you change your mind."
    sp "D'accord chéri, dis-moi si tu changes d'avis."

# game/Scenes/Lisa/lisadinner.rpy:67
translate french lisadinnerconversation_18c6396f:

    # sp "I'm glad. It gets lonely eating by myself."
    sp "Je suis contente. C'est triste de manger toute seule."

# game/Scenes/Lisa/lisadinner.rpy:69
translate french lisadinnerconversation_f7385cce:

    # "She returns to the stove and cooks us both dinner."
    "Elle retourne à la cuisinière et nous prépare le dîner à tous les deux."

# game/Scenes/Lisa/lisadinner.rpy:73
translate french lisadinnerconversation_2aba8403:

    # "Then we sit together in the dining room and have a nice conversation while eating."
    "Puis nous nous asseyons ensemble dans la salle à manger et avons une conversation agréable tout en mangeant."

# game/Scenes/Lisa/lisadinner.rpy:76
translate french lisadinnerconversation_ac9094b5:

    # "Afterwards, we go to the kitchen and I help with the dishes."
    "Après, nous allons dans la cuisine et je l'aide à faire la vaisselle."

# game/Scenes/Lisa/lisadinner.rpy:77
translate french lisadinnerconversation_74aec54b:

    # sp "Thanks for having dinner with me honey. I really enjoyed it."
    sp "Merci d’avoir dîné avec moi, chéri. J’ai vraiment apprécié."

# game/Scenes/Lisa/lisadinner.rpy:78
translate french lisadinnerconversation_6ecfecf0:

    # pc "Any time, [mom]."
    pc "Quand tu veux, [mom]."

# game/Scenes/Lisa/lisadinner.rpy:80
translate french lisadinnerconversation_79c86a4f:

    # sp "Love you, baby."
    sp "Je t’aime, bébé."

# game/Scenes/Lisa/lisadinner.rpy:81
translate french lisadinnerconversation_ce2ae2bf:

    # pc "Love you too."
    pc "Je t’aime aussi."

# game/Scenes/Lisa/lisadinner.rpy:82
translate french lisadinnerconversation_db14aa5a:

    # "We finish up and Lisa goes to her bedroom for the night."
    "Nous finissons et Lisa va se coucher dans sa chambre."

