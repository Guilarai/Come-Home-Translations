# game/Scenes/Lisa/lisabreakfast.rpy:4
translate french lisabreakfast_b90ab6dc:

    # "Lisa must have gone to work early. She didn't cook any breakfast. I guess she's still upset."
    "Lisa a dû partir travailler tôt. Elle n'a pas préparé de petit-déjeuner. Je suppose qu'elle est toujours fâchée."

# game/Scenes/Lisa/lisabreakfast.rpy:12
translate french lisabreakfast_5ba2cbf3:

    # "Lisa stands in the kitchen, cooking some eggs in a pan on the stove."
    "Lisa se tient dans la cuisine, en train de faire cuire des œufs dans une poêle sur la cuisinière."

# game/Scenes/Lisa/lisabreakfast.rpy:19
translate french lisabreakfast_d41d8cd9:

    # voice 'voices/lisa_goodmorning.wav'
    voice 'voices/lisa_goodmorning.wav'

# game/Scenes/Lisa/lisabreakfast.rpy:20
translate french lisabreakfast_09b21b2a:

    # sp "Good morning honey. Want some breakfast?"
    sp "Bonjour chéri. Tu veux un petit-déjeuner ?"

# game/Scenes/Lisa/lisabreakfast.rpy:35
translate french nottodaymom_d0417e78:

    # sp "Okay honey, let me know if you change your mind."
    sp "D'accord chéri, dis-moi si tu changes d'avis."

# game/Scenes/Lisa/lisabreakfast.rpy:45
translate french lisabreakfastconvo_c299cac3:

    # sp "I'll cook you some eggs and bacon."
    sp "Je vais te faire des œufs et du bacon."

# game/Scenes/Lisa/lisabreakfast.rpy:46
translate french lisabreakfastconvo_e45e3b16:

    # "She returns to the stove and cooks us both breakfast."
    "Elle retourne à la cuisinière et nous prépare le petit-déjeuner à tous les deux."

# game/Scenes/Lisa/lisabreakfast.rpy:49
translate french lisabreakfastconvo_2ccb9eb9:

    # "Then we sit down together and have a nice conversation while eating breakfast."
    "Puis on s'assoit ensemble et on discute agréablement tout en mangeant."

# game/Scenes/Lisa/lisabreakfast.rpy:51
translate french lisabreakfastconvo_280140a3:

    # "Afterwards, she cleans up the plates and I head upstairs and get dressed for the day."
    "Après, elle fait la vaisselle et je monte m'habiller pour la journée."

