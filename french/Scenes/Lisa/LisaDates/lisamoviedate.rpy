# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:13
translate french lisamoviedate_f71339b6:

    # sp "A movie sounds fun. I'll go get ready."
    sp "Un film, ça me dit bien. Je vais me préparer."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:18
translate french lisamoviedate_d3ea5d3b:

    # "Lisa and I drive out to the movie theater and get a seat in the back."
    "Lisa et moi, on se rend au cinéma en voiture et on s'installe au fond de la salle."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:20
translate french lisamoviedate_8ef0f6a5:

    # sp "It's been so long since I've gone to the movies. I really missed it."
    sp "Ça fait tellement longtemps que je ne suis pas allée au cinéma. Ça m'a vraiment manqué."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:21
translate french lisamoviedate_7c0dd464:

    # pc "What are we watching?"
    pc "On va voir quoi ?"

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:23
translate french lisamoviedate_06dbe416:

    # sp "Oh, it doesn't matter. I picked one that had an interesting poster. I don't even remember the name. Something about dragons."
    sp "Oh, peu importe. J'en ai choisi un dont l'affiche m'a plu. Je ne me souviens même plus du titre. Quelque chose à propos de dragons."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:24
translate french lisamoviedate_e4de1026:

    # sp "I'm just happy to be here with you, eating popcorn and watching a movie together."
    sp "Je suis juste heureuse d'être ici avec toi, à manger du pop-corn et à regarder un film ensemble."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:25
translate french lisamoviedate_025a041d:

    # sp "It's like a perfect night for me."
    sp "Pour moi, c'est une soirée parfaite."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:26
translate french lisamoviedate_3da16dc9:

    # pc "Sounds pretty great to me too, [mom]."
    pc "Ça me semble plutôt génial aussi, [mom]."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:27
translate french lisamoviedate_3196ae44:

    # "We chat for a bit before the movie starts."
    "On discute un peu avant que le film commence."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:33
translate french lisamoviedate_8de46db7:

    # "Then the theater goes dark and everybody quiets down."
    "Puis la salle s'assombrit et tout le monde se tait."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:38
translate french lisamoviedate_3e191240:

    # "We watch the movie together. It's pretty good."
    "On regarde le film ensemble. Il est plutôt bien."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:39
translate french lisamoviedate_05c28cd3:

    # "But just being here with her is the best part."
    "Mais le simple fait d'être ici avec elle, c'est ce qu'il y a de mieux."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:44
translate french lisamoviedate_fafd701d:

    # "She leans over onto my shoulder and I put my arm around her. Then she whispers."
    "Elle se penche sur mon épaule et je passe mon bras autour d'elle. Puis elle murmure."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:45
translate french lisamoviedate_46467c02:

    # sp "I love you, honey."
    sp "Je t'aime, chéri."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:46
translate french lisamoviedate_937e153c:

    # pc "I love you too."
    pc "Je t'aime aussi."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:50
translate french lisamoviedate_dc85127c:

    # "When the movie is over, she sits up and looks at me."
    "Quand le film est terminé, elle se redresse et me regarde."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:51
translate french lisamoviedate_73385641:

    # sp "Hey, that was pretty good, huh?"
    sp "Hé, c'était plutôt bien, hein ?"

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:52
translate french lisamoviedate_47637b2a:

    # pc "Yeah, it was fun."
    pc "Ouais, c'était sympa."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:53
translate french lisamoviedate_a5f32ab1:

    # sp "I gotta get out of here though. I've had to pee for the last twenty minutes."
    sp "Mais je dois y aller. J'ai envie de faire pipi depuis vingt minutes."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:54
translate french lisamoviedate_fdad4fea:

    # pc "Haha. Okay let's go."
    pc "Haha. D'accord, allons-y."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:56
translate french lisamoviedate_4080b235:

    # "We watch the movie together, enjoying each other's company."
    "Nous regardons le film ensemble, en profitant de la compagnie l'un de l'autre."

# game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:59
translate french lisamoviedate_c38b2f2c:

    # "We stop by the restroom on our way out, then go home together."
    "On passe aux toilettes en sortant, puis on rentre ensemble."

translate french strings:

    # game/Scenes/Lisa/LisaDates/lisamoviedate.rpy:6
    old "Ask her if she wants to go see a movie."
    new "Je lui demande si elle veut aller voir un film."

