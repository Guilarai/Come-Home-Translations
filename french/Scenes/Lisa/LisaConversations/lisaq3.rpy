# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:68
translate french lisaq3_6caccc38:

    # sp "You're so smart. You could do anything you want to do."
    sp "Tu es si intelligent. Tu pourrais faire tout ce que tu veux."

# game/Scenes/Lisa/LisaConversations/lisaq3.rpy:70
