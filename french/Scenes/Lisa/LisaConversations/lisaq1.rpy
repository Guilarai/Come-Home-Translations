# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:13
translate french lisaq1_add20cbe:

    # sp "So... how long has this thing with Suzy been going on?"
    sp "Alors... depuis combien de temps ça dure avec Suzy ?"

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:14
translate french lisaq1_9af8bccc:

    # pc "Oh um... not very long."
    pc "Oh euh... pas très longtemps."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:15
translate french lisaq1_8d463b4f:

    # pc "Things have just been different between us since I came back."
    pc "Les choses ont juste changé entre nous depuis que je suis revenu."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:17
translate french lisaq1_924a8187:

    # sp "Yeah, I can see that."
    sp "Oui, je vois ça."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:18
translate french lisaq1_71469425:

    # pc "I'm sorry I didn't tell you."
    pc "Je suis désolé de ne pas te l'avoir dit."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:20
translate french lisaq1_5591a8c6:

    # sp "I can understand why you didn't."
    sp "Je comprends pourquoi tu ne l'as pas fait."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:21
translate french lisaq1_8a4bd704:

    # sp "If I would have known that you were with her, I never would have done anything with you."
    sp "Si j'avais su que tu étais avec elle, je n'aurais jamais rien eu avec toi."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:23
translate french lisaq1_ede4bd3d:

    # sp "And now that I have these feelings for you, it puts me in a really awkward position."
    sp "Et maintenant que j'ai ces sentiments pour toi, ça me met dans une situation vraiment délicate."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:24
translate french lisaq1_609a2247:

    # pc "I know. I'm sorry."
    pc "Je sais. Je suis désolé."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:26
translate french lisaq1_1bac2538:

    # sp "No more apologizing. I get it."
    sp "Arrête de t'excuser. Je comprends."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:27
translate french lisaq1_8cb15e0b:

    # sp "It is what it is. We can't put that genie back in the bottle."
    sp "C'est comme ça. On ne peut pas remettre le génie dans la bouteille."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:29
translate french lisaq1_fe8d5ccd:

    # sp "Just don't break her heart, okay?"
    sp "Mais ne lui brise pas le cœur, d'accord ?"

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:30
translate french lisaq1_ce87c02f:

    # pc "I know. I don't want that to happen either."
    pc "Je sais. Je ne veux pas que ça arrive non plus."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:31
translate french lisaq1_a49b57ce:

    # pc "Everything just got so messy."
    pc "Tout est devenu tellement compliqué."

# game/Scenes/Lisa/LisaConversations/lisaq1.rpy:33
translate french lisaq1_067ebb87:

    # sp "Love always does."
    sp "C'est toujours comme ça avec l'amour."

translate french strings:

    # game/Scenes/Lisa/LisaConversations/lisaq1.rpy:2
    old "To have this conversation, you have to progress with Suzy as well, until Suzy catches you with her mom."
    new "Pour avoir cette conversation, tu dois aussi faire avancer les choses avec Suzy, jusqu'à ce que Suzy te surprenne avec sa mère."

