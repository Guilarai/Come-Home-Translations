    # pc "What's your biggest fear?"
    pc "Quelle est ta plus grande peur ?"

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:14
translate french lisasurface3_0c2d2f79:

    # sp "Hm."
    sp "Hum."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:15
translate french lisasurface3_4dd00fa8:

    # sp "I guess that something bad will happen to the people I love."
    sp "Je suppose que quelque chose de grave arrive aux gens que j'aime."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:16
translate french lisasurface3_af724a2a:

    # sp "Suzy, you, your father."
    sp "Suzy, toi, ton père."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:17
translate french lisasurface3_7b391ae8:

    # sp "Losing you all scares me more than anything."
    sp "Vous perdre tous me fait plus peur que tout."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:19
translate french lisasurface3_f8fdcbd9:

    # sp "That's why I've been feeling so awful since your father disappeared. I need to know where he is."
    sp "C'est pour ça que je me sens si mal depuis que ton père a disparu. J'ai besoin de savoir où il est."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:20
translate french lisasurface3_107f9102:

    # pc "We'll find him."
    pc "On va le retrouver."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:22
translate french lisasurface3_d3457ab3:

    # sp "I hope so."
    sp "J'espère bien."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:23
translate french lisasurface3_56728b9e:

    # sp "That got a little too heavy, huh?"
    sp "Ça devient un peu trop grave, hein ?"

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:24
translate french lisasurface3_b8aa611b:

    # sp "I should have said something simple, like rats."
    sp "J'aurais dû dire quelque chose de simple, comme les rats."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:25
translate french lisasurface3_c516b7ed:

    # sp "I am scared of rats. I hate the little things."
    sp "J'ai peur des rats. Je déteste ces petites bestioles."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:26
translate french lisasurface3_75f05bcb:

    # pc "Aw they're not too bad. Kind of cute really."
    pc "Oh, ils ne sont pas si terribles. Ils sont plutôt mignons, en fait."

# game/Scenes/Lisa/LisaConversations/lisasurface3.rpy:28
translate french lisasurface3_f9c97e6f:

    # sp "No. No rats. They're gross and awful with their little teeth and long wriggly tails. Yuck."
    sp "Non. Pas les rats. Ils sont dégoûtants et horribles avec leurs petites dents et leurs longues queues frétillantes. Beurk."

