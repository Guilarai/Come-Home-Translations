    sp "Et ton père et moi, on en a d'ailleurs vu un il y a quelques années."

# game/Scenes/Lisa/LisaConversations/lisas9.rpy:17
translate french lisas9_4d42df9a:

    # pc "Really? I didn't know that."
    pc "Vraiment ? Je ne savais pas ça."

