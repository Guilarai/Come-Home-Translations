# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Micha/micha10.rpy:15
translate french micha10_53d7eff6:

    # "She gets in my car and we drive back towards the school and park near the dorms."
    "Elle monte dans ma voiture et on retourne vers l'école pour se garer près des dortoirs."

# game/Scenes/Micha/micha10.rpy:18
translate french micha10_0ba0ce57:

    # mc "Would you walk to my dorm with me?"
    mc "Tu veux bien m'accompagner jusqu'à mon dortoir ?"

# game/Scenes/Micha/micha10.rpy:19
translate french micha10_61f77a4c:

    # pc "Sure."
    pc "Bien sûr."

# game/Scenes/Micha/micha10.rpy:26
translate french micha10_fc5b71e7:

    # "We walk through the school courtyard, towards her dorm building."
    "On traverse la cour de l'école, en direction de son dortoir."

# game/Scenes/Micha/micha10.rpy:27
translate french micha10_9c8bddba:

    # "The night air is cool, and the school is surprisingly peaceful and quiet."
    "L'air nocturne est frais, et l'école est étonnamment paisible et calme."

# game/Scenes/Micha/micha10.rpy:34
translate french micha10_8f3659cb:

    # "She glances over at me and then slides her hand into mine."
    "Elle me jette un coup d'œil, puis glisse sa main dans la mienne."

# game/Scenes/Micha/micha10.rpy:35
translate french micha10_b17081d9:

    # "Her hand is cold and small and soft. I hold it gently as we continue walking."
    "Sa main est froide, petite et douce. Je la tiens délicatement tandis que nous continuons à marcher."

# game/Scenes/Micha/micha10.rpy:42
translate french micha10_9207436c:

    # mc "Would you maybe want to sit and chat for a while before I go inside?"
    mc "Tu voudrais peut-être t'asseoir et discuter un moment avant que je rentre ?"

# game/Scenes/Micha/micha10.rpy:43
translate french micha10_8fefe090:

    # mc "I had such a good time with you today. I am not quite ready for it to end."
    mc "J'ai passé un si bon moment avec toi aujourd'hui. Je ne suis pas tout à fait prête à ce que ça se termine."

# game/Scenes/Micha/micha10.rpy:44
translate french micha10_4476e592:

    # pc "Sure, we can do that."
    pc "Bien sûr, on peut faire ça."

# game/Scenes/Micha/micha10.rpy:51
translate french micha10_d96ba613:

    # "We sit on the bench together, her hand still enveloped in mine."
    "Nous nous asseyons ensemble sur le banc, sa main toujours enveloppée dans la mienne."

# game/Scenes/Micha/micha10.rpy:52
translate french micha10_5e2207f4:

    # "I wonder what she would want to talk about? She barely talks about anything at all."
    "Je me demande de quoi elle voudrait parler ? Elle ne parle presque jamais de rien."

# game/Scenes/Micha/micha10.rpy:59
translate french micha10_5ec89b3b:

    # mc "I like it here."
    mc "J’aime bien cet endroit."

# game/Scenes/Micha/micha10.rpy:60
translate french micha10_00ff76ff:

    # pc "Yeah, the fresh air feels really nice. And the trees are pretty."
    pc "Oui, l’air frais est vraiment agréable. Et les arbres sont jolis."

# game/Scenes/Micha/micha10.rpy:61
translate french micha10_277d368d:

    # mc "No. I meant I like it here... in America."
    mc "Non. Je voulais dire que j’aime bien cet endroit… ici, en Amérique."

# game/Scenes/Micha/micha10.rpy:62
translate french micha10_193e6392:

    # mc "I wish that I could stay."
    mc "J’aimerais pouvoir rester."

# game/Scenes/Micha/micha10.rpy:69
translate french micha10_4354fa16:

    # pc "What do you mean? You have to go back to Korea?"
    pc "Comment ça ? Tu dois retourner en Corée ?"

# game/Scenes/Micha/micha10.rpy:71
translate french micha10_d41d8cd9:

    # voice 'voices/micha_yes2.mp3'
    voice 'voices/micha_yes2.mp3'

# game/Scenes/Micha/micha10.rpy:72
translate french micha10_b63541c5:

    # mc "Yes. I have to return and become married after I finish this semester."
    mc "Oui. Je dois rentrer et me marier après avoir terminé ce semestre."

# game/Scenes/Micha/micha10.rpy:73
translate french micha10_1ae5f5f0:

    # pc "What? Why?"
    pc "Quoi ? Pourquoi ?"

# game/Scenes/Micha/micha10.rpy:74
translate french micha10_97c2ea57:

    # mc "My parents have arranged it. They have chosen a man. I will become his wife when I return."
    mc "Mes parents ont tout arrangé. Ils ont choisi un homme. Je deviendrai sa femme à mon retour."

# game/Scenes/Micha/micha10.rpy:75
translate french micha10_29f911d6:

    # pc "Is that what you want? Do you even like him?"
    pc "C’est ce que tu veux ? Tu l’aimes bien, au moins ?"

# game/Scenes/Micha/micha10.rpy:76
translate french micha10_e1f07ca9:

    # mc "I have never met him. I am sure that he is nice though. My parents chose him."
    mc "Je ne l’ai jamais rencontré. Mais je suis sûre qu’il est gentil. Ce sont mes parents qui l’ont choisi."

# game/Scenes/Micha/micha10.rpy:77
translate french micha10_51e20623:

    # pc "You want that though?"
    pc "Mais c’est ce que tu veux ?"

# game/Scenes/Micha/micha10.rpy:78
translate french micha10_4989970d:

    # mc "I want to be a wife, yes. But I do like it here."
    mc "Je veux être une épouse, oui. Mais j’aime bien être ici."

# game/Scenes/Micha/micha10.rpy:79
translate french micha10_22cefe33:

    # pc "Why don't you just stay then? Why don't you tell your parents no, and stay here?"
    pc "Pourquoi ne restes-tu pas, alors ? Pourquoi ne dis-tu pas non à tes parents et ne restes-tu pas ici ?"

# game/Scenes/Micha/micha10.rpy:86
translate french micha10_d64f1fa7:

    # mc "It does not work that way."
    mc "Ça ne marche pas comme ça."

# game/Scenes/Micha/micha10.rpy:89
translate french micha10_14baa1d2:

    # mc "I really like you too, [pcname]."
    mc "Je t’aime bien aussi, [pcname]."

# game/Scenes/Micha/micha10.rpy:91
translate french micha10_24676458:

    # mc "Yes, I guess so."
    mc "Oui, je suppose."

# game/Scenes/Micha/micha10.rpy:98
translate french micha10_52765170:

    # "We grow silent again, looking up at the stars."
    "Nous nous taisons à nouveau, en regardant les étoiles."

# game/Scenes/Micha/micha10.rpy:99
translate french micha10_9e978195:

    # "She has to go back to Korea after this semester. I doubt I would see her again."
    "Elle doit retourner en Corée après ce semestre. Je doute que je la revoie un jour."

# game/Scenes/Micha/micha10.rpy:100
translate french micha10_494d2b9e:

    # "I can't help but feel really sad about that."
    "Je ne peux m’empêcher d’être vraiment triste à cette idée."

# game/Scenes/Micha/micha10.rpy:107
translate french micha10_06878b88:

    # "As we're watching the sky, a shooting star flies past. She gasps."
    "Alors que nous regardons le ciel, une étoile filante passe. Elle pousse un cri de surprise."

# game/Scenes/Micha/micha10.rpy:108
translate french micha10_05fba3d4:

    # mc "Oh! It's so beautiful."
    mc "Oh ! C’est tellement beau."

# game/Scenes/Micha/micha10.rpy:109
translate french micha10_013ea0ef:

    # pc "You should make a wish."
    pc "Tu devrais faire un vœu."

# game/Scenes/Micha/micha10.rpy:110
translate french micha10_9d8e700d:

    # mc "A wish?"
    mc "Un vœu ?"

# game/Scenes/Micha/micha10.rpy:111
translate french micha10_10994647:

    # pc "Yeah, when you see a shooting star, you make a wish and it might come true."
    pc "Oui, quand tu vois une étoile filante, tu fais un vœu et il pourrait se réaliser."

# game/Scenes/Micha/micha10.rpy:118
translate french micha10_74c726d2:

    # "She looks at me and speaks in a low, shy voice."
    "Elle me regarde et parle d’une voix basse et timide."

# game/Scenes/Micha/micha10.rpy:120
translate french micha10_d41d8cd9_1:

    # voice 'voices/micha_10_1.mp3'
    voice 'voices/micha_10_1.mp3'

# game/Scenes/Micha/micha10.rpy:121
translate french micha10_c0a252cf:

    # mc "I wish you would kiss me."
    mc "Je souhaite que tu m’embrasses."

# game/Scenes/Micha/micha10.rpy:122
translate french micha10_2b10aa09:

    # pc "Oh. Well you're not supposed to tell anybody, or it won't happen."
    pc "Oh. Eh bien, tu n’es pas censée le dire à personne, sinon ça ne se réalisera pas."

# game/Scenes/Micha/micha10.rpy:123
translate french micha10_23b76a7a:

    # mc "Oh... I did not know that."
    mc "Oh… Je ne savais pas ça."

# game/Scenes/Micha/micha10.rpy:139
translate french micha10kiss_4cdfc044:

    # "I lean in and kiss her."
    "Je me penche vers elle et l’embrasse."

# game/Scenes/Micha/micha10.rpy:140
translate french micha10kiss_ca40b1c0:

    # pc "It's just dumb superstition anyway."
    pc "C’est juste une superstition idiote de toute façon."

# game/Scenes/Micha/micha10.rpy:141
translate french micha10kiss_39894277:

    # "At first, she is stiff, not moving at all as I kiss her lips. It's like kissing a mannequin."
    "Au début, elle est raide, immobile tandis que j’embrasse ses lèvres. C’est comme embrasser un mannequin."

# game/Scenes/Micha/micha10.rpy:154
translate french micha10kiss_4319b810:

    # "But then I feel her body loosen, she puts her hand on my arm and leans in further, her lips moving against mine, breath coming quicker."
    "Mais ensuite, je sens son corps se détendre, elle pose sa main sur mon bras et se penche davantage, ses lèvres se pressant contre les miennes, sa respiration s'accélérant."

# game/Scenes/Micha/micha10.rpy:155
translate french micha10kiss_b9bbd6df:

    # "We kiss like that, under the stars, until the moment turns into minutes, and time seems to float away on the cool night breeze."
    "Nous nous embrassons ainsi, sous les étoiles, jusqu’à ce que l’instant se transforme en minutes, et que le temps semble s’envoler dans la brise fraîche de la nuit."

# game/Scenes/Micha/micha10.rpy:167
translate french micha10kiss_a2abceb1:

    # "I have no idea how much time has passed when she finally, reluctantly, pulls away."
    "Je n’ai aucune idée du temps qui s’est écoulé lorsqu’elle s’écarte enfin, à contrecœur."

# game/Scenes/Micha/micha10.rpy:168
translate french micha10kiss_e9b48769:

    # mc "I should go."
    mc "Je devrais y aller."

# game/Scenes/Micha/micha10.rpy:169
translate french micha10kiss_7cf89165:

    # pc "You have to?"
    pc "Tu dois vraiment ?"

# game/Scenes/Micha/micha10.rpy:170
translate french micha10kiss_1145978d:

    # mc "Yes, I apologize."
    mc "Oui, je m'excuse."

# game/Scenes/Micha/micha10.rpy:173
translate french micha10kiss_d89f8402:

    # pc "I should probably go home."
    pc "Je devrais probablement rentrer chez moi."

# game/Scenes/Micha/micha10.rpy:174
translate french micha10kiss_2148e939:

    # mc "Okay. Me too then."
    mc "D'accord. Moi aussi, alors."

# game/Scenes/Micha/micha10.rpy:186
translate french micha10kiss_53fd2d63:

    # mc "I had a very good time tonight, [pcname]. Thank you."
    mc "J'ai passé un très bon moment ce soir, [pcname]. Merci."

# game/Scenes/Micha/micha10.rpy:187
translate french micha10kiss_445c1419:

    # pc "I'm glad. I did too."
    pc "Je suis content. Moi aussi."

# game/Scenes/Micha/micha10.rpy:188
translate french micha10kiss_7aea7a63:

    # mc "I hope we can do this again soon."
    mc "J'espère qu'on pourra recommencer bientôt."

# game/Scenes/Micha/micha10.rpy:190
translate french micha10kiss_d41d8cd9:

    # voice 'voices/micha_goodnight1.mp3'
    voice 'voices/micha_goodnight1.mp3'

# game/Scenes/Micha/micha10.rpy:191
translate french micha10kiss_9b0423ef:

    # mc "Good night."
    mc "Bonne nuit."

# game/Scenes/Micha/micha10.rpy:192
translate french micha10kiss_c2ed5d6f:

    # pc "Good night, Mi-Cha."
    pc "Bonne nuit, Mi-Cha."

# game/Scenes/Micha/micha10.rpy:195
translate french micha10kiss_17735f99:

    # "With that, she goes inside of her dorm building and I walk back to my car and drive away."
    "Sur ces mots, elle rentre dans son dortoir et je retourne à ma voiture pour partir."

# game/Scenes/Micha/micha10.rpy:196
translate french micha10kiss_de8a7413:

    # "Maybe Mi-Cha and I will only get the rest of the semester together, but we'll be sure to make it count."
    "Peut-être que Mi-Cha et moi ne passerons ensemble que le reste du semestre, mais on va s’assurer d’en profiter pleinement."

translate french strings:

    # game/Scenes/Micha/micha10.rpy:3
    old "Take Mi-Cha on more dates by calling her in the evening. Eventually she will ask you to walk her back to her dorm after one."
    new "Invite Mi-Cha à d’autres rendez-vous en l’appelant le soir. À un moment donné, elle te demandera de la raccompagner à sa résidence après minuit."

    # game/Scenes/Micha/micha10.rpy:4
    old "Take your opportunity and kiss her when the moment arises."
    new "Saisis ta chance et embrasse-la quand l’occasion se présentera."

    # game/Scenes/Micha/micha10.rpy:88
    old "That sucks, because I really like you"
    new "C’est dommage, parce que je t’aime vraiment bien"

    # game/Scenes/Micha/micha10.rpy:90
    old "I guess we're just temporary friends then, huh?"
    new "Je suppose qu’on est juste des amis de passage, alors ?"

    # game/Scenes/Micha/micha10.rpy:172
    old "Tell her good night"
    new "Dis-lui bonne nuit."

