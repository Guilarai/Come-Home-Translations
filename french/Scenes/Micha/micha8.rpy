# game/Scenes/Micha/micha8.rpy:14
translate french micha8_5f9760c9:

    # "Before I go to Gertrude's office, Mi-Cha stops me in the lobby."
    "Avant que j’aille au bureau de Gertrude, Mi-Cha m’arrête dans le hall."

# game/Scenes/Micha/micha8.rpy:15
translate french micha8_ed6bde86:

    # mc "Hello, [pcname]."
    mc "Bonjour, [pcname]."

# game/Scenes/Micha/micha8.rpy:16
translate french micha8_f481dcaa:

    # pc "Hi, Mi-Cha. How are you?"
    pc "Salut, Mi-Cha. Comment vas-tu ?"

# game/Scenes/Micha/micha8.rpy:17
translate french micha8_72cb11f5:

    # mc "I am good, thank you."
    mc "Je vais bien, merci."

# game/Scenes/Micha/micha8.rpy:19
translate french micha8_bdbd1fa8:

    # mc "I want to tell you that I enjoyed our coffee date."
    mc "Je voulais te dire que j'ai apprécié notre rendez-vous autour d'un café."

# game/Scenes/Micha/micha8.rpy:20
translate french micha8_8a7120da:

    # mc "I apologize for rushing off early and would like to again another sometime."
    mc "Je m'excuse d'être partie si vite et j'aimerais bien recommencer un de ces jours."

# game/Scenes/Micha/micha8.rpy:21
translate french micha8_3171636b:

    # mc "If you would like to this evening?"
    mc "Si ça te dit ce soir ?"

# game/Scenes/Micha/micha8.rpy:25
translate french micha8_2d186b97:

    # mc "Good. I will meet you in the Skyhill Cafe this evening then."
    mc "Parfait. Je te retrouve au Skyhill Café ce soir alors."

# game/Scenes/Micha/micha8.rpy:29
translate french micha8_2f88594e:

    # mc "Oh. Okay. Yes, I'm sure you're busy."
    mc "Oh. D'accord. Oui, je suis sûre que tu es occupée."

# game/Scenes/Micha/micha8.rpy:31
translate french micha8_08d0510d:

    # mc "Enjoy your visit with Mrs. Spann."
    mc "Passe un bon moment avec Mme Spann."

# game/Scenes/Micha/micha8.rpy:32
translate french micha8_32a03447:

    # pc "Okay. I'll see you later, Mi-Cha."
    pc "D'accord. À tout à l'heure, Mi-Cha."

translate french strings:

    # game/Scenes/Micha/micha8.rpy:2
    old "After your first date with Mi-Cha, go talk to her in the counselor's lobby on a weekday morning."
    new "Après ton premier rendez-vous avec Mi-Cha, va lui parler dans le hall du conseiller un matin en semaine."

    # game/Scenes/Micha/micha8.rpy:3
    old "She will want to go on another date with you."
    new "Elle voudra sortir à nouveau avec toi."

    # game/Scenes/Micha/micha8.rpy:27
    old "Maybe some other night"
    new "Peut-être un autre soir"

