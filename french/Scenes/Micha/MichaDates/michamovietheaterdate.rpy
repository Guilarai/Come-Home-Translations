# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:24
translate french michamovietheaterstartdate_929c1af5:

    # "I head over to the movie theater to meet Mi-Cha."
    "Je me rends au cinéma pour retrouver Mi-Cha."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:27
translate french michamovietheaterstartdate_53aa213e:

    # "I meet Mi-Cha in the movie theater parking lot."
    "Je retrouve Mi-Cha sur le parking du cinéma."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:29
translate french michamovietheaterstartdate_1696084c:

    # pc "You look very cute."
    pc "Tu es vraiment mignonne."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:32
translate french michamovietheaterstartdate_d41d8cd9:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:33
translate french michamovietheaterstartdate_bb0eeaf4:

    # mc "Thank you."
    mc "Merci."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:34
translate french michamovietheaterstartdate_17670cf3:

    # mc "You look nice also."
    mc "Toi aussi, tu es très bien."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:37
translate french michamovietheaterstartdate_88edd4ad:

    # "Then we go inside and sit in the back."
    "Puis on entre et on s'assoit tout au fond."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:39
translate french michamovietheaterstartdate_90b2b501:

    # "She's so quiet. I should try to start up a conversation."
    "Elle est tellement silencieuse. Je devrais essayer d'engager la conversation."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:44
translate french michamovietheaterstartdate_56f38f5f:

    # "The movie starts and we go quiet."
    "Le film commence et on se tait."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:45
translate french michamovietheaterstartdate_0a855fcc:

    # "Throughout the movie, it feels like she starts to relax some."
    "Au fil du film, j'ai l'impression qu'elle commence à se détendre un peu."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:47
translate french michamovietheaterstartdate_914a9aa2:

    # "It's a fun movie and she's nice company, if a little quiet."
    "C'est un film sympa et elle est de bonne compagnie, même si elle est un peu réservée."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:49
translate french michamovietheaterstartdate_0edfdae0:

    # "When it ends, she turns to me."
    "À la fin, elle se tourne vers moi."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:51
translate french michamovietheaterstartdate_bab5119d:

    # mc "Did you like the movie?"
    mc "Tu as aimé le film ?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:52
translate french michamovietheaterstartdate_f4477343:

    # pc "Yeah I enjoyed it."
    pc "Oui, je l'ai bien aimé."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:53
translate french michamovietheaterstartdate_e4993620:

    # mc "Me too. I thought it was very good."
    mc "Moi aussi. Je l'ai trouvé très bien."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:54
translate french michamovietheaterstartdate_365db8f9:

    # "We hang out during the credits and chat a little bit more."
    "On reste là pendant le générique et on discute encore un peu."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:59
translate french michamovietheaterstartdate_63e18d0b:

    # "When the credits end, we go outside to the parking lot and stand near her car."
    "Quand le générique se termine, on sort sur le parking et on se tient près de sa voiture."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:60
translate french michamovietheaterstartdate_725fffe9:

    # mc "I had a very good time. Thank you for taking me."
    mc "J'ai passé un très bon moment. Merci de m'avoir emmenée."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:61
translate french michamovietheaterstartdate_07c9c5ab:

    # pc "You're welcome."
    pc "De rien."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:65
translate french michamovietheaterstartdate_5f014a7b:

    # "She rushes up to me, leans up and gives me a tiny peck of a kiss on the mouth, our lips barely touching."
    "Elle se précipite vers moi, se penche et me donne un tout petit baiser sur la bouche, nos lèvres se touchant à peine."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:67
translate french michamovietheaterstartdate_5ac477c2:

    # "Then she pulls back once again."
    "Puis elle s’écarte à nouveau."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:68
translate french michamovietheaterstartdate_50afc9a0:

    # mc "Okay goodbye, [pcname]."
    mc "Bon, au revoir, [pcname]."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:70
translate french michamovietheaterstartdate_0488daa1:

    # "And before I can say anything in response, she rushes to her car, starts it up, and drives away."
    "Et avant que je puisse répondre quoi que ce soit, elle se précipite vers sa voiture, démarre et s’en va."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:72
translate french michamovietheaterstartdate_6cbf222e:

    # "Well, I guess we're making some progress at least?"
    "Bon, je suppose qu’on fait au moins quelques progrès ?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:78
translate french michamovietheaterstartdate_2674be8c:

    # mc "Would you mind taking me back to my dorm?"
    mc "Ça te dérangerait de me ramener à ma résidence universitaire ?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:79
translate french michamovietheaterstartdate_a274c9a4:

    # pc "Of course not."
    pc "Bien sûr que non."

