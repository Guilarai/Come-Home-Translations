# game/Scenes/Micha/MichaDates/michabeachdate.rpy:29
translate french michabeachdate_314e52b7:

    # mc "Is my swimsuit really okay?"
    mc "Mon maillot de bain va vraiment bien ?"

# game/Scenes/Micha/MichaDates/michabeachdate.rpy:30
translate french michabeachdate_714c0cf0:

    # pc "It's more than okay. It's incredibly sexy."
    pc "Il est plus que bien. Il est incroyablement sexy."

# game/Scenes/Micha/MichaDates/michabeachdate.rpy:31
translate french michabeachdate_d355b065:

    # mc "I want to be sexy for you."
    mc "Je veux être sexy pour toi."

# game/Scenes/Micha/MichaDates/michabeachdate.rpy:34
translate french michabeachdate_93419ef3:

    # "We spend some time swimming around and chatting."
    "On passe un moment à nager et à discuter."

# game/Scenes/Micha/MichaDates/michabeachdate.rpy:37
translate french michabeachdate_b0c8b01b:

    # "We spend a little longer making out, her crotch grinding against mine."
