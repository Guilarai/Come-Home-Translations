# game/Scenes/Micha/MichaDates/michabeachdate.rpy:18
translate french michabeachdate_a5a32f2f:

    # pc "Are you excited about the beach?"
    pc "Tu es impatiente d’aller à la plage ?"

# game/Scenes/Micha/MichaDates/michabeachdate.rpy:19
translate french michabeachdate_d1ab0aa5:

    # mc "Excited, yes. Nervous too."
