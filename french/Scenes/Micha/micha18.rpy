# game/Scenes/Micha/micha18.rpy:15
translate french micha18_688d0c7f:

    # "My phone starts buzzing in my pocket. I check and see that Mi-Cha is calling."
    "Mon téléphone se met à vibrer dans ma poche. Je vérifie et je vois que c’est Mi-Cha qui m’appelle."

# game/Scenes/Micha/micha18.rpy:20
translate french micha18_3f3890ee:

    # pc "Hey, Mi-Cha. How are you doing?"
    pc "Salut, Mi-Cha. Comment ça va ?"

# game/Scenes/Micha/micha18.rpy:21
translate french micha18_871ef5af:

    # mc "I am feeling very nervous, but also excited."
    mc "Je me sens très nerveuse, mais aussi excitée."

# game/Scenes/Micha/micha18.rpy:22
translate french micha18_e61255db:

    # pc "About what?"
    pc "À propos de quoi ?"

# game/Scenes/Micha/micha18.rpy:24
translate french micha18_0366f1bc:

    # mc "My dance performance is tonight. Will you come?"
    mc "Mon spectacle de danse a lieu ce soir. Tu viendras ?"

# game/Scenes/Micha/micha18.rpy:25
translate french micha18_33cc462a:

    # pc "What? Of course! Why didn't you tell me already? I didn't know it was tonight!"
    pc "Quoi ? Bien sûr ! Pourquoi tu ne me l'as pas déjà dit ? Je ne savais pas que c'était ce soir !"

# game/Scenes/Micha/micha18.rpy:27
translate french micha18_b360fd8d:

    # mc "I'm sorry, [mcsir]."
    mc "Je suis désolée, [mcsir]."

# game/Scenes/Micha/micha18.rpy:28
translate french micha18_c2363c70:

    # mc "I have been shy to talk about it."
    mc "J'avais honte d'en parler."

# game/Scenes/Micha/micha18.rpy:30
translate french micha18_a4fac60b:

    # mc "It is only a small performance. Nothing to get excited about."
    mc "Ce n'est qu'un petit spectacle. Il n'y a pas de quoi s'exciter."

# game/Scenes/Micha/micha18.rpy:32
translate french micha18_0bb075ff:

    # pc "That's nonsense! You should be excited about it!"
    pc "C'est n'importe quoi ! Tu devrais être excitée !"

# game/Scenes/Micha/micha18.rpy:33
translate french micha18_16694b2f:

    # pc "I'm really happy for you and I'll be in the audience supporting you."
    pc "Je suis vraiment contente pour toi et je serai dans le public pour t'encourager."

# game/Scenes/Micha/micha18.rpy:35
translate french micha18_7c591fc4:

    # mc "Okay. I am happy that you will be there."
    mc "D'accord. Je suis contente que tu sois là."

# game/Scenes/Micha/micha18.rpy:36
translate french micha18_5f7f4323:

    # mc "It is at 7pm on the school's stage."
    mc "C'est à 19 h sur la scène de l'école."

# game/Scenes/Micha/micha18.rpy:37
translate french micha18_9d74725b:

    # pc "I'll be there. As close as I can get to the front row."
    pc "Je serai là. Aussi près que possible du premier rang."

# game/Scenes/Micha/micha18.rpy:39
translate french micha18_02124621:

    # mc "Thank you, [pcname]. I will see you there."
    mc "Merci, [pcname]. On se voit là-bas."

# game/Scenes/Micha/micha18.rpy:42
translate french micha18_25a2f290:

    # "We say our goodbyes, then later that evening, I drive to the school to watch her performance."
    "On se dit au revoir, puis plus tard dans la soirée, je me rends en voiture à l'école pour assister à son spectacle."

# game/Scenes/Micha/micha18.rpy:45
translate french micha18_ebb5885b:

    # "I show up a little early and am able to get a front row seat. There's a few other people in the audience, but it's pretty empty."
    "J'arrive un peu en avance et j'arrive à avoir une place au premier rang. Il y a quelques autres personnes dans le public, mais la salle est plutôt vide."

# game/Scenes/Micha/micha18.rpy:48
translate french micha18_9b44beaa:

    # "A few minutes later, Gertrude comes in and smiles at me."
    "Quelques minutes plus tard, Gertrude entre et me sourit."

# game/Scenes/Micha/micha18.rpy:49
translate french micha18_734ac2ed:

    # sc "Hey, [pcname]. I didn't expect to see you here. I've never seen you at any of the other performances."
    sc "Salut, [pcname]. Je ne m'attendais pas à te voir ici. Je ne t'ai jamais vu à aucun des autres spectacles."

# game/Scenes/Micha/micha18.rpy:50
translate french micha18_c2b482c4:

    # pc "Oh, I'm here to support Mi-Cha."
    pc "Oh, je suis venue soutenir Mi-Cha."

# game/Scenes/Micha/micha18.rpy:51
translate french micha18_6fc91d73:

    # sc "That's nice of you. I'm looking forward to seeing her perform."
    sc "C'est sympa de ta part. J'ai hâte de la voir sur scène."

# game/Scenes/Micha/micha18.rpy:52
translate french micha18_0d7c2170:

    # sc "Do you mind if I sit next to you?"
    sc "Ça te dérange si je m'assois à côté de toi ?"

# game/Scenes/Micha/micha18.rpy:53
translate french micha18_6912ead3:

    # pc "Not at all."
    pc "Pas du tout."

# game/Scenes/Micha/micha18.rpy:57
translate french micha18_618925b1:

    # sc "So are you two dating now?"
    sc "Alors, vous sortez ensemble maintenant ?"

# game/Scenes/Micha/micha18.rpy:58
translate french micha18_f78d20fe:

    # pc "Yeah, we've been seeing each other a bit."
    pc "Ouais, on se voit un peu."

# game/Scenes/Micha/micha18.rpy:59
translate french micha18_5ab35b8c:

    # sc "That's great!"
    sc "C'est génial !"

# game/Scenes/Micha/micha18.rpy:60
translate french micha18_a0b30b82:

    # sc "How serious is it between you two?"
    sc "C'est sérieux entre vous deux ?"

# game/Scenes/Micha/micha18.rpy:61
translate french micha18_b8162d87:

    # pc "Oh I don't know... I think she's great and I like spending time with her."
    pc "Oh, je ne sais pas... Je la trouve géniale et j'aime passer du temps avec elle."

# game/Scenes/Micha/micha18.rpy:63
translate french micha18_8094ff46:

    # sc "We both know she's not the only one you're seeing though..."
    sc "Mais on sait tous les deux qu'elle n'est pas la seule que tu vois..."

# game/Scenes/Micha/micha18.rpy:64
translate french micha18_c417e350:

    # pc "Yeah."
    pc "Oui."

# game/Scenes/Micha/micha18.rpy:65
translate french micha18_eda2d229:

    # sc "Just be careful with her. She's a little naive."
    sc "Fais juste attention à elle. Elle est un peu naïve."

# game/Scenes/Micha/micha18.rpy:66
translate french micha18_11144671:

    # sc "Don't hurt her, okay?"
    sc "Ne lui fais pas de mal, d'accord ?"

# game/Scenes/Micha/micha18.rpy:67
translate french micha18_dd9a629d:

    # pc "I won't."
    pc "Je ne lui ferai pas de mal."

# game/Scenes/Micha/micha18.rpy:70
translate french micha18_0a52de10:

    # "As time grows closer to the start of the show, the seats begin to fill up more."
    "À mesure que le début du spectacle approche, les sièges commencent à se remplir."

# game/Scenes/Micha/micha18.rpy:73
translate french micha18_14f8d7ae:

    # "I see Ms. Welch walk in and sit down."
    "Je vois Mme Welch entrer et s'asseoir."

# game/Scenes/Micha/micha18.rpy:77
translate french micha18_5868bd91:

    # "She spots me and gives me a wave and a wink."
    "Elle m'aperçoit et me fait un signe de la main et un clin d'œil."

# game/Scenes/Micha/micha18.rpy:80
translate french micha18_f6954d22:

    # "Then I look over and see Mrs. McGee sitting as well."
    "Puis je regarde de l'autre côté et je vois Mme McGee assise elle aussi."

# game/Scenes/Micha/micha18.rpy:81
translate french micha18_e5a0cf64:

    # "It's more people than I expected to see."
    "Il y a plus de monde que je ne m'y attendais."

# game/Scenes/Micha/micha18.rpy:85
translate french micha18_f05e2763:

    # "She and Pete both smile and wave at me."
    "Elle et Pete me sourient et me font signe tous les deux."

# game/Scenes/Micha/micha18.rpy:89
translate french micha18_29bbeb02:

    # "Then the lights dim, a spotlight shines on the stage, and music begins to play."
    "Puis les lumières s'éteignent, un projecteur éclaire la scène et la musique commence à jouer."

# game/Scenes/Micha/micha18.rpy:92
translate french micha18_16e9fa91:

    # "The curtains open and the ballet starts."
    "Le rideau s'ouvre et le ballet commence."

# game/Scenes/Micha/micha18.rpy:93
translate french micha18_5069de6b:

    # "I'm not really sure what is happening, but everybody on stage moves in a well-choreographed dance along with the music."
    "Je ne sais pas vraiment ce qui se passe, mais tout le monde sur scène évolue dans une danse parfaitement chorégraphiée, en rythme avec la musique."

# game/Scenes/Micha/micha18.rpy:94
translate french micha18_e615adbc:

    # "Everybody else seems to fade into the background as my eyes lock onto Mi-Cha, though."
    "Tout le monde semble toutefois s’effacer à l’arrière-plan alors que mon regard se fixe sur Mi-Cha."

# game/Scenes/Micha/micha18.rpy:95
translate french micha18_f7a5d1fe:

    # "She's gorgeous in her costume and her movements are almost hypnotizing in their beauty."
    "Elle est magnifique dans son costume et la beauté de ses mouvements est presque hypnotisante."

# game/Scenes/Micha/micha18.rpy:98
translate french micha18_9d2a99c2:

    # "One of the male dancers spins her, then lifts her up like she's flying."
    "L’un des danseurs la fait tournoyer, puis la soulève comme si elle volait."

# game/Scenes/Micha/micha18.rpy:101
translate french micha18_b95ea171:

    # "Amazingly, she doesn't look nervous at all."
    "Étonnamment, elle n’a pas l’air nerveuse du tout."

# game/Scenes/Micha/micha18.rpy:102
translate french micha18_728386fb:

    # "Her usual self-conscious and timid attitude is gone, as if she's in her own world and none of us are even here."
    "Son attitude habituellement timide et gênée a disparu, comme si elle était dans son propre monde et qu’aucun d’entre nous n’était là."

# game/Scenes/Micha/micha18.rpy:105
translate french micha18_ffb4c520:

    # "Part of the way through the performance - I've long lost the story by now - the lights dim once again and only Mi-Cha is illuminated."
    "À mi-parcours du spectacle – j’ai depuis longtemps perdu le fil de l’histoire –, les lumières s’éteignent à nouveau et seule Mi-Cha est éclairée."

# game/Scenes/Micha/micha18.rpy:106
translate french micha18_ee38e730:

    # "The rest of the cast falls back into the shadows and all eyes are on her."
    "Le reste de la troupe retombe dans l’ombre et tous les regards se tournent vers elle."

# game/Scenes/Micha/micha18.rpy:110
translate french micha18_235a0510:

    # "And she dances."
    "Et elle danse."

# game/Scenes/Micha/micha18.rpy:111
translate french micha18_af3cfdb9:

    # "I'm sure her dance is telling the story of her character in the ballet, but I feel like it's telling Mi-Cha's story as well."
    "Je suis sûr que sa danse raconte l’histoire de son personnage dans le ballet, mais j’ai l’impression qu’elle raconte aussi l’histoire de Mi-Cha."

# game/Scenes/Micha/micha18.rpy:112
translate french micha18_b3efe8d7:

    # "I feel like I can see right through to her heart. She's wearing clothes, but she is also naked, baring her soul."
    "J’ai l’impression de voir droit au fond de son cœur. Elle porte des vêtements, mais elle est aussi nue, mettant son âme à nu."

# game/Scenes/Micha/micha18.rpy:113
translate french micha18_cd9f512f:

    # "There's only been a couple of times where I've felt like Mi-Cha has been completely free and uninhibited - when she's dancing, and when we're fucking."
    "Il n’y a eu que deux ou trois fois où j’ai eu l’impression que Mi-Cha était complètement libre et sans inhibition : quand elle danse, et quand on baise."

# game/Scenes/Micha/micha18.rpy:114
translate french micha18_9b3a0aea:

    # "In both cases, she's absolutely beautiful."
    "Dans les deux cas, elle est absolument magnifique."

# game/Scenes/Micha/micha18.rpy:120
translate french micha18_abeb9237:

    # "When the show is over, the whole crowd stands up and applauds."
    "Quand le spectacle est terminé, tout le public se lève et applaudit."

# game/Scenes/Micha/micha18.rpy:121
translate french micha18_aca55a3d:

    # "I'm just so happy that everybody can see how amazing Mi-Cha is."
    "Je suis tellement heureux que tout le monde puisse voir à quel point Mi-Cha est incroyable."

# game/Scenes/Micha/micha18.rpy:124
translate french micha18_f1614496:

    # sc "Wow, that was incredible. She is so talented!"
    sc "Waouh, c'était incroyable. Elle a tellement de talent !"

# game/Scenes/Micha/micha18.rpy:125
translate french micha18_6c11c780:

    # pc "Yeah. I'm going to go find her."
    pc "Ouais. Je vais aller la chercher."

# game/Scenes/Micha/micha18.rpy:126
translate french micha18_9b70b49a:

    # sc "Okay. You two have a good night."
    sc "D'accord. Passez une bonne soirée tous les deux."

# game/Scenes/Micha/micha18.rpy:130
translate french micha18_72d6b54c:

    # "I look backstage, but the cast tells me that she's already left."
    "Je jette un œil dans les coulisses, mais les autres membres de la troupe me disent qu'elle est déjà partie."

# game/Scenes/Micha/micha18.rpy:131
translate french micha18_d18e5603:

    # "So I rush out towards her dorm, looking for her."
    "Je me précipite donc vers son dortoir, à sa recherche."

# game/Scenes/Micha/micha18.rpy:134
translate french micha18_9cd32c90:

    # "When I find her, she's sitting on the bench outside her dorm, sobbing into her hands."
    "Quand je la trouve, elle est assise sur le banc devant son dortoir, en larmes, le visage enfoui dans ses mains."

# game/Scenes/Micha/micha18.rpy:135
translate french micha18_0003d575:

    # pc "Hey, what's wrong? Are you okay?"
    pc "Hé, qu'est-ce qui ne va pas ? Ça va ?"

# game/Scenes/Micha/micha18.rpy:137
translate french micha18_d41d8cd9:

    # voice 'voices/micha_18_1.mp3'
    voice 'voices/micha_18_1.mp3'

# game/Scenes/Micha/micha18.rpy:138
translate french micha18_918fea83:

    # mc "I'm sorry."
    mc "Je suis désolée."

# game/Scenes/Micha/micha18.rpy:141
translate french micha18_2db90f14:

    # pc "What's wrong? You were amazing. They all loved you."
    pc "Qu'est-ce qui ne va pas ? Tu étais géniale. Ils t'ont tous adorée."

# game/Scenes/Micha/micha18.rpy:143
translate french micha18_d41d8cd9_1:

    # voice 'voices/micha_18_2.mp3'
    voice 'voices/micha_18_2.mp3'

# game/Scenes/Micha/micha18.rpy:144
translate french micha18_cd855510:

    # mc "I don't want this to be over."
    mc "Je ne veux pas que ça se termine."

# game/Scenes/Micha/micha18.rpy:146
translate french micha18_d41d8cd9_2:

    # voice 'voices/micha_18_3.mp3'
    voice 'voices/micha_18_3.mp3'

# game/Scenes/Micha/micha18.rpy:147
translate french micha18_b624d3b4:

    # mc "I have to go back home. No more dancing."
    mc "Je dois rentrer chez moi. Fini la danse."

# game/Scenes/Micha/micha18.rpy:151
translate french micha18_d41d8cd9_3:

    # voice 'voices/micha_18_4.mp3'
    voice 'voices/micha_18_4.mp3'

# game/Scenes/Micha/micha18.rpy:152
translate french micha18_4a94d1aa:

    # mc "And no more of you."
    mc "Et fini toi aussi."

# game/Scenes/Micha/micha18.rpy:154
translate french micha18_d41d8cd9_4:

    # voice 'voices/micha_18_5.mp3'
    voice 'voices/micha_18_5.mp3'

# game/Scenes/Micha/micha18.rpy:155
translate french micha18_b954ffce:

    # mc "I'm so happy. I don't want to leave."
    mc "Je suis tellement heureux. Je ne veux pas partir."

# game/Scenes/Micha/micha18.rpy:158
translate french micha18_6d39e617:

    # "I hold her for a while. Squeezing her close until she stops crying."
    "Je la serre dans mes bras un moment. Je la serre fort jusqu'à ce qu'elle arrête de pleurer."

# game/Scenes/Micha/micha18.rpy:159
translate french micha18_c40fa025:

    # pc "What if you just stay?"
    pc "Et si tu restais, tout simplement ?"

# game/Scenes/Micha/micha18.rpy:161
translate french micha18_d41d8cd9_5:

    # voice 'voices/micha_18_6.mp3'
    voice 'voices/micha_18_6.mp3'

# game/Scenes/Micha/micha18.rpy:162
translate french micha18_fe1e7b75:

    # mc "I can't. I'm only authorized until the end of the semester. If I stay longer, I will be illegal."
    mc "Je ne peux pas. Je n’ai l’autorisation que jusqu’à la fin du semestre. Si je reste plus longtemps, je serai en situation irrégulière."

# game/Scenes/Micha/micha18.rpy:163
translate french micha18_dcbbb7ed:

    # pc "Yeah, I guess that's bad."
    pc "Oui, je suppose que c’est grave."

# game/Scenes/Micha/micha18.rpy:166
translate french micha18_e22cecb4:

    # pc "Could you get your date extended?"
    pc "Tu pourrais faire prolonger ton séjour ?"

# game/Scenes/Micha/micha18.rpy:168
translate french micha18_d41d8cd9_6:

    # voice 'voices/micha_18_7.mp3'
    voice 'voices/micha_18_7.mp3'

# game/Scenes/Micha/micha18.rpy:169
translate french micha18_6be2096b:

    # mc "I don't know. I will talk to Mrs. Spann about it. She knows better than me."
    mc "Je ne sais pas. J’en parlerai à Mme Spann. Elle s’y connaît mieux que moi."

# game/Scenes/Micha/micha18.rpy:171
translate french micha18_d41d8cd9_7:

    # voice 'voices/micha_18_8.mp3'
    voice 'voices/micha_18_8.mp3'

# game/Scenes/Micha/micha18.rpy:172
translate french micha18_708ee42e:

    # mc "I think I have to have a reason to extend though."
    mc "Mais je crois qu’il me faut une bonne raison pour obtenir une prolongation."

# game/Scenes/Micha/micha18.rpy:174
translate french micha18_d41d8cd9_8:

    # voice 'voices/micha_18_9.mp3'
    voice 'voices/micha_18_9.mp3'

# game/Scenes/Micha/micha18.rpy:175
translate french micha18_d4d465f0:

    # mc "Like taking more school. Or marriage."
    mc "Comme continuer tes études. Ou le mariage."

# game/Scenes/Micha/micha18.rpy:179
translate french micha18_d41d8cd9_9:

    # voice 'voices/micha_18_10.mp3'
    voice 'voices/micha_18_10.mp3'

# game/Scenes/Micha/micha18.rpy:180
translate french micha18_1cf758a9:

    # mc "I'm sorry. I said I wouldn't mention it again, and I did."
    mc "Je suis désolée. J’avais dit que je n’en parlerais plus, et je l’ai fait."

# game/Scenes/Micha/micha18.rpy:182
translate french micha18_d41d8cd9_10:

    # voice 'voices/micha_18_11.mp3'
    voice 'voices/micha_18_11.mp3'

# game/Scenes/Micha/micha18.rpy:183
translate french micha18_d88ba6c6:

    # mc "I don't want to pressure you."
    mc "Je ne veux pas te mettre la pression."

# game/Scenes/Micha/micha18.rpy:185
translate french micha18_d41d8cd9_11:

    # voice 'voices/micha_18_12.mp3'
    voice 'voices/micha_18_12.mp3'

# game/Scenes/Micha/micha18.rpy:186
translate french micha18_0a8cc307:

    # mc "I just love you so much."
    mc "C’est juste que je t’aime tellement."

# game/Scenes/Micha/micha18.rpy:189
translate french micha18_5735beae:

    # pc "I love you too, Mi-Cha."
    pc "Je t’aime aussi, Mi-Cha."

# game/Scenes/Micha/micha18.rpy:190
translate french micha18_83eef187:

    # pc "We'll figure this out, one way or another."
    pc "On va trouver une solution, d’une manière ou d’une autre."

# game/Scenes/Micha/micha18.rpy:191
translate french micha18_39f98ad4:

    # pc "Everything will be okay."
    pc "Tout ira bien."

# game/Scenes/Micha/micha18.rpy:192
translate french micha18_2c147205:

    # pc "I just want you to keep dancing. I just want you to be happy."
    pc "Je veux juste que tu continues à danser. Je veux juste que tu sois heureuse."

# game/Scenes/Micha/micha18.rpy:196
translate french micha18_d41d8cd9_12:

    # voice 'voices/micha_18_13.mp3'
    voice 'voices/micha_18_13.mp3'

# game/Scenes/Micha/micha18.rpy:197
translate french micha18_06801be0:

    # mc "I am. So happy."
    mc "Je le suis. Tellement heureuse."

# game/Scenes/Micha/micha18.rpy:201
translate french micha18_d41d8cd9_13:

    # voice 'voices/micha_18_14.mp3'
    voice 'voices/micha_18_14.mp3'

# game/Scenes/Micha/micha18.rpy:202
translate french micha18_bb0eeaf4:

    # mc "Thank you."
    mc "Merci."

# game/Scenes/Micha/micha18.rpy:204
translate french micha18_d41d8cd9_14:

    # voice 'voices/micha_18_15.mp3'
    voice 'voices/micha_18_15.mp3'

# game/Scenes/Micha/micha18.rpy:205
translate french micha18_4d562fad:

    # mc "Even if we are not together forever. You have changed me."
    mc "Même si nous ne sommes pas ensemble pour toujours. Tu m’as changée."

# game/Scenes/Micha/micha18.rpy:207
translate french micha18_d41d8cd9_15:

    # voice 'voices/micha_18_16.mp3'
    voice 'voices/micha_18_16.mp3'

# game/Scenes/Micha/micha18.rpy:208
translate french micha18_4a1f6929:

