# game/Scenes/Micha/MichaConversations/michaq4.rpy:14
translate french michaq4_c84ba0ab:

    # mc "I want to apologize for bringing up marriage with you before."
    mc "Je veux m’excuser d’avoir abordé le sujet du mariage avec toi tout à l’heure."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:15
translate french michaq4_85bd1eca:

    # mc "I should not have put that pressure on you."
    mc "Je n’aurais pas dû te mettre cette pression."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:17
translate french michaq4_893c413d:

    # mc "If you marry me, I want it to be because you want that. Not because you feel sorry for me."
    mc "Si tu m'épouses, je veux que ce soit parce que tu le souhaites. Pas parce que tu as pitié de moi."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:18
translate french michaq4_ce223137:

    # pc "It's okay. I understand."
    pc "Ce n'est pas grave. Je comprends."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:20
translate french michaq4_f14438ef:

    # mc "I do want to marry you."
    mc "Je veux vraiment t'épouser."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:21
translate french michaq4_7a6cf72a:

    # mc "Not to stay in America. Not to avoid going back to Korea."
    mc "Pas pour rester aux États-Unis. Pas pour éviter de retourner en Corée."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:23
translate french michaq4_73c955db:

    # mc "I want to marry you because I want to be with you forever."
    mc "Je veux t'épouser parce que je veux être avec toi pour toujours."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:24
translate french michaq4_ca28c45a:

    # mc "Because I love you."
    mc "Parce que je t'aime."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:28
translate french michaq4_5735beae:

    # pc "I love you too, Mi-Cha."
    pc "Je t'aime aussi, Mi-Cha."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:29
translate french michaq4_86516b71:

    # pc "Thanks for explaining your feelings."
    pc "Merci de m'avoir expliqué ce que tu ressens."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:30
translate french michaq4_b57bfac8:

    # pc "I'm not ready for a commitment like marriage right now, but I will think about it, okay?"
    pc "Je ne suis pas prêt pour un engagement comme le mariage pour l’instant, mais j’y réfléchirai, d’accord ?"

# game/Scenes/Micha/MichaConversations/michaq4.rpy:32
translate french michaq4_016cf893:

    # pc "I care about you, Mi-Cha, but I'm not ready for a commitment like that yet."
    pc "Je tiens à toi, Mi-Cha, mais je ne suis pas encore prêt pour un engagement comme celui-là."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:34
translate french michaq4_83495ed0:

    # mc "I understand."
    mc "Je comprends."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:35
translate french michaq4_d27eb005:

    # mc "I want you to know..."
    mc "Je veux que tu saches..."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:37
translate french michaq4_9f7cbd29:

    # mc "...that if I go back to Korea, I will still love you."
    mc "... que si je retourne en Corée, je t’aimerai toujours."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:38
translate french michaq4_68f93173:

    # mc "I hope that we can be together, no matter where we are."
    mc "J’espère que nous pourrons être ensemble, peu importe où nous serons."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:40
translate french michaq4_35d8d871:

    # mc "I will try to focus on now and enjoy however much time we have together."
    mc "Je vais essayer de me concentrer sur le présent et de profiter de chaque instant que nous passons ensemble."

# game/Scenes/Micha/MichaConversations/michaq4.rpy:41
translate french michaq4_8db25c79:

    # pc "That's a good way of looking at things."
    pc "C'est une bonne façon de voir les choses."

translate french strings:

    # game/Scenes/Micha/MichaConversations/michaq4.rpy:2
    old "She will only ask this question after you have had sex with her."
    new "Elle ne te posera cette question qu'après avoir couché avec toi."

    # game/Scenes/Micha/MichaConversations/michaq4.rpy:31
    old "I'm not ready to say that"
    new "Je ne suis pas prêt à dire ça."

