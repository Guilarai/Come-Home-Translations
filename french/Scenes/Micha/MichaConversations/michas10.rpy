translate french michas10_50692d3e:

    # mc "Oh yes, one hundred percent for sure, I would."
    mc "Oh oui, à cent pour cent, c'est sûr, je le ferais."

# game/Scenes/Micha/MichaConversations/michas10.rpy:17
translate french michas10_809ae075:

    # mc "After I get married, I will have three children. Two boys and one girl."
    mc "Après mon mariage, j'aurai trois enfants. Deux garçons et une fille."

# game/Scenes/Micha/MichaConversations/michas10.rpy:19
translate french michas10_ccfeeccd:

    # mc "The boys are to carry on my husband's bloodline."
    mc "Les garçons pour perpétuer la lignée de mon mari."

# game/Scenes/Micha/MichaConversations/michas10.rpy:21
translate french michas10_ed688514:

    # mc "And the girl, because I'd like to dress her in pretty outfits."
    mc "Et la fille, parce que j'aimerais l'habiller avec de jolies tenues."

# game/Scenes/Micha/MichaConversations/michas10.rpy:23
translate french michas10_339fcc19:

    # mc "Of course, if my husband wants more children, I would give them to him."
    mc "Bien sûr, si mon mari veut plus d'enfants, je lui en donnerai."

# game/Scenes/Micha/MichaConversations/michas10.rpy:25
translate french michas10_75023170:

    # mc "But I think that three is the perfect number."
    mc "Mais je pense que trois, c'est le nombre idéal."

# game/Scenes/Micha/MichaConversations/michas10.rpy:26
translate french michas10_09e8961d:

    # pc "Sounds like you have it all planned out."
    pc "On dirait que tu as tout prévu."

# game/Scenes/Micha/MichaConversations/michas10.rpy:28
translate french michas10_6d5c8dc8:

    # mc "Yes, this is something I often think about."
    mc "Oui, c'est quelque chose auquel je pense souvent."

