# game/Scenes/Micha/MichaConversations/michap1.rpy:14
translate french michap1_d6002025:

    # mc "I have not decided."
    mc "Je n'ai pas encore décidé."

# game/Scenes/Micha/MichaConversations/michap1.rpy:15
translate french michap1_a4fc434d:

    # mc "My mother wants me to specialize in oncology, but my father says I should be a surgeon."
    mc "Ma mère veut que je me spécialise en oncologie, mais mon père dit que je devrais être chirurgien."

# game/Scenes/Micha/MichaConversations/michap1.rpy:16
translate french michap1_dd9900fe:

    # pc "But what do you want?"
    pc "Mais qu'est-ce que tu veux, toi ?"

# game/Scenes/Micha/MichaConversations/michap1.rpy:18
translate french michap1_3ed64e02:

    # mc "I want to make them happy."
    mc "Je veux les rendre heureux."

# game/Scenes/Micha/MichaConversations/michap1.rpy:19
translate french michap1_27f59fe3:

    # pc "That's no way to choose your career though."
    pc "Ce n'est pas une façon de choisir sa carrière."

# game/Scenes/Micha/MichaConversations/michap1.rpy:20
translate french michap1_4d97ed4b:

    # pc "I mean, it's your entire life. You should do what makes you happy."
    pc "Je veux dire, c'est toute ta vie. Tu devrais faire ce qui te rend heureux."

# game/Scenes/Micha/MichaConversations/michap1.rpy:22
translate french michap1_07770008:

    # mc "Making other people happy makes me happy."
    mc "Rendre les autres heureux me rend heureux."

# game/Scenes/Micha/MichaConversations/michap1.rpy:23
translate french michap1_e82ab978:

    # mc "Either an oncologist or a surgeon is a respectable career that pays well and helps people."
    mc "Que ce soit oncologue ou chirurgien, ce sont des carrières respectables, bien rémunérées et qui aident les gens."

# game/Scenes/Micha/MichaConversations/michap1.rpy:24
translate french michap1_a496522c:

    # mc "I will be satisfied doing either and I'm sure my parents will come to a decision soon."
    mc "Je serai satisfait dans l’une ou l’autre, et je suis sûr que mes parents prendront bientôt une décision."

# game/Scenes/Micha/MichaConversations/michap1.rpy:25
translate french michap1_88e0bd03:

    # pc "But it's your life. It should be your decision."
    pc "Mais c’est ta vie. C’est à toi de décider."

# game/Scenes/Micha/MichaConversations/michap1.rpy:27
translate french michap1_34cfcd3a:

    # mc "They are more experienced and knowledgeable. I trust in their judgment."
    mc "Ils ont plus d’expérience et de connaissances. Je fais confiance à leur jugement."

# game/Scenes/Micha/MichaConversations/michap1.rpy:28
translate french michap1_6539b869:

    # pc "That's just so different than the way I think."
    pc "C’est tellement différent de ma façon de penser."

# game/Scenes/Micha/MichaConversations/michap1.rpy:29
translate french michap1_e04a3a8d:

    # pc "I would never want somebody else making my decisions for me!"
    pc "Je ne voudrais jamais que quelqu’un d’autre prenne des décisions à ma place !"

# game/Scenes/Micha/MichaConversations/michap1.rpy:37
translate french michap1_bb7217d6:

    # pc "I'm an adult. I can make my own choices."
    pc "Je suis adulte. Je peux faire mes propres choix."

# game/Scenes/Micha/MichaConversations/michap1.rpy:39
translate french michap1_41099ebd:

    # mc "That is a very American mindset."
    mc "C'est une mentalité très américaine."

# game/Scenes/Micha/MichaConversations/michap1.rpy:40
translate french michap1_e97051ad:

    # mc "I understand, but I do trust my parents to choose what is best for me."
    mc "Je comprends, mais je fais confiance à mes parents pour choisir ce qui est le mieux pour moi."

