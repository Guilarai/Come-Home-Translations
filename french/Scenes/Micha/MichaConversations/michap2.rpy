# game/Scenes/Micha/MichaConversations/michap2.rpy:12
translate french michap2_45b5138b:

    # mc "No. There was no time for that in Korea."
    mc "Non. Je n'avais pas le temps pour ça en Corée."

# game/Scenes/Micha/MichaConversations/michap2.rpy:13
translate french michap2_5d42a10f:

    # mc "It was study, study, study. From 5 A.M. to midnight every day."
    mc "C'était des études, des études, encore des études. De 5 h du matin à minuit, tous les jours."

# game/Scenes/Micha/MichaConversations/michap2.rpy:14
translate french michap2_64cdab63:

    # pc "Wow, that's a lot!"
    pc "Ouah, c'est énorme !"

# game/Scenes/Micha/MichaConversations/michap2.rpy:15
translate french michap2_8c07142f:

    # mc "Yes. It is easier here. Korean schools are very competitive."
    mc "Oui. C'est plus facile ici. Les écoles coréennes sont très compétitives."

# game/Scenes/Micha/MichaConversations/michap2.rpy:16
translate french michap2_4f4f2d1a:

    # pc "You must be very smart then."
    pc "Tu dois être très intelligente, alors."

# game/Scenes/Micha/MichaConversations/michap2.rpy:18
translate french michap2_b7e0b20e:

    # mc "No, I'm not."
    mc "Non, pas du tout."

# game/Scenes/Micha/MichaConversations/michap2.rpy:19
translate french michap2_a6f61528:

    # mc "I was in the lower half of my graduating class."
    mc "J'étais dans la moitié inférieure de ma promotion."

# game/Scenes/Micha/MichaConversations/michap2.rpy:20
translate french michap2_86a347e9:

    # mc "Which is why I came here, instead of going to a prestigious university like SKY."
    mc "C'est pour ça que je suis venue ici, au lieu d'aller dans une université prestigieuse comme SKY."

# game/Scenes/Micha/MichaConversations/michap2.rpy:21
translate french michap2_e168ecba:

    # pc "Sky?"
    pc "Sky ?"

# game/Scenes/Micha/MichaConversations/michap2.rpy:23
translate french michap2_d0e76a7c:

    # mc "SKY."
    mc "SKY."

# game/Scenes/Micha/MichaConversations/michap2.rpy:24
translate french michap2_002489ae:

    # mc "That's what we call the three big universities in Korea."
    mc "C'est comme ça qu'on appelle les trois grandes universités en Corée."

# game/Scenes/Micha/MichaConversations/michap2.rpy:25
translate french michap2_8360ab7c:

    # mc "Seoul National, Korea, and Yonsei Universities."
    mc "Les universités nationales de Séoul, de Corée et de Yonsei."

# game/Scenes/Micha/MichaConversations/michap2.rpy:26
translate french michap2_34f75a54:

    # pc "Oh, okay."
    pc "Oh, d'accord."

# game/Scenes/Micha/MichaConversations/michap2.rpy:27
translate french michap2_d55bf5ab:

    # pc "So, no boyfriends?"
    pc "Alors, pas de petit ami ?"

# game/Scenes/Micha/MichaConversations/michap2.rpy:29
translate french michap2_1f577bf5:

    # mc "You are the first boy I have even spoken to alone like this."
    mc "Tu es le premier garçon à qui j'ai parlé seule comme ça."

# game/Scenes/Micha/MichaConversations/michap2.rpy:30
translate french michap2_4f4ea4aa:

    # mc "Which is why it is so hard for me."
    mc "C'est pour ça que c'est si difficile pour moi."

# game/Scenes/Micha/MichaConversations/michap2.rpy:31
translate french michap2_34b44705:

    # pc "I understand."
    pc "Je comprends."

# game/Scenes/Micha/MichaConversations/michap2.rpy:33
translate french michap2_19a58c00:

    # mc "It is getting easier though."
    mc "Mais ça devient plus facile."

# game/Scenes/Micha/MichaConversations/michap2.rpy:34
translate french michap2_81d4c8f6:

    # mc "And I enjoy it."
    mc "Et j'apprécie ça."

