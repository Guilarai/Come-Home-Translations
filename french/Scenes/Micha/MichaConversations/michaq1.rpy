# game/Scenes/Micha/MichaConversations/michaq1.rpy:12
translate french michaq1_5cfde87c:

    # mc "Do you have a job, [pcname]?"
    mc "Tu as un travail, [pcname] ?"

# game/Scenes/Micha/MichaConversations/michaq1.rpy:13
translate french michaq1_3b07f277:

    # pc "Yeah, I work as an assistant at a law firm."
    pc "Oui, je travaille comme assistante dans un cabinet d'avocats."

# game/Scenes/Micha/MichaConversations/michaq1.rpy:15
translate french michaq1_a244753a:

    # mc "Oh that is very good. A lawyer is a respectable career."
    mc "Oh, c'est très bien. Avocat, c'est une carrière respectable."

# game/Scenes/Micha/MichaConversations/michaq1.rpy:16
translate french michaq1_3b106a99:

    # pc "I'm just doing it for some extra money. Not really planning on making a career out of it."
    pc "Je fais ça juste pour gagner un peu d'argent de côté. Je ne compte pas vraiment en faire ma carrière."

# game/Scenes/Micha/MichaConversations/michaq1.rpy:18
translate french michaq1_ab26a812:

    # mc "Oh? What career do you plan on having then?"
    mc "Ah bon ? Quelle carrière comptes-tu embrasser alors ?"

# game/Scenes/Micha/MichaConversations/michaq1.rpy:19
translate french michaq1_5a0f335d:

    # pc "I'm majoring in quantum physics."
    pc "Je me spécialise en physique quantique."

# game/Scenes/Micha/MichaConversations/michaq1.rpy:20
translate french michaq1_0ccfe2a7:

    # pc "I'll probably work in a lab somewhere. Maybe in the same lab where my dad worked."
    pc "Je travaillerai probablement dans un laboratoire quelque part. Peut-être dans le même laboratoire où travaillait mon père."

# game/Scenes/Micha/MichaConversations/michaq1.rpy:22
translate french michaq1_14ccf300:

    # mc "So you will be a scientist?"
    mc "Tu seras donc scientifique ?"

# game/Scenes/Micha/MichaConversations/michaq1.rpy:23
translate french michaq1_9f00d552:

    # pc "Yeah, I guess so."
    pc "Oui, je suppose."

# game/Scenes/Micha/MichaConversations/michaq1.rpy:25
translate french michaq1_bbda5dfb:

    # mc "That is a noble career path. Also respectable."
    mc "C'est un parcours professionnel noble. Et respectable aussi."

