# game/Scenes/Micha/MichaConversations/michas2.rpy:15
translate french michas2_da01eade:

    # mc "I really like America."
    mc "J'aime vraiment beaucoup l'Amérique."

# game/Scenes/Micha/MichaConversations/michas2.rpy:16
translate french michas2_07843369:

    # mc "I have been enjoying it here so much."
    mc "Je m'y plais beaucoup."

# game/Scenes/Micha/MichaConversations/michas2.rpy:18
translate french michas2_12adfa49:

    # mc "But I do miss my family. I have been sad sometimes being alone here."
    mc "Mais ma famille me manque. Je me sens parfois triste d'être seule ici."

# game/Scenes/Micha/MichaConversations/michas2.rpy:19
translate french michas2_3981a950:

    # pc "I can understand that. Being away from family can be hard."
    pc "Je comprends ça. Être loin de sa famille, ça peut être dur."

# game/Scenes/Micha/MichaConversations/michas2.rpy:20
translate french michas2_f800bed0:

    # mc "Yes."
    mc "Oui."

# game/Scenes/Micha/MichaConversations/michas2.rpy:22
translate french michas2_a8dcda18:

    # mc "I also miss being able to blend in."
    mc "Ça me manque aussi de pouvoir me fondre dans la masse."

# game/Scenes/Micha/MichaConversations/michas2.rpy:23
translate french michas2_2ab67308:

    # mc "It feels like I stand out here. Nobody else looks like me."
    mc "J'ai l'impression de me démarquer ici. Personne d'autre ne me ressemble."

# game/Scenes/Micha/MichaConversations/michas2.rpy:24
translate french michas2_fcb00f98:

    # mc "Everybody notices me when I walk into a room. That Korean girl."
    mc "Tout le monde me remarque quand j'entre dans une pièce. « Cette fille coréenne. »"

# game/Scenes/Micha/MichaConversations/michas2.rpy:26
translate french michas2_b356b2c8:

    # mc "But I am much more than where I was born. I am more than my heritage."
    mc "Mais je suis bien plus que mon lieu de naissance. Je suis plus que mon héritage."

# game/Scenes/Micha/MichaConversations/michas2.rpy:27
translate french michas2_e2dad910:

    # pc "I like that. I'd love to get to know the real you."
    pc "J'aime ça. J'adorerais apprendre à connaître la vraie toi."

# game/Scenes/Micha/MichaConversations/michas2.rpy:30
translate french michas2_d41d8cd9:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

# game/Scenes/Micha/MichaConversations/michas2.rpy:31
translate french michas2_bb0eeaf4:

    # mc "Thank you."
    mc "Merci."

# game/Scenes/Micha/MichaConversations/michas2.rpy:32
translate french michas2_63ace05b:

    # mc "I want to learn more about you too."
    mc "J'aimerais aussi en savoir plus sur toi."

