# game/Scenes/Update19/Act1/act1scene8.rpy:60
translate french u19a1s8_578e2001:

    # pc "Okay, well where is this queen? I'll go talk to her and get my bracelet back."
    pc "Bon, alors où est cette reine ? Je vais aller lui parler et récupérer mon bracelet."

# game/Scenes/Update19/Act1/act1scene8.rpy:61
translate french u19a1s8_bdec5088:

    # dad "It's no use, Son."
