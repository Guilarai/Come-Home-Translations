# game/Scenes/Update19/Act1/act1scene9.rpy:14
translate french u19a1s9_b669ce15:

    # rm "Oh hush, Joan. It's not that bad out there."
    rm "Oh, tais-toi, Joan. Ce n’est pas si grave là-bas."

# game/Scenes/Update19/Act1/act1scene9.rpy:15
translate french u19a1s9_9d89cbcd:

    # dad "If anybody tries to rob you, just give them whatever they want."
    dad "Si quelqu’un essaie de te voler, donne-lui simplement ce qu’il veut."

# game/Scenes/Update19/Act1/act1scene9.rpy:16
