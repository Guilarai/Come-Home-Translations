# game/Scenes/Update19/Act2/act2scene7a.rpy:25
translate french u19a2s7a_d7391ca9:

    # "We walk until the sun begins to set and it's time to set up camp once again."
    "Nous marchons jusqu’à ce que le soleil commence à se coucher et qu’il soit temps de monter le camp une fois de plus."

# game/Scenes/Update19/Act2/act2scene7a.rpy:28
translate french u19a2s7a_6347fb4c:

    # mc "You say you are from another world, where there is another me?"
    mc "Tu dis que tu viens d’un autre monde, où il y a une autre moi ?"

# game/Scenes/Update19/Act2/act2scene7a.rpy:29
translate french u19a2s7a_ba87bb2f:

    # pc "Yeah, I am."
    pc "Oui, c’est vrai."

# game/Scenes/Update19/Act2/act2scene7a.rpy:30
translate french u19a2s7a_2aa5ee09:

    # mc "What is she like? Is she a dancer as well?"
    mc "Comment est-elle ? Est-elle danseuse elle aussi ?"

# game/Scenes/Update19/Act2/act2scene7a.rpy:31
translate french u19a2s7a_74677430:

    # pc "She is, actually. She loves to dance."
    pc "En fait, oui. Elle adore danser."

# game/Scenes/Update19/Act2/act2scene7a.rpy:32
translate french u19a2s7a_b815dc04:

    # pc "She's very sweet and kind and always trying to please."
    pc "Elle est très douce et gentille, et elle essaie toujours de faire plaisir."

# game/Scenes/Update19/Act2/act2scene7a.rpy:33
translate french u19a2s7a_9ee66c04:

    # pc "She's a little too worried about pleasing everybody else, and doing what everybody else wants her to do..."
    pc "Elle se soucie un peu trop de plaire à tout le monde et de faire ce que les autres veulent qu’elle fasse…"

# game/Scenes/Update19/Act2/act2scene7a.rpy:34
translate french u19a2s7a_70ebbfb3:

    # pc "... instead of focusing on what she wants to do."
    pc "… au lieu de se concentrer sur ce qu’elle veut faire."

# game/Scenes/Update19/Act2/act2scene7a.rpy:36
translate french u19a2s7a_8eb4e936:

    # mc "Hm, that is not like me at all."
    mc "Hum, ça ne me ressemble pas du tout."

# game/Scenes/Update19/Act2/act2scene7a.rpy:37
translate french u19a2s7a_2c7a1ece:

    # mc "I always do what I want to do. I am free. Nobody tells Mi-Cha what to do... unless I want them to."
    mc "Je fais toujours ce que je veux. Je suis libre. Personne ne dit à Mi-Cha ce qu’elle doit faire… à moins que je ne le veuille."

# game/Scenes/Update19/Act2/act2scene7a.rpy:39
translate french u19a2s7a_42ed4bba:

    # mc "You have to help this other me see that. She is free to do whatever she wants."
    mc "Tu dois aider cette autre moi à s’en rendre compte. Elle est libre de faire tout ce qu’elle veut."

# game/Scenes/Update19/Act2/act2scene7a.rpy:40
translate french u19a2s7a_078d69a7:

    # pc "I've been trying."
    pc "J’ai essayé."

# game/Scenes/Update19/Act2/act2scene7a.rpy:44
translate french u19a2s7a_35550ef3:

    # cw "I lost my freedom for a long time. It's an awful feeling."
    cw "J’ai perdu ma liberté pendant longtemps. C’est un sentiment horrible."

# game/Scenes/Update19/Act2/act2scene7a.rpy:45
translate french u19a2s7a_2d600ef3:

    # cw "Everybody should be free to make their own decisions and do what they want with their lives."
    cw "Tout le monde devrait être libre de prendre ses propres décisions et de faire ce qu’il veut de sa vie."

# game/Scenes/Update19/Act2/act2scene7a.rpy:46
translate french u19a2s7a_fcf340b6:

    # mc "I agree."
    mc "Je suis d’accord."

# game/Scenes/Update19/Act2/act2scene7a.rpy:49
translate french u19a2s7a_45de856f:

    # sg "Why would you care what anybody else thinks? They aren't living your life."
    sg "Pourquoi te soucierais-tu de ce que pensent les autres ? Ce ne sont pas eux qui vivent ta vie."

# game/Scenes/Update19/Act2/act2scene7a.rpy:50
translate french u19a2s7a_8ef70686:

    # sg "Just live it however makes you the happiest, I think."
    sg "Vivez simplement de la manière qui vous rend le plus heureux, je pense."

# game/Scenes/Update19/Act2/act2scene7a.rpy:51
translate french u19a2s7a_7db64ce6:

    # sg "You only get one, and it's not very long."
    sg "On n’en a qu’une, et elle n’est pas très longue."

# game/Scenes/Update19/Act2/act2scene7a.rpy:52
translate french u19a2s7a_fcf340b6_1:

    # mc "I agree."
    mc "Je suis d’accord."

# game/Scenes/Update19/Act2/act2scene7a.rpy:54
translate french u19a2s7a_a52521e6:

    # gg "It's important to be whoever you feel like you are meant to be, and nobody else can decide that for you."
    gg "C’est important d’être qui tu sens que tu es censé être, et personne d’autre ne peut décider ça à ta place."

# game/Scenes/Update19/Act2/act2scene7a.rpy:55
translate french u19a2s7a_fcf340b6_2:

    # mc "I agree."
    mc "Je suis d'accord."

# game/Scenes/Update19/Act2/act2scene7a.rpy:57
translate french u19a2s7a_54bfdc0f:

    # bn "Sometimes it's difficult to know how to act, and guidance is necessary."
    bn "Parfois, il est difficile de savoir comment agir, et on a besoin de conseils."

# game/Scenes/Update19/Act2/act2scene7a.rpy:58
translate french u19a2s7a_d671023b:

    # bn "But in the end, everybody should be free to make their own decisions."
    bn "Mais au final, chacun devrait être libre de prendre ses propres décisions."

# game/Scenes/Update19/Act2/act2scene7a.rpy:59
translate french u19a2s7a_fcf340b6_3:

    # mc "I agree."
    mc "Je suis d'accord."

# game/Scenes/Update19/Act2/act2scene7a.rpy:62
translate french u19a2s7a_4387a8df:

    # sst "Freedom is the most important thing in the world."
    sst "La liberté est la chose la plus importante au monde."

# game/Scenes/Update19/Act2/act2scene7a.rpy:63
translate french u19a2s7a_aa965ea9:

    # sst "Nobody should be allowed to make decisions for you or control your fate!"
    sst "Personne ne devrait avoir le droit de prendre des décisions à ta place ou de contrôler ton destin !"

# game/Scenes/Update19/Act2/act2scene7a.rpy:64
translate french u19a2s7a_fcf340b6_4:

    # mc "I agree."
    mc "Je suis d'accord."

# game/Scenes/Update19/Act2/act2scene7a.rpy:67
translate french u19a2s7a_da8c9804:

    # rb "Nobody can tell Reba what to do!"
    rb "Personne ne peut dire à Reba ce qu’elle doit faire !"

# game/Scenes/Update19/Act2/act2scene7a.rpy:68
translate french u19a2s7a_6ac871f9:

    # rb "I'm gonna do whatever the heck I want to, I promise you that!"
    rb "Je vais faire tout ce que je veux, je te le promets !"

# game/Scenes/Update19/Act2/act2scene7a.rpy:69
translate french u19a2s7a_61a2b50c:

    # mc "That is a good way to live."
    mc "C’est une bonne façon de vivre."

# game/Scenes/Update19/Act2/act2scene7a.rpy:71
translate french u19a2s7a_5706ecf8:

    # mc "I will help you get back to her so that you can help her."
    mc "Je vais t’aider à retourner auprès d’elle pour que tu puisses l’aider."

# game/Scenes/Update19/Act2/act2scene7a.rpy:72
translate french u19a2s7a_124c4acc:

    # pc "Thanks Mi-Cha. It's definitely nice having you around."
    pc "Merci Mi-Cha. C’est vraiment sympa de t’avoir à mes côtés."

# game/Scenes/Update19/Act2/act2scene7a.rpy:73
translate french u19a2s7a_a9a280cd:

    # mc "I am getting tired now. I think I will try to sleep."
    mc "Je commence à être fatigué. Je pense que je vais essayer de dormir."

# game/Scenes/Update19/Act2/act2scene7a.rpy:74
translate french u19a2s7a_d5f58427:

    # pc "Good idea. We should keep a watch overnight though. I can take first watch."
    pc "Bonne idée. Mais on devrait monter la garde cette nuit. Je peux prendre le premier quart."

# game/Scenes/Update19/Act2/act2scene7a.rpy:77
translate french u19a2s7a_d0ff659c:

    # sst "Then I will take second."
    sst "Ensuite, je prendrai le deuxième."

# game/Scenes/Update19/Act2/act2scene7a.rpy:80
translate french u19a2s7a_fd391d92:

    # rb "Then I will take second."
    rb "Puis ce sera mon tour."

# game/Scenes/Update19/Act2/act2scene7a.rpy:83
translate french u19a2s7a_fa5c2825:

    # cw "Then I will take second."
    cw "Et après, ce sera mon tour."

# game/Scenes/Update19/Act2/act2scene7a.rpy:86
translate french u19a2s7a_9a2d0f32:

    # sg "Then me."
    sg "Puis moi."

# game/Scenes/Update19/Act2/act2scene7a.rpy:89
translate french u19a2s7a_f73f5a01:

    # bn "And I'll be next."
    bn "Et je serai le suivant."

# game/Scenes/Update19/Act2/act2scene7a.rpy:92
translate french u19a2s7a_ad230cd5:

    # gg "And I'll take the next one."
    gg "Et je prendrai le suivant."

# game/Scenes/Update19/Act2/act2scene7a.rpy:93
translate french u19a2s7a_80ca8121:

    # mc "This is a good idea. I will do the last watch then."
    mc "C'est une bonne idée. Je ferai donc le dernier quart."

# game/Scenes/Update19/Act2/act2scene7a.rpy:99
translate french u19a2s7a_0466c0c7:

    # mc "This is fun. Travelling, talking, sleeping next to the fire."
    mc "C'est sympa. Voyager, discuter, dormir près du feu."

# game/Scenes/Update19/Act2/act2scene7a.rpy:100
translate french u19a2s7a_2ee6cb68:

    # pc "Yeah, it is. If it wasn't for the bandits and the monsters, this place would be pretty nice."
    pc "Oui, c'est vrai. S'il n'y avait pas les bandits et les monstres, cet endroit serait plutôt sympa."

# game/Scenes/Update19/Act2/act2scene7a.rpy:101
translate french u19a2s7a_68957625:

    # mc "Yes, that is true. I hope it stays peaceful like this."
    mc "Oui, c'est vrai. J'espère que ça restera aussi paisible."

# game/Scenes/Update19/Act2/act2scene7a.rpy:104
translate french u19a2s7a_98dcde50:

    # mc "Good night [pcname]. I am glad that we met."
    mc "Bonne nuit [pcname]. Je suis content qu'on se soit rencontrés."

# game/Scenes/Update19/Act2/act2scene7a.rpy:105
translate french u19a2s7a_eede79c7:

    # pc "Me too. Good night, Mi-Cha."
    pc "Moi aussi. Bonne nuit, Mi-Cha."

