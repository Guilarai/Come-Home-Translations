    # sg "Holy shit, she's breathing fire! Is [pcname] going to be okay?"
    sg "Putain, elle crache du feu ! Est-ce que [pcname] va s'en sortir ?"

# game/Scenes/Update19/Act2/act2scene15.rpy:347
translate french u19a2s15_44cc934f_1:

    # gg "We need to move faster or that dragon is going to catch up to them."
    gg "On doit aller plus vite, sinon ce dragon va les rattraper."

# game/Scenes/Update19/Act2/act2scene15.rpy:349
translate french u19a2s15_c08b71dd:

    # sst "That centaur better be able to outrun the flames."
    sst "Ce centaure a intérêt à pouvoir distancer les flammes."

# game/Scenes/Update19/Act2/act2scene15.rpy:350
translate french u19a2s15_150f3742:

    # sst "I'm going to be very angry if [pcname] dies after all of this."
    sst "Je vais être très en colère si [pcname] meurt après tout ça."

# game/Scenes/Update19/Act2/act2scene15.rpy:352
translate french u19a2s15_4ffb596f:

    # rb "The horse woman can outrun the dragon, right? Right?"
    rb "La femme à cheval peut distancer le dragon, n'est-ce pas ? N'est-ce pas ?"

# game/Scenes/Update19/Act2/act2scene15.rpy:354
translate french u19a2s15_d4159ee1:

    # cw "Whitney can outrun the dragon, right? [pcname] can't die now!"
    cw "Whitney peut distancer le dragon, n'est-ce pas ? [pcname] ne peut pas mourir maintenant !"

# game/Scenes/Update19/Act2/act2scene15.rpy:356
translate french u19a2s15_7882c24f:

    # gg "She can outrun the dragon, right? [pcname] can't die now!"
    gg "Elle peut distancer le dragon, n'est-ce pas ? [pcname] ne peut pas mourir maintenant !"

# game/Scenes/Update19/Act2/act2scene15.rpy:358
translate french u19a2s15_c24ffa61:

    # sg "That horse lady better be able to outrun the dragon!"
    sg "Cette femme à cheval a intérêt à pouvoir distancer le dragon !"

# game/Scenes/Update19/Act2/act2scene15.rpy:359
translate french u19a2s15_cb0d37cb:

    # sg "If [pcname] dies, I'm going to be pissed!"
    sg "Si [pcname] meurt, je vais être furieux !"

# game/Scenes/Update19/Act2/act2scene15.rpy:361
translate french u19a2s15_7d0c406c:

    # bn "Dragons can fly faster than centaurs can run if moving in a straight line."
    bn "Les dragons peuvent voler plus vite que les centaures ne courent s'ils se déplacent en ligne droite."

# game/Scenes/Update19/Act2/act2scene15.rpy:362
translate french u19a2s15_744b0003:

    # bn "But a centaur would have more agility on curves."
    bn "Mais un centaure serait plus agile dans les virages."

# game/Scenes/Update19/Act2/act2scene15.rpy:363
translate french u19a2s15_08e59b70:

    # bn "I hope she knows that."
    bn "J'espère qu'elle le sait."

# game/Scenes/Update19/Act2/act2scene15.rpy:365
translate french u19a2s15_daf2df56:

    # mc "She can outrun the dragon, right? Oh no, [pcname] can't die."
    mc "Elle peut distancer le dragon, n'est-ce pas ? Oh non, [pcname] ne doit pas mourir."

# game/Scenes/Update19/Act2/act2scene15.rpy:367
translate french u19a2s15_eaad070e:

    # fr "That horse lady better run faster."
    fr "Cette femme-cheval ferait mieux de courir plus vite."

# game/Scenes/Update19/Act2/act2scene15.rpy:368
translate french u19a2s15_99b0c524:

    # fr "I will not be happy if [pcname] gets killed now."
    fr "Je ne serai pas content si [pcname] se fait tuer maintenant."

# game/Scenes/Update19/Act2/act2scene15.rpy:370
translate french u19a2s15_cc5677cb:

    # det "Damn it, horse lady, run!"
    det "Bon sang, la fille à cheval, cours !"

# game/Scenes/Update19/Act2/act2scene15.rpy:371
translate french u19a2s15_88c3bfcb:

    # det "Don't let that dragon kill [pcname], please."
    det "Ne laisse pas ce dragon tuer [pcname], s'il te plaît."

# game/Scenes/Update19/Act2/act2scene15.rpy:378
translate french u19a2s15_aba3b359:

    # wt "It looks like they've made it. Time to get you there now."
    wt "On dirait qu'ils s'en sont sortis. Il est temps de t'y emmener maintenant."

# game/Scenes/Update19/Act2/act2scene15.rpy:380
translate french u19a2s15_18f5133c:

    # wt "It looks like your friend made it. Time to get you there now."
    wt "On dirait que ton amie s'en est sortie. Il est temps de t'y emmener maintenant."

# game/Scenes/Update19/Act2/act2scene15.rpy:381
translate french u19a2s15_8266c6d6:

    # pc "What about you?"
    pc "Et toi ?"

# game/Scenes/Update19/Act2/act2scene15.rpy:382
translate french u19a2s15_348a756b:

    # wt "I'll get away once I get you to safety."
    wt "Je m'enfuirai une fois que je t'aurai mise en sécurité."

# game/Scenes/Update19/Act2/act2scene15.rpy:385
translate french u19a2s15_555f114e:

    # pc "Thanks for your help, Whitney."
    pc "Merci pour ton aide, Whitney."

# game/Scenes/Update19/Act2/act2scene15.rpy:386
translate french u19a2s15_acdc6592:

    # wt "I had no choice. The other me said that she needed you back, or else she is going to be in danger."
    wt "Je n'avais pas le choix. Mon autre moi m'a dit qu'elle avait besoin que tu reviennes, sinon elle serait en danger."

# game/Scenes/Update19/Act2/act2scene15.rpy:387
translate french u19a2s15_83d00131:

    # pc "How did you speak to her?"
    pc "Comment as-tu pu lui parler ?"

# game/Scenes/Update19/Act2/act2scene15.rpy:388
translate french u19a2s15_d72cbd8f:

    # wt "She contacted me in my dreams. I do not know how."
    wt "Elle m'a contactée dans mes rêves. Je ne sais pas comment."

# game/Scenes/Update19/Act2/act2scene15.rpy:389
translate french u19a2s15_2e227492:

    # wt "I have never claimed to be a genius."
    wt "Je n'ai jamais prétendu être un génie."

# game/Scenes/Update19/Act2/act2scene15.rpy:392
translate french u19a2s15_80d3d854:

    # wt "But I do my part. And I am very fast."
    wt "Mais je fais ma part. Et je suis très rapide."

# game/Scenes/Update19/Act2/act2scene15.rpy:393
translate french u19a2s15_f8540421:

    # wt "You're going to have to let go of my tits and jump off up here."
    wt "Tu vas devoir lâcher mes seins et sauter d'ici."

# game/Scenes/Update19/Act2/act2scene15.rpy:394
translate french u19a2s15_2b228e6d:

    # pc "Oh, sorry, you're just easier to hold there."
    pc "Oh, désolée, c'est juste plus facile de te tenir là."

# game/Scenes/Update19/Act2/act2scene15.rpy:395
translate french u19a2s15_bdf7d65f:

    # wt "Yeah, sure. Remember to tuck and roll."
    wt "Ouais, bien sûr. N'oublie pas de te recroqueviller et de rouler."

# game/Scenes/Update19/Act2/act2scene15.rpy:396
translate french u19a2s15_3f8cb39e:

    # pc "What?"
    pc "Quoi ?"

# game/Scenes/Update19/Act2/act2scene15.rpy:397
translate french u19a2s15_c4365179:

    # wt "It was nice to meet you. I wish we had more time together."
    wt "J'ai été ravie de te rencontrer. J'aurais aimé qu'on passe plus de temps ensemble."

# game/Scenes/Update19/Act2/act2scene15.rpy:398
translate french u19a2s15_4ad8a399:

    # wt "Now jump!"
    wt "Maintenant, saute !"

# game/Scenes/Update19/Act2/act2scene15.rpy:401
translate french u19a2s15_2b23e831:

    # "She doesn't slow as I leap from her back, the dragon right on her literal tail."
    "Elle ne ralentit pas alors que je saute de son dos, le dragon littéralement à ses trousses."

# game/Scenes/Update19/Act2/act2scene15.rpy:404
translate french u19a2s15_5e07bf68:

    # "I hit the ground hard and roll near the cairn she pointed out earlier."
    "Je heurte le sol violemment et roule près du cairn qu'elle m'avait indiqué plus tôt."

# game/Scenes/Update19/Act2/act2scene15.rpy:405
translate french u19a2s15_2cfcb1c8:

    # "Another blast of flame scorches the ground behind her, but she is able to dodge out of the way."
    "Une autre gerbe de flammes brûle le sol derrière elle, mais elle parvient à l'esquiver."

# game/Scenes/Update19/Act2/act2scene15.rpy:408
translate french u19a2s15_3479b1c3:

    # "She should be able to get back to the woods and escape."
    "Elle devrait pouvoir retourner dans les bois et s'échapper."

# game/Scenes/Update19/Act2/act2scene15.rpy:410
translate french u19a2s15_dfaa5936:

    # "We're fortunate that she showed up when she did."
    "On a de la chance qu'elle soit arrivée à ce moment-là."

# game/Scenes/Update19/Act2/act2scene15.rpy:411
translate french u19a2s15_f39e0d10:

    # "None of us would have been able to outmaneuver the dragon like that."
    "Aucun d'entre nous n'aurait pu déjouer le dragon comme ça."

# game/Scenes/Update19/Act2/act2scene15.rpy:413
translate french u19a2s15_999634bf:

    # "I'm fortunate that she showed up when she did."
    "J'ai de la chance qu'elle soit arrivée à ce moment-là."

# game/Scenes/Update19/Act2/act2scene15.rpy:414
translate french u19a2s15_c8efec21:

    # "No way I would have been able to outmaneuver the dragon like that."
    "Pas question que j'aie pu déjouer le dragon comme ça."

# game/Scenes/Update19/Act2/act2scene15.rpy:418
translate french u19a2s15_1e16ee6a:

    # "She got us here. Now we just have to get through a dungeon, find the Ice Queen, find my bracelet, and get back home."
    "C'est grâce à elle qu'on est ici. Maintenant, il ne nous reste plus qu'à traverser un donjon, trouver la Reine des Glaces, retrouver mon bracelet et rentrer chez nous."

# game/Scenes/Update19/Act2/act2scene15.rpy:420
translate french u19a2s15_2aa9d7f8:

    # "She got me here. Now I just have to get through a dungeon, find the Ice Queen, find my bracelet, and get back home."
    "C'est grâce à elle que je suis ici. Maintenant, il ne me reste plus qu'à traverser un donjon, trouver la Reine des Glaces, retrouver mon bracelet et rentrer chez moi."

