# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Update19/Act2/act2scene10a.rpy:7
translate french u19a2s10a_8e44da15:

    # "I choose a path and walk towards where I feel the voice of Bai pulling me."
    "Je choisis un chemin et je marche vers l'endroit où je sens que la voix de Bai m'attire."

# game/Scenes/Update19/Act2/act2scene10a.rpy:32
translate french u19a2s10a_f84fcc3d:

    # "The path leads into a valley where the sparse forest falls away and opens to a field of large boulders."
    "Le chemin mène à une vallée où la forêt clairsemée s'estompe pour laisser place à un champ de gros rochers."

# game/Scenes/Update19/Act2/act2scene10a.rpy:39
translate french u19a2s10a_7b09d796:

    # "Ahead, I see a figure, sitting cross-legged on top of one of the boulders."
    "Devant moi, j'aperçois une silhouette, assise en tailleur sur l'un des rochers."

# game/Scenes/Update19/Act2/act2scene10a.rpy:40
translate french u19a2s10a_2e5d0a87:

    # "As I get closer, I see that it's Bai, though his hair is different than I'm used to."
    "En m'approchant, je vois que c'est Bai, bien que ses cheveux soient différents de ce à quoi je suis habitué."

# game/Scenes/Update19/Act2/act2scene10a.rpy:41
translate french u19a2s10a_6290c528:

    # "He seems to be meditating."
    "Il semble être en train de méditer."

# game/Scenes/Update19/Act2/act2scene10a.rpy:44
translate french u19a2s10a_81695b86:

    # "With his eyes closed, he doesn't see the threatening creatures creeping towards him."
    "Les yeux fermés, il ne voit pas les créatures menaçantes qui rampent vers lui."

# game/Scenes/Update19/Act2/act2scene10a.rpy:45
translate french u19a2s10a_182117bb:

    # "I have to warn him!"
    "Je dois l'avertir !"

# game/Scenes/Update19/Act2/act2scene10a.rpy:48
translate french u19a2s10a_6e4b7ce7:

    # "I rush towards him, pulling my sword from its sheath. I'm not going to get there in time."
    "Je me précipite vers lui, tirant mon épée de son fourreau. Je n'y arriverai pas à temps."

# game/Scenes/Update19/Act2/act2scene10a.rpy:49
translate french u19a2s10a_9083d650:

    # pc "Bai! Watch out!"
    pc "Bai ! Attention !"

# game/Scenes/Update19/Act2/act2scene10a.rpy:52
translate french u19a2s10a_63525cda:

    # "His eyes snap open, a white light spilling from within him, and he holds out a single finger to block the attack."
    "Ses yeux s’ouvrent brusquement, une lumière blanche jaillit de son intérieur, et il tend un seul doigt pour bloquer l’attaque."

# game/Scenes/Update19/Act2/act2scene10a.rpy:53
translate french u19a2s10a_42a85cd9:

    # "The creature's jaw drops, suddenly realizing that it has made a horrible mistake."
    "La créature reste bouche bée, réalisant soudain qu’elle a commis une terrible erreur."

# game/Scenes/Update19/Act2/act2scene10a.rpy:56
translate french u19a2s10a_9cc3b281:

    # "Bai's movements are precise and lethal, his hands and feet meeting any exposed weak points with deadly accuracy."
    "Les mouvements de Bai sont précis et mortels, ses mains et ses pieds frappant tous les points faibles exposés avec une précision redoutable."

# game/Scenes/Update19/Act2/act2scene10a.rpy:59
translate french u19a2s10a_9900cebc:

    # "The monsters don't stand a chance."
    "Les monstres n’ont aucune chance."

# game/Scenes/Update19/Act2/act2scene10a.rpy:60
translate french u19a2s10a_9eda6f19:

    # "His body moves like the tide, flowing away from their attacks, then crashing back with his own."
    "Son corps ondule comme la marée, esquivant leurs attaques, puis ripostant avec les siennes."

# game/Scenes/Update19/Act2/act2scene10a.rpy:63
translate french u19a2s10a_998374b4:

    # "After three of them have fallen, the rest change their mind about targeting this man and flee."
    "Après que trois d’entre eux sont tombés, les autres changent d’avis quant à l’idée de s’en prendre à cet homme et s’enfuient."

# game/Scenes/Update19/Act2/act2scene10a.rpy:64
translate french u19a2s10a_f3bc96bb:

    # "Bai has barely moved from the place where he started."
    "Bai n’a pratiquement pas bougé de l’endroit où il a commencé."

# game/Scenes/Update19/Act2/act2scene10a.rpy:67
translate french u19a2s10a_0fc9a1fc:

    # "By the time I reach him, the fight is over and he sits meditating once again, like it had never even happened."
    "Le temps que je le rejoigne, le combat est terminé et il est assis en train de méditer à nouveau, comme si de rien n’était."

# game/Scenes/Update19/Act2/act2scene10a.rpy:68
translate french u19a2s10a_6eee5369:

    # pc "Uh... Bai?"
    pc "Euh… Bai ?"

# game/Scenes/Update19/Act2/act2scene10a.rpy:71
translate french u19a2s10a_9f50d180:

    # "His eyes open, pure white light spilling from his sockets."
    "Ses yeux s’ouvrent, une lumière blanche pure jaillissant de ses orbites."

# game/Scenes/Update19/Act2/act2scene10a.rpy:72
translate french u19a2s10a_1d911abb:

    # "I take a step back, not wanting him to mistake me for another monster."
    "Je recule d’un pas, ne voulant pas qu’il me prenne pour un autre monstre."

# game/Scenes/Update19/Act2/act2scene10a.rpy:75
translate french u19a2s10a_434024c0:

    # "But then his eyes become normal and he smiles at me."
    "Mais ses yeux redeviennent normaux et il me sourit."

# game/Scenes/Update19/Act2/act2scene10a.rpy:76
translate french u19a2s10a_1eaab237:

    # bai "Hello, [pcname]. I was expecting you."
    bai "Bonjour, [pcname]. Je t’attendais."

# game/Scenes/Update19/Act2/act2scene10a.rpy:99
translate french u19a2s10a_8602d312:

    # pc "You were?"
    pc "Vraiment ?"

# game/Scenes/Update19/Act2/act2scene10a.rpy:100
translate french u19a2s10a_1f5a8cd0:

    # bai "Yes, I have been sitting here for two fortnights."
    bai "Oui, je suis assis ici depuis deux semaines."

# game/Scenes/Update19/Act2/act2scene10a.rpy:101
translate french u19a2s10a_c906d38f:

    # bai "I knew eventually you would make your way here."
    bai "Je savais que tu finirais par venir ici."

# game/Scenes/Update19/Act2/act2scene10a.rpy:103
translate french u19a2s10a_4b8c8bc4:

    # pc "So, you know who I am?"
    pc "Alors, tu sais qui je suis ?"

# game/Scenes/Update19/Act2/act2scene10a.rpy:104
translate french u19a2s10a_d56f63bd:

    # bai "I know that you are [pcname] and that you are trying to get back home."
    bai "Je sais que tu es [pcname] et que tu essaies de rentrer chez toi."

# game/Scenes/Update19/Act2/act2scene10a.rpy:105
translate french u19a2s10a_8203865b:

    # bai "And I know that I am intended to help you do that."
    bai "Et je sais que je suis censé t'aider à y parvenir."

# game/Scenes/Update19/Act2/act2scene10a.rpy:106
translate french u19a2s10a_f50f1eaa:

    # bai "It's nice to finally meet you."
    bai "Je suis ravi de te rencontrer enfin."

# game/Scenes/Update19/Act2/act2scene10a.rpy:109
translate french u19a2s10a_efbd7008:

    # "Without warning, he steps forward, leans up, and kisses me."
    "Sans crier gare, il s'avance, se penche vers moi et m'embrasse."

# game/Scenes/Update19/Act2/act2scene10a.rpy:131
translate french u19a2s10a_47f270eb:

    # "I don't even know how to respond to this. I'm speechless."
    "Je ne sais même pas comment réagir. Je reste sans voix."

# game/Scenes/Update19/Act2/act2scene10a.rpy:155
translate french u19a2s10a_3dde3c45:

    # bai "Hello. I'm Bai. Glad to meet you as well."
    bai "Bonjour. Je m'appelle Bai. Ravi de te rencontrer moi aussi."

# game/Scenes/Update19/Act2/act2scene10a.rpy:156
translate french u19a2s10a_5997fbff:

    # bai "We should get moving."
    bai "On devrait y aller."

# game/Scenes/Update19/Act2/act2scene10a.rpy:183
translate french u19a2s10a_31fd58d7:

    # "With that, we continue on the path north together."
    "Sur ces mots, nous continuons ensemble notre chemin vers le nord."

