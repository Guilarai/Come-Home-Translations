# game/Scenes/Update19/Act2/act2scene10b.rpy:8
translate french u19a2s10b_a8453d21:

    # "I choose a path and walk towards where I feel the voice of Izzy pulling me."
    "Je choisis un sentier et marche vers l’endroit où je sens la voix d’Izzy m’attirer."

# game/Scenes/Update19/Act2/act2scene10b.rpy:34
translate french u19a2s10b_f84fcc3d:

    # "The path leads into a valley where the sparse forest falls away and opens to a field of large boulders."
    "Le sentier mène à une vallée où la forêt clairsemée s’estompe pour laisser place à un champ de gros rochers."

# game/Scenes/Update19/Act2/act2scene10b.rpy:40
translate french u19a2s10b_1666fb38:

    # "Ahead, I hear laughter and a blast of orange fire explodes into the sky."
    "Devant moi, j’entends des rires et une gerbe de feu orange explose dans le ciel."

# game/Scenes/Update19/Act2/act2scene10b.rpy:41
translate french u19a2s10b_fe1ee4f7:

    # "Sounds of screaming, explosions, and combat fill the valley and I run towards it."
    "Des cris, des explosions et des bruits de combat remplissent la vallée et je cours vers elle."

# game/Scenes/Update19/Act2/act2scene10b.rpy:45
translate french u19a2s10b_772cc889:

    # "When I reach the top of the hill, I see Izzy, fire blazing from her body, launching blasts of flame at a group of monsters."
    "Quand j’atteins le sommet de la colline, j’aperçois Izzy, le corps en feu, lançant des salves de flammes sur un groupe de monstres."

# game/Scenes/Update19/Act2/act2scene10b.rpy:48
translate french u19a2s10b_e2f3209d:

    # gl "Hahaha! Burn, bitches!"
    gl "Hahaha ! Brûlez, bande de salopes !"

# game/Scenes/Update19/Act2/act2scene10b.rpy:49
translate french u19a2s10b_2a66d1b5:

    # gl "Y'all messed with the wrong girl!"
    gl "Vous vous êtes attaqués à la mauvaise fille !"

# game/Scenes/Update19/Act2/act2scene10b.rpy:52
translate french u19a2s10b_4cae4909:

    # "Without warning, she turns and launches a fireball directly at me."
    "Sans crier gare, elle se retourne et lance une boule de feu directement sur moi."

# game/Scenes/Update19/Act2/act2scene10b.rpy:53
translate french u19a2s10b_af77953e:

    # "I dive out of the way, just in time, feeling the heat from the flames on my back."
    "Je plonge pour l’esquiver, juste à temps, sentant la chaleur des flammes dans mon dos."

# game/Scenes/Update19/Act2/act2scene10b.rpy:56
translate french u19a2s10b_0438a9f9:

    # gl "Aw, damn! You's a dude!"
    gl "Oh, merde ! T’es un mec !"

# game/Scenes/Update19/Act2/act2scene10b.rpy:57
translate french u19a2s10b_b384cb8e:

    # gl "Sorry man, I thought you was one of those scaly motherfuckers."
    gl "Désolée mec, je pensais que t'étais un de ces enfoirés écailleux."

# game/Scenes/Update19/Act2/act2scene10b.rpy:58
translate french u19a2s10b_be04cd68:

    # gl "Didn't mean to light you up like a dry twig there."
    gl "Je voulais pas te faire griller comme une brindille sèche."

# game/Scenes/Update19/Act2/act2scene10b.rpy:59
translate french u19a2s10b_0d0c5a3a:

    # gl "You all right, Twig?"
    gl "T'es d'accord, Twig ?"

# game/Scenes/Update19/Act2/act2scene10b.rpy:82
translate french u19a2s10b_54fd8e2f:

    # pc "Yeah, I'm all right, Izzy."
    pc "Ouais, ça va, Izzy."

# game/Scenes/Update19/Act2/act2scene10b.rpy:83
translate french u19a2s10b_87c13a38:

    # gl "How you know my name, Twig?"
    gl "Comment tu connais mon nom, Twig ?"

# game/Scenes/Update19/Act2/act2scene10b.rpy:84
translate french u19a2s10b_cd200f0f:

    # pc "My name is [pcname], by the way."
    pc "Au fait, je m'appelle [pcname]."

# game/Scenes/Update19/Act2/act2scene10b.rpy:85
translate french u19a2s10b_1a7ceb8c:

    # gl "I ain't gonna remember that. I'll just call you Twig."
    gl "Je vais pas m'en souvenir. Je vais juste t'appeler Twig."

# game/Scenes/Update19/Act2/act2scene10b.rpy:86
translate french u19a2s10b_157b6482:

    # pc "Yeah... that feels appropriate."
    pc "Ouais... ça me semble approprié."

# game/Scenes/Update19/Act2/act2scene10b.rpy:88
translate french u19a2s10b_24374ea4:

    # "I explain everything to her about the other world, the bracelet, and the Ice Queen."
    "Je lui explique tout sur l'autre monde, le bracelet et la Reine des Glaces."

# game/Scenes/Update19/Act2/act2scene10b.rpy:89
translate french u19a2s10b_3b1392fd:

    # gl "Damn, that's some heavy stuff."
    gl "Merde, c'est du lourd."

# game/Scenes/Update19/Act2/act2scene10b.rpy:92
translate french u19a2s10b_2a5a4515:

    # pc "Holy shit! Where did that come from?"
    pc "Putain de merde ! D'où ça sort ?"

# game/Scenes/Update19/Act2/act2scene10b.rpy:93
translate french u19a2s10b_f65c4932:

    # gl "My weed? I carry that shit everywhere."
    gl "Mon herbe ? Je traîne ce truc partout."

# game/Scenes/Update19/Act2/act2scene10b.rpy:94
translate french u19a2s10b_29597977:

    # gl "And I need it if I'm gonna believe this crazy shit you're throwing at me."
    gl "Et j'en ai besoin si je dois croire à toutes ces conneries que tu me racontes."

# game/Scenes/Update19/Act2/act2scene10b.rpy:97
translate french u19a2s10b_06a5285e:

    # gl "All right, I'll come with you, Twig."
    gl "D'accord, je viens avec toi, Twig."

# game/Scenes/Update19/Act2/act2scene10b.rpy:98
translate french u19a2s10b_8347afa3:

    # gl "I'll help you get back to your world and all that."
    gl "Je vais t'aider à retourner dans ton monde et tout ça."

# game/Scenes/Update19/Act2/act2scene10b.rpy:99
translate french u19a2s10b_cece2e22:

    # pc "Why are you helping me?"
    pc "Pourquoi tu m'aides ?"

# game/Scenes/Update19/Act2/act2scene10b.rpy:102
translate french u19a2s10b_4a33ffa1:

    # gl "Ain't got nothin' better to do, and it'll give me a chance to blast some fools."
    gl "J'ai rien de mieux à faire, et ça me donnera l'occasion de descendre quelques crétins."

# game/Scenes/Update19/Act2/act2scene10b.rpy:103
translate french u19a2s10b_38ed4a10:

    # gl "Looking to raise my body count, you know?"
    gl "Je cherche à faire monter mon compteur de victimes, tu vois ?"

# game/Scenes/Update19/Act2/act2scene10b.rpy:106
translate french u19a2s10b_a69af730:

    # gl "Let's do this, Twig. This is gonna be fun."
    gl "C'est parti, Twig. Ça va être marrant."

# game/Scenes/Update19/Act2/act2scene10b.rpy:107
translate french u19a2s10b_cedc640d:

    # pc "All right, let's go then."
    pc "D'accord, allons-y alors."

# game/Scenes/Update19/Act2/act2scene10b.rpy:131
translate french u19a2s10b_516c6a7e:

    # gl "Whattup, bitches? I'm Izzy and we gonna be good friends."
    gl "Ça va, les filles ? Je m'appelle Izzy et on va devenir de bonnes amies."

# game/Scenes/Update19/Act2/act2scene10b.rpy:158
translate french u19a2s10b_31fd58d7:

    # "With that, we continue on the path north together."
    "Sur ce, on continue ensemble notre chemin vers le nord."

