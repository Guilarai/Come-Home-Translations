# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Update19/Act3/act3scene4.rpy:4
translate french act3scene4_594c2912:

    # "In a blink, I'm suddenly back in the Ice Queen's throne room."
    "En un clin d’œil, je me retrouve soudain dans la salle du trône de la Reine des Glaces."

# game/Scenes/Update19/Act3/act3scene4.rpy:6
translate french act3scene4_41d6859f:

    # "My friends are still frozen around me, but I feel my body thawing."
    "Mes amis sont toujours figés autour de moi, mais je sens mon corps se dégeler."

# game/Scenes/Update19/Act3/act3scene4.rpy:9
translate french act3scene4_785bdb9f:

    # "When I can move again, I stumble forward and almost fall."
    "Quand je peux à nouveau bouger, je trébuche en avant et manque de tomber."

# game/Scenes/Update19/Act3/act3scene4.rpy:10
translate french act3scene4_9fe7bb42:

    # "But I'm able to stop myself and it seems that the Ice Queen didn't notice."
    "Mais j’arrive à me rattraper et il semble que la Reine des Glaces ne s’en soit pas aperçue."

# game/Scenes/Update19/Act3/act3scene4.rpy:11
translate french act3scene4_269679eb:

    # "Time to make my move."
    "Il est temps de passer à l’action."

# game/Scenes/Update19/Act3/act3scene4.rpy:15
translate french act3scene4_f4ddd564:

    # "I rush up and hug her from behind, pulling her close to me."
    "Je me précipite et la serre dans mes bras par derrière, la tirant vers moi."

# game/Scenes/Update19/Act3/act3scene4.rpy:16
translate french act3scene4_6145e44f:

    # sp "WHAT!?"
    sp "QUOI ?!"

# game/Scenes/Update19/Act3/act3scene4.rpy:17
translate french act3scene4_d519fcc2:

    # sp "{i}WHAT{/i} are you doing? Unhand me!"
    sp "{i}QUOI{/i} fais-tu ? Lâche-moi !"

# game/Scenes/Update19/Act3/act3scene4.rpy:20
translate french act3scene4_0d90b60a:

    # pc "I'm sorry that you lost Suzy. I'm so sorry that happened to you."
    pc "Je suis désolé que tu aies perdu Suzy. Je suis vraiment désolé que cela t'arrive."

# game/Scenes/Update19/Act3/act3scene4.rpy:21
translate french act3scene4_641a9d68:

    # sp "Don't say her name--"
    sp "Ne prononce pas son nom..."

# game/Scenes/Update19/Act3/act3scene4.rpy:22
translate french act3scene4_ad5d8a1e:

    # pc "I know your heart is broken."
    pc "Je sais que tu as le cœur brisé."

# game/Scenes/Update19/Act3/act3scene4.rpy:23
translate french act3scene4_c39f9ad8:

    # pc "That just shows how much love you had."
    pc "Cela montre à quel point tu l'aimais."

# game/Scenes/Update19/Act3/act3scene4.rpy:24
translate french act3scene4_eb5ca914:

    # sp "You don't know--"
    sp "Tu ne sais pas..."

# game/Scenes/Update19/Act3/act3scene4.rpy:27
translate french act3scene4_82d048f3:

    # pc "Suzy wants you to know that she loves you so much."
    pc "Suzy veut que tu saches qu'elle t'aime tellement."

# game/Scenes/Update19/Act3/act3scene4.rpy:28
translate french act3scene4_acba1f83:

    # sp "Stop--"
    sp "Arrête..."

# game/Scenes/Update19/Act3/act3scene4.rpy:31
translate french act3scene4_cdd644dd:

    # pc "She wants you to know that she's going to always be with you."
    pc "Elle veut que tu saches qu'elle sera toujours avec toi."

# game/Scenes/Update19/Act3/act3scene4.rpy:32
translate french act3scene4_10d0ad27:

    # sp "How do you--"
    sp "Comment peux-tu..."

# game/Scenes/Update19/Act3/act3scene4.rpy:35
translate french act3scene4_978f88d1:

    # pc "And she doesn't like seeing what you've become."
    pc "Et elle n'aime pas voir ce que tu es devenu."

# game/Scenes/Update19/Act3/act3scene4.rpy:36
translate french act3scene4_8144a68d:

    # pc "She wants you to be warm and loving again, like she remembers you."
    pc "Elle veut que tu redeviennes chaleureux et aimant, comme elle se souvient de toi."

# game/Scenes/Update19/Act3/act3scene4.rpy:37
translate french act3scene4_ad07f09a:

    # sp "I'm not--"
    sp "Je ne suis pas..."

# game/Scenes/Update19/Act3/act3scene4.rpy:40
translate french act3scene4_38d06822:

    # "She doesn't finish her sentence, instead bursting into tears and crumpling in my arms."
    "Elle ne termine pas sa phrase, mais fond en larmes et s'effondre dans mes bras."

# game/Scenes/Update19/Act3/act3scene4.rpy:41
translate french act3scene4_5b98a3b5:

    # pc "I'm sorry, Lisa. I'm sorry she's gone."
    pc "Je suis désolé, Lisa. Je suis désolé qu'elle soit partie."

# game/Scenes/Update19/Act3/act3scene4.rpy:42
translate french act3scene4_d761b7e0:

    # pc "I love you."
    pc "Je t'aime."

# game/Scenes/Update19/Act3/act3scene4.rpy:45
translate french act3scene4_3689094d:

    # "I hold her for a long time while she cries."
    "Je la serre longtemps dans mes bras pendant qu’elle pleure."

# game/Scenes/Update19/Act3/act3scene4.rpy:46
translate french act3scene4_fcd85bea:

    # "I wonder if she's ever let herself really feel the loss."
    "Je me demande si elle s’est déjà vraiment autorisée à ressentir cette perte."

# game/Scenes/Update19/Act3/act3scene4.rpy:47
translate french act3scene4_6f05f3c1:

    # "I wonder if she's ever had anybody to hold her like this."
    "Je me demande si elle a déjà eu quelqu’un pour la serrer ainsi dans ses bras."

# game/Scenes/Update19/Act3/act3scene4.rpy:50
translate french act3scene4_49651a35:

    # "After some time, she stops crying and sits up again."
    "Au bout d’un moment, elle cesse de pleurer et se redresse."

# game/Scenes/Update19/Act3/act3scene4.rpy:51
translate french act3scene4_77d46c18:

    # sp "Who {i}are{/i} you?"
    sp "Qui {i}es-tu{/i} ?"

# game/Scenes/Update19/Act3/act3scene4.rpy:52
translate french act3scene4_22be1576:

    # pc "It's a long story..."
    pc "C’est une longue histoire…"

# game/Scenes/Update19/Act3/act3scene4.rpy:53
translate french act3scene4_0eb855c9:

    # "So I tell her everything about the other world, about the bracelet, about coming here to see her."
    "Je lui raconte donc tout sur l’autre monde, sur le bracelet, sur ma venue ici pour la voir."

# game/Scenes/Update19/Act3/act3scene4.rpy:56
translate french act3scene4_299824e4:

    # sp "You did so much to find your father."
    sp "Tu as tant fait pour retrouver ton père."

# game/Scenes/Update19/Act3/act3scene4.rpy:57
translate french act3scene4_4aa0965e:

    # pc "Well yeah... I love him."
    pc "Eh bien oui… Je l’aime."

# game/Scenes/Update19/Act3/act3scene4.rpy:58
translate french act3scene4_2c93668b:

    # sp "I suppose so. I'd do anything to get Suzy back."
    sp "Je suppose que oui. Je ferais n’importe quoi pour récupérer Suzy."

# game/Scenes/Update19/Act3/act3scene4.rpy:61
translate french act3scene4_f8215d8f:

    # pc "I know, [mom]... but sometimes people can't come back."
    pc "Je sais, [mom]… mais parfois, les gens ne peuvent pas revenir."

# game/Scenes/Update19/Act3/act3scene4.rpy:62
translate french act3scene4_2022e63e:

    # pc "We lose people that we love sometimes..."
    pc "On perd parfois des gens qu’on aime…"

# game/Scenes/Update19/Act3/act3scene4.rpy:63
translate french act3scene4_d1689608:

    # pc "...and we have to find a way to deal with that without hurting ourselves or others."
    pc "… et on doit trouver un moyen de faire face à ça sans se faire de mal ni en faire aux autres."

# game/Scenes/Update19/Act3/act3scene4.rpy:66
translate french act3scene4_c3dfeaa2:

    # sp "How? How can a person deal with that sort of loss?"
    sp "Comment ? Comment peut-on faire face à ce genre de perte ?"

# game/Scenes/Update19/Act3/act3scene4.rpy:68
translate french act3scene4_8b7fb492:

    # pc "Well, in my world..."
    pc "Eh bien, dans mon monde..."

# game/Scenes/Update19/Act3/act3scene4.rpy:72
translate french act3scene4_22817e0f:

    # pc "... Nora lost what she thought her life was going to be."
    pc "... Nora a perdu ce qu’elle pensait que sa vie allait être."

# game/Scenes/Update19/Act3/act3scene4.rpy:73
translate french act3scene4_a6290b41:

    # pc "The man that was supposed to love her treated her badly and she was forced into this new life."
    pc "L’homme qui était censé l’aimer l’a maltraitée et elle a été contrainte de mener cette nouvelle vie."

# game/Scenes/Update19/Act3/act3scene4.rpy:74
translate french act3scene4_1e07804a:

    # pc "But she dove in and accepted it and is thriving on her own now."
    pc "Mais elle s’y est lancée, l’a acceptée et s’épanouit désormais par elle-même."

# game/Scenes/Update19/Act3/act3scene4.rpy:75
translate french act3scene4_03b53305:

    # pc "She's discovering that there's a lot of love out there if you let yourself be open to it."
    pc "Elle découvre qu’il y a beaucoup d’amour autour de soi si on se permet d’y être ouvert."

# game/Scenes/Update19/Act3/act3scene4.rpy:79
translate french act3scene4_ff6ea314:

    # pc "... Reba's father passed away and it put her whole family in a sort of limbo."
    pc "... Le père de Reba est décédé, ce qui a plongé toute sa famille dans une sorte de limbes."

# game/Scenes/Update19/Act3/act3scene4.rpy:80
translate french act3scene4_0115c38f:

    # pc "Her mother seems to have given up on her own life and Reba has been forced to take care of her."
    pc "Sa mère semble avoir renoncé à sa propre vie et Reba a été contrainte de s’occuper d’elle."

# game/Scenes/Update19/Act3/act3scene4.rpy:81
translate french act3scene4_233c26c0:

    # pc "But she's trying her best to move on and be a better version of herself, while also not forgetting about her family."
    pc "Mais elle fait de son mieux pour aller de l’avant et devenir une meilleure version d’elle-même, sans pour autant oublier sa famille."

# game/Scenes/Update19/Act3/act3scene4.rpy:85
translate french act3scene4_b0752170:

    # pc "... Dana lost what she thought her life was going to be."
    pc "... Dana a perdu ce qu’elle pensait que sa vie allait être."

# game/Scenes/Update19/Act3/act3scene4.rpy:86
translate french act3scene4_4054bf2c:

    # pc "The man that was supposed to love her treated her badly and her family didn't support her."
    pc "L'homme qui était censé l'aimer l'a maltraitée et sa famille ne l'a pas soutenue."

# game/Scenes/Update19/Act3/act3scene4.rpy:87
translate french act3scene4_e1dbd7a3:

    # pc "But she's finding herself again, and discovering that there's a lot of love out there if you let yourself be open to it."
    pc "Mais elle se redécouvre et se rend compte qu'il y a beaucoup d'amour autour de soi si l'on s'ouvre à lui."

# game/Scenes/Update19/Act3/act3scene4.rpy:91
translate french act3scene4_684ddcd7:

    # pc "... Adrian embraced her true self and some of the people she loved didn't support her."
    pc "... Adrian a assumé sa véritable identité et certaines des personnes qu'elle aimait ne l'ont pas soutenue."

# game/Scenes/Update19/Act3/act3scene4.rpy:92
translate french act3scene4_0baf3bdf:

    # pc "She lost her father because he loved {i}his{/i} idea of who she was more than her actual self."
    pc "Elle a perdu son père parce qu'il aimait {i}son{/i} idée de qui elle était plus qu'elle-même."

# game/Scenes/Update19/Act3/act3scene4.rpy:93
translate french act3scene4_0778a7bc:

    # pc "But she's happier than she's ever been and finding people who love her for who she really is."
    pc "Mais elle est plus heureuse qu’elle ne l’a jamais été et trouve des gens qui l’aiment pour ce qu’elle est vraiment."

# game/Scenes/Update19/Act3/act3scene4.rpy:97
translate french act3scene4_9eadd263:

    # pc "... Kendra is sick and will likely not live to be very old."
    pc "... Kendra est malade et ne vivra probablement pas très longtemps."

# game/Scenes/Update19/Act3/act3scene4.rpy:98
translate french act3scene4_5cec7ee5:

    # pc "When she dies, she will lose everybody and everybody will lose her."
    pc "Quand elle mourra, elle perdra tout le monde et tout le monde la perdra."

# game/Scenes/Update19/Act3/act3scene4.rpy:99
translate french act3scene4_fa1731ad:

    # pc "But she's determined to still love as hard as she can and enjoy life as much as she can while she's alive."
    pc "Mais elle est déterminée à continuer d’aimer de toutes ses forces et à profiter de la vie autant qu’elle le peut tant qu’elle est en vie."

# game/Scenes/Update19/Act3/act3scene4.rpy:103
translate french act3scene4_a64c27f0:

    # pc "... Juliana lost both of her parents and has grown up with her grandmother."
    pc "... Juliana a perdu ses deux parents et a grandi avec sa grand-mère."

# game/Scenes/Update19/Act3/act3scene4.rpy:104
translate french act3scene4_1653b6af:

    # pc "She's had a hard time making friends and has a lot of fear about loving someone and losing them."
    pc "Elle a eu du mal à se faire des amis et a très peur d’aimer quelqu’un et de le perdre."

# game/Scenes/Update19/Act3/act3scene4.rpy:105
translate french act3scene4_3e7f244a:

    # pc "But she's learning to put herself out there anyways, to make herself vulnerable."
    pc "Mais elle apprend à s’ouvrir aux autres malgré tout, à se rendre vulnérable."

# game/Scenes/Update19/Act3/act3scene4.rpy:106
translate french act3scene4_57cb2c2d:

    # pc "Because the rewards are worth it."
    pc "Car les récompenses en valent la peine."

# game/Scenes/Update19/Act3/act3scene4.rpy:110
translate french act3scene4_6fd90af8:

    # pc "... Mi-Cha hasn't lost anything yet, but she knows she will."
    pc "... Mi-Cha n’a encore rien perdu, mais elle sait qu’elle le fera."

# game/Scenes/Update19/Act3/act3scene4.rpy:111
translate french act3scene4_c726ce2f:

    # pc "She came to a place, gave her heart to somebody, and now she's being forced to leave that place and her love behind."
    pc "Elle est arrivée dans un endroit, a donné son cœur à quelqu’un, et maintenant elle est contrainte de quitter cet endroit et de laisser son amour derrière elle."

# game/Scenes/Update19/Act3/act3scene4.rpy:112
translate french act3scene4_3d2ddad3:

    # pc "Maybe it'll work out, but in the end. She knows it's better to love and lose than never love at all."
    pc "Peut-être que tout s’arrangera, mais au final, elle sait qu’il vaut mieux aimer et perdre que de ne jamais aimer du tout."

# game/Scenes/Update19/Act3/act3scene4.rpy:119
translate french act3scene4_322b87f1:

    # pc "... Mari has lost everything. Her whole family taken from her in a moment."
    pc "... Mari a tout perdu. Toute sa famille lui a été enlevée en un instant."

# game/Scenes/Update19/Act3/act3scene4.rpy:120
translate french act3scene4_29625c9a:

    # pc "She still lives in the shadow of that tragedy, but she shines brightly anyways."
    pc "Elle vit toujours dans l’ombre de cette tragédie, mais elle rayonne malgré tout."

# game/Scenes/Update19/Act3/act3scene4.rpy:121
translate french act3scene4_6a46eb5e:

    # pc "She carries on with their love inside of her, knowing that they would be proud of her."
    pc "Elle continue d’avancer avec leur amour en elle, sachant qu’ils seraient fiers d’elle."

# game/Scenes/Update19/Act3/act3scene4.rpy:125
translate french act3scene4_62feec4d:

    # pc "... Izzy lost both of her parents and has been put into a position where she has to care for her two little brothers."
    pc "... Izzy a perdu ses deux parents et s’est retrouvée dans une situation où elle doit s’occuper de ses deux petits frères."

# game/Scenes/Update19/Act3/act3scene4.rpy:126
translate french act3scene4_e5564799:

    # pc "She could be resentful of this, but she loves those two boys so much."
    pc "Elle pourrait en vouloir à la vie, mais elle aime tellement ces deux garçons."

# game/Scenes/Update19/Act3/act3scene4.rpy:127
translate french act3scene4_289024f9:

    # pc "When she thought she lost them, she fought so hard to get them back."
    pc "Quand elle a cru les avoir perdus, elle s’est battue de toutes ses forces pour les récupérer."

# game/Scenes/Update19/Act3/act3scene4.rpy:131
translate french act3scene4_a06ddb36:

    # pc "... Jamie loved a boy so much, but he tossed her aside without a word."
    pc "... Jamie aimait tellement un garçon, mais il l’a rejetée sans un mot."

# game/Scenes/Update19/Act3/act3scene4.rpy:132
translate french act3scene4_9714d5b1:

    # pc "But she kept moving forward, just being herself."
    pc "Mais elle a continué d’avancer, en restant simplement elle-même."

# game/Scenes/Update19/Act3/act3scene4.rpy:133
translate french act3scene4_7f79356e:

    # pc "And eventually, things came back around and worked out for her."
    pc "Et finalement, les choses ont tourné en sa faveur."

# game/Scenes/Update19/Act3/act3scene4.rpy:137
translate french act3scene4_d7d23337:

    # pc "And then there's me..."
    pc "Et puis il y a moi..."

# game/Scenes/Update19/Act3/act3scene4.rpy:139
translate french act3scene4_6cc0d265:

    # pc "Well, I can only talk about myself..."
    pc "Eh bien, je ne peux parler que de moi..."

# game/Scenes/Update19/Act3/act3scene4.rpy:140
translate french act3scene4_cdb25042:

    # pc "I lost my mom when I was a teenager and it was really hard on me."
    pc "J’ai perdu ma mère quand j’étais adolescent et ça a été très dur pour moi."

# game/Scenes/Update19/Act3/act3scene4.rpy:141
translate french act3scene4_739643a0:

    # pc "I took it out on the people around me and did things I regret."
    pc "Je m’en suis pris à mon entourage et j’ai fait des choses que je regrette."

# game/Scenes/Update19/Act3/act3scene4.rpy:142
translate french act3scene4_ac0e651a:

    # pc "But I've done my best to change that and make things right."
    pc "Mais j’ai fait de mon mieux pour changer ça et réparer mes erreurs."

# game/Scenes/Update19/Act3/act3scene4.rpy:145
translate french act3scene4_e7e67352:

    # sp "I suppose that's what I should do now."
    sp "Je suppose que c’est ce que je devrais faire maintenant."

# game/Scenes/Update19/Act3/act3scene4.rpy:146
translate french act3scene4_1e770403:

    # pc "I think so."
    pc "Je pense que oui."

# game/Scenes/Update19/Act3/act3scene4.rpy:147
translate french act3scene4_2610ae2e:

    # sp "I feel so ashamed. How can I face people?"
    sp "J’ai tellement honte. Comment vais-je pouvoir affronter les gens ?"

# game/Scenes/Update19/Act3/act3scene4.rpy:150
translate french act3scene4_5c7a5888:

    # pc "The ones that really matter still love you, Lisa."
    pc "Ceux qui comptent vraiment t’aiment toujours, Lisa."

# game/Scenes/Update19/Act3/act3scene4.rpy:151
translate french act3scene4_34903c2d:

    # pc "They feel the same loss that you feel."
    pc "Ils ressentent la même perte que toi."

# game/Scenes/Update19/Act3/act3scene4.rpy:152
translate french act3scene4_a346789c:

    # pc "But they feel like they lost {i}you{/i} as well."
    pc "Mais ils ont aussi l’impression de t’avoir perdue."

# game/Scenes/Update19/Act3/act3scene4.rpy:155
translate french act3scene4_02541c65:

    # tm "It's true, Your Majesty."
    tm "C’est vrai, Votre Majesté."

# game/Scenes/Update19/Act3/act3scene4.rpy:156
translate french act3scene4_e56ac275:

    # tm "I miss Suzy so much."
    tm "Suzy me manque tellement."

# game/Scenes/Update19/Act3/act3scene4.rpy:157
translate french act3scene4_2b1387cd:

    # tm "And I miss you too."
    tm "Et tu me manques aussi."

# game/Scenes/Update19/Act3/act3scene4.rpy:160
translate french act3scene4_909876ef:

    # sp "Oh God, I'm so sorry, Tammy. Of course you miss her too."
    sp "Oh mon Dieu, je suis tellement désolée, Tammy. Bien sûr qu’elle te manque aussi."

# game/Scenes/Update19/Act3/act3scene4.rpy:161
translate french act3scene4_ddc42ef4:

    # sp "I'll fix this. I'll make it better."
    sp "Je vais arranger ça. Je vais tout arranger."

# game/Scenes/Update19/Act3/act3scene4.rpy:165
translate french act3scene4_f8a1c7af:

    # sp "Starting with this."
    sp "En commençant par ça."

