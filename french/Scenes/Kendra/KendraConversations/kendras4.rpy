# game/Scenes/Kendra/KendraConversations/kendras4.rpy:34
translate french kendras4_47c89f5e:

    # sg "Who knows what's going to happen tomorrow, so why worry about it?"
    sg "Qui sait ce qui va se passer demain, alors pourquoi s'en inquiéter ?"

