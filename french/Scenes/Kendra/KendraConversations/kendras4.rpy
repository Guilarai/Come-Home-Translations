translate french kendras4_da33da98:

    # sg "Nah, man. I'm not going to waste my life working at some job that I hate."
    sg "Non, mec. Je vais pas gâcher ma vie à faire un boulot que je déteste."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:14
translate french kendras4_154f33d2:

    # pc "What about money?"
    pc "Et l'argent ?"

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:16
translate french kendras4_3bdab488:

    # sg "Don't need it."
    sg "J'en ai pas besoin."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:17
translate french kendras4_1ea5be82:

    # sg "Why the hell would I need money?"
    sg "Pourquoi j'aurais besoin d'argent, bordel ?"

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:18
translate french kendras4_a5acda19:

    # pc "I don't know. To buy stuff? Food? Clothes?"
    pc "Je sais pas. Pour acheter des trucs ? De la bouffe ? Des fringues ?"

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:19
translate french kendras4_f972c97b:

    # sg "Eh, I get by. I don't need much."
    sg "Eh, je m'en sors. J'ai pas besoin de grand-chose."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:21
translate french kendras4_45cb15cf:

    # sg "I just value my time much more than anybody could pay me."
    sg "C'est juste que j'accorde bien plus de valeur à mon temps que ce que n'importe qui pourrait me payer."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:22
translate french kendras4_484e8cb5:

    # pc "I guess that makes sense, but I worry about what's going to happen in the future."
    pc "Je suppose que ça se tient, mais moi, je m'inquiète de ce qui va se passer dans le futur."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:23
translate french kendras4_c26abf81:

    # sg "Not me. No point."
    sg "Pas moi. Ça sert à rien."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:24
translate french kendras4_a2a6fb65:

    # pc "What do you mean?"
    pc "T'entends quoi par là ?"

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:26
translate french kendras4_4908e6af:

    # sg "I mean who knows if I'm even going to be here tomorrow, so why worry about it?"
    sg "Je veux dire, qui sait si je serai encore là demain, alors pourquoi s'en inquiéter ?"

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:27
translate french kendras4_00f6902e:

    # pc "Why wouldn't you be here tomorrow?"
    pc "Pourquoi tu ne serais pas là demain ?"

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:29
translate french kendras4_1ebd7d80:

    # sg "I don't fucking know, [pcname]."
    sg "J'en sais rien, putain, [pcname]."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:30
translate french kendras4_92ebfa3d:

    # sg "Maybe I have a brain aneurysm. Maybe I get hit by a truck."
    sg "Peut-être que j'aurai un anévrisme cérébral. Peut-être que je me ferai renverser par un camion."

# game/Scenes/Kendra/KendraConversations/kendras4.rpy:32
translate french kendras4_9caef9ae:

    # sg "Maybe a fucking meteor falls from the sky and smashes my head in?"
