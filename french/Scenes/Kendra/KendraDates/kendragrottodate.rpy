    # "I drive over and pick Kendra up."
    "Je passe la prendre."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:24
translate french kendragrottostartdate_63ac34de:

    # "As soon as I park the car, she jumps into the passenger seat."
    "Dès que je gare la voiture, elle saute sur le siège passager."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:31
translate french kendragrottostartdate_d41d8cd9:

    # voice 'voices/kendra_whoa.wav'
    voice 'voices/kendra_whoa.wav'

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:32
translate french kendragrottostartdate_cbfbb13b:

    # sg "Woah, you're wearing a suit. So fancy! You look like a fucking stud!"
    sg "Waouh, tu portes un costume. C'est tellement chic ! T'as l'air d'un vrai tombeur !"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:33
translate french kendragrottostartdate_93be84d9:

    # pc "Thanks! You look amazing too."
    pc "Merci ! T'es superbe toi aussi."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:34
translate french kendragrottostartdate_f9a9256b:

    # sg "Yeah, I got all dressed up and shit. No big. Let's go eat!"
    sg "Ouais, je me suis mise sur mon trente-et-un. C'est pas grand-chose. Allons manger !"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:36
translate french kendragrottostartdate_eddccec4:

    # sg "I'm so hungry! Let's eat!"
    sg "J'ai tellement faim ! Allons manger !"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:40
translate french kendragrottostartdate_92e5e80f:

    # "We drive to The Grotto and are led to a table by the host."
    "On roule jusqu'au Grotto et l'hôte nous conduit à une table."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:45
translate french kendragrottostartdate_2e543208:

    # "We sit at our table and begin looking over the menus."
    "On s'assoit à notre table et on commence à parcourir les menus."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:46
translate french kendragrottostartdate_5508ff55:

    # sg "Wow this place is so fancy. Is the food here any good?"
    sg "Waouh, cet endroit est tellement chic. La bouffe est bonne ici ?"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:47
translate french kendragrottostartdate_494fc97b:

    # pc "Yeah, it's amazing."
    pc "Ouais, c'est incroyable."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:48
translate french kendragrottostartdate_f3f82f77:

    # sg "That's good. Whenever my parents took me to fancy restaurants like this, the food would always end up looking super pretty, but tasting gross."
    sg "C'est bien. Chaque fois que mes parents m'emmenaient dans des restos chics comme ça, la bouffe avait toujours l'air super jolie, mais avait un goût dégueulasse."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:49
translate french kendragrottostartdate_720f2b03:

    # sg "Like they want to put some weird spices on it or something to make it different from other places, but I just want some dang chicken nuggets, you know?"
    sg "Comme s'ils voulaient mettre des épices bizarres dessus ou un truc du genre pour que ça soit différent des autres endroits, mais moi je veux juste des fichus nuggets de poulet, tu vois ?"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:50
translate french kendragrottostartdate_039e7c94:

    # pc "Ha, you order whatever you'd like."
    pc "Ha, tu commandes ce que tu veux."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:56
translate french kendragrottostartdate_45ee2ac4:

    # "A couple of minutes later the server approaches us to take our order."
    "Quelques minutes plus tard, le serveur s'approche de nous pour prendre notre commande."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:57
translate french kendragrottostartdate_477af30d:

    # "Server" "Are you ready to place your order, or would you like some more time to look over the menu? I can answer any questions you have."
    "Server" "Êtes-vous prêtes à commander, ou souhaitez-vous un peu plus de temps pour consulter le menu ? Je peux répondre à toutes vos questions."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:58
translate french kendragrottostartdate_11cbd844:

    # sg "Do y'all have any chicken nuggets?"
    sg "Avez-vous des nuggets de poulet ?"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:59
translate french kendragrottostartdate_2e8784f2:

    # "Server" "We have pan-fried buttermilk and panko chicken breast medallions, served over shingled potatoes with a creamy thyme sauce."
    "Server" "Nous avons des médaillons de blanc de poulet poêlés au babeurre et à la chapelure panko, servis sur un lit de pommes de terre en lamelles avec une sauce crémeuse au thym."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:60
translate french kendragrottostartdate_e04bae2d:

    # sg "Is that kinda like chicken nuggets?"
    sg "C'est un peu comme des nuggets de poulet ?"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:61
translate french kendragrottostartdate_b16a388e:

    # "Server" "Yes ma'am. It's like chicken nuggets."
    "Server" "Oui madame. C'est comme des nuggets de poulet."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:62
translate french kendragrottostartdate_f57e52c6:

    # sg "Gimme some of them then. And a Dr. Pepper."
    sg "Donne-m'en quelques-uns alors. Et un Dr Pepper."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:65
translate french kendragrottostartdate_3d97b32c:

    # "After the server takes our orders, Kendra and I chat for a while."
    "Une fois que le serveur a pris notre commande, Kendra et moi discutons un moment."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:68
translate french kendragrottostartdate_55bc048d:

    # "After we talk for a while, our food is brought out."
    "Après avoir bavardé un moment, on nous apporte notre repas."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:72
translate french kendragrottostartdate_12bdb83d:

    # sg "I don't think these people know what chicken nuggets are."
    sg "Je crois pas que ces gens-là sachent ce que sont des nuggets de poulet."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:75
translate french kendragrottostartdate_84073847:

    # sg "Oh well. I'm hungry. I'll give it a try."
    sg "Bon, tant pis. J'ai faim. Je vais goûter."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:78
translate french kendragrottostartdate_bfde7d54:

    # "We continue chatting and eating."
    "On continue à discuter et à manger."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:88
translate french kendragrottostartdate_35489cf9:

    # "When the waiter brings the bill out, Kendra quickly snatches it up."
    "Quand le serveur apporte l'addition, Kendra s'en empare rapidement."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:89
translate french kendragrottostartdate_618f396f:

    # sg "Wait, these chicken nuggets were thirty bucks!?"
    sg "Attends, ces nuggets de poulet coûtaient trente dollars ?!"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:90
translate french kendragrottostartdate_4853a04c:

    # sg "That's crazy! They were good, but I could get like 200 nuggies from McDonalds for that price."
    sg "C'est dingue ! Ils étaient bons, mais je pourrais avoir genre 200 nuggets chez McDonald's pour ce prix-là."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:91
translate french kendragrottostartdate_011e7134:

    # pc "You're paying for the atmosphere here too. Can't get a view like this at McDonalds."
    pc "Tu paies aussi pour l'ambiance ici. On a pas une vue comme ça chez McDonald's."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:92
translate french kendragrottostartdate_5895d784:

    # sg "Yeah I guess. But dang, thirty dollars?"
    sg "Ouais, je suppose. Mais bon sang, trente dollars ?"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:93
translate french kendragrottostartdate_7ceb71ac:

    # pc "Don't worry about that. I got it."
    pc "Ne t'en fais pas pour ça. Je m'en occupe."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:94
translate french kendragrottostartdate_738449bb:

    # sg "If you say so. Just know, you don't have to take me anywhere fancy and expensive. I'd be just as happy anywhere else with you."
    sg "Si tu le dis. Sache juste que tu n'as pas besoin de m'emmener dans un endroit chic et cher. Je serais tout aussi heureuse n'importe où ailleurs avec toi."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:100
translate french kendragrottostartdate_99c80cd6:

    # "After I pay, we start to walk out and stop to look over the lake for a moment."
    "Après avoir payé, on commence à sortir et on s'arrête un instant pour admirer le lac."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:101
translate french kendragrottostartdate_a1d66bdf:

    # sg "It {i}is{/i} really pretty though."
    sg "C'est {i}vraiment{/i} joli quand même."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:110
translate french kendragrottostartdate_cd966f27:

    # "I lean in and kiss her. She returns the kiss passionately, pressing hard into my mouth, her hands climbing up my body."
    "Je me penche vers elle et l'embrasse. Elle me rend mon baiser avec passion, pressant ses lèvres contre les miennes, ses mains remontant le long de mon corps."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:111
translate french kendragrottostartdate_f0046ea4:

    # pc "Do you want to dance?"
    pc "Tu veux danser ?"

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:112
translate french kendragrottostartdate_3f909766:

    # sg "Not really. I want you to take me back to your place and pound me into your bed."
    sg "Pas vraiment. Je veux que tu m'emmènes chez toi et que tu me prennes dans ton lit."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:113
translate french kendragrottostartdate_1909f58c:

    # pc "That sounds good too."
    pc "Ça me va aussi."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:120
translate french kendragrottostartdate_72295199:

    # "We leave, then drive back to my house and rush up to my bedroom, barely able to keep our hands off each other."
    "On part, puis on rentre chez moi en voiture et on se précipite dans ma chambre, à peine capables de nous empêcher de nous toucher."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:127
translate french kendragrottostartdate_72295199_1:

    # "We leave, then drive back to my house and rush up to my bedroom, barely able to keep our hands off each other."
    "On part, puis on rentre chez moi et on se précipite dans ma chambre, incapables de nous empêcher de nous toucher."

# game/Scenes/Kendra/KendraDates/kendragrottodate.rpy:130
translate french kendragrottostartdate_60db26d1:

    # "We go get in the car, then I drive her back to her house and tell her goodnight."
    "On monte dans la voiture, puis je la ramène chez elle et je lui dis bonne nuit."

