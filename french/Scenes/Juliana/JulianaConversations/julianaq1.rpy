# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:12
translate french julianaq1_1cacfd33:

    # bn "What are you majoring in?"
    bn "Tu fais quoi comme études ?"

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:13
translate french julianaq1_5d06df91:

    # pc "Quantum physics."
    pc "De la physique quantique."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:15
translate french julianaq1_c1d9d633:

    # bn "Really?"
    bn "Vraiment ?"

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:16
translate french julianaq1_2daa63ba:

    # bn "Are you just messing with me?"
    bn "Tu te moques de moi ?"

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:17
translate french julianaq1_9844e31a:

    # pc "No, really. I'm already done with all my science courses. I did them when I was down in Brazil."
    pc "Non, vraiment. J’ai déjà fini tous mes cours de sciences. Je les ai suivis quand j’étais au Brésil."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:19
translate french julianaq1_b6dd3987:

    # bn "Well, I'm impressed. I had no idea that you were so smart."
    bn "Eh bien, je suis impressionnée. Je ne savais pas que tu étais si intelligent."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:21
translate french julianaq1_85604386:

    # bn "Oh! I'm sorry! That came out wrong!"
    bn "Oh ! Je suis désolée ! Ça n'est pas sorti comme ça !"

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:22
translate french julianaq1_364509ec:

    # bn "I didn't mean that I thought you were dumb or anything. Just, I wouldn't have expected you to be a scientist."
    bn "Je ne voulais pas dire que je te trouvais bête ou quoi que ce soit. C'est juste que je ne m'attendais pas à ce que tu sois scientifique."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:24
translate french julianaq1_b121e8d9:

    # bn "Ugh! I'm sorry."
    bn "Ugh ! Je suis désolée."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:25
translate french julianaq1_8c3b35c6:

    # pc "It's okay. I know what you meant… I think."
    pc "C'est bon. Je sais ce que tu voulais dire… Je crois."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:26
translate french julianaq1_7707110b:

    # bn "I'm so bad at this."
    bn "Je suis tellement nulle à ça."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:27
translate french julianaq1_db66b636:

    # pc "What? Talking?"
    pc "Quoi ? Parler ?"

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:29
translate french julianaq1_eda6e479:

    # bn "Yes? Specifically to guys that I like."
    bn "Oui ? Surtout avec les garçons qui me plaisent."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:30
translate french julianaq1_1e75dd6f:

    # pc "You just need practice. We'll talk a lot more. You'll get better at it."
    pc "Il te faut juste un peu de pratique. On en reparlera souvent. Tu t'amélioreras."

# game/Scenes/Juliana/JulianaConversations/julianaq1.rpy:31
translate french julianaq1_65100e8b:

    # bn "I hope so. Couldn't get much worse."
    bn "J'espère bien. Ça ne pourrait pas être pire."

