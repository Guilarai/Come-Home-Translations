# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:15
translate french julianap4_0d4f184b:

    # bn "No. I don't."
    bn "Non. Je n’ai pas envie."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:16
translate french julianap4_6a7bc165:

    # bn "Which honestly surprises me."
    bn "Ce qui, honnêtement, me surprend."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:18
translate french julianap4_5006c5c9:

    # bn "I told myself that the most logical way for me to determine what I like is to try different things with different people."
    bn "Je me suis dit que la façon la plus logique pour moi de déterminer ce que j’aime, c’est d’essayer différentes choses avec différentes personnes."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:19
translate french julianap4_2010fc71:

    # bn "Five people, minimum. That's what I decided."
    bn "Cinq personnes, au minimum. C’est ce que j’ai décidé."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:21
translate french julianap4_41ddadc4:

    # bn "And at least two women. Just so I have enough data to make a real decision."
    bn "Et au moins deux femmes. Juste pour avoir assez de données pour prendre une vraie décision."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:23
translate french julianap4_19816440:

    # bn "But I don't need that anymore. I know what I want."
    bn "Mais je n'en ai plus besoin. Je sais ce que je veux."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:25
translate french julianap4_3314ac6e:

    # bn "I want you. Only you."
    bn "Je te veux. Toi seule."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:26
translate french julianap4_ce7650ca:

    # pc "That's uh... that's really nice, Juliana."
    pc "C'est... c'est vraiment gentil, Juliana."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:27
translate french julianap4_1b67228c:

    # pc "I want you too."
    pc "Je te veux aussi."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:29
translate french julianap4_f57a8165:

    # bn "Not {i}just{/i} me though, right?"
    bn "Mais pas {i}seulement{/i} moi, n'est-ce pas ?"

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:30
translate french julianap4_944b5ed3:

    # pc "Well..."
    pc "Eh bien..."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:32
translate french julianap4_ac511e0c:

    # bn "It's okay. You don't have to decide now."
    bn "Ce n'est pas grave. Tu n'as pas à te décider tout de suite."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:34
translate french julianap4_8e2ce633:

    # bn "But I hope one day soon you will want just me."
    bn "Mais j'espère qu'un jour prochain, tu ne voudras que moi."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:35
translate french julianap4_dd039758:

    # bn "I want to be yours."
    bn "Je veux être à toi."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:37
translate french julianap4_3ccbbaf1:

    # bn "I just wanted you to know that. It's something I've been meaning to tell you."
    bn "Je voulais juste que tu le saches. C'est quelque chose que j'avais envie de te dire depuis longtemps."

# game/Scenes/Juliana/JulianaConversations/julianap4.rpy:38
translate french julianap4_3f0a7992:

    # pc "I'm glad you did."
    pc "Je suis content que tu l'aies fait."

