# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:14
translate french julianaq6_3cacc2d7:

    # bn "[pcname]... I want to ask you something kind of serious."
    bn "[pcname]… Je voudrais te poser une question assez sérieuse."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:15
translate french julianaq6_7b63426e:

    # pc "Sure. Go ahead."
    pc "Bien sûr. Vas-y."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:17
translate french julianaq6_6877f574:

    # bn "Do you want to move into an apartment with me?"
    bn "Tu veux emménager dans un appartement avec moi ?"

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:18
translate french julianaq6_62bf3353:

    # pc "Wow... that's a little sudden."
    pc "Ouah... ça tombe un peu à l'improviste."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:20
translate french julianaq6_7b77325d:

    # bn "I'm sorry. I didn't mean to spring it on you."
    bn "Je suis désolée. Je ne voulais pas te prendre au dépourvu."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:22
translate french julianaq6_2e6419a0:

    # bn "I've just been thinking about things."
    bn "J'ai juste réfléchi à tout ça."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:23
translate french julianaq6_bc43805b:

    # bn "I really like you, [pcname]."
    bn "Je t'aime vraiment beaucoup, [pcname]."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:24
translate french julianaq6_cc7ae2f3:

    # bn "No... more than that. I'm in love with you."
    bn "Non... plus que ça. Je suis amoureuse de toi."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:26
translate french julianaq6_2383195e:

    # bn "I miss you any time we're not together."
    bn "Tu me manques dès que nous ne sommes pas ensemble."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:27
translate french julianaq6_3a26c9b9:

    # bn "I want to be with you more, so that I won't miss you so much."
    bn "Je veux passer plus de temps avec toi, pour que tu ne me manques pas autant."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:28
translate french julianaq6_e7c0c16e:

    # bn "I want our relationship to be more serious."
    bn "Je veux que notre relation devienne plus sérieuse."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:30
translate french julianaq6_2368faf1:

    # bn "I've thought about marriage and kids..."
    bn "J'ai pensé au mariage et aux enfants..."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:32
translate french julianaq6_1941b42b:

    # bn "But before marriage, I think it's important to live with each other for a while."
    bn "Mais avant de nous marier, je pense qu'il est important de vivre ensemble pendant un certain temps."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:34
translate french julianaq6_08d13444:

    # bn "If we got married, but you were very annoying to live with, that could cause friction and divorce."
    bn "Si on se mariait et que tu étais insupportable à vivre, ça pourrait causer des tensions et mener au divorce."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:35
translate french julianaq6_2389408e:

    # bn "I don't want to be a divorcee."
    bn "Je ne veux pas être divorcée."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:37
translate french julianaq6_613c2f28:

    # bn "So I'd like to get an apartment with you and then live together for at least two years before we get married."
    bn "J'aimerais donc trouver un appartement avec toi et vivre ensemble pendant au moins deux ans avant de nous marier."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:38
translate french julianaq6_cc374d09:

    # pc "That sounds like a good plan. It's still a little sudden."
    pc "Ça me semble être un bon plan. C'est quand même un peu soudain."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:40
translate french julianaq6_b97ca13c:

    # bn "Oh. I'm sorry. We don't have to move in together immediately."
    bn "Oh. Je suis désolée. On n'est pas obligés d'emménager ensemble tout de suite."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:41
translate french julianaq6_a67e3d44:

    # bn "I was thinking over the summer. After the semester is over."
    bn "Je pensais plutôt à l'été. Une fois le semestre terminé."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:42
translate french julianaq6_8f9cc15b:

    # pc "Yeah, that's coming up soon."
    pc "Oui, ça approche à grands pas."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:44
translate french julianaq6_9d04ce0e:

    # bn "And I'd want to be exclusive then."
    bn "Et j'aimerais qu'on soit exclusifs à ce moment-là."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:46
translate french julianaq6_b0b7432c:

    # bn "I know you're seeing other people... I don't have a problem with that."
    bn "Je sais que tu vois d’autres personnes… Ça ne me pose pas de problème."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:48
translate french julianaq6_799bd235:

    # bn "But I'd want us to be honest with each other if we're living together."
    bn "Mais j’aimerais qu’on soit honnêtes l’un envers l’autre si on vit ensemble."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:49
translate french julianaq6_6b702eae:

    # pc "Makes sense."
    pc "C’est logique."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:51
translate french julianaq6_30c36a56:

    # bn "If you decide that you don't want things to get more serious with me... I'll understand."
    bn "Si tu décides que tu ne veux pas que les choses deviennent plus sérieuses entre nous… je comprendrai."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:53
translate french julianaq6_eaad1423:

    # bn "I'll be sad, but I'm still thankful for everything that you've introduced me to."
    bn "Je serai triste, mais je te serai quand même reconnaissante pour tout ce que tu m’as fait découvrir."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:55
translate french julianaq6_813a7b44:

    # bn "I don't mind if you want to keep things like they are, but I should probably start looking for another boyfriend, if that's the case."
    bn "Ça ne me dérange pas si tu veux que les choses restent comme ça, mais je devrais probablement commencer à chercher un autre petit ami, si c'est le cas."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:57
translate french julianaq6_2a406892:

    # bn "I do want to get married and have kids one day."
    bn "Je veux me marier et avoir des enfants un jour."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:58
translate french julianaq6_62e7a7c7:

    # bn "I should find a man who also wants those things with me."
    bn "Je devrais trouver un homme qui souhaite aussi ces choses avec moi."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:59
translate french julianaq6_5edd1314:

    # pc "I'll be thinking about it."
    pc "J'y réfléchirai."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:60
translate french julianaq6_31b844dd:

    # pc "You're amazing, Juliana and any man will be lucky to marry you."
    pc "Tu es formidable, Juliana, et n'importe quel homme aura de la chance de t'épouser."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:62
translate french julianaq6_7767853c:

    # bn "Thank you, [pcname]."
    bn "Merci, [pcname]."

# game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:64
translate french julianaq6_c4ceb757:

    # bn "Whatever you choose, I will always love you and appreciate everything you've done for me."
    bn "Quel que soit ton choix, je t'aimerai toujours et j'apprécierai tout ce que tu as fait pour moi."

translate french strings:

    # game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:2
    old "This is a question that Juliana will ask on a date."
    new "C'est une question que Juliana posera lors d'un rendez-vous."

    # game/Scenes/Juliana/JulianaConversations/julianaq6.rpy:3
    old "To unlock this conversation, you must progress with the main story until Whitney has finished the portal and Juliana has asked all her other questions."
    new "Pour débloquer cette conversation, tu dois progresser dans l'histoire principale jusqu'à ce que Whitney ait terminé le portail et que Juliana ait posé toutes ses autres questions."

