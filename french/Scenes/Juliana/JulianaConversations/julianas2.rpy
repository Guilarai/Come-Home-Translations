translate french julianas2_c0b8df8d:

    # bn "Hm. Maybe Beloved? Or Jane Eyre?"
    bn "Hum. Peut-être Beloved ? Ou Jane Eyre ?"

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:15
translate french julianas2_e7b3f581:

    # bn "There's a newer book called Homegoing by Yaa Gyasi. That might be my favorite book written in my lifetime."
    bn "Il y a un livre plus récent intitulé Homegoing, de Yaa Gyasi. C'est peut-être mon livre préféré de toute ma vie."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:16
translate french julianas2_7a090c45:

    # pc "I've never read any of those."
    pc "Je n'ai jamais lu aucun de ceux-là."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:18
translate french julianas2_7291f8be:

    # bn "You don't read much?"
    bn "Tu ne lis pas beaucoup ?"

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:21
translate french julianas2_3265c09b:

    # pc "I just haven't read any of those books."
    pc "C'est juste que je n'ai lu aucun de ces livres."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:23
translate french julianas2_8af4dd8a:

    # bn "Oh, that's cool. Give them a try sometime maybe? They're really good."
    bn "Oh, c'est cool. Tu devrais peut-être les essayer un jour ? Ils sont vraiment bons."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:26
translate french julianas2_a5e9444c:

    # pc "Just not that kind of book."
    pc "Ce n'est juste pas mon genre de livres."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:28
translate french julianas2_f8a5291b:

    # bn "Oh, that's cool. I read a lot of other genres as well."
    bn "Oh, c'est cool. Je lis aussi beaucoup d'autres genres."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:29
translate french julianas2_a5da21dd:

    # bn "I've read Stephen King, some fantasy, and even some comic books."
    bn "J'ai lu Stephen King, un peu de fantasy, et même des bandes dessinées."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:30
translate french julianas2_b11e8737:

    # bn "But I tend to enjoy the more serious books about human relationships."
    bn "Mais j'ai tendance à préférer les livres plus sérieux sur les relations humaines."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:33
translate french julianas2_06ccfd57:

    # bn "Oh, okay."
    bn "Oh, d'accord."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:34
translate french julianas2_75c3ff7b:

    # bn "I think that a lot of people don't read much anymore."
    bn "Je pense que beaucoup de gens ne lisent plus beaucoup."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:35
translate french julianas2_d3079f8d:

    # bn "I guess with all the television, movies, and video games, there are so many other ways to experience stories."
    bn "Je suppose qu'avec la télévision, les films et les jeux vidéo, il y a tellement d'autres façons de découvrir des histoires."

# game/Scenes/Juliana/JulianaConversations/julianas2.rpy:36
translate french julianas2_46c4be03:

    # bn "There's just something about curling up with a good book that I love more than anything."
    bn "Mais il y a quelque chose dans le fait de se blottir avec un bon livre que j'aime plus que tout."

