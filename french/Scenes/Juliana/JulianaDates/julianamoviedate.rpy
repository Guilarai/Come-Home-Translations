# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:32
translate french julianamovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "On arrive au cinéma et on s'assoit au fond."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:33
translate french julianamovietheaterstartdate_cd1f1d61:

    # bn "What kind of movie are we watching?"
    bn "On va voir quel genre de film ?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:37
translate french julianamovietheaterstartdate_9753ecc6:

    # bn "That sounds very nice."
    bn "Ça a l'air très sympa."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:38
translate french julianamovietheaterstartdate_08edcd3e:

    # bn "I like romantic movies."
    bn "J'aime bien les films romantiques."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:43
translate french julianamovietheaterstartdate_22be6204:

    # bn "Oh really?"
    bn "Ah vraiment ?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:44
translate french julianamovietheaterstartdate_a7aa68a8:

    # bn "I'm not really interested dumb action movies, but okay."
    bn "Je ne suis pas vraiment fan des films d'action stupides, mais bon."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:50
translate french julianamovietheaterstartdate_a36785e7:

    # bn "Oh really? I don't really like scary movies at all."
    bn "Ah vraiment ? Je n'aime pas du tout les films d'horreur."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:51
translate french julianamovietheaterstartdate_5b88690f:

    # bn "Unless they're about hauntings, or they have some sort of romance in them."
    bn "Sauf s’ils parlent de fantômes, ou s’il y a une histoire d’amour dedans."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:52
translate french julianamovietheaterstartdate_ffedd8a3:

    # bn "Most horror movies are really dumb."
    bn "La plupart des films d’horreur sont vraiment nuls."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:58
translate french julianamovietheaterstartdate_352ba7de:

    # bn "Oh okay."
    bn "Oh d’accord."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:59
translate french julianamovietheaterstartdate_9c6a96f5:

    # bn "I try to enjoy comedies, but I don't always get the jokes."
    bn "J’essaie d’apprécier les comédies, mais je ne comprends pas toujours les blagues."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:60
translate french julianamovietheaterstartdate_74eb3e05:

    # bn "There's a lot of times that I just don't understand what is supposed to be funny and what's not."
    bn "Souvent, je ne comprends tout simplement pas ce qui est censé être drôle et ce qui ne l’est pas."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:61
translate french julianamovietheaterstartdate_cf50250b:

    # bn "But I'll try my best to laugh at the parts I'm supposed to."
    bn "Mais je ferai de mon mieux pour rire aux moments où je suis censée le faire."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:63
translate french julianamovietheaterstartdate_2fcc7df5:

    # "There's a little time before the movie starts for us to chat some."
    "On a un peu de temps avant le début du film pour discuter un peu."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:67
translate french julianamovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Enfin, le film commence et on se tait."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:70
translate french julianamovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Elle se penche vers moi et me prend la main par-dessus l’accoudoir."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:74
translate french julianamovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Les bandes-annonces durent environ quinze minutes, puis le film commence vraiment."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:78
translate french julianamovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Pendant le film, elle s’appuie contre mon épaule, complètement absorbée par l’histoire."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:80
translate french julianamovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Puis, lors d’une scène particulièrement romantique, elle lève la tête et pose ses lèvres sur les miennes."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:81
translate french julianamovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "On ne regarde pas vraiment le reste du film, on passe plutôt notre temps à s’embrasser."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:84
translate french julianamovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Pendant le film, elle s’appuie contre mon épaule, complètement absorbée par l’histoire."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:86
translate french julianamovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Elle a l’air d’apprécier le film."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:89
translate french julianamovietheaterstartdate_dcbaecf4:

    # "Juliana watches the movie, but she looks annoyed the entire time."
    "Juliana regarde le film, mais elle a l’air agacée tout le temps."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:92
translate french julianamovietheaterstartdate_40670365:

    # "Eventually, she turns towards me."
    "Finalement, elle se tourne vers moi."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:93
translate french julianamovietheaterstartdate_b867ff88:

    # bn "This movie is really bad, isn't it? It might be the worst movie I've ever seen."
    bn "Ce film est vraiment nul, non ? C’est peut-être le pire film que j’ai jamais vu."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:94
translate french julianamovietheaterstartdate_e3d0d8a6:

    # "She does not speak quietly, and some people in front of us turn and look at us."
    "Elle ne parle pas à voix basse, et certaines personnes devant nous se retournent pour nous regarder."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:95
translate french julianamovietheaterstartdate_d58327fc:

    # pc "Do you want to leave?"
    pc "Tu veux qu’on parte ?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:97
translate french julianamovietheaterstartdate_25b2e9a4:

    # bn "No, can we just kiss or something instead? I don't care about watching this."
    bn "Non, on peut juste s’embrasser ou faire autre chose à la place ? Je m’en fiche de regarder ça."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:98
translate french julianamovietheaterstartdate_4f1735dd:

    # pc "Sounds good to me."
    pc "Ça me va."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:100
translate french julianamovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Je me penche vers elle et je l'embrasse ; on ne regarde plus vraiment le film, on se concentre plutôt l'un sur l'autre."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:103
translate french julianamovietheaterstartdate_c1b8c885:

    # "The horror movie was not about hauntings and had no romance in it."
    "Ce film d'horreur ne parlait pas de fantômes et ne comportait aucune histoire d'amour."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:104
translate french julianamovietheaterstartdate_003c9dc3:

    # "I'm pretty sure Juliana hated it."
    "Je suis presque sûr que Juliana l'a détesté."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:105
translate french julianamovietheaterstartdate_27d6edde:

    # "At one point, I even tried holding her hand, but she was not interested."
    "À un moment, j'ai même essayé de lui tenir la main, mais elle n'était pas intéressée."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:106
translate french julianamovietheaterstartdate_d58327fc_1:

    # pc "Do you want to leave?"
    pc "Tu veux partir ?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:107
translate french julianamovietheaterstartdate_4aa1d16b:

    # bn "We're already too far in. I have to know which of these dumb girls is going to live."
    bn "On est déjà trop avancés. Je dois savoir laquelle de ces filles stupides va survivre."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:108
translate french julianamovietheaterstartdate_880b4aa8:

    # pc "Okay..."
    pc "D'accord..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:111
translate french julianamovietheaterstartdate_92b7555a:

    # "At first, I'm not sure that Juliana is going to like the movie at all."
    "Au début, je ne suis pas sûr que Juliana va aimer le film."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:112
translate french julianamovietheaterstartdate_c421db42:

    # "She looks frustrated through the beginning."
    "Elle a l'air frustrée pendant le début."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:113
translate french julianamovietheaterstartdate_4e4b3a2b:

    # "But then..."
    "Mais ensuite..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:115
translate french julianamovietheaterstartdate_bd97c290:

    # "During one of the dumb jokes, she bursts into a fit of laughter that seems to go on forever."
    "Pendant une des blagues stupides, elle éclate d'un fou rire qui semble durer une éternité."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:116
translate french julianamovietheaterstartdate_fa75bbc3:

    # pc "Are you okay?"
    pc "Ça va ?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:117
translate french julianamovietheaterstartdate_5b62109c:

    # bn "Yes. I'm sorry. It's so funny though."
    bn "Oui. Désolée. C'est tellement drôle."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:118
translate french julianamovietheaterstartdate_6ecb5d88:

    # bn "It's funny because he farted in a place where it was awkward to fart."
    bn "C'est drôle parce qu'il a pété dans un endroit où c'était gênant de péter."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:119
translate french julianamovietheaterstartdate_b59d1ff2:

    # bn "And he couldn't stop farting!"
    bn "Et il n'arrivait plus à s'arrêter de péter !"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:120
translate french julianamovietheaterstartdate_9ef4273c:

    # "Once she starts laughing, she barely stops throughout the rest of the movie."
    "Une fois qu'elle a commencé à rire, elle n'a pratiquement pas arrêté pendant le reste du film."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:124
translate french julianamovietheaterstartdate_e42d81a7:

    # bn "I really liked that. I love when they go through some hardships, but stay together in the end."
    bn "J'ai vraiment aimé ça. J'adore quand ils traversent des épreuves, mais qu'ils restent ensemble à la fin."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:125
translate french julianamovietheaterstartdate_fe15de53:

    # bn "Thank you for bringing me. I enjoyed all of it."
    bn "Merci de m'avoir emmenée. J'ai tout apprécié."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:129
translate french julianamovietheaterstartdate_71eb6066:

    # bn "Well, thanks for bringing me, but maybe not an action movie next time?"
    bn "Eh bien, merci de m'avoir emmené, mais peut-être pas un film d'action la prochaine fois ?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:130
translate french julianamovietheaterstartdate_6f6931a9:

    # bn "Even the noise of it was giving me a headache."
    bn "Rien que le bruit m'a donné mal à la tête."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:134
translate french julianamovietheaterstartdate_5bf0a9a9:

    # bn "That was the dumbest thing I've ever seen in my life."
    bn "C'était la chose la plus stupide que j'aie jamais vue de ma vie."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:135
translate french julianamovietheaterstartdate_2f39e364:

    # pc "It was pretty bad."
    pc "C'était vraiment nul."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:136
translate french julianamovietheaterstartdate_02a07558:

    # bn "I hated it."
    bn "J'ai détesté."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:137
translate french julianamovietheaterstartdate_09c476ba:

    # bn "No more horror movies. They're all trash."
    bn "Plus de films d'horreur. Ce ne sont que des navets."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:138
translate french julianamovietheaterstartdate_459e0f19:

    # pc "Okay. No more horror movies."
    pc "D'accord. Plus de films d'horreur."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:141
translate french julianamovietheaterstartdate_850f6df3:

    # bn "That was so funny."
    bn "C'était tellement drôle."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:142
translate french julianamovietheaterstartdate_4083c4d8:

    # bn "I'm sorry if I laughed too much."
    bn "Désolée si j’ai trop ri."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:143
translate french julianamovietheaterstartdate_cd4369b1:

    # pc "No, it was fun to see you cut loose like that."
    pc "Non, c’était sympa de te voir te lâcher comme ça."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:144
translate french julianamovietheaterstartdate_f50c4948:

    # bn "I guess I don't laugh very often, huh?"
    bn "Je suppose que je ne ris pas très souvent, hein ?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:145
translate french julianamovietheaterstartdate_b459f5c7:

    # bn "But when I do... wow, you have to look out."
    bn "Mais quand ça arrive… waouh, il faut faire gaffe."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:146
translate french julianamovietheaterstartdate_985a02fd:

    # "We hang out after the movie and chat during the credits."
    "On traîne après le film et on discute pendant le générique."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:150
translate french julianamovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Quand le générique se termine, on sort ensemble et on se dirige vers ma voiture."

