# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:28
translate french julianaparkstartdate_1271ced5:

    # "Juliana and I walk around the trails, chit-chatting for a while."
    "Juliana et moi, on se promène sur les sentiers en bavardant un moment."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:36
translate french julianaparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "Finalement, on arrive au banc situé à mi-chemin du sentier."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:42
translate french julianaparkstartdate_d2cc15d6:

    # "We sit next to each other on the bench for a bit, listening to the morning birds sing."
    "On s’assoit l’un à côté de l’autre sur le banc pendant un moment, en écoutant le chant des oiseaux du matin."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:44
translate french julianaparkstartdate_7104b1ef:

    # bn "This is really nice."
    bn "C’est vraiment sympa."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:45
translate french julianaparkstartdate_c417e350:

    # pc "Yeah."
    pc "Ouais."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:47
translate french julianaparkstartdate_7bdeb8b7:

    # bn "I really like you, [pcname]. I look forward to any time I get to spend with you."
    bn "Je t’aime vraiment bien, [pcname]. J’ai hâte de passer du temps avec toi."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:48
translate french julianaparkstartdate_d7904a68:

    # pc "I like you too, Juliana."
    pc "Je t’aime bien aussi, Juliana."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:49
translate french julianaparkstartdate_cde9a4ac:

    # bn "Do you maybe want to kiss some more? Like we did on my bed?"
    bn "Tu veux peut-être qu'on s'embrasse encore ? Comme on l'a fait sur mon lit ?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:51
translate french julianaparkstartdate_f49a462d:

    # "I lean in and kiss her and she pulls me in deeper, hungry for more."
    "Je me penche vers elle et l'embrasse, et elle m'attire plus fort vers elle, avide de plus."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:52
translate french julianaparkstartdate_78efd588:

    # "She moans into my mouth, barely able to control her hands as they touch my chest and arms."
    "Elle gémit dans ma bouche, à peine capable de contrôler ses mains qui effleurent ma poitrine et mes bras."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:54
translate french julianaparkstartdate_79d7237e:

    # "I touch her too, keeping my hands away from her more sensitive areas for now. I'm not sure how far she is ready to go and I don't want to pressure her."
    "Je la touche aussi, en gardant mes mains loin de ses zones les plus sensibles pour l'instant. Je ne sais pas jusqu'où elle est prête à aller et je ne veux pas la mettre la pression."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:55
translate french julianaparkstartdate_2cb8d2e6:

    # "We kiss like that for a while before finally pulling away."
    "On s'embrasse comme ça pendant un moment avant de finalement s'écarter l'un de l'autre."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:57
translate french julianaparkstartdate_5f798c5f:

    # bn "Wow."
    bn "Ouah."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:58
translate french julianaparkstartdate_6a1c0d46:

    # bn "I've never felt like that before. It's incredible."
    bn "Je n'ai jamais ressenti ça avant. C'est incroyable."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:59
translate french julianaparkstartdate_d95bd6ed:

    # bn "Does it feel like that for you too?"
    bn "Tu ressens ça aussi ?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:60
translate french julianaparkstartdate_0c391334:

    # pc "Like what?"
    pc "Ressens quoi ?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:61
translate french julianaparkstartdate_cbf3c8a2:

    # bn "Just like fire, spreading all through you."
    bn "Comme un feu qui se propage en toi."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:62
translate french julianaparkstartdate_f85c6ac5:

    # bn "Like all my nerves coming alive and dancing in my skin."
    bn "Comme si tous mes nerfs s'animaient et dansaient sous ma peau."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:63
translate french julianaparkstartdate_1ae6abfe:

    # pc "Yeah, it feels like that for me too."
    pc "Ouais, je ressens ça aussi."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:64
translate french julianaparkstartdate_e40b3a25:

    # bn "Incredible."
    bn "Incroyable."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:65
translate french julianaparkstartdate_7fd26fb6:

    # bn "What time is it?"
    bn "Quelle heure est-il ?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:66
translate french julianaparkstartdate_d038199e:

    # pc "Just about time for us to head back to school."
    pc "Il est presque l'heure de retourner à l'école."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:67
translate french julianaparkstartdate_bd5f19a8:

    # bn "Yeah, that's what I thought. Let's enjoy this for one more minute though."
    bn "Ouais, c'est ce que je pensais. Mais profitons-en encore une minute."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:68
translate french julianaparkstartdate_08551511:

    # pc "You got it."
    pc "D'accord."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:69
translate french julianaparkstartdate_10106d85:

    # "We sit there for another minute, just enjoying the quiet, enjoying the warmth of each other's bodies."
    "On reste assis là encore une minute, à profiter du calme, de la chaleur de nos corps l'un contre l'autre."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:70
translate french julianaparkstartdate_da3cd183:

    # "Then it's time to get back to school."
    "Puis il est temps de retourner à l'école."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:77
translate french julianaparkstartdate_ebc1db78:

    # bn "I had a really good time, [pcname]. I hope we can do that again soon."
    bn "J'ai passé un très bon moment, [pcname]. J'espère qu'on pourra recommencer bientôt."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:78
translate french julianaparkstartdate_97cc796e:

    # bn "Any time you'd rather go to the park instead of study, just let me know."
    bn "Si jamais tu préfères aller au parc plutôt que d'étudier, dis-le-moi."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:79
translate french julianaparkstartdate_f350b961:

    # bn "There's plenty of other time to study throughout the day."
    bn "On a tout le temps d'étudier pendant la journée."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:80
translate french julianaparkstartdate_f8733479:

    # pc "I will, Juliana. Looking forward to our next date."
    pc "Je le ferai, Juliana. J'ai hâte de notre prochain rendez-vous."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:81
translate french julianaparkstartdate_d8a5a64b:

    # bn "Is that what that was?"
    bn "C'était donc ça ?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:82
translate french julianaparkstartdate_c4b7f80e:

    # pc "Sure, I'd call it a date."
    pc "Bien sûr, j'appellerais ça un rendez-vous."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:83
translate french julianaparkstartdate_b2c60616:

    # bn "Wow, I just had my first date and I didn't even realize it."
    bn "Ouah, je viens d'avoir mon premier rendez-vous et je ne m'en suis même pas rendu compte."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:84
translate french julianaparkstartdate_3d335832:

    # pc "Not a big deal. There will be plenty more."
    pc "Ce n'est pas grave. Il y en aura plein d'autres."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:85
translate french julianaparkstartdate_7c86fcff:

    # bn "Yeah, I guess so. Still, it was incredible."
    bn "Ouais, je suppose. Mais c'était quand même incroyable."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:87
translate french julianaparkstartdate_bed43be6:

    # bn "Well, we better head to class."
    bn "Bon, on ferait mieux d'aller en cours."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:91
translate french julianaparkstartdate_b0662d5f:

    # "I step up to her and pull her in for a kiss before we go."
    "Je m'approche d'elle et l'attire vers moi pour l'embrasser avant de partir."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:92
translate french julianaparkstartdate_d196e134:

    # "Then after a few moments, we pull away once again."
    "Puis, après quelques instants, on s'écarte à nouveau."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:94
translate french julianaparkstartdate_92b8b462:

    # bn "I'll see you later, [pcname]."
    bn "À plus tard, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:97
translate french julianaparkstartdate_24be2fc8:

    # "I step up to her and pull her in for a hug before we go."
    "Je m'approche d'elle et l'attire vers moi pour la serrer dans mes bras avant de partir."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:98
translate french julianaparkstartdate_d196e134_1:

    # "Then after a few moments, we pull away once again."
    "Puis, après quelques instants, on s'écarte à nouveau."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:100
translate french julianaparkstartdate_92b8b462_1:

    # bn "I'll see you later, [pcname]."
    bn "À plus tard, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:103
translate french julianaparkstartdate_449d1425:

    # pc "Bye Juliana."
    pc "Au revoir Juliana."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:104
translate french julianaparkstartdate_a8de1634:

    # bn "See you later, [pcname]."
    bn "À plus tard, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:105
translate french julianaparkstartdate_3768ae38:

    # "With that, we both go to class."
    "Sur ce, nous partons tous les deux en cours."

