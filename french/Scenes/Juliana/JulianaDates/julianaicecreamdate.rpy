# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:28
translate french julianaicecreamstartdate_6e86a495:

    # bn "I'll have vanilla please."
    bn "Je prendrai de la vanille, s'il te plaît."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:29
translate french julianaicecreamstartdate_e28b03b7:

    # pc "Just vanilla? You don't want a flavor?"
    pc "Juste de la vanille ? Tu ne veux pas d’un parfum ?"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:30
translate french julianaicecreamstartdate_c049ae90:

    # bn "I like vanilla. It's the finest of the flavors."
    bn "J’aime la vanille. C’est le meilleur des parfums."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:32
translate french julianaicecreamstartdate_bf0f1fe7:

    # pc "\"Gotta see the show, 'cause then you'll know the vertigo is gonna grow 'cause it's so dangerous, you'll have to sign a waiver?\""
    pc "« Il faut voir le spectacle, parce qu’alors tu sauras que le vertige va s’intensifier, parce que c’est tellement dangereux que tu devras signer une décharge ? »"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:33
translate french julianaicecreamstartdate_3a694dff:

    # bn "Uh... what?"
    bn "Euh… quoi ?"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:34
translate french julianaicecreamstartdate_3efc5a94:

    # pc "Oh, it's from a song. I thought you were making a reference."
    pc "Oh, ça vient d’une chanson. Je pensais que tu faisais une référence."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:35
translate french julianaicecreamstartdate_43de1e25:

    # bn "I'm sorry, I don't know the song."
    bn "Je suis désolé, je ne connais pas cette chanson."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:36
translate french julianaicecreamstartdate_385889cf:

    # pc "Oh... okay. Ignore that then."
    pc "Oh... d'accord. Oublie ça alors."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:41
translate french julianaicecreamstartdate_a716a63e:

    # "We sit down and enjoy our ice cream and chat for a while."
    "On s'assoit, on savoure notre glace et on discute un moment."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:49
translate french julianaicecreamstartdate_bec02a72:

    # "With the ice cream finished, our conversation slows down."
    "Une fois la glace terminée, la conversation s'essouffle."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:50
translate french julianaicecreamstartdate_1b4b54ec:

    # bn "I think I'm ready for you to come back to my house now."
    bn "Je pense que je suis prête à ce que tu viennes chez moi maintenant."

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:51
translate french julianaicecreamstartdate_18e0895f:

    # pc "Okay, let's go."
    pc "D'accord, allons-y."

