# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:40
translate french julianaluigisstartdate_a71bf22a:

    # pc "Well it's very pretty."
    pc "Eh bien, elle est très jolie."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:41
translate french julianaluigisstartdate_3dc0e34e:

    # "She turns away and blushes a little."
    "Elle se détourne et rougit un peu."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:43
translate french julianaluigisstartdate_313b6a1f:

    # bn "Oh, um. I don't know."
    bn "Oh, euh. Je ne sais pas."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:44
translate french julianaluigisstartdate_2f29693a:

    # bn "I like to wear them when I go out somewhere nice."
    bn "J'aime bien les porter quand je sors dans un endroit sympa."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:47
translate french julianaluigisstartdate_1431cc27:

    # bn "Thank you."
    bn "Merci."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:48
translate french julianaluigisstartdate_3dc0e34e_1:

    # "She turns away and blushes a little."
    "Elle détourne le regard et rougit légèrement."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:50
translate french julianaluigisstartdate_563fa2c8:

    # bn "Okay. Well I prefer the wig when I go somewhere nice."
    bn "D'accord. Eh bien, je préfère la perruque quand je vais dans un endroit sympa."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:51
translate french julianaluigisstartdate_e256026f:

    # "I'm not really sure how to respond, so we end up driving the rest of the way to the restaurant in an awkward silence."
    "Je ne sais pas trop comment réagir, alors nous finissons par faire le reste du trajet jusqu'au restaurant dans un silence gêné."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:54
translate french julianaluigisstartdate_62345451:

    # "When we get to Luigi's, we sit and order our meals."
    "Quand nous arrivons chez Luigi, nous nous asseyons et commandons nos plats."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:55
translate french julianaluigisstartdate_c57a5228:

    # "Then we chat for a while."
    "Puis on discute un moment."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:58
translate french julianaluigisstartdate_0875967f:

    # "The server brings our food out, and we continue talking while we eat."
    "Le serveur nous apporte notre repas, et on continue à parler pendant qu'on mange."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:60
translate french julianaluigisstartdate_dbe7b11f:

    # "When we're done eating, we just hang around and talk for a little more."
    "Quand on a fini de manger, on reste là à discuter encore un peu."

# game/Scenes/Juliana/JulianaDates/julianaluigisdate.rpy:63
translate french julianaluigisstartdate_018a4945:

    # "After our conversation, I pay for the food and we leave the restaurant and drive back to Juliana's house."
    "Après notre conversation, je paie l'addition, on quitte le restaurant et on rentre chez Juliana."

