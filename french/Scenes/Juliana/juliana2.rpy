# game/Scenes/Juliana/juliana2.rpy:13
translate french juliana2_ba25a872:

    # "The school day goes by normally until English class."
    "La journée d'école se déroule normalement jusqu'au cours d'anglais."

# game/Scenes/Juliana/juliana2.rpy:14
translate french juliana2_5631544c:

    # "Mrs. McGee lectures all period about the archetypes and subtext of the short story we are reading."
    "Mme McGee passe tout le cours à nous parler des archétypes et du sous-texte de la nouvelle qu'on est en train de lire."

# game/Scenes/Juliana/juliana2.rpy:15
translate french juliana2_88daeb16:

    # "The entire time, I don't even look at Juliana, I'm still so annoyed with her."
    "Pendant tout ce temps, je ne regarde même pas Juliana, je suis toujours aussi agacé par elle."

# game/Scenes/Juliana/juliana2.rpy:18
translate french juliana2_1c2cecc3:

    # "When the class is over, I gather my things and get up to leave."
    "Quand le cours est terminé, je rassemble mes affaires et me lève pour partir."

# game/Scenes/Juliana/juliana2.rpy:19
translate french juliana2_290ef46a:

    # bn "[pcname]?"
    bn "[pcname]?"

# game/Scenes/Juliana/juliana2.rpy:20
translate french juliana2_fc83ac13:

    # "I think about continuing to walk, but the nervousness in her voice makes me stop."
    "Je pense à continuer mon chemin, mais la nervosité dans sa voix me fait m'arrêter."

# game/Scenes/Juliana/juliana2.rpy:24
translate french juliana2_395d1511:

    # bn "[pcname], can you just talk to me for a second?"
    bn "[pcname], tu peux juste me parler une seconde ?"

# game/Scenes/Juliana/juliana2.rpy:25
translate french juliana2_63023601:

    # pc "Okay."
    pc "D'accord."

# game/Scenes/Juliana/juliana2.rpy:28
translate french juliana2_9da0d89a:

    # bn "I'm sorry about the things I wrote on your essay."
    bn "Je suis désolée pour ce que j’ai écrit sur ta dissertation."

# game/Scenes/Juliana/juliana2.rpy:29
translate french juliana2_ec9b7d74:

    # bn "I know that sometimes I can be too harsh. Too blunt with my words."
    bn "Je sais que parfois je peux être trop dure. Trop directe dans mes propos."

# game/Scenes/Juliana/juliana2.rpy:30
translate french juliana2_e1eed4cc:

    # bn "I'm not good with talking to people. I get nervous and my words come out muddled."
    bn "Je ne suis pas douée pour parler aux gens. Je deviens nerveuse et mes mots sortent tout confus."

# game/Scenes/Juliana/juliana2.rpy:31
translate french juliana2_439f936e:

    # bn "When I was editing your essay, I failed to take into account that there was a person on the other side of the writing."
    bn "Quand j’ai corrigé ta dissertation, je n’ai pas pris en compte le fait qu’il y avait une personne derrière ce texte."

# game/Scenes/Juliana/juliana2.rpy:32
translate french juliana2_828e0032:

    # bn "And I apologize for that. I should have been kinder."
    bn "Et je m’en excuse. J’aurais dû être plus gentille."

# game/Scenes/Juliana/juliana2.rpy:33
translate french juliana2_6ac1535a:

    # "I look at her, genuinely sorry for what she had written."
    "Je la regarde, sincèrement désolée pour ce qu’elle a écrit."

# game/Scenes/Juliana/juliana2.rpy:34
translate french juliana2_4af91df8:

    # "It's difficult for me to stay mad after that."
    "J’ai du mal à rester en colère après ça."

# game/Scenes/Juliana/juliana2.rpy:35
translate french juliana2_7836aabb:

    # pc "I forgive you."
    pc "Je te pardonne."

# game/Scenes/Juliana/juliana2.rpy:36
translate french juliana2_359954db:

    # pc "Besides, your input did help me get an A on that essay."
    pc "En plus, tes remarques m’ont aidée à avoir un A à cette dissertation."

# game/Scenes/Juliana/juliana2.rpy:39
translate french juliana2_49b20716:

    # bn "Good. I'm glad."
    bn "Bien. Je suis contente."

# game/Scenes/Juliana/juliana2.rpy:40
translate french juliana2_36f62856:

    # bn "That was my intention. To help you fix your essay."
    bn "C’était mon intention. T’aider à améliorer ta dissertation."

# game/Scenes/Juliana/juliana2.rpy:41
translate french juliana2_5d0adf4a:

    # pc "Well you did a good job there."
    pc "Eh bien, tu as fait du bon boulot."

# game/Scenes/Juliana/juliana2.rpy:44
translate french juliana2_a559e42c:

    # bn "I could help you more if you want."
    bn "Je pourrais t’aider davantage si tu veux."

# game/Scenes/Juliana/juliana2.rpy:45
translate french juliana2_7e811564:

    # bn "If you want to maybe study together sometime?"
    bn "Si tu veux, on pourrait peut-être étudier ensemble un de ces jours ?"

# game/Scenes/Juliana/juliana2.rpy:46
translate french juliana2_ff08c86f:

    # bn "I'm usually in the café here on campus in the morning."
    bn "Je suis généralement au café du campus le matin."

# game/Scenes/Juliana/juliana2.rpy:47
translate french juliana2_e4b8a84b:

    # bn "You could come by and study with me if you want."
    bn "Tu pourrais passer et étudier avec moi si tu veux."

# game/Scenes/Juliana/juliana2.rpy:52
translate french juliana2_1abdf9b6:

    # bn "Good, I'm looking forward to it!"
    bn "Super, j’ai hâte !"

# game/Scenes/Juliana/juliana2.rpy:53
translate french juliana2_d63c89db:

    # bn "Okay, well I better get on to my next class."
    bn "Bon, je ferais mieux d’aller à mon prochain cours."

# game/Scenes/Juliana/juliana2.rpy:54
translate french juliana2_9c9c1091:

    # bn "I'm glad we talked."
    bn "Je suis contente qu’on ait discuté."

# game/Scenes/Juliana/juliana2.rpy:57
translate french juliana2_b237b55e:

    # bn "Okay, well if you change your mind, I'll be there."
    bn "D’accord, si tu changes d’avis, je serai là."

# game/Scenes/Juliana/juliana2.rpy:58
translate french juliana2_5dfb772a:

    # bn "I better get on to my next class."
    bn "Je ferais mieux d’aller à mon prochain cours."

# game/Scenes/Juliana/juliana2.rpy:59
translate french juliana2_268fafe9:

    # bn "But I'm glad we talked."
    bn "Mais je suis contente qu’on ait discuté."

# game/Scenes/Juliana/juliana2.rpy:62
translate french juliana2_fa503b05:

    # "With that, she walks out of Mrs. McGee's class and rushes down the hall."
    "Sur ces mots, elle sort de la classe de Mme McGee et se précipite dans le couloir."

# game/Scenes/Juliana/juliana2.rpy:63
translate french juliana2_5b956f56:

    # "I head the opposite direction towards my own class."
    "Je pars dans la direction opposée, vers ma propre classe."

# game/Scenes/Juliana/juliana2.rpy:64
translate french juliana2_02bf7eb2:

    # "The rest of the day passes quickly and without incident, then it's time to go to work."
    "Le reste de la journée passe rapidement et sans incident, puis c’est l’heure d’aller travailler."

translate french strings:

    # game/Scenes/Juliana/juliana2.rpy:2
    old "After the scene where Juliana critiques your essay,"
    new "Après la scène où Juliana critique ta dissertation,"

    # game/Scenes/Juliana/juliana2.rpy:3
    old "this scene will happen automatically in English class."
    new "cette scène se déroulera automatiquement en cours d’anglais."

    # game/Scenes/Juliana/juliana2.rpy:55
    old "Maybe, I don't know"
    new "Peut-être, je ne sais pas"

