translate french julianastudy_501a4fef:

    # "Juliana is sitting by herself with papers and books on the table in front of her."
    "Juliana est assise toute seule, avec des papiers et des livres sur la table devant elle."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:5
translate french julianastudy_9338d40c:

    # "She looks up at me when I walk up."
    "Elle lève les yeux vers moi quand je m'approche."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:6
translate french julianastudy_19256309:

    # bn "Hey, [pcname]. Come to study? Have a seat."
    bn "Salut, [pcname]. Tu viens étudier ? Assieds-toi."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:9
translate french julianastudy_6e243554:

    # "I sit down across from her and pull out my English homework."
    "Je m'assois en face d'elle et sors mes devoirs d'anglais."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:12
translate french julianastudy_235b565e:

    # bn "Hey, [pcname]."
    bn "Salut, [pcname]."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:14
translate french julianastudy_094e6e6a:

    # bn "I'm not really in a study mood, and I don't really need to study for this stuff."
    bn "Je ne suis pas vraiment d'humeur à étudier, et je n'ai pas vraiment besoin de réviser tout ça."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:15
translate french julianastudy_d70725f5:

    # bn "Do you feel like maybe going down to the park for a walk before class?"
    bn "Ça te dirait d'aller faire un tour au parc avant le cours ?"

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:19
translate french julianastudy_07986b35:

    # bn "Great. Let's go."
    bn "Super. Allons-y."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:22
translate french julianastudy_3e48fef9:

    # "She rides with me down to the park and we get out and start walking around the trail."
    "Elle m'accompagne en voiture jusqu'au parc, on descend et on commence à marcher sur le sentier."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:25
translate french julianastudy_a267d321:

    # bn "Oh okay, no problem."
    bn "Oh d'accord, pas de problème."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:30
translate french julianastudy_7ab60128:

    # bn "Hey, [pcname]. You want to study today, or maybe just go down to the park?"
    bn "Salut, [pcname]. Tu veux étudier aujourd'hui, ou peut-être juste aller au parc ?"

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:33
translate french julianastudy_f8afec59:

    # bn "Okay. There's some things I need to go over anyway."
    bn "D'accord. Il y a des trucs que je dois réviser de toute façon."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:36
translate french julianastudy_6bd56e41:

    # bn "That sounds like fun. Let's go."
    bn "Ça a l'air sympa. Allons-y."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:39
translate french julianastudy_6bd56e41_1:

    # bn "That sounds like fun. Let's go."
    bn "Ça a l'air sympa. Allons-y."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:45
translate french julianastudynormal_1a99d7a4:

    # "I spend some time studying with Juliana in the café."
    "Je passe un moment à étudier avec Juliana au café."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:46
translate french julianastudynormal_e181f315:

    # "She doesn't talk much, but we chit-chat a little bit."
    "Elle ne parle pas beaucoup, mais on bavarde un peu."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:47
translate french julianastudynormal_3baf4786:

    # "She points out problems with my work and shows me how to fix them."
    "Elle me signale des erreurs dans mon travail et me montre comment les corriger."

# game/Scenes/Juliana/JulianaStudy/julianastudy.rpy:49
translate french julianastudynormal_29c37b45:

    # "Then it's time for class, so we leave the café together and go our separate ways."
    "Puis c'est l'heure du cours, alors on quitte le café ensemble et on se sépare."

