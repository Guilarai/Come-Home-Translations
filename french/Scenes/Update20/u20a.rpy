    # pc "Hello?"
    pc "Allô ?"

# game/Scenes/Update20/u20a.rpy:7
translate french u20a_744243a9:

    # "It's Whitney's laboratory, but it's dark and quiet."
    "C’est le laboratoire de Whitney, mais c’est sombre et silencieux."

# game/Scenes/Update20/u20a.rpy:8
translate french u20a_730217b4:

    # "I hope that I'm in the right world. I hope that nothing bad has happened."
    "J'espère que je suis dans le bon monde. J'espère qu'il ne s'est rien passé de grave."

# game/Scenes/Update20/u20a.rpy:11
translate french u20a_96c9481d:

    # "Then the lights kick on and the door opens."
    "Puis les lumières s'allument et la porte s'ouvre."

# game/Scenes/Update20/u20a.rpy:14
translate french u20a_45da60e7:

    # wt "Finally, you're back. Took you long enough."
    wt "Enfin, tu es de retour. Tu en as mis du temps."

# game/Scenes/Update20/u20a.rpy:15
translate french u20a_fd9e8f88:

    # wt "I really thought I might be going to jail!"
    wt "J'ai vraiment cru que j'allais finir en prison !"

# game/Scenes/Update20/u20a.rpy:18
translate french u20a_a33db221:

    # pc "How long have I been gone?"
    pc "Depuis combien de temps suis-je parti ?"

# game/Scenes/Update20/u20a.rpy:19
translate french u20a_e000eef8:

    # wt "Thirty days."
    wt "Trente jours."

# game/Scenes/Update20/u20a.rpy:22
translate french u20a_8d8b1bd7:

    # pc "THIRTY!?"
    pc "TRENTE !?"

# game/Scenes/Update20/u20a.rpy:23
translate french u20a_d92a0cb0:

    # wt "Yes. It's been a difficult time for me as well."
    wt "Oui. Ça a été une période difficile pour moi aussi."

# game/Scenes/Update20/u20a.rpy:27
translate french u20a_c77aa2a4:

    # wt "Lisa has been very persistent and is nearing her breaking point. I suspect she may involve the police soon."
    wt "Lisa s’est montrée très insistante et elle est au bord de la rupture. Je crains qu’elle ne fasse bientôt appel à la police."

# game/Scenes/Update20/u20a.rpy:28
translate french u20a_c1e86e55:

    # wt "She thinks I killed both you and your dad."
    wt "Elle pense que je t’ai tué, toi et ton père."

# game/Scenes/Update20/u20a.rpy:32
translate french u20a_9a9b3000:

    # wt "Suzy and Tammy have been after me every day. I don't think I could hold them off from calling the police for much longer."
    wt "Suzy et Tammy m’ont harcelé tous les jours. Je ne pense pas pouvoir les empêcher d’appeler la police encore très longtemps."

# game/Scenes/Update20/u20a.rpy:33
translate french u20a_24d0649b:

    # wt "They brought in Suzy's mom too, Lisa."
    wt "Elles ont aussi fait venir la mère de Suzy, Lisa."

# game/Scenes/Update20/u20a.rpy:34
translate french u20a_c0b726db:

    # wt "They are not happy with me. Tammy has threatened me with physical violence. I'd prefer to avoid that."
    wt "Elles ne sont pas contentes de moi. Tammy m’a menacé de violence physique. Je préférerais éviter ça."

# game/Scenes/Update20/u20a.rpy:38
translate french u20a_0904113a:

    # wt "Jamie has been after me every day. I don't think I could hold her off from calling the police for much longer."
    wt "Jamie me harcèle tous les jours. Je ne pense pas pouvoir l’empêcher d’appeler la police encore très longtemps."

# game/Scenes/Update20/u20a.rpy:39
translate french u20a_9dc19f81:

    # wt "She's really not happy with me and she really misses you."
    wt "Elle n’est vraiment pas contente de moi et tu lui manques énormément."

# game/Scenes/Update20/u20a.rpy:43
