# game/Scenes/Update20/u20a.rpy:92
translate french u20a_129be4b0:

    # wt "Nobody's tracked you down to here yet, but I knew it was only a matter of time."
    wt "Personne ne t’a encore retrouvé ici, mais je savais que ce n’était qu’une question de temps."

# game/Scenes/Update20/u20a.rpy:93
translate french u20a_ab459ea2:

    # wt "I'm really glad you made it back."
    wt "Je suis vraiment contente que tu sois de retour."

# game/Scenes/Update20/u20a.rpy:97
translate french u20a_ecc127cf:

    # wt "Bai has been after me every day. I don't think I could hold him off from calling the police for much longer."
