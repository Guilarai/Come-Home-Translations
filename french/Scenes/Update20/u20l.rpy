# game/Scenes/Update20/u20l.rpy:3
translate french u20l_c0cbad5f:

    # "For now, I should go see Brandi."
    "Pour l'instant, je devrais aller voir Brandi."

# game/Scenes/Update20/u20l.rpy:6
translate french u20l_6783b0e6:

    # "I drive to Brandi's apartment and knock on her door."
    "Je me rends en voiture à l'appartement de Brandi et je frappe à sa porte."

# game/Scenes/Update20/u20l.rpy:7
translate french u20l_7043290e:

    # "It's late, but I hope she'll still be awake. I have to see her."
    "Il est tard, mais j'espère qu'elle sera encore réveillée. Je dois la voir."

# game/Scenes/Update20/u20l.rpy:11
translate french u20l_1ccac3d3:

    # "After a few moments, Brandi opens the door."
    "Au bout de quelques instants, Brandi ouvre la porte."

# game/Scenes/Update20/u20l.rpy:12
translate french u20l_4a243063:

    # fd "Holy shit, [pcname]! You're back!"
    fd "Putain de merde, [pcname] ! Tu es de retour !"

# game/Scenes/Update20/u20l.rpy:15
translate french u20l_ad7d3606:

    # "I wrap my arms around Brandi, pulling her in tight."
    "J'enlace Brandi et la serre fort contre moi."

# game/Scenes/Update20/u20l.rpy:16
translate french u20l_e1a3df9c:

    # fd "I thought that machine killed you!"
    fd "Je croyais que cette machine t'avait tué !"

# game/Scenes/Update20/u20l.rpy:17
translate french u20l_ebe2f7cf:

    # fd "I thought I was never going to see you again!"
    fd "Je croyais que je ne te reverrais plus jamais !"

# game/Scenes/Update20/u20l.rpy:20
translate french u20l_946b2987:

    # fd "What happened to you? Did you really go to another world, like you said?"
    fd "Qu'est-ce qui t'est arrivé ? Tu es vraiment allé dans un autre monde, comme tu l'avais dit ?"

# game/Scenes/Update20/u20l.rpy:21
translate french u20l_aac4f177:

    # pc "Yeah, I did. I saw my dad again. It was... a lot."
    pc "Oui, c'est vrai. J'ai revu mon père. C'était... intense."

# game/Scenes/Update20/u20l.rpy:22
translate french u20l_34a96f57:

    # fd "Wow, I can't believe it. Are you okay?"
    fd "Ouah, j'arrive pas à y croire. Ça va ?"

# game/Scenes/Update20/u20l.rpy:23
translate french u20l_3c3fa8e3:

    # pc "Yeah, I'm great. I'll tell you everything tomorrow, I promise."
    pc "Oui, je vais super bien. Je te raconterai tout demain, promis."

# game/Scenes/Update20/u20l.rpy:26
translate french u20l_4188b1fa:

    # fd "I'm just so glad you're back."
    fd "Je suis tellement contente que tu sois de retour."

# game/Scenes/Update20/u20l.rpy:27
translate french u20l_80452f29:

    # fd "You're going to have to cut that hair though. Big oof."
    fd "Mais tu vas devoir te couper les cheveux. C'est un vrai fouet."

# game/Scenes/Update20/u20l.rpy:30
translate french u20l_7d64063d:

    # "She kisses me softly, her lips warm and inviting."
    "Elle m'embrasse doucement, ses lèvres sont chaudes et invitantes."

# game/Scenes/Update20/u20l.rpy:31
translate french u20l_392f9f2c:

    # fd "I'm so happy you came home."
    fd "Je suis tellement heureuse que tu sois rentrée."

# game/Scenes/Update20/u20l.rpy:32
translate french u20l_4d7d812c:

    # fd "Let's get you in the shower. You smell like a horse."
    fd "Allons te mettre sous la douche. Tu sens le cheval."

