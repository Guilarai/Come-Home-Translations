translate french u20g_fc5b5a95:

    # "For now, I should go see Juliana."
    "Pour l'instant, je devrais aller voir Juliana."

# game/Scenes/Update20/u20g.rpy:5
translate french u20g_2257ecc3:

    # "I drive over to Juliana's house and knock on her door."
    "Je me rends en voiture chez Juliana et je frappe à sa porte."

# game/Scenes/Update20/u20g.rpy:6
translate french u20g_4fc89239:

    # "It's late and I hate to wake her, but I need to see her."
    "Il est tard et je déteste la réveiller, mais j'ai besoin de la voir."

# game/Scenes/Update20/u20g.rpy:9
translate french u20g_5ac21d19:

    # "Juliana's grandmother comes to the door, looking surprised."
    "La grand-mère de Juliana vient à la porte, l'air surpris."

# game/Scenes/Update20/u20g.rpy:10
translate french u20g_12baa67b:

    # jg "Oh you're Juliana's friend... I'm sorry, I forgot your name."
    jg "Oh, tu es l'ami de Juliana... Je suis désolée, j'ai oublié ton nom."

# game/Scenes/Update20/u20g.rpy:11
translate french u20g_529f52b6:

    # pc "It's [pcname]."
    pc "C'est [pcname]."

# game/Scenes/Update20/u20g.rpy:12
translate french u20g_0a7b8aae:

    # jg "What happened to your hair, boy? You miss a barber appointment?"
    jg "Qu'est-ce qui est arrivé à tes cheveux, mon garçon ? Tu as raté ton rendez-vous chez le coiffeur ?"

# game/Scenes/Update20/u20g.rpy:13
translate french u20g_84c963f6:

    # pc "I'm sorry. I know it's late, but can I see Juliana?"
    pc "Je suis désolé. Je sais qu'il est tard, mais je peux voir Juliana ?"

# game/Scenes/Update20/u20g.rpy:14
translate french u20g_975fcca2:

    # jg "Oh, it's okay. I was up watching Love Island. You know that show?"
    jg "Oh, ça va. J'étais debout en train de regarder Love Island. Tu connais cette émission ?"

# game/Scenes/Update20/u20g.rpy:17
translate french u20g_70d520dc:

    # jg "I just love all the drama with sexy people trying to get in each other's pants."
    jg "J'adore tous ces drames avec des gens sexy qui essaient de se mettre dans le lit les uns des autres."

# game/Scenes/Update20/u20g.rpy:18
translate french u20g_5ab1c947:

    # jg "Anyway, come in. Yeah, you can go up to see Juliana."
    jg "Bref, entre. Oui, tu peux monter voir Juliana."

# game/Scenes/Update20/u20g.rpy:19
translate french u20g_60d8396d:

    # jg "I'll turn up the volume on the TV, so you two can have some privacy."
    jg "Je vais monter le son de la télé pour que vous puissiez être tranquilles."

# game/Scenes/Update20/u20g.rpy:20
translate french u20g_c6880d17:

    # pc "Thanks!"
    pc "Merci !"

# game/Scenes/Update20/u20g.rpy:24
translate french u20g_ea76bd5b:

    # "I walk quietly up the stairs and into Juliana's room. She's in bed, sleeping."
    "Je monte les escaliers sans faire de bruit et entre dans la chambre de Juliana. Elle est au lit, en train de dormir."

# game/Scenes/Update20/u20g.rpy:27
translate french u20g_a95bfc0c:

    # "Trying not to wake her immediately, I lie next to her and wrap her in my arms."
    "Pour ne pas la réveiller tout de suite, je m'allonge à côté d'elle et l'enlace."

# game/Scenes/Update20/u20g.rpy:30
translate french u20g_c981bd85:

    # "She jolts awake and looks at me, shocked."
    "Elle se réveille en sursaut et me regarde, stupéfaite."

# game/Scenes/Update20/u20g.rpy:31
translate french u20g_c026970e:

    # bn "[pcname]? Is it really you?"
    bn "[pcname] ? C'est vraiment toi ?"

# game/Scenes/Update20/u20g.rpy:32
translate french u20g_7f340d6d:

    # pc "It's really me."
    pc "C'est bien moi."

# game/Scenes/Update20/u20g.rpy:35
translate french u20g_b5e336f8:

    # "She leans in and kisses me deeply, her lips soft and warm against mine."
    "Elle se penche vers moi et m’embrasse longuement, ses lèvres douces et chaudes contre les miennes."

# game/Scenes/Update20/u20g.rpy:36
translate french u20g_df5fc180:

    # bn "Oh, I missed you so much."
    bn "Oh, tu m’as tellement manqué."

# game/Scenes/Update20/u20g.rpy:39
translate french u20g_cfc15aa3:

    # bn "So everything was true? You really saw your dad?"
    bn "Alors tout était vrai ? Tu as vraiment vu ton père ?"

# game/Scenes/Update20/u20g.rpy:40
translate french u20g_e5c0f2f9:

    # pc "Yeah, I did. It's all true. I'll tell you all about it tomorrow."
    pc "Oui, c’est vrai. Tout est vrai. Je te raconterai tout ça demain."

# game/Scenes/Update20/u20g.rpy:43
translate french u20g_2b545022:

    # bn "I'm just glad you're back. I was so worried about you."
    bn "Je suis juste contente que tu sois de retour. J’étais tellement inquiète pour toi."

# game/Scenes/Update20/u20g.rpy:44
translate french u20g_98d08bed:

    # bn "You look and smell awful though."
    bn "Mais tu as l’air et tu sens vraiment mauvais."

# game/Scenes/Update20/u20g.rpy:47
translate french u20g_4aea05d2:

    # bn "I'll go get the bathroom ready for you."
    bn "Je vais te préparer la salle de bain."

# game/Scenes/Update20/u20g.rpy:48
translate french u20g_a3acbba5:

    # bn "If you're going to stay the night in my bed, you need to shower and shave."
    bn "Si tu comptes passer la nuit dans mon lit, tu dois prendre une douche et te raser."

