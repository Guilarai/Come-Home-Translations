# game/Scenes/Update20/u20e.rpy:2
translate french u20e_ee43eaac:

    # "For now, I should go see Dana."
    "Pour l’instant, je devrais aller voir Dana."

# game/Scenes/Update20/u20e.rpy:5
translate french u20e_8200a66a:

    # "I drive over to Dana's apartment and knock on her door."
    "Je me rends en voiture à l’appartement de Dana et je frappe à sa porte."

# game/Scenes/Update20/u20e.rpy:6
translate french u20e_4fc89239:

    # "It's late and I hate to wake her, but I need to see her."
    "Il est tard et je déteste la réveiller, mais j’ai besoin de la voir."

# game/Scenes/Update20/u20e.rpy:10
translate french u20e_92b16112:

    # cw "[pcname]? Oh my God!"
    cw "[pcname] ? Oh mon Dieu !"

# game/Scenes/Update20/u20e.rpy:13
translate french u20e_da2e1dbd:

    # "She rushes to me and wraps her arms around me tightly."
    "Elle se précipite vers moi et m’enlace fermement."

# game/Scenes/Update20/u20e.rpy:14
translate french u20e_140e4956:

    # "I hug her back, feeling her warmth and the softness of her body."
    "Je la serre dans mes bras à mon tour, sentant sa chaleur et la douceur de son corps."

# game/Scenes/Update20/u20e.rpy:15
translate french u20e_ed44c8a5:

    # pc "I missed you."
    pc "Tu m’as manqué."

# game/Scenes/Update20/u20e.rpy:18
translate french u20e_35280183:

    # cw "I missed you too. What happened? I thought that machine killed you."
    cw "Tu m’as manqué aussi. Que s’est-il passé ? Je croyais que cette machine t’avait tué."

# game/Scenes/Update20/u20e.rpy:19
translate french u20e_b4f81641:

    # pc "I'm sorry. I didn't mean to leave for so long."
    pc "Je suis désolé. Je ne voulais pas partir aussi longtemps."

# game/Scenes/Update20/u20e.rpy:20
translate french u20e_356f7f42:

    # pc "I'll tell you everything tomorrow, I promise."
    pc "Je te raconterai tout demain, je te le promets."

# game/Scenes/Update20/u20e.rpy:23
translate french u20e_1569fad0:

    # cw "I'm just glad you're back."
    cw "Je suis juste contente que tu sois de retour."

# game/Scenes/Update20/u20e.rpy:24
translate french u20e_634678a9:

    # cw "Wow, your hair grew a lot."
    cw "Ouah, tes cheveux ont beaucoup poussé."

# game/Scenes/Update20/u20e.rpy:25
translate french u20e_ab3cf051:

    # cw "It looks awful."
    cw "C'est affreux."

# game/Scenes/Update20/u20e.rpy:28
translate french u20e_7d64063d:

    # "She kisses me softly, her lips warm and inviting."
    "Elle m'embrasse doucement, ses lèvres sont chaudes et invitantes."

# game/Scenes/Update20/u20e.rpy:29
translate french u20e_9cf9ef15:

    # cw "But I don't care. You came home."
    cw "Mais je m'en fiche. Tu es rentré."

# game/Scenes/Update20/u20e.rpy:30
translate french u20e_ad7289ff:

    # cw "I missed you so much, [pcname]."
    cw "Tu m'as tellement manqué, [pcname]."

# game/Scenes/Update20/u20e.rpy:31
translate french u20e_0ea8f604:

    # cw "Let's go to bed. We can talk in the morning."
    cw "Allons nous coucher. On pourra parler demain matin."

