# game/Scenes/Update20/u20d.rpy:2
translate french u20d_57a32b89:

    # "For now, I should go see Jamie."
    "Pour l'instant, je devrais aller voir Jamie."

# game/Scenes/Update20/u20d.rpy:5
translate french u20d_09cc067a:

    # "I drive home, then walk over to Jamie's house, and ring the doorbell."
    "Je rentre en voiture, puis je marche jusqu'à la maison de Jamie et je sonne à la porte."

# game/Scenes/Update20/u20d.rpy:6
translate french u20d_5240dedf:

    # "It's late and I hate to wake them, but I need to see her."
    "Il est tard et je déteste les réveiller, mais j’ai besoin de la voir."

# game/Scenes/Update20/u20d.rpy:9
translate french u20d_65a45c72:

    # jd "[pcname]?"
    jd "[pcname]?"

# game/Scenes/Update20/u20d.rpy:10
translate french u20d_4297141b:

    # jd "What the hell happened to you, son?"
    jd "Mais qu’est-ce qui t’est arrivé, fiston ?"

# game/Scenes/Update20/u20d.rpy:11
translate french u20d_606da365:

    # jd "I thought you took off again. Jamie's been upset for weeks."
    jd "Je croyais que tu t’étais encore enfui. Jamie est bouleversée depuis des semaines."

# game/Scenes/Update20/u20d.rpy:12
translate french u20d_61c5bb7a:

    # pc "I'm sorry. I didn't mean to leave for so long. I've been trying to get back."
    pc "Je suis désolé. Je ne voulais pas partir aussi longtemps. J’essayais de revenir."

# game/Scenes/Update20/u20d.rpy:15
translate french u20d_ad0c6ecb:

    # jd "She's going to be happy to see you."
    jd "Elle va être contente de te voir."

# game/Scenes/Update20/u20d.rpy:16
translate french u20d_a1205e82:

    # jd "Why don't you just go up and see her?"
    jd "Pourquoi tu ne montes pas la voir ?"

# game/Scenes/Update20/u20d.rpy:17
translate french u20d_02b70148:

    # pc "Thanks, Rich."
    pc "Merci, Rich."

# game/Scenes/Update20/u20d.rpy:18
translate french u20d_f246a5a7:

    # jd "Nice beard by the way."
    jd "Jolie barbe, au fait."

# game/Scenes/Update20/u20d.rpy:22
translate french u20d_e2bc298b:

    # "I walk quietly up the stairs and into Jamie's room. She's in bed, sleeping."
    "Je monte les escaliers sans faire de bruit et entre dans la chambre de Jamie. Elle est au lit, endormie."

# game/Scenes/Update20/u20d.rpy:25
translate french u20d_a95bfc0c:

    # "Trying not to wake her immediately, I lie next to her and wrap her in my arms."
    "Pour ne pas la réveiller tout de suite, je m'allonge à côté d'elle et l'enlace."

# game/Scenes/Update20/u20d.rpy:28
translate french u20d_c981bd85:

    # "She jolts awake and looks at me, shocked."
    "Elle se réveille en sursaut et me regarde, stupéfaite."

# game/Scenes/Update20/u20d.rpy:29
translate french u20d_95496a48:

    # gnd "[pcname]? Is it really you?"
    gnd "[pcname]? C'est vraiment toi ?"

# game/Scenes/Update20/u20d.rpy:32
translate french u20d_0f0952fe:

    # "I don't answer. I just pull her close and kiss her deeply."
    "Je ne réponds pas. Je la serre simplement contre moi et l'embrasse longuement."

# game/Scenes/Update20/u20d.rpy:33
translate french u20d_3375c7eb:

    # gnd "I thought I lost you! I've been so worried."
    gnd "Je croyais t'avoir perdu ! J'étais tellement inquiète."

# game/Scenes/Update20/u20d.rpy:36
translate french u20d_de1105f0:

    # gnd "So all of that stuff was true? You really saw your dad?"
    gnd "Alors, tout ce que tu as raconté était vrai ? Tu as vraiment vu ton père ?"

# game/Scenes/Update20/u20d.rpy:37
translate french u20d_2a9e9f2b:

    # pc "Yeah, I did. It's all true. I'll tell you about it tomorrow."
    pc "Oui, c'est vrai. Tout est vrai. Je t'en parlerai demain."

# game/Scenes/Update20/u20d.rpy:40
translate french u20d_34ae9f69:

    # gnd "I'm just glad you're back."
    gnd "Je suis juste contente que tu sois de retour."

# game/Scenes/Update20/u20d.rpy:41
translate french u20d_25f299a8:

    # gnd "That hair looks awful though."
    gnd "Mais tes cheveux sont dans un état épouvantable."

# game/Scenes/Update20/u20d.rpy:44
translate french u20d_f432b969:

    # "I pull her close and kiss her again, feeling her warmth."
    "Je la serre contre moi et l'embrasse à nouveau, sentant sa chaleur."

# game/Scenes/Update20/u20d.rpy:45
translate french u20d_137d3396:

    # gnd "I missed you so much, [pcname]."
    gnd "Tu m’as tellement manqué, [pcname]."

# game/Scenes/Update20/u20d.rpy:46
translate french u20d_12a0fbc0:

    # pc "I missed you too, Jamie."
    pc "Tu m’as manqué aussi, Jamie."

