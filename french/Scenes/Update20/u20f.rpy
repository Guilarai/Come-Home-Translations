# game/Scenes/Update20/u20f.rpy:2
translate french u20f_7d92946f:

    # "For now, I should go see Mari."
    "Pour l'instant, je devrais aller voir Mari."

# game/Scenes/Update20/u20f.rpy:5
translate french u20f_2bb3b023:

    # "I drive to Mari's house and knock on her door."
    "Je me rends en voiture chez Mari et je frappe à sa porte."

# game/Scenes/Update20/u20f.rpy:6
translate french u20f_0b175aad:

    # "Her dogs start barking at the door and I hear footsteps approaching."
    "Ses chiens se mettent à aboyer et j'entends des pas s'approcher."

# game/Scenes/Update20/u20f.rpy:7
translate french u20f_be91a4c9:

    # fr "Who is it?"
    fr "Qui est-ce ?"

# game/Scenes/Update20/u20f.rpy:8
translate french u20f_1063bb8b:

    # pc "It's me! [pcname]."
    pc "C'est moi ! [pcname]."

# game/Scenes/Update20/u20f.rpy:12
translate french u20f_a9b3d399:

    # fr "Oh my God, [pcname]!"
    fr "Oh mon Dieu, [pcname] !"

# game/Scenes/Update20/u20f.rpy:13
translate french u20f_ea03fec2:

    # "She opens the door and stares at me for a moment, shocked."
    "Elle ouvre la porte et me fixe un instant, sous le choc."

# game/Scenes/Update20/u20f.rpy:14
translate french u20f_40412d0f:

    # "I can see her eyes welling up with tears."
    "Je vois ses yeux se remplir de larmes."

# game/Scenes/Update20/u20f.rpy:15
translate french u20f_23647146:

    # fr "I thought..."
    fr "Je pensais..."

# game/Scenes/Update20/u20f.rpy:18
translate french u20f_540e25ed:

    # "She rushes into my arms and hugs me tightly."
    "Elle se jette dans mes bras et me serre très fort."

# game/Scenes/Update20/u20f.rpy:19
translate french u20f_140e4956:

    # "I hug her back, feeling her warmth and the softness of her body."
    "Je la serre à mon tour, sentant sa chaleur et la douceur de son corps."

# game/Scenes/Update20/u20f.rpy:20
translate french u20f_dddaeb84:

    # pc "I missed you, Mari. I'm sorry I was gone for so long."
    pc "Tu m'as manqué, Mari. Je suis désolé d’être parti si longtemps."

# game/Scenes/Update20/u20f.rpy:23
translate french u20f_b77230d2:

    # fr "I was so worried about you. I thought that machine killed you."
    fr "J’étais tellement inquiet pour toi. Je croyais que cette machine t’avait tuée."

# game/Scenes/Update20/u20f.rpy:24
translate french u20f_40e4fe9b:

    # pc "I fought so hard to get back."
    pc "Je me suis battu de toutes mes forces pour revenir."

# game/Scenes/Update20/u20f.rpy:25
translate french u20f_356f7f42:

    # pc "I'll tell you everything tomorrow, I promise."
    pc "Je te raconterai tout demain, je te le promets."

# game/Scenes/Update20/u20f.rpy:28
translate french u20f_e5e85df6:

    # fr "I'm just glad you're back."
    fr "Je suis juste contente que tu sois de retour."

# game/Scenes/Update20/u20f.rpy:29
translate french u20f_1f943087:

    # fr "Wow, your hair grew a lot."
    fr "Waouh, tes cheveux ont beaucoup poussé."

# game/Scenes/Update20/u20f.rpy:30
translate french u20f_c49af8d0:

    # fr "It makes you look all rugged."
    fr "Ça te donne un air bien viril."

# game/Scenes/Update20/u20f.rpy:33
translate french u20f_7d64063d:

    # "She kisses me softly, her lips warm and inviting."
    "Elle m’embrasse doucement, ses lèvres sont chaudes et invitantes."

# game/Scenes/Update20/u20f.rpy:34
translate french u20f_e6ca1864:

    # fr "I'm so happy you came home."
    fr "Je suis tellement heureuse que tu sois rentré."

# game/Scenes/Update20/u20f.rpy:35
translate french u20f_402e55b1:

    # fr "Let's go to bed. We can talk in the morning."
    fr "Allons nous coucher. On pourra parler demain matin."

