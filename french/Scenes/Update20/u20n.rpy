# game/Scenes/Update20/u20n.rpy:5
translate french u20n_5e377e6b:

    # "I drive to Bai's apartment and knock on the door."
    "Je me rends en voiture à l'appartement de Bai et je frappe à la porte."

# game/Scenes/Update20/u20n.rpy:6
translate french u20n_cd826cbc:

    # "It's late, but I have to see him."
    "Il est tard, mais je dois le voir."

# game/Scenes/Update20/u20n.rpy:10
translate french u20n_435415c3:

    # "After a few moments, Bai opens the door."
    "Au bout de quelques instants, Bai ouvre la porte."

# game/Scenes/Update20/u20n.rpy:11
translate french u20n_fce568f9:

    # bai "Holy shit, [pcname]! You're back!"
    bai "Putain de merde, [pcname] ! Tu es de retour !"

# game/Scenes/Update20/u20n.rpy:14
translate french u20n_7e7c2a33:

    # "I wrap my arms around Bai, pulling him in tight."
    "J'enlace Bai et le serre très fort contre moi."

# game/Scenes/Update20/u20n.rpy:15
translate french u20n_e660f3f5:

    # bai "I thought that machine killed you!"
    bai "Je croyais que cette machine t'avait tué !"

# game/Scenes/Update20/u20n.rpy:16
translate french u20n_52e92c2d:

    # bai "I thought I might never see you again."
    bai "Je croyais que je ne te reverrais jamais."

# game/Scenes/Update20/u20n.rpy:19
translate french u20n_e99c4913:

    # bai "So what happened? Did you really go to another universe?"
    bai "Alors, qu’est-ce qui s’est passé ? Tu es vraiment allé dans un autre univers ?"

# game/Scenes/Update20/u20n.rpy:20
translate french u20n_4859fa2f:

    # pc "Yeah, I did. I saw my dad."
    pc "Oui, j’y suis allé. J’ai vu mon père."

# game/Scenes/Update20/u20n.rpy:21
translate french u20n_d8ec5a44:

    # bai "Wow. Are you okay?"
    bai "Ouah. Tu vas bien ?"

# game/Scenes/Update20/u20n.rpy:22
translate french u20n_3c3fa8e3:

    # pc "Yeah, I'm great. I'll tell you everything tomorrow, I promise."
    pc "Oui, je vais super bien. Je te raconterai tout demain, promis."

# game/Scenes/Update20/u20n.rpy:25
translate french u20n_feac206a:

    # bai "I'm just glad you're back."
    bai "Je suis juste content que tu sois de retour."

# game/Scenes/Update20/u20n.rpy:26
