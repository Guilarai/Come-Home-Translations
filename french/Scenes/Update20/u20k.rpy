translate french u20k_3f1cfb62:

    # "For now, I should go see Nora."
    "Pour l'instant, je devrais aller voir Nora."

# game/Scenes/Update20/u20k.rpy:6
translate french u20k_4d7966b5:

    # "I drive to Nora's house and ring her doorbell."
    "Je me rends en voiture chez Nora et sonne à sa porte."

# game/Scenes/Update20/u20k.rpy:7
translate french u20k_4238613f:

    # "It's late, but I have to see her, and I think she'll want to see me."
    "Il est tard, mais je dois la voir, et je pense qu’elle voudra me voir."

# game/Scenes/Update20/u20k.rpy:11
translate french u20k_69b62070:

    # "After a few moments, I hear her running down the stairs, then she answers the door."
    "Au bout de quelques instants, je l’entends dévaler les escaliers, puis elle vient ouvrir la porte."

# game/Scenes/Update20/u20k.rpy:12
translate french u20k_f8d211b5:

    # sst "Holy shit, [pcname]! You're back!"
    sst "Putain de merde, [pcname] ! T’es de retour !"

# game/Scenes/Update20/u20k.rpy:15
translate french u20k_eccf68ff:

    # sst "I thought that stupid machine killed you!"
    sst "Je croyais que cette stupide machine t’avait tué !"

# game/Scenes/Update20/u20k.rpy:16
translate french u20k_ee6c5ba9:

    # sst "I was going to the police tomorrow to tell them everything!"
    sst "J’allais aller voir la police demain pour tout leur raconter !"

# game/Scenes/Update20/u20k.rpy:17
translate french u20k_0ea0e7d1:

    # sst "Whitney's been talking me out of it for days."
    sst "Whitney essaie de m’en dissuader depuis des jours."

# game/Scenes/Update20/u20k.rpy:20
translate french u20k_65904dc5:

    # sst "What the hell happened? What was all that shit?"
    sst "Mais qu'est-ce qui s'est passé, bon sang ? C'était quoi, tout ce bordel ?"

# game/Scenes/Update20/u20k.rpy:21
translate french u20k_04446d5f:

    # pc "I'll tell you all about it tomorrow, but yeah... I went to another world and saw my dad."
    pc "Je te raconterai tout ça demain, mais oui… Je suis allé dans un autre monde et j'ai vu mon père."

# game/Scenes/Update20/u20k.rpy:22
translate french u20k_641bbc8f:

    # sst "That's ridiculous. So fucking stupid."
    sst "C'est ridicule. C'est vraiment trop stupide."

# game/Scenes/Update20/u20k.rpy:25
translate french u20k_f6493f5d:

    # sst "But, whatever! I'm just glad you're back."
    sst "Mais peu importe ! Je suis juste contente que tu sois de retour."

# game/Scenes/Update20/u20k.rpy:26
translate french u20k_fc4e92ee:

    # sst "You look and smell like you crawled out of a dumpster, but you're back!"
    sst "Tu as l'air et tu sens comme si tu venais de sortir d'une benne à ordures, mais tu es de retour !"

# game/Scenes/Update20/u20k.rpy:29
translate french u20k_e5a41f4c:

    # sst "Damn I missed you."
    sst "Bon sang, tu m'as manqué."

# game/Scenes/Update20/u20k.rpy:30
translate french u20k_919f8db7:

    # sst "Come on... let's take a shower and get in bed."
    sst "Allez… allons prendre une douche et nous mettre au lit."

