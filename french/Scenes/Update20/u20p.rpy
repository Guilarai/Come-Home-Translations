# game/Scenes/Update20/u20p.rpy:3
translate french u20p_1b7a0d04:

    # "For now, I should go see Mi-Cha."
    "Pour l'instant, je devrais aller voir Mi-Cha."

# game/Scenes/Update20/u20p.rpy:6
translate french u20p_6c85aa97:

    # "I drive over to Mi-Cha's dorm and knock on her door, trying to be quiet so I don't wake up anyone else."
    "Je me rends en voiture au dortoir de Mi-Cha et frappe à sa porte, en essayant de ne pas faire de bruit pour ne réveiller personne d'autre."

# game/Scenes/Update20/u20p.rpy:10
translate french u20p_a016dbb5:

    # "After a few moments, Mi-Cha opens the door."
    "Au bout de quelques instants, Mi-Cha ouvre la porte."

# game/Scenes/Update20/u20p.rpy:11
translate french u20p_78132b1d:

    # mc "[pcname]! Oh my God, it's you!"
    mc "[pcname]! Oh mon Dieu, c'est toi !"

# game/Scenes/Update20/u20p.rpy:14
translate french u20p_29857b39:

    # "She practically leaps into my arms, wrapping me in a tight embrace."
    "Elle se jette pratiquement dans mes bras et m'enlace très fort."

# game/Scenes/Update20/u20p.rpy:15
translate french u20p_daf29bbf:

    # mc "I missed you so much!"
    mc "Tu m'as tellement manqué !"

# game/Scenes/Update20/u20p.rpy:16
translate french u20p_48732134:

    # pc "I missed you too, Mi-Cha."
    pc "Tu m’as manqué aussi, Mi-Cha."

# game/Scenes/Update20/u20p.rpy:19
translate french u20p_6c2a8295:

    # mc "What happened? Did the thing you were trying to do work?"
    mc "Que s’est-il passé ? Est-ce que ce que tu essayais de faire a marché ?"

# game/Scenes/Update20/u20p.rpy:20
translate french u20p_f4fa6482:

    # pc "Yes it did. I didn't mean to be gone so long, but it worked."
    pc "Oui, ça a marché. Je ne voulais pas m’absenter aussi longtemps, mais ça a marché."

# game/Scenes/Update20/u20p.rpy:21
translate french u20p_48ae30e6:

    # pc "I'll tell you all about it tomorrow."
    pc "Je te raconterai tout ça demain."

# game/Scenes/Update20/u20p.rpy:22
translate french u20p_556bcc63:

    # mc "But you are here now? You won't leave me again?"
    mc "Mais tu es là maintenant ? Tu ne me quitteras plus ?"

# game/Scenes/Update20/u20p.rpy:23
translate french u20p_39bfeeda:

    # pc "No, I'm not going anywhere."
    pc "Non, je ne vais nulle part."

# game/Scenes/Update20/u20p.rpy:26
translate french u20p_8253f92f:

    # mc "I am so glad you came home."
    mc "Je suis tellement contente que tu sois rentrée."

# game/Scenes/Update20/u20p.rpy:27
translate french u20p_6d3a55c4:

    # mc "I didn't know what to do without you."
    mc "Je ne savais pas quoi faire sans toi."

# game/Scenes/Update20/u20p.rpy:30
translate french u20p_b55a59c5:

    # "She leans in and kisses me softly."
    "Elle se penche vers moi et m'embrasse doucement."

# game/Scenes/Update20/u20p.rpy:31
translate french u20p_d17bdb85:

    # mc "I love you so much."
    mc "Je t'aime tellement."

# game/Scenes/Update20/u20p.rpy:32
translate french u20p_5735beae:

    # pc "I love you too, Mi-Cha."
    pc "Je t'aime aussi, Mi-Cha."

