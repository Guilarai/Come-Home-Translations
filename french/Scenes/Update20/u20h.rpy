translate french u20h_5aee407c:

    # "For now, I should go see Izzy."
    "Pour l’instant, je devrais aller voir Izzy."

# game/Scenes/Update20/u20h.rpy:5
translate french u20h_72a90d54:

    # "I drive over to Izzy's house and knock on her door."
    "Je me rends en voiture chez Izzy et je frappe à sa porte."

# game/Scenes/Update20/u20h.rpy:6
translate french u20h_a6bc8933:

    # "It's late, but she might still be awake. I need to see her."
    "Il est tard, mais elle est peut-être encore réveillée. J’ai besoin de la voir."

# game/Scenes/Update20/u20h.rpy:10
translate french u20h_9342f0d4:

    # "Izzy opens the door, her eyes wide with surprise and filling with tears."
    "Izzy ouvre la porte, les yeux écarquillés de surprise et remplis de larmes."

# game/Scenes/Update20/u20h.rpy:11
translate french u20h_01dbc2b7:

    # gl "Holy shit, [pcname]!"
    gl "Putain de merde, [pcname] !"

# game/Scenes/Update20/u20h.rpy:14
translate french u20h_840b6638:

    # gl "Damn, I thought that machine killed you, Twig."
    gl "Merde, je croyais que cette machine t'avait tuée, Twig."

# game/Scenes/Update20/u20h.rpy:15
translate french u20h_404faba8:

    # gl "I missed you so damn much."
    gl "Tu m'as tellement manqué."

# game/Scenes/Update20/u20h.rpy:18
translate french u20h_d9c0289b:

    # gl "What happened? Did you see your dad?"
    gl "Qu'est-ce qui s'est passé ? Tu as vu ton père ?"

# game/Scenes/Update20/u20h.rpy:19
translate french u20h_0118c310:

    # pc "Yeah, I did. I'll tell you all about it tomorrow."
    pc "Oui, je l'ai vu. Je te raconterai tout ça demain."

# game/Scenes/Update20/u20h.rpy:22
translate french u20h_9051c62e:

    # gl "Alright then. I'm just glad you're back."
    gl "D'accord. Je suis juste contente que tu sois de retour."

# game/Scenes/Update20/u20h.rpy:23
translate french u20h_bd739f39:

    # gl "But your hair... damn. You gotta cut that shit."
    gl "Mais tes cheveux... putain. Il faut que tu les coupes."

# game/Scenes/Update20/u20h.rpy:24
translate french u20h_e7bdc60a:

    # pc "Yeah, yeah, I know."
    pc "Ouais, ouais, je sais."

# game/Scenes/Update20/u20h.rpy:27
translate french u20h_0f040bf1:

    # gl "Come on, let's go to my room."
    gl "Allez, viens, on va dans ma chambre."

# game/Scenes/Update20/u20h.rpy:28
translate french u20h_e0cc24b1:

    # gl "We gotta be quiet, because the boys are here, but I'm gonna get me some of that dick tonight."
    gl "On doit faire attention, parce que les garçons sont là, mais je vais me faire baiser ce soir."

