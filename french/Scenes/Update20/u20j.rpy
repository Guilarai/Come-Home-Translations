# game/Scenes/Update20/u20j.rpy:2
translate french u20j_be7d1e50:

    # "For now, I should go see Adrian."
    "Pour l’instant, je devrais aller voir Adrian."

# game/Scenes/Update20/u20j.rpy:5
translate french u20j_33260fe1:

    # "I drive over to Adrian's house and ring the doorbell."
    "Je me rends en voiture chez Adrian et je sonne à la porte."

# game/Scenes/Update20/u20j.rpy:6
translate french u20j_4fc89239:

    # "It's late and I hate to wake her, but I need to see her."
    "Il est tard et je déteste la réveiller, mais j’ai besoin de la voir."

# game/Scenes/Update20/u20j.rpy:9
translate french u20j_494a3331:

    # "Adrian's Mom" "Hello? Do you know how late it is?"
    "Adrian's Mom" "Allô ? Tu sais quelle heure il est ?"

# game/Scenes/Update20/u20j.rpy:10
translate french u20j_7d43c485:

    # pc "I'm sorry, I know. I'm a friend of Adrian's."
    pc "Je suis désolé, je sais. Je suis un ami d’Adrian."

# game/Scenes/Update20/u20j.rpy:11
translate french u20j_87309e2a:

    # pc "Could I talk to her, please?"
    pc "Je pourrais lui parler, s'il vous plaît ?"

# game/Scenes/Update20/u20j.rpy:12
translate french u20j_ad012933:

    # "Adrian's Mom" "Oh, are you [pcname]? She's been worried about you for weeks."
    "Adrian's Mom" "Oh, c'est vous [pcname] ? Elle s'inquiète pour vous depuis des semaines."

# game/Scenes/Update20/u20j.rpy:13
translate french u20j_332de7e5:

    # pc "Yes, I'm sorry. That's me."
    pc "Oui, je suis désolé. C'est moi."

# game/Scenes/Update20/u20j.rpy:16
translate french u20j_1a0d366a:

    # "Adrian's Mom" "She's going to be really happy to see you."
    "Adrian's Mom" "Elle va être vraiment contente de vous voir."

# game/Scenes/Update20/u20j.rpy:17
translate french u20j_1108c1b8:

    # "Adrian's Mom" "You can go up and see her, just keep things PG, okay?"
    "Adrian's Mom" "Vous pouvez monter la voir, mais restez correct, d'accord ?"

# game/Scenes/Update20/u20j.rpy:18
translate french u20j_e170ff6c:

    # pc "Yes, ma'am. Thank you."
    pc "Oui, madame. Merci."

# game/Scenes/Update20/u20j.rpy:22
translate french u20j_f5638052:

    # "I walk quietly up the stairs and into Adrian's room. She's in bed, sleeping."
    "Je monte les escaliers sans faire de bruit et entre dans la chambre d’Adrian. Elle est au lit, endormie."

# game/Scenes/Update20/u20j.rpy:25
translate french u20j_cbba5bfa:

    # "Trying not to wake her immediately, I lie next to her and wrap my arms around her."
    "Pour ne pas la réveiller tout de suite, je m’allonge à côté d’elle et l’enlace."

# game/Scenes/Update20/u20j.rpy:28
translate french u20j_c981bd85:

    # "She jolts awake and looks at me, shocked."
    "Elle se réveille en sursaut et me regarde, stupéfaite."

# game/Scenes/Update20/u20j.rpy:29
translate french u20j_a857ee55:

    # gg "What the fuck? [pcname]?"
    gg "C’est quoi ce bordel ? [pcname] ?"

# game/Scenes/Update20/u20j.rpy:32
translate french u20j_0f0952fe:

    # "I don't answer. I just pull her close and kiss her deeply."
    "Je ne réponds pas. Je la serre simplement contre moi et l’embrasse longuement."

# game/Scenes/Update20/u20j.rpy:33
translate french u20j_09b23034:

    # gg "Fuck, I was so worried about you. I thought you weren't ever coming back."
    gg "Putain, j’étais tellement inquiète pour toi. Je croyais que tu ne reviendrais jamais."

# game/Scenes/Update20/u20j.rpy:36
translate french u20j_b1adfb65:

    # gg "So you went to another world, for real?"
    gg "Alors tu es vraiment allée dans un autre monde ?"

# game/Scenes/Update20/u20j.rpy:37
translate french u20j_e5f2498c:

    # pc "Yeah, I did."
    pc "Oui, c’est vrai."

# game/Scenes/Update20/u20j.rpy:38
translate french u20j_29a8b357:

    # gg "And you saw your dad?"
    gg "Et tu as vu ton père ?"

# game/Scenes/Update20/u20j.rpy:39
translate french u20j_c417e350:

    # pc "Yeah."
    pc "Oui."

# game/Scenes/Update20/u20j.rpy:40
translate french u20j_fa6e7016:

    # gg "You have to tell me everything."
    gg "Tu dois tout me raconter."

# game/Scenes/Update20/u20j.rpy:41
translate french u20j_0bb899f2:

    # pc "I will, I promise. Tomorrow."
    pc "Je le ferai, je te le promets. Demain."

# game/Scenes/Update20/u20j.rpy:44
translate french u20j_92c42e64:

    # gg "Right. Tomorrow. I'm just glad you're back!"
    gg "D’accord. Demain. Je suis juste contente que tu sois de retour !"

# game/Scenes/Update20/u20j.rpy:45
translate french u20j_d2639c3b:

    # gg "I can't believe you're back."
    gg "Je n'arrive pas à croire que tu sois de retour."

# game/Scenes/Update20/u20j.rpy:46
translate french u20j_c01c395d:

    # gg "I'm so happy, I can't stand it."
    gg "Je suis tellement heureuse, je n'en peux plus."

# game/Scenes/Update20/u20j.rpy:49
translate french u20j_f432b969:

    # "I pull her close and kiss her again, feeling her warmth."
    "Je la serre contre moi et l'embrasse à nouveau, sentant sa chaleur."

# game/Scenes/Update20/u20j.rpy:50
translate french u20j_bf4f63bf:

    # gg "Good idea. Shut me up with your mouth."
    gg "Bonne idée. Fais-moi taire avec ta bouche."

# game/Scenes/Update20/u20j.rpy:51
translate french u20j_1530bf0e:

    # gg "I just missed you so much."
    gg "Tu m'as tellement manqué."

# game/Scenes/Update20/u20j.rpy:52
translate french u20j_9c24a5ca:

    # pc "I missed you too, Adrian."
    pc "Tu m'as manqué aussi, Adrian."

