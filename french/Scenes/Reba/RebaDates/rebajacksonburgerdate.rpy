translate french rebajacksonburgerstartdate_65a4a9d8:

    # "I meet Reba in front of Jackson Burger and we walk in together."
    "Je retrouve Reba devant le Jackson Burger et on entre ensemble."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:29
translate french rebajacksonburgerstartdate_aee9ac2a:

    # "We sit in the back in my usual booth."
    "On s’assoit au fond, à ma table habituelle."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:31
translate french rebajacksonburgerstartdate_3f6c7563:

    # rb "I love this place. I don't get to come here very often, but it's so good when I do."
    rb "J’adore cet endroit. Je n’ai pas souvent l’occasion d’y venir, mais c’est tellement bien quand j’y vais."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:34
translate french rebajacksonburgerstartdate_e0d8209b:

    # "A few moments after we sit down, Mari walks up to take our order."
    "Quelques instants après qu’on se soit assis, Mari s’approche pour prendre notre commande."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:36
translate french rebajacksonburgerstartdate_32aad169:

    # fr "Hey, [pcname]. Who's your date?"
    fr "Salut, [pcname]. C’est qui ta copine ?"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:37
translate french rebajacksonburgerstartdate_293f257d:

    # pc "This is Reba. We met a little while back and have started dating a bit."
    pc "C’est Reba. On s’est rencontrés il y a quelque temps et on a commencé à sortir ensemble."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:38
translate french rebajacksonburgerstartdate_50370da8:

    # fr "Hi, Reba. Nice to meet you."
