# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:53
translate french rebajacksonburgerstartdate_32597348:

    # rb "You're just adorable."
    rb "Tu es tout simplement adorable."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:54
