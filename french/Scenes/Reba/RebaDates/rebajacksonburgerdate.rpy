# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:42
translate french rebajacksonburgerstartdate_fb8c8e3b:

    # rb "Aw girl, it's nice to meet you too."
    rb "Oh ma belle, ravie de te rencontrer aussi."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:43
translate french rebajacksonburgerstartdate_9ab5b8d9:

    # rb "I guess you're another one of [pcname]'s friends?"
    rb "Je suppose que tu es une autre amie de [pcname] ?"

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:45
translate french rebajacksonburgerstartdate_8a01148f:

    # fr "Yep, that I am."
    fr "Oui, c'est ça."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:47
translate french rebajacksonburgerstartdate_eedef566:

    # fr "Yeah we're friends. Hopefully more eventually."
    fr "Ouais, on est amies. J'espère qu'on le sera davantage à terme."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:49
translate french rebajacksonburgerstartdate_c260d345:

    # fr "Yeah, we're friends."
    fr "Ouais, on est amies."

# game/Scenes/Reba/RebaDates/rebajacksonburgerdate.rpy:52
translate french rebajacksonburgerstartdate_d628d3cf:

    # rb "Well he sure knows how to pick them, huh?"
