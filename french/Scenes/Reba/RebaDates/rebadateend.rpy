# game/Scenes/Reba/RebaDates/rebadateend.rpy:5
translate french rebadateend_4407114d:

    # rb "That was fun, I had a really good time."
    rb "C'était sympa, j'ai vraiment passé un bon moment."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:10
translate french rebadateend_86e2c035:

    # "I step up and pull her into a kiss, which she returns enthusiastically."
    "Je m'approche et l'attire vers moi pour l'embrasser, ce qu'elle me rend avec enthousiasme."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:11
translate french rebadateend_39c7b3ca:

    # rb "Wow, I wish I could do more of that, but I gotta get home and make some supper for Mama."
    rb "Ouah, j'aimerais bien pouvoir faire ça plus souvent, mais je dois rentrer à la maison et préparer le dîner pour maman."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:13
translate french rebadateend_895c572b:

    # rb "I hope we can do this again soon. And maybe more. I want so much more."
    rb "J'espère qu'on pourra recommencer bientôt. Et peut-être plus. J'en veux tellement plus."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:16
translate french rebadateend_744ec225:

    # "I step up and pull her into a hug. She wraps her arms around me and squeezes me close."
    "Je m'approche et l'attire contre moi pour l'embrasser. Elle m'enlace et me serre fort contre elle."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:17
translate french rebadateend_91433507:

    # rb "Thanks for taking me out. I hope we can do this again soon."
    rb "Merci de m'avoir invitée. J'espère qu'on pourra recommencer bientôt."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:18
translate french rebadateend_4f8314b3:

    # rb "But I better get home. Gotta make supper for Mama."
    rb "Mais je ferais mieux de rentrer. Je dois préparer le dîner pour maman."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:21
translate french rebadateend_24de817d:

    # pc "Do you want to come back to my house for a while?"
    pc "Tu veux venir chez moi un moment ?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:23
translate french rebadateend_c8f7ca44:

    # rb "You want a little hanky-panky?"
    rb "Tu veux un peu de piment ?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:24
translate french rebadateend_f4be2d3d:

    # rb "Good, because I {i}really{/i} do too. Let's go."
    rb "Parfait, parce que moi aussi, {i}vraiment{/i}. Allons-y."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:28
translate french rebadateend_ed307571:

    # "We drive back to my house and go up to my bedroom, where things quickly lead to us being naked on the bed."
    "On rentre chez moi en voiture et on monte dans ma chambre, où les choses dégénèrent rapidement et on se retrouve nus sur le lit."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:32
translate french rebadateend_52303b0f:

    # pc "Yeah, it was good. I'll see you later Reba."
    pc "Ouais, c'était bien. À plus tard, Reba."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:33
translate french rebadateend_7657b93c:

    # rb "Uh, okay."
    rb "Euh, d'accord."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:34
translate french rebadateend_46d8c374:

    # rb "I'll see you later, [pcname]."
    rb "À plus tard, [pcname]."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:35
translate french rebadateend_2fd019a4:

    # "She waves goodbye and gets into her truck and drives away."
    "Elle me fait un signe de la main, monte dans son pick-up et s'en va."

