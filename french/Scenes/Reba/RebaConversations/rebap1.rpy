# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Reba/RebaConversations/rebap1.rpy:12
translate french rebap1_33512a1b:

    # rb "I think you know the answer to that."
    rb "Je pense que tu connais la réponse à ça."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:13
translate french rebap1_1b283206:

    # rb "No. I'm not happy. But what am I supposed to do?"
    rb "Non. Je ne suis pas contente. Mais qu'est-ce que je suis censée faire ?"

# game/Scenes/Reba/RebaConversations/rebap1.rpy:14
translate french rebap1_9c9b6016:

    # rb "I don't make enough money to live by myself anyways, and even if I did..."
    rb "Je ne gagne pas assez d'argent pour vivre seule de toute façon, et même si c'était le cas..."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:15
translate french rebap1_190acff7:

    # rb "... I can't leave Mama."
    rb "... Je ne peux pas laisser maman."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:16
translate french rebap1_cb78bdc6:

    # pc "You could probably get some sort of financial aid if you went to college."
    pc "Tu pourrais probablement obtenir une aide financière si tu allais à l'université."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:17
translate french rebap1_674b9eed:

    # pc "You could stay at the dorms."
    pc "Tu pourrais vivre en résidence universitaire."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:19
translate french rebap1_35288230:

    # rb "That's not a bad idea. Maybe I'd be able to do that and still go home and take care of Mama sometimes too."
    rb "Ce n'est pas une mauvaise idée. Peut-être que je pourrais faire ça tout en rentrant à la maison pour m'occuper de maman de temps en temps."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:20
translate french rebap1_61f77a4c:

    # pc "Sure."
    pc "Bien sûr."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:22
translate french rebap1_58d87f84:

    # rb "Eventually though... I know I need to live my own life."
    rb "Mais à terme... je sais que je dois vivre ma propre vie."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:24
translate french rebap1_9049ec3c:

    # rb "This is supposed to be the best time of my life, you know? I'm young, I'm pretty, and I got my whole life ahead of me."
    rb "C'est censé être la meilleure période de ma vie, tu sais ? Je suis jeune, je suis jolie, et j'ai toute la vie devant moi."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:25
translate french rebap1_44258c2a:

    # rb "I don't want to spend it all taking care of Mama."
    rb "Je ne veux pas passer tout ce temps à m'occuper de maman."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:26
translate french rebap1_87c60ffa:

    # pc "Yeah, I get that."
    pc "Oui, je comprends ça."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:28
translate french rebap1_015cec10:

    # rb "But I can't just abandon her either."
    rb "Mais je ne peux pas non plus l'abandonner comme ça."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:30
translate french rebap1_a5b0020a:

    # rb "I just don't know what to do. It's so hard."
    rb "Je ne sais tout simplement pas quoi faire. C'est tellement dur."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:31
translate french rebap1_66f2eaa8:

    # pc "Well, whatever you want to do, I'm here for you."
    pc "Eh bien, quoi que tu décides de faire, je suis là pour toi."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:33
translate french rebap1_7edfc2c9:

    # rb "Thanks, [pcname]."
    rb "Merci, [pcname]."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:34
translate french rebap1_aa660344:

    # rb "I'm really glad that we met."
    rb "Je suis vraiment contente qu’on se soit rencontrées."

# game/Scenes/Reba/RebaConversations/rebap1.rpy:35
translate french rebap1_03eaad50:

    # pc "Me too."
    pc "Moi aussi."

