# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Reba/RebaConversations/rebas1.rpy:14
translate french rebas1_703a7a1f:

    # rb "Well you've met Mama and Mickey."
    rb "Bon, tu as rencontré maman et Mickey."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:15
translate french rebas1_96542516:

    # rb "Mama used to be a teacher. Now she's on disability. Bad knees."
    rb "Maman était enseignante. Maintenant, elle est en invalidité. Elle a mal aux genoux."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:17
translate french rebas1_a876459e:

    # rb "And Mickey. Ugh."
    rb "Et Mickey. Beurk."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:18
translate french rebas1_e06598b6:

    # rb "I love my brother, but he drives me bananas."
    rb "J'aime mon frère, mais il me rend dingue."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:19
translate french rebas1_a078429c:

    # rb "He's just always messing things up, gettin' into trouble, causing problems."
    rb "Il ne fait que tout gâcher, s'attirer des ennuis, causer des problèmes."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:21
translate french rebas1_8f0c1d05:

    # rb "Mama says he's got too much of Daddy in him."
    rb "Maman dit qu'il tient trop de papa."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:22
translate french rebas1_de773d17:

    # rb "And he acts like he's Daddy too, always trying to tell me what to do."
    rb "Et il se comporte comme s'il était papa lui aussi, toujours en train d'essayer de me dire quoi faire."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:23
translate french rebas1_6e032bd6:

    # rb "Just want to clobber him sometimes."
    rb "J'ai juste envie de le frapper parfois."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:24
translate french rebas1_fa340cd0:

    # pc "And your dad? He's in prison?"
    pc "Et ton père ? Il est en prison ?"

# game/Scenes/Reba/RebaConversations/rebas1.rpy:26
translate french rebas1_2ef44ad1:

    # rb "No, Daddy's in heaven."
    rb "Non, papa est au paradis."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:27
translate french rebas1_6c6d9416:

    # pc "Oh, I'm sorry."
    pc "Oh, je suis désolé."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:28
translate french rebas1_096f84a0:

    # rb "He got sick in prison. Died there. It was real hard on Mama. On me and Mickey too, of course, but Mama took it real bad."
    rb "Il est tombé malade en prison. Il y est mort. Ça a été très dur pour maman. Pour moi et Mickey aussi, bien sûr, mais maman l’a très mal pris."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:30
translate french rebas1_aa778eb3:

    # rb "That's when she stopped working, gained all the weight, pretty much sits in front of the television now and doesn't do much."
    rb "C’est là qu’elle a arrêté de travailler, qu’elle a pris tout ce poids, qu’elle passe pratiquement son temps devant la télévision maintenant et ne fait plus grand-chose."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:31
translate french rebas1_58925e02:

    # rb "So I dropped out of school so that I could help make money. 19 years old now and still in the same place."
    rb "Alors j’ai arrêté l’école pour pouvoir aider à gagner de l’argent. J’ai 19 ans maintenant et je suis toujours au même point."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:32
translate french rebas1_2b85a0c1:

    # pc "Not happy about that?"
    pc "Ça ne te plaît pas ?"

# game/Scenes/Reba/RebaConversations/rebas1.rpy:34
translate french rebas1_8ac2576b:

    # rb "No. Not really."
    rb "Non. Pas vraiment."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:35
translate french rebas1_91097140:

    # rb "But I can't just leave Mama."
    rb "Mais je ne peux pas simplement abandonner maman."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:36
translate french rebas1_d3a89021:

    # rb "She... and Mickey... are all that I have."
    rb "Elle… et Mickey… sont tout ce que j’ai."

