# game/Scenes/Reba/RebaConversations/rebaq5.rpy:13
translate french rebaq5_0bd21536:

    # rb "So, I wanted to talk with you about something..."
    rb "Alors, je voulais te parler d’une chose…"

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:15
translate french rebaq5_1f171cb4:

    # rb "Do you really love me, [pcname]?"
    rb "Est-ce que tu m’aimes vraiment, [pcname] ?"

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:16
translate french rebaq5_94f3d162:

    # pc "Of course. You're incredible."
    pc "Bien sûr. Tu es incroyable."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:18
translate french rebaq5_635685ea:

    # rb "So how would you feel about becoming exclusive?"
    rb "Alors, qu’est-ce que tu dirais de devenir exclusifs ?"

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:20
translate french rebaq5_b27fef81:

    # rb "I know you're dating other people right now. Which is fine."
    rb "Je sais que tu sors avec d’autres personnes en ce moment. Ça ne me dérange pas."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:21
translate french rebaq5_8a2043a4:

    # rb "But I ain't gonna be okay with that forever, you know?"
    rb "Mais je ne vais pas accepter ça éternellement, tu comprends ?"

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:23
translate french rebaq5_60ae3551:

    # rb "Once we get serious, you're mine. That's it. No sharing."
    rb "Une fois qu’on sera sérieux, tu seras à moi. C’est tout. Pas de partage."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:26
translate french rebaq5_1b493e00:

    # rb "Well, except maybe with Mari. Her, I'm okay with, as long as I'm with you."
    rb "Enfin, sauf peut-être avec Mari. Elle, ça ne me dérange pas, tant que je suis avec toi."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:28
translate french rebaq5_fa5ccb87:

    # rb "But besides her, no sharing."
    rb "Mais à part elle, pas de partage."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:30
translate french rebaq5_64cf444e:

    # rb "And I'm ready to get serious. I want you all to myself."
    rb "Et je suis prêt à m'engager sérieusement. Je te veux rien que pour moi."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:31
translate french rebaq5_c8fd7dde:

    # rb "You're a great boyfriend, and I can see us getting married and making babies and everything."
    rb "Tu es un super petit ami, et je nous imagine bien nous marier, avoir des enfants et tout ça."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:33
translate french rebaq5_c0b2d44d:

    # rb "So I need to know if you want that."
    rb "Alors j'ai besoin de savoir si c'est ce que tu veux."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:35
translate french rebaq5_ab6b0af5:

    # rb "And if you don't... well, I need to know that too, so I can decide what I want to do next."
    rb "Et si ce n'est pas le cas... eh bien, j'ai besoin de le savoir aussi, pour pouvoir décider de la suite."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:36
translate french rebaq5_a6921540:

    # pc "Can I have a little bit to think about it?"
    pc "Je peux avoir un peu de temps pour y réfléchir ?"

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:38
translate french rebaq5_e817da28:

    # rb "Of course! I don't wanna just throw this in your face now."
    rb "Bien sûr ! Je ne veux pas te mettre ça sur le dos tout de suite."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:39
translate french rebaq5_d69c298a:

    # rb "I want you to think about it."
    rb "Je veux que tu y réfléchisses."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:41
translate french rebaq5_7b3daf06:

    # rb "But soon, okay? Maybe after the end of the school year?"
    rb "Mais bientôt, d'accord ? Peut-être après la fin de l'année scolaire ?"

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:42
translate french rebaq5_f6efa27a:

    # pc "Yeah, I can do that."
    pc "Oui, je peux faire ça."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:44
translate french rebaq5_9da15242:

    # rb "Great. Until then, we'll just continue like we have been."
    rb "Super. D'ici là, on continuera comme avant."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:46
translate french rebaq5_f431b055:

    # rb "I really do love you, [pcname]. And no matter what you choose, I'm always going to love you."
    rb "Je t'aime vraiment, [pcname]. Et peu importe ce que tu choisiras, je t'aimerai toujours."

# game/Scenes/Reba/RebaConversations/rebaq5.rpy:47
translate french rebaq5_ae468fb0:

    # pc "I love you too, Reba."
    pc "Je t'aime aussi, Reba."

