# game/Scenes/Reba/reba9.rpy:5
translate french reba9_4a2deb47:

    # "My phone starts buzzing. Reba is calling."
    "Mon téléphone se met à vibrer. C’est Reba qui appelle."

# game/Scenes/Reba/reba9.rpy:9
translate french reba9_62aee7f1:

    # rb "Hey, [pcname]. You know how we talked about hanging out in town some time?"
    rb "Salut, [pcname]. Tu te souviens qu'on avait parlé de sortir en ville un de ces jours ?"

# game/Scenes/Reba/reba9.rpy:10
translate french reba9_28c6d658:

    # rb "Are you busy right now? I'm really craving a burger."
    rb "Tu es occupé en ce moment ? J'ai vraiment envie d'un hamburger."

# game/Scenes/Reba/reba9.rpy:14
translate french reba9_15d1a1d2:

    # rb "Awesome! I'll meet you at Jackson Burger, alright?"
    rb "Super ! On se retrouve chez Jackson Burger, d'accord ?"

# game/Scenes/Reba/reba9.rpy:15
translate french reba9_b0ab0038:

    # pc "Sounds good. See you there."
    pc "Ça me va. À tout à l'heure."

# game/Scenes/Reba/reba9.rpy:19
translate french reba9_e23feda5:

    # rb "Aw alright. Well if you change your mind, just give me a call sometime."
    rb "Ah, d'accord. Bon, si tu changes d'avis, appelle-moi quand tu veux."

# game/Scenes/Reba/reba9.rpy:20
translate french reba9_24b552e3:

    # rb "I'm available most evenings."
    rb "Je suis disponible presque tous les soirs."

# game/Scenes/Reba/reba9.rpy:21
translate french reba9_64c8cb1f:

    # pc "Okay, I will."
    pc "D'accord, je le ferai."

# game/Scenes/Reba/reba9.rpy:22
translate french reba9_e0e1ea50:

    # rb "See you later, [pcname]."
    rb "À plus tard, [pcname]."

# game/Scenes/Reba/reba9.rpy:34
translate french reba9b_0e02b106:

    # "My phone buzzes. It looks like I got a text from Reba."
    "Mon téléphone vibre. On dirait que j'ai reçu un SMS de Reba."

# game/Scenes/Reba/reba9.rpy:49
translate french reba9b_bce9991d:

    # "Wow."
    "Ouah."

# game/Scenes/Reba/reba9.rpy:53
translate french reba9b_ab930a7e:

    # "Just wow."
    "Tout simplement ouah."

# game/Scenes/Reba/reba9.rpy:59
translate french reba9b_cb625026:

    # "I put the phone away and go to sleep, thinking about burying my face between those big tits."
    "Je range mon téléphone et je vais me coucher, en pensant à enfouir mon visage entre ces gros seins."

translate french strings:

    # game/Scenes/Reba/reba9.rpy:26
    old "A few days after you go mudding with Reba, she will call and ask if you want to go out for a burger."
    new "Quelques jours après être allé faire du tout-terrain avec Reba, elle t'appellera pour te demander si tu veux sortir manger un hamburger."

    # game/Scenes/Reba/reba9.rpy:27
    old "Go on the date with her and she will send you a text at night."
    new "Accepte son invitation et elle t'enverra un SMS dans la soirée."

