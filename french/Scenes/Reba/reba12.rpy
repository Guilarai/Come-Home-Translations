    rb "Je veux te donner ma virginité ce soir, d'accord ?"

# game/Scenes/Reba/reba12.rpy:93
translate french reba12_659c9116:

    # pc "Are you sure?"
    pc "Tu es sûre ?"

# game/Scenes/Reba/reba12.rpy:94
