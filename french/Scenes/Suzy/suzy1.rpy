# game/Scenes/Suzy/suzy1.rpy:13
translate french suzy1_b52dca5a:

    # "I go to the kitchen and make a plate with what's left, then sit down across from her at the table."
    "Je vais dans la cuisine et je me prépare une assiette avec ce qui reste, puis je m'assois en face d'elle à table."

# game/Scenes/Suzy/suzy1.rpy:14
translate french suzy1_c4e96a72:

    # "She puts her phone away and looks up at me."
    "Elle range son téléphone et lève les yeux vers moi."

# game/Scenes/Suzy/suzy1.rpy:17
translate french suzy1_43f2e75d:

    # ss "So how's it been going [bro]?"
    ss "Alors, comment ça va [bro] ?"

# game/Scenes/Suzy/suzy1.rpy:18
translate french suzy1_d48b3188:

    # pc "Pretty good, I guess."
    pc "Plutôt bien, je suppose."

# game/Scenes/Suzy/suzy1.rpy:19
translate french suzy1_c84b49b4:

    # ss "Have you found out anything about Dad?"
    ss "Tu as appris quelque chose à propos de papa ?"

# game/Scenes/Suzy/suzy1.rpy:20
translate french suzy1_0b7558fc:

    # pc "Not yet."
    pc "Pas encore."

# game/Scenes/Suzy/suzy1.rpy:22
translate french suzy1_e47fa0f8:

    # ss "I miss him."
    ss "Il me manque."

# game/Scenes/Suzy/suzy1.rpy:23
translate french suzy1_0b941cef:

    # pc "You got along with him well?"
    pc "Tu t'entendais bien avec lui ?"

# game/Scenes/Suzy/suzy1.rpy:24
translate french suzy1_0442c0e0:

    # ss "Yeah."
    ss "Ouais."

# game/Scenes/Suzy/suzy1.rpy:25
translate french suzy1_d244b907:

    # ss "I mean, we didn't spend a lot of time together. He was down in that basement a lot."
    ss "Je veux dire, on ne passait pas beaucoup de temps ensemble. Il était souvent dans ce sous-sol."

# game/Scenes/Suzy/suzy1.rpy:26
translate french suzy1_34edb007:

    # ss "But he would have breakfast with me every morning before school. He was funny. He'd make me laugh every day."
    ss "Mais il prenait le petit-déjeuner avec moi tous les matins avant l'école. Il était drôle. Il me faisait rire tous les jours."

# game/Scenes/Suzy/suzy1.rpy:27
translate french suzy1_85af114e:

    # pc "Kind of like this, huh?"
    pc "Un peu comme ça, hein ?"

# game/Scenes/Suzy/suzy1.rpy:29
translate french suzy1_226f4904:

    # ss "I said he was funny, not obnoxious. Plus, he wore pants. Why are you walking around in your boxers?"
    ss "J'ai dit qu'il était drôle, pas odieux. En plus, il portait un pantalon. Pourquoi tu te promènes en caleçon ?"

# game/Scenes/Suzy/suzy1.rpy:30
translate french suzy1_4cc016bf:

    # pc "It's morning, I don't want to get dressed yet. You can eat breakfast in your underwear if you want."
    pc "C'est le matin, je n'ai pas encore envie de m'habiller. Tu peux prendre ton petit-déjeuner en sous-vêtements si tu veux."

# game/Scenes/Suzy/suzy1.rpy:31
translate french suzy1_bd01965a:

    # ss "Yeah, I bet you'd like that. You'd just stare at me the whole time."
    ss "Ouais, je parie que ça te plairait. Tu passerais ton temps à me mater."

# game/Scenes/Suzy/suzy1.rpy:35
translate french suzy1_d7a0aba4:

    # ss "You're such a perv."
    ss "T'es vraiment un pervers."

# game/Scenes/Suzy/suzy1.rpy:38
translate french suzy1_0ca3339d:

    # ss "You're such a jerk."
    ss "T'es vraiment un crétin."

# game/Scenes/Suzy/suzy1.rpy:39
translate french suzy1_a976ce63:

    # pc "Besides, you act like you don't stare at me when I'm in my boxers."
    pc "En plus, tu fais comme si tu ne me fixais pas quand je suis en caleçon."

# game/Scenes/Suzy/suzy1.rpy:40
translate french suzy1_23992985:

    # ss "What!? I do not!"
    ss "Quoi ?! Mais non !"

# game/Scenes/Suzy/suzy1.rpy:41
translate french suzy1_25e7a80f:

    # pc "Come on now [sis], I've seen you."
    pc "Allez [sis], je t'ai vu."

# game/Scenes/Suzy/suzy1.rpy:43
translate french suzy1_873662ce:

    # ss "You're out of your mind. I've never stared at you. Like you have anything to stare at anyways."
    ss "T'es complètement dingue. Je t'ai jamais fixée. Comme si t'avais quelque chose à regarder de toute façon."

# game/Scenes/Suzy/suzy1.rpy:44
translate french suzy1_6e7bc529:

    # pc "Oh I don't have anything to stare at?"
    pc "Oh, j'ai rien à regarder ?"

# game/Scenes/Suzy/suzy1.rpy:45
translate french suzy1_ec7a8238:

    # ss "Nope."
    ss "Non."

# game/Scenes/Suzy/suzy1.rpy:48
translate french suzy1_7745b76d:

    # ss "Yeah, whatever."
    ss "Ouais, peu importe."

# game/Scenes/Suzy/suzy1.rpy:51
translate french suzy1_24166e5d:

    # ss "No! I don't want to see!"
    ss "Non ! Je veux pas voir ça !"

# game/Scenes/Suzy/suzy1.rpy:52
translate french suzy1_483160a9:

    # ss "Sit down. Stop playing around."
    ss "Assieds-toi. Arrête de faire le malin."

# game/Scenes/Suzy/suzy1.rpy:53
translate french suzy1_ce7899d2:

    # pc "I'm not playing. I'll show you."
    pc "Je fais pas le malin. Je vais te montrer."

# game/Scenes/Suzy/suzy1.rpy:54
translate french suzy1_626bbd17:

    # ss "I don't want to see it. I believe you have something there, but I don't want to see it."
    ss "Je veux pas voir ça. Je crois que t'as bien quelque chose là, mais je veux pas voir ça."

# game/Scenes/Suzy/suzy1.rpy:55
translate french suzy1_c1226f21:

    # ss "Put it away, sit down."
    ss "Range ça, assieds-toi."

# game/Scenes/Suzy/suzy1.rpy:56
translate french suzy1_02b8ec2b:

    # pc "Alright, I'm sitting."
    pc "D'accord, je m'assois."

# game/Scenes/Suzy/suzy1.rpy:58
translate french suzy1_c7580a8a:

    # ss "You're such a weirdo."
    ss "T'es vraiment bizarre."

# game/Scenes/Suzy/suzy1.rpy:59
translate french suzy1_086a625f:

    # "We spend the rest of the breakfast talking about school and work and joking around."
    "On passe le reste du petit-déjeuner à parler de l'école et du travail et à plaisanter."

# game/Scenes/Suzy/suzy1.rpy:60
translate french suzy1_74d7aff9:

    # "Then we finish eating and it's time to go to school."
    "Puis on finit de manger et c'est l'heure d'aller à l'école."

# game/Scenes/Suzy/suzy1.rpy:65
translate french suzy1_74b357a7:

    # ss "Have a good day [bro]. See you later."
    ss "Passe une bonne journée [bro]. À plus tard."

# game/Scenes/Suzy/suzy1.rpy:66
translate french suzy1_7dee10c4:

    # pc "Bye [sis]."
    pc "Salut [sis]."

# game/Scenes/Suzy/suzy1.rpy:71
translate french suzy1_015cad61:

    # "She leaves for school and I follow right after her."
    "Elle part à l'école et je la suis de près."

