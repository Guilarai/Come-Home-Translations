# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:16
translate french suzybeachdate_e0e387e2:

    # "Suzy gets ready and we drive out to the beach together."
    "Suzy se prépare et on part ensemble en voiture à la plage."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:19
translate french suzybeachdate_a4746763:

    # "We spend some time swimming around and chatting with each other."
    "On passe un moment à nager et à discuter."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:22
translate french suzybeachdate_da78be7b:

    # "The water is nice and she's just fun to be with."
    "L'eau est agréable et c'est vraiment sympa d'être avec elle."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:25
translate french suzybeachdate_e8a06208:

    # "When we're both tired from swimming and the sun is starting to set, we sit on the beach together and eat the dinner that we packed."
    "Quand on est tous les deux fatigués d'avoir nagé et que le soleil commence à se coucher, on s'assoit ensemble sur la plage et on mange le dîner qu'on a emporté."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:28
translate french suzybeachdate_e615ede1:

    # "Then we lean back and talk for a while about whatever comes to mind."
    "Puis on se penche en arrière et on discute un moment de tout ce qui nous passe par la tête."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:38
translate french suzybeachdate_90f82d97:

    # "When the sun starts to set, we sit and watch it together, the sky growing darker and the air cooler."
    "Quand le soleil commence à se coucher, on s'assoit et on le regarde ensemble, le ciel s'assombrissant et l'air se rafraîchissant."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:39
translate french suzybeachdate_a8ff3746:

    # "Until the last ray of sunlight dips below the horizon."
    "Jusqu'à ce que le dernier rayon de soleil disparaisse sous l'horizon."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:42
translate french suzybeachdate_dd9441ef:

    # ss "That was beautiful."
    ss "C'était magnifique."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:43
translate french suzybeachdate_805db1af:

    # pc "You're beautiful."
    pc "Tu es magnifique."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:44
translate french suzybeachdate_68db0d5c:

    # ss "You're a dork. Let's go home."
    ss "T'es un crétin. Rentrons à la maison."

# game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:47
translate french suzybeachdate_7804a69a:

    # "We drive back home, both of us tired, Suzy dozing off against the window."
    "On rentre à la maison en voiture, tous les deux fatigués, Suzy somnolant contre la vitre."

translate french strings:

    # game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:2
    old "After the first time you and Suzy go to the beach together,"
    new "Après la première fois où toi et Suzy allez à la plage ensemble,"

    # game/Scenes/Suzy/SuzyDates/suzybeachdate.rpy:3
    old "you can go to her room in the evening to invite her out to the beach any day."
    new "tu peux passer dans sa chambre le soir pour l'inviter à la plage n'importe quel jour."

