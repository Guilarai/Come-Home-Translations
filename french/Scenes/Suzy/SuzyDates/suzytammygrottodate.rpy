translate french suzytammygrottodate_edef91a3:

    # "We get ready and go out to The Grotto together."
    "On se prépare et on sort ensemble au Grotto."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:19
translate french suzytammygrottodate_a118cb72:

    # ss "I love this place."
    ss "J'adore cet endroit."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:21
translate french suzytammygrottodate_f556393a:

    # tm "Me too. Thanks for taking us, [pcname]."
    tm "Moi aussi. Merci de nous emmener, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:23
translate french suzytammygrottodate_ad1121f0:

    # ss "Yeah, thanks [bro]."
    ss "Ouais, merci [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:25
translate french suzytammygrottodate_a91a4522:

    # "We chat while we eat and enjoy the atmosphere."
    "On discute tout en mangeant et on profite de l'ambiance."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:33
translate french suzytammygrottodate_a306e385:

    # "After we eat, we dance to a couple of songs."
    "Après le repas, on danse sur quelques morceaux."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:36
translate french suzytammygrottodate_ffb49b98:

    # "Fuck, they're gorgeous. I can't help but to stare at them and wonder how I got to be so lucky."
    "Putain, elles sont magnifiques. Je ne peux m’empêcher de les fixer et de me demander comment j’ai pu avoir autant de chance."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:39
translate french suzytammygrottodate_7909898e:

    # ss "You ready to take us home, [bro]?"
    ss "Tu es prêt à nous ramener à la maison, [bro] ?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:40
translate french suzytammygrottodate_3dae9d31:

    # pc "Uh, yeah... we should go."
    pc "Euh, ouais… on devrait y aller."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:46
translate french suzytammygrottodate_d41d8cd9:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:47
translate french suzytammygrottodate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "On dirait que maman dort déjà. Alors, tu veux qu’on termine le rendez-vous ici, ou qu’on monte dans ta chambre pour le finir comme il faut ?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:50
translate french suzytammygrottodate_df8719cf:

    # tm "Fuck yes."
    tm "Putain, oui."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:53
translate french suzytammygrottodate_621e1461:

    # "We quietly walk upstairs together, go into my bedroom, and lock the door."
    "On monte tranquillement ensemble, on entre dans ma chambre et on verrouille la porte."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:58
translate french suzytammygrottodate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Bon, j’ai passé un bon moment, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:59
translate french suzytammygrottodate_be17834a:

    # tm "Yeah, me too."
    tm "Ouais, moi aussi."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:60
translate french suzytammygrottodate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "Dors bien. À demain."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:61
translate french suzytammygrottodate_d35669a0:

    # tm "Good night, [pcname]."
    tm "Bonne nuit, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:64
translate french suzytammygrottodate_d747330a:

    # "They go up to Suzy's bedroom, leaving me to decide what I want to do with my night."
    "Elles montent dans la chambre de Suzy, me laissant décider ce que je veux faire de ma soirée."

