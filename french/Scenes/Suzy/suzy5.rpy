    old "Don't worry, it'll be fine"
    new "Ne t'inquiète pas, tout ira bien"

    # game/Scenes/Suzy/suzy5.rpy:51
    old "Let me take a look at it"
    new "Laisse-moi jeter un œil"

    # game/Scenes/Suzy/suzy5.rpy:54
    old "Maybe don't drive like a crazy person?"
    new "Tu devrais peut-être éviter de conduire comme une folle ?"

    # game/Scenes/Suzy/suzy5.rpy:94
    old "I didn't mind"
    new "Ça ne me dérangeait pas"

    # game/Scenes/Suzy/suzy5.rpy:105
