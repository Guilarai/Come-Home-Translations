translate french suzytammys2_e9711f63:

    # tm "Oh, fuck yeah."
    tm "Oh, putain, ouais."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:14
translate french suzytammys2_79c364b6:

    # tm "Not stopping until somebody stops me."
    tm "Je m'arrêterai pas tant que quelqu'un m'en empêchera pas."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:16
translate french suzytammys2_b9ce75f8:

    # ss "Nobody's gonna stop you, baby. You're gonna kick all their asses."
    ss "Personne va t'arrêter, bébé. Tu vas leur botter le cul à tous."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:18
translate french suzytammys2_be00951c:

    # pc "When's your next fight?"
    pc "C'est quand ton prochain combat ?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:20
translate french suzytammys2_b8f8c31b:

    # tm "Ugh, I'm not sure right now."
    tm "Pff, je ne sais pas trop pour l'instant."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:21
translate french suzytammys2_841b4733:

    # tm "Chuck is taking forever to find somebody else to fight me. Probably not gonna happen for a while."
    tm "Chuck met une éternité à me trouver un adversaire. Ça ne va probablement pas se faire avant un moment."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:22
translate french suzytammys2_027c2f91:

    # tm "Which sucks, because I really wanna fight again."
    tm "C'est dommage, parce que j'ai vraiment envie de me battre à nouveau."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:23
translate french suzytammys2_3199c375:

    # tm "I'd love to be able to do some bigger fights too. Work my way up, you know? Maybe even fight professionally one day."
    tm "J'adorerais pouvoir faire des combats plus importants aussi. Grimper les échelons, tu vois ? Peut-être même devenir pro un jour."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:25
translate french suzytammys2_03f13fa0:

    # ss "I know you could."
    ss "Je sais que tu en es capable."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:27
translate french suzytammys2_62e9c248:

    # pc "What's stopping you?"
    pc "Qu'est-ce qui t'en empêche ?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:28
translate french suzytammys2_9fdd7168:

    # tm "Just location. Can't do shit in Skyhill. Need to go to a bigger city and get involved in the fighting circuits there."
    tm "C'est juste le lieu. Je peux rien faire à Skyhill. Faut que j'aille dans une plus grande ville et que je m'implique dans les circuits de combat là-bas."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:29
translate french suzytammys2_2e7dd32a:

    # pc "Why don't you do that then?"
    pc "Pourquoi tu le fais pas, alors ?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:30
translate french suzytammys2_9112c25c:

    # tm "Money, baby. It's all about money."
    tm "L'argent, bébé. Tout est une question d'argent."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:32
translate french suzytammys2_10013f01:

    # tm "I'm getting there though. Hopefully one day soon, I'll be able to get myself in a better position."
    tm "Mais j'y arrive petit à petit. J'espère qu'un jour, bientôt, je pourrai me mettre dans une meilleure position."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:34
translate french suzytammys2_039c7f19:

    # ss "I like you in any position."
    ss "Je t'aime dans n'importe quelle position."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:36
translate french suzytammys2_fb3d3cc3:

    # tm "You're such a slut!"
    tm "T'es vraiment une salope !"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys2.rpy:38
translate french suzytammys2_00e7f15e:

    # ss "Only for you two. I'll be your slut any time."
    ss "Juste pour vous deux. Je serai votre salope quand vous voulez."

