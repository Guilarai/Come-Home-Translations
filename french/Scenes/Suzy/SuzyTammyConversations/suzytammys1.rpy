# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:49
translate french suzytammys1_ac8f4b6e:

    # pc "Yeah, damn. I hope it's not anything like that."
    pc "Ouais, merde. J'espère que c'est pas quelque chose comme ça."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:51
translate french suzytammys1_7939d1e1:

    # ss "I'm sure it's not. But he's hiding something!"
    ss "Je suis sûre que non. Mais il cache quelque chose !"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:52
translate french suzytammys1_d8c3a717:

    # pc "Has he ever done anything weird to you?"
