translate french suzytammys1_2ad68341:

    # pc "What do you mean, weird?"
    pc "Comment ça, bizarre ?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:20
translate french suzytammys1_f5500674:

    # ss "Like overly cheerful and wholesome."
    ss "Genre trop joyeux et trop sain."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:22
translate french suzytammys1_8140ae26:

    # ss "People like that freak me out. Makes me feel like he's hiding something."
    ss "Les gens comme ça me font flipper. J'ai l'impression qu'il cache quelque chose."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:23
translate french suzytammys1_15026317:

    # ss "Like he's a secret pervert or something."
    ss "Comme s'il était un pervers secret ou un truc du genre."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:25
translate french suzytammys1_3af8aacf:

    # pc "You may be onto something there."
    pc "Tu as peut-être mis le doigt sur quelque chose là."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:27
translate french suzytammys1_84f23d86:

    # ss "I knew it!"
    ss "Je le savais !"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:28
translate french suzytammys1_754b07cd:

    # tm "What are you talking about? What do you know?"
    tm "De quoi tu parles ? Qu'est-ce que tu sais ?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:29
translate french suzytammys1_6d3f5bbb:

    # pc "I can't say any more!"
    pc "Je ne peux pas en dire plus !"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:31
translate french suzytammys1_e3b699f1:

    # tm "Really!?"
    tm "Vraiment ?!"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:32
translate french suzytammys1_ef763d54:

    # ss "You're going to do that to us?"
    ss "Tu vas nous faire ça ?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:33
translate french suzytammys1_4465b574:

    # pc "I'm sorry. I promised!"
    pc "Je suis désolé. Je l’ai promis !"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:35
translate french suzytammys1_0c8828b4:

    # pc "He's not so bad though. It's nothing to worry about."
    pc "Il n’est pas si mal que ça, pourtant. Il n’y a pas de quoi s’inquiéter."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:37
translate french suzytammys1_4570994a:

    # ss "We're going to get it out of you eventually."
    ss "On finira bien par te le faire avouer."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:38
translate french suzytammys1_9d64452a:

    # pc "You think so?"
    pc "Tu crois ?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:40
translate french suzytammys1_a3419192:

    # tm "We have our ways."
    tm "On a nos méthodes."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:43
translate french suzytammys1_f59ffb5b:

    # tm "I think everybody's a secret pervert... unless they're a pervert openly, anyways."
