# game/Scenes/Tammy/tammy2.rpy:12
translate french tammy2_58882cf4:

    # "I spend some time working out with Tammy."
    "Je passe un moment à m'entraîner avec Tammy."

# game/Scenes/Tammy/tammy2.rpy:13
translate french tammy2_f8739613:

    # "First I spot her."
    "D'abord, je la repère."

# game/Scenes/Tammy/tammy2.rpy:16
translate french tammy2_b03ba21e:

    # "Then she spots me."
    "Puis elle me repère."

# game/Scenes/Tammy/tammy2.rpy:20
translate french tammy2_f59c8527:

    # "Then we start chatting a bit between reps."
    "Ensuite, on commence à discuter un peu entre deux séries."

# game/Scenes/Tammy/tammy2.rpy:21
translate french tammy2_e027ab69:

    # tm "You ever think about trying MMA?"
    tm "Tu as déjà pensé à essayer le MMA ?"

# game/Scenes/Tammy/tammy2.rpy:22
translate french tammy2_08f599b9:

    # pc "MMA? Like fighting?"
    pc "Le MMA ? Comme le combat ?"

# game/Scenes/Tammy/tammy2.rpy:23
translate french tammy2_7ed92c4d:

    # tm "Yeah, like fighting. I train every weekend in the morning."
    tm "Ouais, comme le combat. Je m'entraîne tous les week-ends le matin."

# game/Scenes/Tammy/tammy2.rpy:24
translate french tammy2_690f9781:

    # tm "You could come join me sometime."
    tm "Tu pourrais venir me rejoindre un de ces jours."

# game/Scenes/Tammy/tammy2.rpy:25
translate french tammy2_50211aa2:

    # pc "You're just looking for an excuse to beat me up."
    pc "Tu cherches juste une excuse pour me tabasser."

# game/Scenes/Tammy/tammy2.rpy:27
translate french tammy2_d669bb2f:

    # "She punches me hard in the arm."
    "Elle me donne un coup de poing bien fort dans le bras."

# game/Scenes/Tammy/tammy2.rpy:28
translate french tammy2_68bd08bc:

    # tm "Ha! I don't need an excuse for that."
    tm "Ha ! J'ai pas besoin d'excuse pour ça."

# game/Scenes/Tammy/tammy2.rpy:29
translate french tammy2_dedf8f6f:

    # pc "Ow! Damn."
    pc "Aïe ! Merde."

# game/Scenes/Tammy/tammy2.rpy:31
translate french tammy2_eb4630f0:

    # tm "See that's why you need to come train in MMA. You got a nice body, but you're too soft."
    tm "Tu vois, c'est pour ça que tu dois venir t'entraîner au MMA. T'as un beau corps, mais t'es trop mou."

# game/Scenes/Tammy/tammy2.rpy:32
translate french tammy2_eb998a13:

    # pc "You think I have a nice body?"
    pc "Tu trouves que j'ai un beau corps ?"

# game/Scenes/Tammy/tammy2.rpy:33
translate french tammy2_9ac6fb46:

    # tm "Well, yeah."
    tm "Eh bien, ouais."

# game/Scenes/Tammy/tammy2.rpy:34
translate french tammy2_cce51848:

    # pc "Alright, I'll come wrestle with you some time."
    pc "D'accord, je viendrai m'entraîner avec toi un de ces jours."

# game/Scenes/Tammy/tammy2.rpy:35
translate french tammy2_bdefbf8e:

    # tm "Good. I'm looking forward to it. Mornings and Afternoons on the weekends, I'll be here."
    tm "Super. J'ai hâte. Le week-end, le matin et l'après-midi, je serai là."

# game/Scenes/Tammy/tammy2.rpy:39
translate french tammy2_7cd89556:

    # "We finish our workout and say goodbye to each other."
    "On termine notre entraînement et on se dit au revoir."

# game/Scenes/Tammy/tammy2.rpy:41
translate french tammy2_d33670c7:

    # "I have to admit, rolling around on the mat with her has a certain appeal."
    "Je dois admettre que me rouler par terre sur le tapis avec elle a un certain charme."

# game/Scenes/Tammy/tammy2.rpy:42
translate french tammy2_bf0d0df4:

    # "For now though, I leave the gym and go out to my car."
    "Pour l'instant, je quitte la salle et je sors vers ma voiture."

translate french strings:

    # game/Scenes/Tammy/tammy2.rpy:2
    old "Workout with Tammy on the weekend again."
    new "Entraîne-toi encore avec Tammy ce week-end."

    # game/Scenes/Tammy/tammy2.rpy:3
    old "Then she will ask if you want to train MMA with her."
    new "Elle te demandera alors si tu veux t'entraîner au MMA avec elle."

