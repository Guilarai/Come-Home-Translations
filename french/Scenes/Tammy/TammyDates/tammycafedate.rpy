# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:27
translate french tammycafestartdate_3bd70c3d:

    # tm "I like this place. The coffee isn't quite as good as what we make, but the atmosphere is a little more upbeat, you know?"
    tm "J’aime bien cet endroit. Le café n’est pas aussi bon que celui qu’on fait nous-mêmes, mais l’ambiance est un peu plus animée, tu vois ?"

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:28
translate french tammycafestartdate_d957fd81:

    # tm "I guess just because there's so many college kids that hang out here."
    tm "Je suppose que c’est juste parce qu’il y a plein d’étudiants qui traînent ici."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:29
translate french tammycafestartdate_cfe5cfd9:

    # tm "Java Lava is all business people. People getting their coffee on the way to work or something."
    tm "Au Java Lava, ce ne sont que des gens d’affaires. Des gens qui prennent leur café en allant au travail ou quelque chose comme ça."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:35
translate french tammycafestartdate_d91a9226:

    # "We sit and chat and drink our coffee."
    "On s'assoit, on discute et on boit notre café."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:37
translate french tammycafestartdate_c45a6676:

    # tm "This was nice."
    tm "C'était sympa."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:40
translate french tammycafestartdate_08d5d909:

    # tm "I feel like I need quiet time like this every once in a while, you know?"
    tm "J'ai l'impression d'avoir besoin d'un moment de calme comme ça de temps en temps, tu vois ?"

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:42
translate french tammycafestartdate_067f3278:

    # tm "Feels like I'm so busy all the time."
    tm "J'ai l'impression d'être tout le temps débordé."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:43
translate french tammycafestartdate_6bfbd889:

    # pc "Well, any time you want to just take a break and chill with somebody, I'm here for you."
    pc "Eh bien, chaque fois que tu veux juste faire une pause et te détendre avec quelqu'un, je suis là pour toi."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:45
translate french tammycafestartdate_61b43eaf:

    # tm "Thanks, [pcname]."
