# game/Scenes/Tammy/TammyMMA/tammymma.rpy:17
translate french tammymmanormal_55eb3e45:

    # tm "All right! I'm glad you came. Let's get to business."
    tm "Parfait ! Je suis contente que tu sois venu. Passons aux choses sérieuses."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:18
translate french tammymmanormal_095f6c6f:

    # tm "We're going to start with some stand-up. Get you started on the base punching and kicking technique."
    tm "On va commencer par un peu de combat debout. Je vais t'initier aux techniques de base des coups de poing et des coups de pied."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:19
translate french tammymmanormal_bccaba74:

    # pc "You're going to punch me, aren't you?"
    pc "Tu vas me frapper, n'est-ce pas ?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:21
translate french tammymmanormal_e526c3d8:

    # tm "Oh definitely."
    tm "Oh, sans aucun doute."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:23
translate french tammymmanormal_98c55581:

    # "I get up into the ring with Tammy and she demonstrates punching."
    "Je monte sur le ring avec Tammy et elle me montre comment donner des coups de poing."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:24
translate french tammymmanormal_65f9479a:

    # "I try to block, but I just don't have the motions down yet."
    "J'essaie de parer, mais je ne maîtrise pas encore les mouvements."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:26
translate french tammymmanormal_295f5a57:

    # "And kicking."
    "Et les coups de pied."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:27
translate french tammymmanormal_70863c7f:

    # "It hurts, but I can tell she's not going full-strength."
    "Ça fait mal, mais je vois bien qu'elle ne frappe pas à pleine puissance."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:29
translate french tammymmanormal_8aa64221:

    # "Then she gives me a chance to try to hit her."
    "Puis elle me donne l'occasion d'essayer de la frapper."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:30
translate french tammymmanormal_90068145:

    # "But she blocks every punch I throw."
    "Mais elle bloque tous les coups que je lance."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:32
translate french tammymmanormal_dd5027d0:

    # tm "Focus on technique. Don't worry about actually hitting me, just make sure that your movements are correct."
    tm "Concentre-toi sur la technique. Ne t'inquiète pas de me toucher, assure-toi juste que tes mouvements sont corrects."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:35
translate french tammymmanormal_bfe308ae:

    # "Tammy and I spar in the ring for a while."
    "Tammy et moi faisons un peu de combat sur le ring."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:39
translate french tammymmanormal_0bc42d9a:

    # tm "You did good for a first session."
    tm "Tu t'en es bien sorti pour une première séance."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:42
translate french tammymmanormal_a242518d:

    # tm "Good job. Keep training with me and you'll be a fighting machine in no time."
    tm "Bravo. Continue à t'entraîner avec moi et tu deviendras une machine de combat en un rien de temps."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:45
translate french tammymmanormal_cc85c375:

    # "Now I need to hurry and get to school."
    "Maintenant, je dois me dépêcher d'aller à l'école."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:48
translate french tammymmanormal_7844d429:

    # tm "Want to hit the showers with me?"
    tm "Tu veux aller prendre une douche avec moi ?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:52
translate french tammymmanormal_f7e04aed:

    # "I feel sore and tired, but it was fun and I did learn a lot."
    "Je me sens courbaturée et fatiguée, mais c'était sympa et j'ai beaucoup appris."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:53
translate french tammymmanormal_37ff6d3e:

    # "We say our goodbyes and go our separate ways."
    "On se dit au revoir et on se sépare."

