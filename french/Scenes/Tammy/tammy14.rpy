# game/Scenes/Tammy/tammy14.rpy:168
translate french tammy14_494fc97b:

    # pc "Yeah, it's amazing."
    pc "Ouais, c’est génial."

# game/Scenes/Tammy/tammy14.rpy:171
translate french tammy14_e8b49386:

    # "It doesn't take long, lying like that, for Tammy to fall asleep."
    "Allongée comme ça, Tammy ne tarde pas à s’endormir."

# game/Scenes/Tammy/tammy14.rpy:172
translate french tammy14_815d66b7:

    # "And as soon as she's asleep, she immediately begins snoring loudly."
    "Et dès qu'elle s'endort, elle se met immédiatement à ronfler bruyamment."

# game/Scenes/Tammy/tammy14.rpy:175
translate french tammy14_055d080f:

    # ss "Dang, she's loud, huh?"
    ss "Mince, elle ronfle fort, hein ?"

# game/Scenes/Tammy/tammy14.rpy:176
translate french tammy14_593f6724:

    # "I nod, trying to stay quiet."
    "J'acquiesce, en essayant de rester silencieux."

# game/Scenes/Tammy/tammy14.rpy:177
translate french tammy14_536bf33b:

    # ss "When she's really tired like this, she passes out hard. You could shake her and she's not going to wake up."
    ss "Quand elle est vraiment fatiguée comme ça, elle s'endort comme une masse. Tu pourrais la secouer, elle ne se réveillerait pas."

# game/Scenes/Tammy/tammy14.rpy:178
translate french tammy14_20e84dbf:

    # pc "She deserves a good night sleep."
    pc "Elle mérite une bonne nuit de sommeil."

# game/Scenes/Tammy/tammy14.rpy:179
translate french tammy14_e51a7dc2:

    # ss "Yeah. Thanks for being a good boyfriend tonight, [bro]."
    ss "Ouais. Merci d'avoir été un bon petit ami ce soir, [bro]."

# game/Scenes/Tammy/tammy14.rpy:180
translate french tammy14_a248948f:

    # pc "Of course."
    pc "Bien sûr."

# game/Scenes/Tammy/tammy14.rpy:181
translate french tammy14_53a16996:

    # ss "Love you."
    ss "Je t'aime."

# game/Scenes/Tammy/tammy14.rpy:182
translate french tammy14_3213fe29:

    # pc "Love you too, [sis]."
    pc "Je t'aime aussi, [sis]."

# game/Scenes/Tammy/tammy14.rpy:185
translate french tammy14_87d1006f:

    # "Suzy lies back down again and falls asleep."
    "Suzy se recouche et s'endort."

# game/Scenes/Tammy/tammy14.rpy:188
translate french tammy14_da5d00b9:

    # "Shortly after, despite Tammy's loud snoring, I fall asleep too."
    "Peu après, malgré les ronflements bruyants de Tammy, je m'endors moi aussi."

# game/Scenes/Tammy/tammy14.rpy:189
translate french tammy14_2af8e2e3:

    # "I have great dreams all night, but somehow they don't even compare to my waking life."
    "Je fais de beaux rêves toute la nuit, mais d'une certaine manière, ils ne valent pas ma vie éveillée."

# game/Scenes/Tammy/tammy14.rpy:192
translate french tammy14_d8050fd9:

    # "I must have slept hard as well, because I don't wake up through the entire night."
    "J'ai dû dormir profondément moi aussi, car je ne me réveille pas de toute la nuit."

# game/Scenes/Tammy/tammy14.rpy:195
translate french tammy14_6e97274e:

    # "And when I look around in the morning, they are both gone."
    "Et quand je regarde autour de moi le matin, elles sont toutes les deux parties."

# game/Scenes/Tammy/tammy14.rpy:201
translate french tammy14_d1a14932:

    # "I get up and go to the bathroom, then walk downstairs."
    "Je me lève, je vais aux toilettes, puis je descends."

# game/Scenes/Tammy/tammy14.rpy:204
translate french tammy14_7279822b:

    # "In the dining room, Suzy greets me with a kiss."
    "Dans la salle à manger, Suzy m’accueille avec un baiser."

# game/Scenes/Tammy/tammy14.rpy:205
translate french tammy14_ce46d3ed:

    # ss "There's some breakfast in the kitchen if you want any. Mom made way too much before she left."
    ss "Il y a du petit-déjeuner dans la cuisine si tu veux. Maman en a fait beaucoup trop avant de partir."

# game/Scenes/Tammy/tammy14.rpy:206
translate french tammy14_03e500eb:

    # pc "Where's Tammy?"
    pc "Où est Tammy ?"

# game/Scenes/Tammy/tammy14.rpy:207
translate french tammy14_6a080cce:

    # ss "She had to leave early for work. I doubt we'll be seeing her for breakfast very often."
    ss "Elle a dû partir tôt pour aller travailler. Je doute qu’on la voie souvent au petit-déjeuner."

# game/Scenes/Tammy/tammy14.rpy:208
translate french tammy14_34f75a54:

    # pc "Oh, okay."
    pc "Oh, d’accord."

# game/Scenes/Tammy/tammy14.rpy:211
translate french tammy14_eef7b49f:

    # ss "Did you want to eat breakfast with me... or maybe mess around some?"
    ss "Tu voulais prendre le petit-déjeuner avec moi… ou peut-être faire un peu les fous ?"

# game/Scenes/Tammy/tammy14.rpy:215
translate french tammy14_6ae50746:

    # ss "Oh, alright then."
    ss "Oh, d’accord alors."

# game/Scenes/Tammy/tammy14.rpy:218
translate french tammy14_b9e9893b:

    # ss "I was hoping you would say that."
    ss "J’espérais que tu dirais ça."

# game/Scenes/Tammy/tammy14.rpy:222
translate french tammy14_ca91b2cf:

    # ss "Oh, okay. See you later then, [bro]."
    ss "Oh, d’accord. À plus tard alors, [bro]."

translate french strings:

    # game/Scenes/Tammy/tammy14.rpy:2
    old "After you have gone out on a few dates with Tammy and Suzy together, including going to the ice-cream parlor,"
    new "Après être sorti plusieurs fois avec Tammy et Suzy ensemble, notamment au glacier,"

    # game/Scenes/Tammy/tammy14.rpy:3
    old "and you have talked to them about Tammy moving out of her parents house, this will happen automatically at home at night."
    new "et après leur avoir parlé du départ de Tammy de chez ses parents, ceci se produira automatiquement à la maison le soir."

