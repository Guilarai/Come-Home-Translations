# game/Scenes/Tammy/tammy1b.rpy:11
translate french tammy1b_e3683166:

    # "Tammy is supposed to be here, so I park and walk up to the boxing club."
    "Tammy est censée être là, alors je me gare et je me dirige vers le club de boxe."

# game/Scenes/Tammy/tammy1b.rpy:12
translate french tammy1b_645ac8a9:

    # "The place is not very busy, with only a few people training."
    "Il n’y a pas grand monde, seulement quelques personnes à l’entraînement."

# game/Scenes/Tammy/tammy1b.rpy:13
translate french tammy1b_4394a883:

    # "As soon as I walk in, all eyes turn to me though. They stare at me, unwelcoming."
    "Dès que j’entre, tous les regards se tournent vers moi. Ils me fixent, d’un air peu accueillant."

# game/Scenes/Tammy/tammy1b.rpy:14
translate french tammy1b_29926d95:

    # "Until Tammy speaks up."
    "Jusqu’à ce que Tammy prenne la parole."

# game/Scenes/Tammy/tammy1b.rpy:17
translate french tammy1b_9f753069:

    # tm "Don't worry guys, he's with me."
    tm "Ne vous inquiétez pas les gars, il est avec moi."

# game/Scenes/Tammy/tammy1b.rpy:18
translate french tammy1b_671e6fc9:

    # tm "Hey, [pcname]. Glad you came. Ready to get your workout on?"
    tm "Salut, [pcname]. Content que tu sois venu. Prêt à t’entraîner ?"

# game/Scenes/Tammy/tammy1b.rpy:19
translate french tammy1b_bcae12a9:

    # pc "Sure, let's do this."
    pc "Bien sûr, c'est parti."

# game/Scenes/Tammy/tammy1b.rpy:20
translate french tammy1b_249f802e:

    # tm "Locker room is in the back. Go change into your workout gear and meet me by the bench press."
    tm "Les vestiaires sont au fond. Va enfiler ta tenue de sport et rejoins-moi près du banc de musculation."

# game/Scenes/Tammy/tammy1b.rpy:23
translate french tammy1b_9d33ab78:

    # "I do as she says and head to the locker room in the back of the place. I change into my gym shorts and a muscle shirt and walk back up front to join her."
    "Je fais ce qu'elle me dit et me dirige vers les vestiaires au fond de la salle. J'enfile mon short de sport et un débardeur, puis je retourne à l'avant pour la rejoindre."

# game/Scenes/Tammy/tammy1b.rpy:26
translate french tammy1b_5c6e9d09:

    # tm "Alright, looking good there, [pcname]. You're not in bad shape, but look like you could use a little more muscle."
    tm "Très bien, ça te va bien, [pcname]. Tu n'es pas en mauvaise forme, mais on dirait que tu aurais besoin d'un peu plus de muscle."

# game/Scenes/Tammy/tammy1b.rpy:27
translate french tammy1b_40793a0e:

    # tm "How much do you lift?"
    tm "Tu soulèves combien ?"

# game/Scenes/Tammy/tammy1b.rpy:28
translate french tammy1b_cf4776aa:

    # pc "I'm not sure. I haven't been to the gym since high school."
    pc "Je ne sais pas trop. Je n’ai pas mis les pieds dans une salle de sport depuis le lycée."

# game/Scenes/Tammy/tammy1b.rpy:29
translate french tammy1b_68f22cd1:

    # tm "Wow, how do you keep a body like that without working out?"
    tm "Ouah, comment tu fais pour garder un corps comme ça sans t’entraîner ?"

# game/Scenes/Tammy/tammy1b.rpy:30
translate french tammy1b_a5cfcbe8:

    # pc "I don't know, just stay busy I guess?"
    pc "Je sais pas, je reste juste occupé, j’imagine ?"

# game/Scenes/Tammy/tammy1b.rpy:31
translate french tammy1b_ccc6b955:

    # tm "Well, good job on that."
    tm "Eh bien, bravo pour ça."

# game/Scenes/Tammy/tammy1b.rpy:32
translate french tammy1b_4f70adfd:

    # tm "Here, spot me and I'll show you the proper way to do this, just as a reminder. Then we can figure out how much you can bench."
    tm "Tiens, aide-moi et je vais te montrer la bonne façon de faire, juste pour te rafraîchir la mémoire. Après, on verra combien tu peux soulever."

# game/Scenes/Tammy/tammy1b.rpy:35
translate french tammy1b_c0d9e914:

    # "I stand over her while she demonstrates the proper bench press technique."
    "Je me tiens debout au-dessus d’elle pendant qu’elle me montre la bonne technique de développé couché."

# game/Scenes/Tammy/tammy1b.rpy:36
translate french tammy1b_806df103:

    # "She breathes in and out as she pushes the weight up and down, her triceps bulging."
    "Elle inspire et expire en poussant le poids vers le haut et vers le bas, ses triceps saillant."

# game/Scenes/Tammy/tammy1b.rpy:37
translate french tammy1b_e6fef3d7:

    # "Everything about Tammy is hard and tight - her whole body is a muscle for her to flex."
    "Tout chez Tammy est dur et tendu – son corps tout entier est un muscle qu’elle peut contracter."

# game/Scenes/Tammy/tammy1b.rpy:38
translate french tammy1b_33c443c8:

    # "When she has finished ten reps, I help her put the weight back on its hook."
    "Quand elle a fini ses dix répétitions, je l’aide à remettre le poids sur son crochet."

# game/Scenes/Tammy/tammy1b.rpy:42
translate french tammy1b_c0183d90:

    # tm "Alright, now your turn."
    tm "Bon, maintenant c’est ton tour."

# game/Scenes/Tammy/tammy1b.rpy:43
translate french tammy1b_4a711d57:

    # tm "Start with what I was lifting. You should be able to handle that, given how much bigger than me you are."
    tm "Commence par ce que je soulevais. Tu devrais pouvoir y arriver, vu que tu es bien plus grande que moi."

# game/Scenes/Tammy/tammy1b.rpy:44
translate french tammy1b_63023601:

    # pc "Okay."
    pc "D'accord."

# game/Scenes/Tammy/tammy1b.rpy:47
translate french tammy1b_5ddf218a:

    # "We switch positions to where now I am on the bench and she is standing over me."
    "On change de place : je suis maintenant sur le banc et elle se tient debout au-dessus de moi."

# game/Scenes/Tammy/tammy1b.rpy:48
translate french tammy1b_388a95d1:

    # "I imitate her technique and lift the weight."
    "J'imite sa technique et je soulève le poids."

# game/Scenes/Tammy/tammy1b.rpy:49
translate french tammy1b_1d8c9a1b:

    # "I am surprised at how heavy it is. She hadn't seemed to have much trouble lifting it, but I find myself struggling."
    "Je suis surprise de voir à quel point c'est lourd. Elle n'avait pas l'air d'avoir beaucoup de mal à le soulever, mais moi, j'ai du mal."

# game/Scenes/Tammy/tammy1b.rpy:50
translate french tammy1b_0188fccb:

    # tm "Remember your breathing. Push."
    tm "Pense à respirer. Pousse."

# game/Scenes/Tammy/tammy1b.rpy:51
translate french tammy1b_61239f96:

    # "I try to control my breathing, try to push myself. My muscles ache after only a few reps."
    "J'essaie de contrôler ma respiration, d'aller jusqu'au bout. Mes muscles me font mal après seulement quelques répétitions."

# game/Scenes/Tammy/tammy1b.rpy:52
translate french tammy1b_d6ccb3fd:

    # "I keep pushing, barely making it to 10. Then she pulls the weight back onto the hook for me."
    "Je continue à pousser, arrivant à peine à 10. Puis elle remet le poids sur le crochet pour moi."

# game/Scenes/Tammy/tammy1b.rpy:56
translate french tammy1b_37c438ac:

    # tm "Well you're definitely more out of shape than you look. We're going to need to do a lot more of this."
    tm "Eh bien, tu es clairement moins en forme que tu n'en as l'air. On va devoir faire beaucoup plus d'exercices comme ça."

# game/Scenes/Tammy/tammy1b.rpy:57
translate french tammy1b_cf997fe8:

    # pc "You're telling me. Man, I'm hurting."
    pc "Tu m'en diras tant. Bon sang, j'ai mal partout."

# game/Scenes/Tammy/tammy1b.rpy:58
translate french tammy1b_76be2251:

    # tm "Take a breather and then we'll get started on the other exercises."
    tm "Repose-toi un peu, puis on passera aux autres exercices."

# game/Scenes/Tammy/tammy1b.rpy:59
translate french tammy1b_2df16e27:

    # pc "Other?"
    pc "Les autres ?"

# game/Scenes/Tammy/tammy1b.rpy:62
translate french tammy1b_e32e4b37:

    # tm "Uh, yeah. You can't just workout your arms. Gotta do the whole body."
    tm "Euh, ouais. Tu ne peux pas te contenter de travailler tes bras. Il faut faire tout le corps."

# game/Scenes/Tammy/tammy1b.rpy:65
translate french tammy1b_774f99cb:

    # "I take a rest, then we get back to it, moving around the gym to different areas to do a full-body workout."
    "Je me repose, puis on s'y remet, en se déplaçant dans la salle vers différentes zones pour faire un entraînement complet du corps."

# game/Scenes/Tammy/tammy1b.rpy:66
translate french tammy1b_07f4d546:

    # "By the end, I am exhausted. Tammy is sweating, but is feeling good. I feel like I might die."
    "À la fin, je suis épuisé. Tammy transpire, mais se sent bien. J'ai l'impression que je vais mourir."

# game/Scenes/Tammy/tammy1b.rpy:69
translate french tammy1b_ecf18d91:

    # tm "You did good today for a first gym day in a long time."
    tm "Tu t'en es bien sorti aujourd'hui pour un premier jour de gym depuis longtemps."

# game/Scenes/Tammy/tammy1b.rpy:70
translate french tammy1b_bac72fc8:

    # tm "It'll get easier the more you do it. Then you'll have to start looking for new ways to build muscle."
    tm "Ça deviendra plus facile à force de le faire. Ensuite, tu devras commencer à chercher de nouvelles façons de te muscler."

# game/Scenes/Tammy/tammy1b.rpy:71
translate french tammy1b_2643738c:

    # pc "I don't know about that."
    pc "Je ne sais pas trop."

# game/Scenes/Tammy/tammy1b.rpy:72
translate french tammy1b_c1b44fe4:

    # tm "Well, I had fun today. You're a pretty good workout partner."
    tm "Eh bien, je me suis bien amusé aujourd'hui. Tu es un très bon partenaire d'entraînement."

# game/Scenes/Tammy/tammy1b.rpy:73
translate french tammy1b_644168c9:

    # tm "Come back and do it again with me sometime. I'm here every afternoon."
    tm "Reviens m'accompagner un de ces jours. Je suis là tous les après-midis."

# game/Scenes/Tammy/tammy1b.rpy:74
translate french tammy1b_67cf3c55:

    # tm "Or you can come back by yourself. The guys will let you in, now that they know you're with me."
    tm "Ou tu peux revenir tout seul. Les gars te laisseront entrer, maintenant qu'ils savent que tu es avec moi."

# game/Scenes/Tammy/tammy1b.rpy:75
translate french tammy1b_e43cb525:

    # pc "Okay, I'll do that."
    pc "D'accord, je le ferai."

# game/Scenes/Tammy/tammy1b.rpy:76
translate french tammy1b_e4873b3d:

    # tm "Build up that muscle, [pcname]. Girls love it. You're looking real sexy with that post-workout shine."
    tm "Développe ces muscles, [pcname]. Les filles adorent ça. Tu es vraiment sexy avec cette lueur post-entraînement."

# game/Scenes/Tammy/tammy1b.rpy:79
translate french tammy1b_1df8eb68:

    # tm "Anyway, I gotta go shower and get to work."
    tm "Bref, je dois aller prendre une douche et aller bosser."

# game/Scenes/Tammy/tammy1b.rpy:80
translate french tammy1b_2c74ab1f:

    # tm "I'll see you later, [pcname]."
    tm "À plus tard, [pcname]."

# game/Scenes/Tammy/tammy1b.rpy:81
translate french tammy1b_53fa2ef6:

    # pc "Okay, see ya."
    pc "D'accord, à plus."

# game/Scenes/Tammy/tammy1b.rpy:84
translate french tammy1b_85f2c0dc:

    # "We head to the back, to separate showers."
    "On se dirige vers l'arrière, vers des douches séparées."

# game/Scenes/Tammy/tammy1b.rpy:85
translate french tammy1b_43779587:

    # "By the time I am done washing up, she is already gone."
    "Le temps que je finisse de me laver, elle est déjà partie."

# game/Scenes/Tammy/tammy1b.rpy:86
translate french tammy1b_00b69932:

    # "I leave the gym, my whole body sore, and get in my car."
    "Je quitte la salle de sport, le corps tout endolori, et je monte dans ma voiture."

translate french strings:

    # game/Scenes/Tammy/tammy1b.rpy:2
    old "Tammy wants you to meet her at the gym on the weekend."
    new "Tammy veut que tu la rejoignes à la salle de sport ce week-end."

    # game/Scenes/Tammy/tammy1b.rpy:3
    old "She'll be there during the morning and afternoon."
    new "Elle y sera le matin et l'après-midi."

