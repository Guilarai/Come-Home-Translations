    "Tammy m’aperçoit presque tout de suite et s’approche de moi."

# game/Scenes/Tammy/tammy6.rpy:37
translate french tammy6_d0eb5014:

    # tm "You made it! Good, I was worried you weren't coming."
    tm "Tu es venue ! Super, j’avais peur que tu ne viennes pas."

# game/Scenes/Tammy/tammy6.rpy:38
translate french tammy6_9d3f76f5:

    # pc "I told you I wouldn't miss it."
    pc "Je t’avais dit que je ne manquerais ça pour rien au monde."

# game/Scenes/Tammy/tammy6.rpy:39
