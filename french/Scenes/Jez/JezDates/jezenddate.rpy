translate french jezenddate_d41d8cd9:

    # voice 'voices/jez_myplace.mp3'
    voice 'voices/jez_myplace.mp3'

# game/Scenes/Jez/JezDates/jezenddate.rpy:8
translate french jezenddate_687d0176:

    # det "So, do you want to come back to my place for a while?"
    det "Alors, tu veux venir chez moi un moment ?"

# game/Scenes/Jez/JezDates/jezenddate.rpy:9
translate french jezenddate_30d6b817:

    # det "Mamá's got Javi for a bit. We could spend some time together."
    det "Maman s'occupe de Javi pendant un moment. On pourrait passer un peu de temps ensemble."

# game/Scenes/Jez/JezDates/jezenddate.rpy:12
translate french jezenddate_3ba845d3:

    # det "Good, let's go."
    det "D'accord, allons-y."

# game/Scenes/Jez/JezDates/jezenddate.rpy:15
translate french jezenddate_588b9a6e:

    # "We get in our cars and I follow her back to her house, where we quickly make our way inside to her bedroom."
    "On monte dans nos voitures et je la suis jusqu'à chez elle, où on se précipite dans sa chambre."

# game/Scenes/Jez/JezDates/jezenddate.rpy:19
translate french jezenddate_77b42da9:

    # det "Oh, alright then. Well I had a nice date anyway. I'll see you later, [pcname]."
    det "Oh, d'accord alors. Bon, j'ai quand même passé un bon moment. À plus tard, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:21
translate french jezenddate_b4d69820:

    # "I lean in and we kiss, my arms wrapped around her."
    "Je me penche vers elle et on s'embrasse, mes bras enroulés autour d'elle."

# game/Scenes/Jez/JezDates/jezenddate.rpy:22
translate french jezenddate_3091dff1:

    # pc "Bye, Jez. See you again soon."
    pc "Au revoir, Jez. À bientôt."

# game/Scenes/Jez/JezDates/jezenddate.rpy:25
translate french jezenddate_f48c2630:

    # "She leaves, and I go back out to my car and drive away."
    "Elle part, et je retourne à ma voiture pour repartir."

# game/Scenes/Jez/JezDates/jezenddate.rpy:29
translate french jezenddate_716db417:

    # det "I had a really good time. I'm looking forward to doing this again soon."
    det "J'ai vraiment passé un bon moment. J'ai hâte de recommencer bientôt."

# game/Scenes/Jez/JezDates/jezenddate.rpy:30
translate french jezenddate_03eaad50:

    # pc "Me too."
    pc "Moi aussi."

# game/Scenes/Jez/JezDates/jezenddate.rpy:33
translate french jezenddate_398aacb4:

    # det "I'd invite you over to my place, but I'm not quite ready for my son to meet you yet."
    det "Je t'inviterais bien chez moi, mais je ne suis pas encore tout à fait prête à ce que mon fils te rencontre."

# game/Scenes/Jez/JezDates/jezenddate.rpy:34
translate french jezenddate_70367ea3:

    # det "I don't want him to get confused by male figures being in his life for only a short time."
    det "Je ne veux pas qu'il soit perturbé par la présence d'hommes dans sa vie pour une courte durée seulement."

# game/Scenes/Jez/JezDates/jezenddate.rpy:35
translate french jezenddate_6cf8b822:

    # det "I want to make sure that this thing between me and you is real before we do that. I hope you understand."
    det "Je veux m'assurer que ce qu'il y a entre toi et moi est réel avant de faire ça. J'espère que tu comprends."

# game/Scenes/Jez/JezDates/jezenddate.rpy:36
translate french jezenddate_cca20d9e:

    # pc "I do understand."
    pc "Je comprends."

# game/Scenes/Jez/JezDates/jezenddate.rpy:38
translate french jezenddate_3239d4cf:

    # det "Thanks."
    det "Merci."

# game/Scenes/Jez/JezDates/jezenddate.rpy:41
translate french jezenddate_b4d69820_1:

    # "I lean in and we kiss, my arms wrapped around her."
    "Je me penche vers elle et on s'embrasse, mes bras enroulés autour d'elle."

# game/Scenes/Jez/JezDates/jezenddate.rpy:43
translate french jezenddate_ef81804e:

    # det "Wow, that was nice. Making it really hard for me to say goodbye."
    det "Ouah, c'était sympa. Ça me rend les adieux vraiment difficiles."

# game/Scenes/Jez/JezDates/jezenddate.rpy:44
translate french jezenddate_c18fe3a7:

    # det "But I have to. Bye, [pcname]."
    det "Mais je dois le faire. Salut, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:45
translate french jezenddate_3091dff1_1:

    # pc "Bye, Jez. See you again soon."
    pc "Salut, Jez. À bientôt."

# game/Scenes/Jez/JezDates/jezenddate.rpy:48
translate french jezenddate_f48c2630_1:

    # "She leaves, and I go back out to my car and drive away."
    "Elle part, et je retourne à ma voiture et je m'en vais."

