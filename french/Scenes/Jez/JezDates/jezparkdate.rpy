translate french jezparkstartdate_afd4a633:

    # "I meet Jez at the park for our date and we take a quiet stroll."
    "Je retrouve Jez au parc pour notre rendez-vous et on fait une petite balade tranquille."

# game/Scenes/Jez/JezDates/jezparkdate.rpy:27
translate french jezparkstartdate_4aaf219b:

    # "We take it slow, stopping every once in a while just to talk and take in the evening air."
    "On y va doucement, en s'arrêtant de temps en temps juste pour discuter et profiter de l'air du soir."

# game/Scenes/Jez/JezDates/jezparkdate.rpy:38
translate french jezparkstartdate_bcda10ba:

    # "Then our talking turns into kissing."
    "Puis nos discussions se transforment en baisers."

# game/Scenes/Jez/JezDates/jezparkdate.rpy:39
translate french jezparkstartdate_0a0545cd:

    # det "Fuck, it's so hard for me to keep my hands off of you."
    det "Putain, j'ai tellement de mal à ne pas te toucher."

# game/Scenes/Jez/JezDates/jezparkdate.rpy:42
translate french jezparkstartdate_6fe2a545:

    # "Then a little more than kissing."
    "Puis un peu plus que des baisers."

# game/Scenes/Jez/JezDates/jezparkdate.rpy:43
translate french jezparkstartdate_56c7b013:

    # det "We should go, before I get into trouble."
    det "On devrait y aller, avant que je ne m'attire des ennuis."

# game/Scenes/Jez/JezDates/jezparkdate.rpy:44
translate french jezparkstartdate_c0c0e82f:

    # det "It would look pretty bad for an officer to be arrested for public indecency."
    det "Ça ferait très mauvaise impression qu’un policier se fasse arrêter pour outrage à la pudeur."

# game/Scenes/Jez/JezDates/jezparkdate.rpy:47
translate french jezparkstartdate_d18dd0f8:

    # "We walk back to our cars together."
    "On retourne ensemble à nos voitures."

