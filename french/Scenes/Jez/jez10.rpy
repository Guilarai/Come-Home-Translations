    # game/Scenes/Jez/jez10.rpy:103
    old "Tell her about Izzy"
    new "Parle-lui d'Izzy."

    # game/Scenes/Jez/jez10.rpy:128
    old "Tell her about Reba's brother"
    new "Parle-lui du frère de Reba."

    # game/Scenes/Jez/jez10.rpy:145
    old "It's not important how I know"
    new "Peu importe comment je le sais."

