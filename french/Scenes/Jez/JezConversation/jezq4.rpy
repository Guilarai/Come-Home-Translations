translate french jezq4_dbd11a17:

    # det "I've really liked having you stay over at the house occasionally. Mom and Javi love having you there too."
    det "J'ai vraiment apprécié que tu viennes dormir chez nous de temps en temps. Maman et Javi adorent t'avoir là aussi."

# game/Scenes/Jez/JezConversation/jezq4.rpy:16
translate french jezq4_3e5e32be:

    # pc "Oh yeah? I love being there too. Your family is great."
    pc "Ah oui ? J'adore être là aussi. Ta famille est géniale."

# game/Scenes/Jez/JezConversation/jezq4.rpy:18
translate french jezq4_25f6bf70:

    # det "Maybe you could keep some of your clothes there? A toothbrush and stuff?"
    det "Tu pourrais peut-être laisser quelques vêtements là-bas ? Une brosse à dents et tout ça ?"

# game/Scenes/Jez/JezConversation/jezq4.rpy:19
translate french jezq4_d2ad3f3e:

    # pc "You want me to move in?"
    pc "Tu veux que j'emménage ?"

# game/Scenes/Jez/JezConversation/jezq4.rpy:21
translate french jezq4_cd5b631b:

    # det "Well maybe not all the way in, but a little trial run, sort of?"
    det "Bon, peut-être pas complètement, mais un petit essai, en quelque sorte ?"

# game/Scenes/Jez/JezConversation/jezq4.rpy:23
translate french jezq4_b5358c43:

    # det "I think you're great, [pcname]. Javi and Mom love you. I love you."
    det "Je te trouve génial, [pcname]. Javi et maman t'adorent. Je t'adore."

# game/Scenes/Jez/JezConversation/jezq4.rpy:25
