translate french jez13_d62b2984:

    # det "Bad people doing bad things, you know?"
    det "Des gens mauvais qui font des choses horribles, tu vois ?"

# game/Scenes/Jez/jez13.rpy:98
translate french jez13_d41d8cd9_3:

    # voice 'voices/jez_13_4.mp3'
    voice 'voices/jez_13_4.mp3'

