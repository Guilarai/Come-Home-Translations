translate french jez13_66e2454b:

    # det "I, uh... I see bad stuff at work all the time."
    det "Je, euh… Je vois tout le temps des choses horribles au travail."

# game/Scenes/Jez/jez13.rpy:95
translate french jez13_d41d8cd9_2:

    # voice 'voices/jez_13_3.mp3'
    voice 'voices/jez_13_3.mp3'

