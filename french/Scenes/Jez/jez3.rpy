# game/Scenes/Jez/jez3.rpy:16
translate french jez3_b7d0283a:

    # "Detective Rodriguez picks up the phone after a single ring, as if she had been holding her phone in her hand."
    "L'inspectrice Rodriguez décroche après une seule sonnerie, comme si elle tenait son téléphone à la main."

# game/Scenes/Jez/jez3.rpy:18
translate french jez3_d41d8cd9:

    # voice 'voices/jez_answering.mp3'
    voice 'voices/jez_answering.mp3'

# game/Scenes/Jez/jez3.rpy:19
translate french jez3_6673062e:

    # det "Detective Rodriguez."
    det "Inspectrice Rodriguez."

# game/Scenes/Jez/jez3.rpy:20
translate french jez3_416b4b28:

    # pc "Hello, this is [pcname]."
    pc "Bonjour, c'est [pcname]."

# game/Scenes/Jez/jez3.rpy:22
translate french jez3_d41d8cd9_1:

    # voice 'voices/jez_hey.mp3'
    voice 'voices/jez_hey.mp3'

# game/Scenes/Jez/jez3.rpy:23
translate french jez3_5f1522eb:

    # det "Hey, [pcname]. What's up?"
    det "Salut, [pcname]. Quoi de neuf ?"

# game/Scenes/Jez/jez3.rpy:24
translate french jez3_eb667b3e:

    # pc "I had some new information about my dad's case. I was able to get into his laptop."
    pc "J'ai de nouvelles informations sur l'affaire de mon père. J'ai réussi à accéder à son ordinateur portable."

# game/Scenes/Jez/jez3.rpy:25
translate french jez3_a1187622:

    # pc "I found a bunch of e-mails between him and this Whitney person."
    pc "J'ai trouvé tout un tas d'e-mails entre lui et cette Whitney."

# game/Scenes/Jez/jez3.rpy:26
translate french jez3_d2f98bdb:

    # det "Hey, [pcname]. Hold on a second."
    det "Salut, [pcname]. Attends une seconde."

# game/Scenes/Jez/jez3.rpy:28
translate french jez3_77774b9f:

    # det "I'll be honest with you. I've had a really bad day and I have a migraine from hell."
    det "Je vais être honnête avec toi. J'ai passé une très mauvaise journée et j'ai une migraine d'enfer."

# game/Scenes/Jez/jez3.rpy:29
translate french jez3_b0a1faa8:

    # det "Your voice on this phone is making my head pound. What do you say we meet up in person."
    det "Ta voix au téléphone me donne mal à la tête. Et si on se voyait en personne ?"

# game/Scenes/Jez/jez3.rpy:30
translate french jez3_7cfb0b0e:

    # det "Do you know where The Pit is?"
    det "Tu sais où se trouve The Pit ?"

# game/Scenes/Jez/jez3.rpy:31
translate french jez3_5a003c29:

    # pc "The bar downtown?"
    pc "Le bar en centre-ville ?"

# game/Scenes/Jez/jez3.rpy:32
translate french jez3_c60f38c7:

    # det "That's it. Want to meet me there and have this conversation over drinks?"
    det "C'est ça. Tu veux qu'on se retrouve là-bas pour discuter autour d'un verre ?"

# game/Scenes/Jez/jez3.rpy:33
translate french jez3_a5c9c049:

    # det "I could really use a drink."
    det "J'ai vraiment besoin d'un verre."

# game/Scenes/Jez/jez3.rpy:36
translate french jez3_2ba5f0eb:

    # det "Great, I'll be there in two."
    det "Super, j'y suis dans deux minutes."

# game/Scenes/Jez/jez3.rpy:38
translate french jez3_cd4d07e3:

    # det "Come on man, give me a break."
    det "Allez mec, laisse-moi un peu de répit."

# game/Scenes/Jez/jez3.rpy:39
translate french jez3_84d27d16:

    # det "I just got finished working a 24-hour shift."
    det "Je viens juste de finir un service de 24 heures."

# game/Scenes/Jez/jez3.rpy:40
translate french jez3_cd598c64:

    # pc "Alright, I'll be there in five minutes."
    pc "D'accord, j'y suis dans cinq minutes."

# game/Scenes/Jez/jez3.rpy:41
translate french jez3_2ba5f0eb_1:

    # det "Great, I'll be there in two."
    det "Super, j'y suis dans deux minutes."

# game/Scenes/Jez/jez3.rpy:44
translate french jez3_d1ed5b1b:

    # "She hangs up and I quickly get ready and head out to the car."
    "Elle raccroche et je me prépare rapidement avant de sortir vers la voiture."

# game/Scenes/Jez/jez3.rpy:45
translate french jez3_5ddb21e5:

    # "Only a few minutes later, I park in front of the bar."
    "Quelques minutes plus tard, je me gare devant le bar."

# game/Scenes/Jez/jez3.rpy:47
translate french jez3_23e3b6db:

    # "I walk in and am met with a cloud of cigarette smoke, the dull roar of conversation, and a jukebox playing some rock song I've never heard."
    "J'entre et je suis accueilli par un nuage de fumée de cigarette, le brouhaha des conversations et un juke-box qui passe une chanson rock que je n'ai jamais entendue."

# game/Scenes/Jez/jez3.rpy:48
translate french jez3_64d6327f:

    # "It takes a few moments for me to notice Detective Rodriguez waving at me from a booth in the back of the bar."
    "Il me faut quelques instants pour remarquer l'inspectrice Rodriguez qui me fait signe depuis une table au fond du bar."

# game/Scenes/Jez/jez3.rpy:49
translate french jez3_398f4ad8:

    # "I walk over and sit down across from her."
    "Je m'approche et m'assois en face d'elle."

# game/Scenes/Jez/jez3.rpy:53
translate french jez3_71bded69:

    # det "Thanks for meeting me here. I know it's not very professional, but I need a drink real bad and I hate drinking alone."
    det "Merci de m'avoir donné rendez-vous ici. Je sais que ce n'est pas très professionnel, mais j'ai vraiment besoin d'un verre et je déteste boire seule."

# game/Scenes/Jez/jez3.rpy:54
translate french jez3_ac23b499:

    # det "I ordered you a beer too. You're twenty-one, right?"
    det "Je t'ai commandé une bière aussi. Tu as vingt et un ans, n'est-ce pas ?"

# game/Scenes/Jez/jez3.rpy:55
translate french jez3_c2113814:

    # pc "Twenty-two."
    pc "Vingt-deux."

# game/Scenes/Jez/jez3.rpy:56
translate french jez3_da9af380:

    # det "Good. Drink up then."
    det "Bien. Alors, bois."

# game/Scenes/Jez/jez3.rpy:59
translate french jez3_899cb188:

    # "I take a drink of the beer in front of me. It's nice and smooth."
    "Je prends une gorgée de la bière devant moi. Elle est bonne et douce."

# game/Scenes/Jez/jez3.rpy:62
translate french jez3_cfdfe09b:

    # pc "I'm just here to talk."
    pc "Je suis juste là pour discuter."

# game/Scenes/Jez/jez3.rpy:64
translate french jez3_a023156a:

    # det "So I'm just going to be drinking alone anyway. So be it."
    det "Du coup, je vais quand même boire seule. Tant pis."

# game/Scenes/Jez/jez3.rpy:68
translate french jez3_e5c2530c:

    # det "Okay, so you got into your dad's laptop and found some correspondence?"
    det "Bon, tu as fouillé dans l’ordi portable de ton père et tu as trouvé des e-mails ?"

# game/Scenes/Jez/jez3.rpy:69
translate french jez3_66708b9a:

    # pc "Yeah, and it's crazy."
    pc "Ouais, et c’est dingue."

# game/Scenes/Jez/jez3.rpy:70
translate french jez3_08461fea:

    # det "Give me the summary. You can send the entire thing over to my e-mail later."
    det "Résume-moi tout ça. Tu pourras m’envoyer le tout par e-mail plus tard."

# game/Scenes/Jez/jez3.rpy:71
translate french jez3_2af7a240:

    # pc "Well the gist is that he and Whitney were planning a trip."
    pc "En gros, lui et Whitney prévoyaient un voyage."

# game/Scenes/Jez/jez3.rpy:72
translate french jez3_b2a62e0b:

    # det "So he did run off with her?"
    det "Alors il s’est enfui avec elle ?"

# game/Scenes/Jez/jez3.rpy:73
translate french jez3_d0c263e4:

    # pc "No, he was the only one going on this trip."
    pc "Non, il était le seul à partir en voyage."

# game/Scenes/Jez/jez3.rpy:74
translate french jez3_2908401f:

    # det "Okay, so where did he go?"
    det "D'accord, alors où est-il allé ?"

# game/Scenes/Jez/jez3.rpy:75
translate french jez3_0a1d6430:

    # pc "I'm not sure, but the strangest part is how he got there."
    pc "Je ne sais pas trop, mais le plus étrange, c'est comment il s'y est rendu."

# game/Scenes/Jez/jez3.rpy:76
translate french jez3_09d6eafc:

    # det "Explain."
    det "Explique-moi."

# game/Scenes/Jez/jez3.rpy:77
translate french jez3_61000743:

    # pc "He built some sort of device. I found it in the basement. It looks like a hula hoop."
    pc "Il a construit une sorte d'appareil. Je l'ai trouvé au sous-sol. Ça ressemble à un cerceau."

# game/Scenes/Jez/jez3.rpy:79
translate french jez3_b0e7f9ea:

    # det "What? You lost me."
    det "Quoi ? Je ne te suis pas."

# game/Scenes/Jez/jez3.rpy:80
translate french jez3_40d85287:

    # pc "I don't know how to explain it. It looks like a hoop. He and Whitney built it together. When it's activated, it's supposed to transport you somewhere."
    pc "Je ne sais pas comment l'expliquer. Ça ressemble à un cerceau. Lui et Whitney l'ont construit ensemble. Quand on l'active, c'est censé te transporter quelque part."

# game/Scenes/Jez/jez3.rpy:81
translate french jez3_1f06310c:

    # pc "He needed the diamonds to activate it. That's why he stole them."
    pc "Il avait besoin des diamants pour l'activer. C'est pour ça qu'il les a volés."

# game/Scenes/Jez/jez3.rpy:82
translate french jez3_35f3019c:

    # det "And the meth too?"
    det "Et la méthamphétamine aussi ?"

# game/Scenes/Jez/jez3.rpy:83
translate french jez3_ff210007:

    # pc "Right. He used the meth to speed his heart rate up so his heart didn't stop during the transportation."
    pc "Exactement. Il a utilisé la méthamphétamine pour accélérer son rythme cardiaque afin que son cœur ne s'arrête pas pendant le transport."

# game/Scenes/Jez/jez3.rpy:84
translate french jez3_22ea6d6f:

    # det "You know this is the dumbest fucking thing I've ever heard right?"
    det "Tu sais que c'est la chose la plus débile que j'aie jamais entendue, n'est-ce pas ?"

# game/Scenes/Jez/jez3.rpy:85
translate french jez3_a2fed6c2:

    # pc "I'm just telling you what they were talking about."
    pc "Je te raconte juste ce dont ils parlaient."

# game/Scenes/Jez/jez3.rpy:87
translate french jez3_1b198a7a:

    # det "Well I did look into the diamond theft."
    det "Eh bien, j'ai enquêté sur le vol des diamants."

# game/Scenes/Jez/jez3.rpy:88
translate french jez3_0768d1c5:

    # det "There was a jewelry store over in Whiterock that was broken into only a few days before your dad went missing."
    det "Il y a eu un cambriolage dans une bijouterie à Whiterock quelques jours avant la disparition de ton père."

# game/Scenes/Jez/jez3.rpy:89
translate french jez3_727a0b8a:

    # det "It was just like you described. The security was disabled for only a minute."
    det "C'était exactement comme tu l'as décrit. Le système de sécurité a été désactivé pendant une minute seulement."

# game/Scenes/Jez/jez3.rpy:90
translate french jez3_75b55784:

    # det "The thief entered through the back door, walked in, took two three-carat diamond rings, then walked back out."
    det "Le voleur est entré par la porte de derrière, a pris deux bagues en diamant de trois carats, puis est ressorti."

# game/Scenes/Jez/jez3.rpy:91
translate french jez3_a0cd13f9:

    # det "Security kicked back on. There would have been no trace that anybody was even there, except the rings were gone."
    det "Le système de sécurité s'est réactivé. Il n'y aurait eu aucune trace de sa présence, si ce n'est la disparition des bagues."

# game/Scenes/Jez/jez3.rpy:92
translate french jez3_a595c814:

    # pc "So he did it."
    pc "C'est donc lui le coupable."

# game/Scenes/Jez/jez3.rpy:93
translate french jez3_2cf2afa7:

    # det "It seems that way."
    det "On dirait bien."

# game/Scenes/Jez/jez3.rpy:94
translate french jez3_7b6c844b:

    # pc "Any clue where he got the meth?"
    pc "Une idée d’où il a trouvé la méthamphétamine ?"

# game/Scenes/Jez/jez3.rpy:96
translate french jez3_6063143c:

    # det "God, there's no telling. That shit is all over Skyhill."
    det "Mon Dieu, impossible à dire. Cette merde est partout à Skyhill."

# game/Scenes/Jez/jez3.rpy:97
translate french jez3_399bdc0f:

    # pc "Really?"
    pc "Vraiment ?"

# game/Scenes/Jez/jez3.rpy:99
translate french jez3_94032961:

    # det "Yes. That's what I've been working on. That's my primary job."
    det "Oui. C’est ce sur quoi je travaille. C’est ma mission principale."

# game/Scenes/Jez/jez3.rpy:100
translate french jez3_91bebae5:

    # det "We know a few dealers and we can find people who buy meth."
    det "On connaît quelques dealers et on peut trouver des gens qui achètent de la méthamphétamine."

# game/Scenes/Jez/jez3.rpy:101
translate french jez3_ec847758:

    # det "But we can't seem to locate where the shit is coming from. Somebody around here is cooking it, and I don't know where."
    det "Mais on n’arrive pas à localiser d’où vient cette merde. Quelqu'un dans le coin en fabrique, et je ne sais pas où."

# game/Scenes/Jez/jez3.rpy:102
translate french jez3_ea875425:

    # pc "I had no idea it was that bad around here."
    pc "Je ne savais pas que c'était à ce point par ici."

# game/Scenes/Jez/jez3.rpy:103
translate french jez3_49c82960:

    # det "Yeah. So I'm not sure exactly where your dad got it at, but I've been questioning people."
    det "Ouais. Je ne sais pas exactement où ton père s'en est procuré, mais j'ai interrogé des gens."

# game/Scenes/Jez/jez3.rpy:104
translate french jez3_5d188bd8:

    # det "Look [pcname], it sounds to me like your dad was having some sort of psychotic break."
    det "Écoute [pcname], j'ai l'impression que ton père a fait une sorte de crise psychotique."

# game/Scenes/Jez/jez3.rpy:105
translate french jez3_7a8cf8a1:

    # det "Teleporting hula-hoops, diamond theft, using meth to speed up your heart rate."
    det "Téléporter des cerceaux, voler des diamants, prendre de la méthamphétamine pour accélérer son rythme cardiaque."

# game/Scenes/Jez/jez3.rpy:106
translate french jez3_8ebd5686:

    # det "That sounds like a bunch of nonsense to me."
    det "Pour moi, ça ressemble à un tas d’absurdités."

# game/Scenes/Jez/jez3.rpy:107
translate french jez3_c417e350:

    # pc "Yeah."
    pc "Ouais."

# game/Scenes/Jez/jez3.rpy:108
translate french jez3_4c3ec6a3:

    # det "But the more we dig into it, the more likely we're going to find him."
    det "Mais plus on creuse, plus on a de chances de le retrouver."

# game/Scenes/Jez/jez3.rpy:109
translate french jez3_e004b1ab:

    # det "So keep digging."
    det "Alors continue à creuser."

# game/Scenes/Jez/jez3.rpy:110
translate french jez3_58f0fc2d:

    # det "Send me the info that you found on the laptop and I'll see if I can find this Whitney person."
    det "Envoie-moi les infos que tu as trouvées sur l’ordi portable et je vais voir si je peux retrouver cette Whitney."

# game/Scenes/Jez/jez3.rpy:111
translate french jez3_955d194d:

    # det "Assuming that she's real and not somebody that your dad made up."
    det "En supposant qu’elle existe vraiment et qu’elle n’est pas une invention de ton père."

# game/Scenes/Jez/jez3.rpy:112
translate french jez3_25bfd7d2:

    # pc "It seems like she's real to me, based on the e-mails."
    pc "D’après les e-mails, elle a l’air d’exister."

# game/Scenes/Jez/jez3.rpy:113
translate french jez3_2fc85b75:

    # det "Alright. Well let's find her."
    det "D'accord. Bon, alors trouvons-la."

# game/Scenes/Jez/jez3.rpy:114
translate french jez3_e70c1658:

    # pc "I could e-mail her from Dad's laptop."
    pc "Je pourrais lui envoyer un e-mail depuis l'ordinateur portable de papa."

# game/Scenes/Jez/jez3.rpy:116
translate french jez3_3997e2c3:

    # det "That's not a bad idea. Give it a shot. Start up a conversation with her, see if you can find out more about her."
    det "Ce n'est pas une mauvaise idée. Essaie. Engage la conversation avec elle, vois si tu peux en savoir plus sur elle."

# game/Scenes/Jez/jez3.rpy:117
translate french jez3_4d9bef33:

    # det "And let me know anything you find."
    det "Et tiens-moi au courant de tout ce que tu découvres."

# game/Scenes/Jez/jez3.rpy:119
translate french jez3_5bc44b07:

    # pc "I will."
    pc "Je le ferai."

# game/Scenes/Jez/jez3.rpy:121
translate french jez3_b734eba7:

    # det "Thanks for meeting me here. I needed this."
    det "Merci de m'avoir donné rendez-vous ici. J'en avais besoin."

# game/Scenes/Jez/jez3.rpy:122
translate french jez3_ba520f30:

    # det "Now I have to get home. I haven't seen my kid in two days."
    det "Maintenant, je dois rentrer chez moi. Je n'ai pas vu mon fils depuis deux jours."

# game/Scenes/Jez/jez3.rpy:123
translate french jez3_ce82357f:

    # pc "You have a kid?"
    pc "Tu as un enfant ?"

# game/Scenes/Jez/jez3.rpy:125
translate french jez3_71fc0e0c:

    # det "Yeah, Javi. He's seven. My mom's taking care of him right now."
    det "Oui, Javi. Il a sept ans. Ma mère s'occupe de lui en ce moment."

# game/Scenes/Jez/jez3.rpy:126
translate french jez3_798c23ff:

    # det "You surprised that I have a kid?"
    det "Ça te surprend que j'aie un enfant ?"

# game/Scenes/Jez/jez3.rpy:130
translate french jez3_632e262d:

    # det "Thanks. I had him when I was 17."
    det "Merci. Je l'ai eu quand j'avais 17 ans."

# game/Scenes/Jez/jez3.rpy:133
translate french jez3_ae370b70:

    # det "I'm not. You don't have to be married to have a kid, you know."
    det "Non, pas du tout. On n'a pas besoin d'être marié pour avoir un enfant, tu sais."

# game/Scenes/Jez/jez3.rpy:134
translate french jez3_2356fff3:

    # pc "Right, I didn't mean anything by it."
    pc "C'est vrai, je ne voulais pas dire ça."

# game/Scenes/Jez/jez3.rpy:137
translate french jez3_a82f6cf9:

    # det "Oh, I thought you seemed surprised."
    det "Oh, j'ai trouvé que tu avais l'air surpris."

# game/Scenes/Jez/jez3.rpy:139
translate french jez3_12633b63:

    # det "Anyway, I better get home."
    det "Bref, je ferais mieux de rentrer chez moi."

# game/Scenes/Jez/jez3.rpy:140
translate french jez3_d0fa7dfb:

    # det "I'll see you later, [pcname]."
    det "À plus tard, [pcname]."

# game/Scenes/Jez/jez3.rpy:141
translate french jez3_7b4cad00:

    # pc "Bye Detective Rodriguez."
    pc "Au revoir, inspecteur Rodriguez."

# game/Scenes/Jez/jez3.rpy:144
translate french jez3_d41d8cd9_2:

    # voice 'voices/jez_3_1.mp3'
    voice 'voices/jez_3_1.mp3'

# game/Scenes/Jez/jez3.rpy:145
translate french jez3_e7adfac5:

    # det "You can call me Jez, okay? That's my first name."
    det "Tu peux m'appeler Jez, d'accord ? C'est mon prénom."

# game/Scenes/Jez/jez3.rpy:146
translate french jez3_db79b546:

    # pc "Okay. Bye Jez."
    pc "D'accord. Au revoir, Jez."

# game/Scenes/Jez/jez3.rpy:151
translate french jez3_d41d8cd9_3:

    # voice 'voices/jez_goodnight.mp3'
    voice 'voices/jez_goodnight.mp3'

# game/Scenes/Jez/jez3.rpy:152
translate french jez3_2f6a1cc2:

    # det "Good night."
    det "Bonne nuit."

# game/Scenes/Jez/jez3.rpy:155
translate french jez3_40a94195:

    # "She stands up and walks out of the bar. I sit there alone for a few minutes, thinking about our conversation."
    "Elle se lève et sort du bar. Je reste assis là tout seul pendant quelques minutes, à repenser à notre conversation."

# game/Scenes/Jez/jez3.rpy:156
translate french jez3_06361269:

    # "She thinks Dad was crazy. I'm not so sure."
    "Elle pense que papa était fou. Je n'en suis pas si sûr."

# game/Scenes/Jez/jez3.rpy:157
translate french jez3_d8c1ec54:

    # "The things in his notes and in his conversations with Whitney were wild, but there is so much there that seems true."
    "Ce qu'il y avait dans ses notes et dans ses conversations avec Whitney était farfelu, mais il y a tellement de choses qui semblent vraies."

# game/Scenes/Jez/jez3.rpy:158
translate french jez3_3da12785:

    # "Whitney definitely seems like a real person. I just need to find out who she is."
    "Whitney a vraiment l'air d'être une personne réelle. Je dois juste découvrir qui elle est."

# game/Scenes/Jez/jez3.rpy:159
translate french jez3_8298e18a:

    # "Then maybe I can find out where my dad went."
    "Alors peut-être que je pourrai découvrir où est parti mon père."

# game/Scenes/Jez/jez3.rpy:160
translate french jez3_bc8a9774:

    # "Eventually, I stand up and walk out of the bar, then head home for the night."
    "Finalement, je me lève et je sors du bar, puis je rentre chez moi pour la nuit."

translate french strings:

    # game/Scenes/Jez/jez3.rpy:2
    old "You need to get into your dad's computer. Talk to Adrian about it. She's been at the grocery store trying to find a new game."
    new "Tu dois accéder à l'ordinateur de ton père. Parles-en à Adrian. Elle est à l'épicerie en train de chercher un nouveau jeu."

    # game/Scenes/Jez/jez3.rpy:3
