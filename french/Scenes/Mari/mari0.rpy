# game/Scenes/Mari/mari0.rpy:13
translate french mari0_268d9953:

    # "After about five minutes, a young woman with beautiful curly hair and an even prettier smile walks up with my order."
    "Au bout d'environ cinq minutes, une jeune femme aux beaux cheveux bouclés et au sourire encore plus joli s'approche avec ma commande."

# game/Scenes/Mari/mari0.rpy:14
translate french mari0_61ae3800:

    # fr "Hey there. This must be yours."
    fr "Salut. Ça doit être pour toi."

# game/Scenes/Mari/mari0.rpy:16
translate french mari0_d41d8cd9:

    # voice 'voices/mari_immariwaitress.mp3'
    voice 'voices/mari_immariwaitress.mp3'

# game/Scenes/Mari/mari0.rpy:17
translate french mari0_83cd92ec:

    # fr "I'm Mari. I'll be your waitress today."
    fr "Je m'appelle Mari. Je serai ta serveuse aujourd'hui."

# game/Scenes/Mari/mari0.rpy:18
translate french mari0_0a82c299:

    # fr "You just let me know if you need anything else."
    fr "N'hésite pas à me faire signe si tu as besoin d'autre chose."

# game/Scenes/Mari/mari0.rpy:19
translate french mari0_f711eed2:

    # "She gives me a smile and puts the food down on the table."
    "Elle me sourit et pose le repas sur la table."

# game/Scenes/Mari/mari0.rpy:23
translate french mari0_84e54e6e:

    # "She blushes a bit and playfully slaps my shoulder."
    "Elle rougit un peu et me donne une petite tape espiègle sur l'épaule."

# game/Scenes/Mari/mari0.rpy:24
translate french mari0_967f0281:

    # fr "You're just a charmer, aren't you?"
    fr "Tu es un vrai charmeur, n'est-ce pas ?"

# game/Scenes/Mari/mari0.rpy:27
translate french mari0_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:28
translate french mari0_9af4e82f:

    # fr "Sure thing!"
    fr "Bien sûr !"

# game/Scenes/Mari/mari0.rpy:31
translate french mari0_d41d8cd9_2:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:32
translate french mari0_22159de4:

    # fr "Sure thing! I'll bring it right out."
    fr "Bien sûr ! Je t'apporte ça tout de suite."

# game/Scenes/Mari/mari0.rpy:33
translate french mari0_55ee1584:

    # "She runs to the back and gets the ketchup, then quickly returns with it."
    "Elle court vers l'arrière-boutique chercher le ketchup, puis revient rapidement avec."

# game/Scenes/Mari/mari0.rpy:34
translate french mari0_fe5173b6:

    # fr "Just give me a holler if I can do anything else for you."
    fr "N'hésite pas à m'appeler si je peux faire autre chose pour toi."

# game/Scenes/Mari/mari0.rpy:37
translate french mari0_d0ec727b:

    # "She walks over to a nearby table, pulls out a rag, and starts wiping it down, bending over just enough to give me a good view of her ass."
    "Elle se dirige vers une table voisine, sort un chiffon et commence à l'essuyer, se penchant juste assez pour que j'aie une belle vue sur ses fesses."

# game/Scenes/Mari/mari0.rpy:40
translate french mari0_8458142b:

    # "And damn, that's a nice ass."
    "Et bon sang, quel beau cul."

# game/Scenes/Mari/mari0.rpy:43
translate french mari0_a58a4782:

    # "I eat my food and Mari returns a couple more times to give me a refill on my drink."
    "Je mange mon repas et Mari revient plusieurs fois pour me resservir à boire."

# game/Scenes/Mari/mari0.rpy:46
translate french mari0_cc46d500:

    # "Then when I'm finished, I stand up and give her a smile and a wave."
    "Puis, quand j’ai fini, je me lève et lui adresse un sourire et un signe de la main."

# game/Scenes/Mari/mari0.rpy:49
translate french mari0_d41d8cd9_3:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari0.rpy:50
translate french mari0_8fafd7cf:

    # fr "Thanks for coming in. You have a good night."
    fr "Merci d’être venu. Passe une bonne soirée."

# game/Scenes/Mari/mari0.rpy:53
translate french marifirsttip_1c31faa0:

    # "I place $5 on the table before I leave."
    "Je pose 5 $ sur la table avant de partir."

# game/Scenes/Mari/mari0.rpy:55
translate french marifirsttip_01e672c5:

    # "I head back out to the car."
    "Je retourne à la voiture."

