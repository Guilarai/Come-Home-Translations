# game/Scenes/Mari/mari1.rpy:15
translate french mari1_d41d8cd9:

    # voice 'voices/mari_heysweetie.mp3'
    voice 'voices/mari_heysweetie.mp3'

# game/Scenes/Mari/mari1.rpy:16
translate french mari1_64c354b8:

    # fr "Hey there sweetie, good to see you. How are you doing today?"
    fr "Salut ma belle, ça me fait plaisir de te voir. Comment ça va aujourd’hui ?"

# game/Scenes/Mari/mari1.rpy:19
translate french mari1_223b1496:

    # fr "Good, I'm glad. It's nice to see you in here again, let me know if I can get you anything."
    fr "Bien, j’en suis ravie. C’est sympa de te revoir ici, dis-moi si je peux t’apporter quelque chose."

# game/Scenes/Mari/mari1.rpy:22
translate french mari1_fe03e5ca:

    # fr "You're such a charmer. Keep going, I like it."
    fr "Tu es tellement charmant. Continue, j’adore ça."

# game/Scenes/Mari/mari1.rpy:23
translate french mari1_4d51f194:

    # pc "I mean, the burgers here are great, but I'm really here just to chat with you."
    pc "Je veux dire, les burgers ici sont excellents, mais en fait, je suis surtout venue pour discuter avec toi."

# game/Scenes/Mari/mari1.rpy:25
translate french mari1_67fd9cd9:

    # fr "Really?"
    fr "Vraiment ?"

# game/Scenes/Mari/mari1.rpy:26
translate french mari1_18128c18:

    # pc "Really."
    pc "Vraiment."

# game/Scenes/Mari/mari1.rpy:28
translate french mari1_8aa0b3f4:

    # fr "You're so sweet. Thanks for the compliments, but I better get back to work. Let me know if I can get you anything."
    fr "Tu es si gentil. Merci pour les compliments, mais je ferais mieux de retourner travailler. Dis-moi si je peux t'apporter quelque chose."

# game/Scenes/Mari/mari1.rpy:29
translate french mari1_c0bafa60:

    # pc "Can I get a straw for my drink?"
    pc "Je peux avoir une paille pour ma boisson ?"

# game/Scenes/Mari/mari1.rpy:31
translate french mari1_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari1.rpy:32
translate french mari1_f2433589:

    # fr "Sure thing, honey."
    fr "Bien sûr, chéri."

# game/Scenes/Mari/mari1.rpy:33
translate french mari1_ab35ef2d:

    # "She reaches into her pocket to pull out one of the straws and a dozen more pop out and fall onto the floor, scattering around."
    "Elle fouille dans sa poche pour en sortir une paille, mais une douzaine d'autres s'échappent et tombent par terre, s'éparpillant partout."

# game/Scenes/Mari/mari1.rpy:36
translate french mari1_d41d8cd9_2:

    # voice 'voices/mari_shoot2.mp3'
    voice 'voices/mari_shoot2.mp3'

# game/Scenes/Mari/mari1.rpy:37
translate french mari1_aaf7d6fa:

    # fr "Ah shoot, sorry about that."
    fr "Ah mince, désolée."

# game/Scenes/Mari/mari1.rpy:38
translate french mari1_76e2166e:

    # fr "Just a second, let me get these."
    fr "Attends une seconde, je vais les ramasser."

# game/Scenes/Mari/mari1.rpy:40
translate french mari1_29517e2b:

    # "She kneels down and gets on hands and knees on the floor, picking up the straws that had scattered around."
    "Elle s'agenouille et se met à quatre pattes sur le sol, ramassant les pailles qui s'étaient éparpillées."

# game/Scenes/Mari/mari1.rpy:41
translate french mari1_fa53362f:

    # fr "I'm so sorry."
    fr "Je suis vraiment désolée."

# game/Scenes/Mari/mari1.rpy:44
translate french mari1_6ce37599:

    # fr "I'm so clumsy sometimes."
    fr "Je suis tellement maladroite parfois."

# game/Scenes/Mari/mari1.rpy:45
translate french mari1_bdb852f0:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Elle finit rapidement de ramasser le reste des pailles et se redresse."

# game/Scenes/Mari/mari1.rpy:48
translate french mari1_c84cc9f0:

    # fr "What?"
    fr "Quoi ?"

# game/Scenes/Mari/mari1.rpy:50
translate french mari1_d41d8cd9_3:

    # voice 'voices/mari_youlikethat.mp3'
    voice 'voices/mari_youlikethat.mp3'

# game/Scenes/Mari/mari1.rpy:51
translate french mari1_50b1ddec:

    # fr "Oh. You like that do you?"
    fr "Oh. Ça te plaît, c'est ça ?"

# game/Scenes/Mari/mari1.rpy:53
translate french mari1_7fbd7f76:

    # fr "What about this? You like this?"
    fr "Et ça ? Tu aimes ça ?"

# game/Scenes/Mari/mari1.rpy:54
translate french mari1_9bf0a886:

    # pc "I definitely do."
    pc "J'adore."

# game/Scenes/Mari/mari1.rpy:55
translate french mari1_bdb852f0_1:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Elle finit rapidement de ramasser le reste des pailles et se redresse."

# game/Scenes/Mari/mari1.rpy:57
translate french mari1_2771e6a1:

    # fr "I hope that was worth a little bit more of a tip?"
    fr "J'espère que ça valait un pourboire un peu plus généreux ?"

# game/Scenes/Mari/mari1.rpy:58
translate french mari1_81450635:

    # pc "Oh I could give you more than the tip."
    pc "Oh, je pourrais te donner plus que le pourboire."

# game/Scenes/Mari/mari1.rpy:60
translate french mari1_053e79a0:

    # fr "You're so bad!"
    fr "Tu es trop méchante !"

# game/Scenes/Mari/mari1.rpy:63
translate french mari1_bab66bf3:

    # fr "I'll be right back with a straw that hasn't been on the floor."
    fr "Je reviens tout de suite avec une paille qui n'a pas traîné par terre."

# game/Scenes/Mari/mari1.rpy:64
translate french mari1_c8cd6f6b:

    # "She comes back with my straw and then my food shortly after that."
    "Elle revient avec ma paille, puis mon repas peu après."

# game/Scenes/Mari/mari1.rpy:65
translate french mari1_2e5f61be:

    # "We don't talk much more, but she gives me a beautiful smile every time I look up at her."
    "On ne parle pas beaucoup plus, mais elle m'offre un magnifique sourire chaque fois que je lève les yeux vers elle."

# game/Scenes/Mari/mari1.rpy:69
translate french mari1_e88fc8e1:

    # "When I finish and it's time to leave, she waves at me."
    "Quand j’ai fini et qu’il est temps de partir, elle me fait signe de la main."

# game/Scenes/Mari/mari1.rpy:71
translate french mari1_d41d8cd9_4:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari1.rpy:72
translate french mari1_7949c609:

    # fr "Thanks for coming in! You have a good night!"
    fr "Merci d’être venu ! Passez une bonne soirée !"

# game/Scenes/Mari/mari1.rpy:75
translate french maritip2_1ce16e45:

    # "I walk up to her and put a ten-dollar bill into her hand."
    "Je m’approche d’elle et glisse un billet de dix dollars dans sa main."

# game/Scenes/Mari/mari1.rpy:78
translate french maritip2_d41d8cd9:

    # voice 'voices/mari_thankyousomuch.mp3'
    voice 'voices/mari_thankyousomuch.mp3'

# game/Scenes/Mari/mari1.rpy:79
translate french maritip2_1e720979:

    # fr "Thanks so much, you're the best."
    fr "Merci beaucoup, tu es la meilleure."

# game/Scenes/Mari/mari1.rpy:81
translate french maritip2_890abf2a:

    # "Without warning, she lunges forward and wraps her arms around me, pulling me into a close hug."
    "Sans prévenir, elle se jette en avant et m’enlace, me serrant fort contre elle."

# game/Scenes/Mari/mari1.rpy:82
translate french maritip2_9ba61eed:

    # "She's so warm and soft."
    "Elle est si chaude et douce."

# game/Scenes/Mari/mari1.rpy:83
translate french maritip2_23314f60:

    # "And bonus - she smells like burgers."
    "Et en prime, elle sent le hamburger."

# game/Scenes/Mari/mari1.rpy:84
translate french maritip2_c96f83e2:

    # pc "Well you're a great waitress."
    pc "Eh bien, tu es une super serveuse."

# game/Scenes/Mari/mari1.rpy:85
translate french maritip2_d1889969:

    # fr "It's easy when the customers are as nice as you are."
    fr "C'est facile quand les clients sont aussi sympas que toi."

# game/Scenes/Mari/mari1.rpy:86
translate french maritip2_9bc4e48c:

    # fr "Come back and see me again soon, okay?"
    fr "Reviens me voir bientôt, d'accord ?"

# game/Scenes/Mari/mari1.rpy:87
translate french maritip2_9782867b:

    # pc "Oh I'm sure I will."
    pc "Oh, j'en suis sûr."

# game/Scenes/Mari/mari1.rpy:89
translate french maritip2_fb1fac0d:

    # fr "Have a good night, sweetie."
    fr "Passe une bonne soirée, mon chéri."

# game/Scenes/Mari/mari1.rpy:90
translate french maritip2_eb61ef6e:

    # pc "You too."
    pc "Toi aussi."

# game/Scenes/Mari/mari1.rpy:92
translate french maritip2_3cb27537:

    # "I give her a wave."
    "Je lui fais un signe de la main."

# game/Scenes/Mari/mari1.rpy:93
translate french maritip2_739d2b0c:

    # "With that, I go back outside and head to my car."
    "Sur ce, je retourne dehors et me dirige vers ma voiture."

