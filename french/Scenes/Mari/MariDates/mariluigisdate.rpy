# game/Scenes/Mari/MariDates/mariluigisdate.rpy:28
translate french mariluigisstartdate_1ee44fe2:

    # "Mari and I sit next to each other at one of the booths at Luigi's."
    "Mari et moi sommes assis l'un à côté de l'autre à l'une des tables de Luigi's."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:29
translate french mariluigisstartdate_0d18b373:

    # "We are chatting the whole time about this and that."
    "On discute tout le temps de tout et de rien."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:30
translate french mariluigisstartdate_5bdbd1f6:

    # "The waitress comes by and takes our order, we continue talking."
    "La serveuse passe prendre notre commande, on continue à parler."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:34
translate french mariluigisstartdate_f9e372f9:

    # "After a short time, the waitress brings our food out to us and we continue talking while we eat."
    "Peu de temps après, la serveuse nous apporte notre repas et on continue à discuter tout en mangeant."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:37
translate french mariluigisstartdate_54f7ac2e:

    # "We take our time eating while we talk, just enjoying one another's company."
    "On prend notre temps pour manger tout en discutant, profitant simplement de la compagnie de l'autre."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:40
translate french mariluigisstartdate_764eafa0:

    # fr "Good salad, but the service here isn't great huh?"
    fr "La salade est bonne, mais le service n'est pas terrible ici, hein ?"

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:41
translate french mariluigisstartdate_407731d1:

    # fr "Waiter didn't even face the dang silverware the correct way."
    fr "Le serveur n'a même pas disposé les couverts dans le bon sens."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:42
translate french mariluigisstartdate_c54b50c7:

    # pc "Well they can't all be as good as you."
    pc "Eh bien, ils ne peuvent pas tous être aussi doués que toi."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:44
translate french mariluigisstartdate_a4da275d:

    # fr "Aww..."
    fr "Oh..."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:48
translate french mariluigisstartdate_360f4aaa:

    # "When we're done with the meal, I pay the waitress and Mari and I walk out to the car together and start back towards her house."
    "Une fois le repas terminé, je paie la serveuse, puis Mari et moi sortons ensemble vers la voiture et reprenons la route vers chez elle."

