# game/Scenes/Mari/MariDates/maribeach.rpy:13
translate french maribeachdate_a63d5d5c:

    # fr "The beach sounds amazing! I'll go get in my swimsuit! Come get me."
    fr "La plage, ça a l'air génial ! Je vais mettre mon maillot de bain ! Viens me chercher."

# game/Scenes/Mari/MariDates/maribeach.rpy:14
translate french maribeachdate_8caa4a9c:

    # pc "On my way."
    pc "J'arrive."

# game/Scenes/Mari/MariDates/maribeach.rpy:21
translate french maribeachdate_40c18b34:

    # "I pick Mari up and we drive out towards the beach."
    "Je passe prendre Mari et on part en direction de la plage."

# game/Scenes/Mari/MariDates/maribeach.rpy:23
translate french maribeachdate_427f3be4:

    # fr "I haven't been to the beach in forever."
    fr "Je ne suis pas allée à la plage depuis une éternité."

# game/Scenes/Mari/MariDates/maribeach.rpy:24
translate french maribeachdate_e5624fc2:

    # fr "This is going to be so fun."
    fr "Ça va être tellement sympa."

# game/Scenes/Mari/MariDates/maribeach.rpy:29
translate french maribeachdate_b9c9e980:

    # pc "You look incredible."
    pc "Tu es superbe."

# game/Scenes/Mari/MariDates/maribeach.rpy:30
translate french maribeachdate_8a5a041f:

    # fr "Thanks, honey. The water is so pretty. Let's get in."
    fr "Merci, chéri. L'eau est tellement belle. Allons-y."

# game/Scenes/Mari/MariDates/maribeach.rpy:33
translate french maribeachdate_93419ef3:

    # "We spend some time swimming around and chatting."
    "On passe un moment à nager et à discuter."

# game/Scenes/Mari/MariDates/maribeach.rpy:36
translate french maribeachdate_0e1a2c64:

    # "We spend a little longer making out, our bodies pressed against each other underwater."
    "On passe un peu plus de temps à s'embrasser, nos corps pressés l'un contre l'autre sous l'eau."

# game/Scenes/Mari/MariDates/maribeach.rpy:39
translate french maribeachdate_c4765999:

    # "After a while, we're both tired from swimming and the sun is starting to set, so we lie on the beach and dry off."
    "Au bout d'un moment, on est tous les deux fatigués d'avoir nagé et le soleil commence à se coucher, alors on s'allonge sur la plage pour se sécher."

# game/Scenes/Mari/MariDates/maribeach.rpy:40
translate french maribeachdate_3d2f7709:

    # "We lean back and talk for a while about whatever comes to mind."
    "On s'adosse et on parle un moment de tout ce qui nous passe par la tête."

# game/Scenes/Mari/MariDates/maribeach.rpy:50
translate french maribeachdate_67f91a9e:

    # "When the sun starts to dip below the horizon, we take a moment to watch it together."
    "Quand le soleil commence à plonger sous l'horizon, on prend un moment pour l'admirer ensemble."

# game/Scenes/Mari/MariDates/maribeach.rpy:52
translate french maribeachdate_0b6982cc:

    # fr "It's so beautiful."
    fr "C'est tellement beau."

# game/Scenes/Mari/MariDates/maribeach.rpy:53
translate french maribeachdate_91de8c28:

    # fr "Thanks for bringing me here."
    fr "Merci de m'avoir amenée ici."

# game/Scenes/Mari/MariDates/maribeach.rpy:58
translate french maribeachdate_e10b5f4e:

    # "We kiss and it's like lightning between our lips. It warms me from my heart outward."
    "On s'embrasse et c'est comme un éclair entre nos lèvres. Ça me réchauffe du cœur jusqu'aux extrémités."

# game/Scenes/Mari/MariDates/maribeach.rpy:63
translate french maribeachdate_4462906b:

    # fr "Are you ready to go back to my place?"
    fr "Tu es prête à rentrer chez moi ?"

# game/Scenes/Mari/MariDates/maribeach.rpy:64
translate french maribeachdate_61f77a4c:

    # pc "Sure."
    pc "Bien sûr."

# game/Scenes/Mari/MariDates/maribeach.rpy:65
translate french maribeachdate_63a75f93:

    # fr "Good, because I'm ready to get out of this swimsuit. And to get you out of yours."
    fr "Parfait, parce que j'ai hâte d'enlever ce maillot de bain. Et de t'enlever le tien."

# game/Scenes/Mari/MariDates/maribeach.rpy:69
translate french maribeachdate_69da3812:

    # "When the sun sets, I drive us back to her house."
    "Quand le soleil se couche, je nous ramène chez elle en voiture."

# game/Scenes/Mari/MariDates/maribeach.rpy:70
translate french maribeachdate_e3551ef8:

    # fr "So... are you coming inside?"
    fr "Alors... tu rentres ?"

# game/Scenes/Mari/MariDates/maribeach.rpy:73
translate french maribeachdate_b1aed98f:

    # fr "Good. Let's go."
    fr "Parfait. Allons-y."

# game/Scenes/Mari/MariDates/maribeach.rpy:80
translate french maribeachdate_b1aed98f_1:

    # fr "Good. Let's go."
    fr "Bien. Allons-y."

# game/Scenes/Mari/MariDates/maribeach.rpy:88
translate french maribeachdate_92c16c18:

    # fr "Dang, really? Too busy for little ol' me tonight?"
    fr "Mince, vraiment ? Trop occupé pour moi ce soir ?"

# game/Scenes/Mari/MariDates/maribeach.rpy:89
translate french maribeachdate_ea7c5dae:

    # fr "Fine. Good night then."
    fr "Très bien. Bonne nuit alors."

# game/Scenes/Mari/MariDates/maribeach.rpy:92
translate french maribeachdate_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "J'attends qu'elle sorte et entre dans sa maison avant de repartir."

translate french strings:

    # game/Scenes/Mari/MariDates/maribeach.rpy:3
    old "When you are able to ask Mari out on a date, and you have unlocked the beach through Suzy's path, invite Mari to the beach."
    new "Quand tu peux inviter Mari à sortir, et que tu as débloqué la plage grâce au chemin de Suzy, invite Mari à la plage."

    # game/Scenes/Mari/MariDates/maribeach.rpy:4
    old "She is available to date any time before night on the weekends."
    new "Elle est disponible pour sortir à tout moment avant la nuit le week-end."

