# game/Scenes/Mari/MariDates/maribardate.rpy:29
translate french maripitstartdate_fbec04d2:

    # fr "So what are we doing today?"
    fr "Alors, on fait quoi aujourd’hui ?"

# game/Scenes/Mari/MariDates/maribardate.rpy:30
translate french maripitstartdate_63b21df2:

    # pc "Figured we'd go to a bar and just chat over some drinks."
    pc "Je pensais qu’on pourrait aller dans un bar et discuter autour d’un verre."

# game/Scenes/Mari/MariDates/maribardate.rpy:31
translate french maripitstartdate_37c43aa9:

    # fr "Oh, I like that. Been a while since I've had a good drink."
    fr "Oh, j’aime bien cette idée. Ça fait un moment que je n’ai pas pris un bon verre."

# game/Scenes/Mari/MariDates/maribardate.rpy:35
translate french maripitstartdate_9583b335:

    # "I order us both drinks and we sit next to each other at the back booth."
    "Je commande deux verres et on s’assoit l’un à côté de l’autre dans la banquette du fond."

# game/Scenes/Mari/MariDates/maribardate.rpy:38
translate french maripitstartdate_998ad3c4:

    # "We drink a little bit more."
    "On boit encore un peu."

# game/Scenes/Mari/MariDates/maribardate.rpy:42
translate french maripitstartdate_53becc9f:

    # fr "Well that's enough drinks for me."
    fr "Bon, ça suffit pour moi."

# game/Scenes/Mari/MariDates/maribardate.rpy:43
translate french maripitstartdate_5428c2a4:

    # "I only had a beer, so I feel fine to drive."
    "Je n’ai bu qu’une bière, donc je me sens tout à fait capable de conduire."

# game/Scenes/Mari/MariDates/maribardate.rpy:44
translate french maripitstartdate_5e357f23:

    # "We walk out to the car together and start back towards her house."
    "On sort ensemble et on se dirige vers sa maison."

