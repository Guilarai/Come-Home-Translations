# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Mari/MariDates/marimoviedate.rpy:26
translate french marimovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Nous arrivons au cinéma et nous installons à l'arrière."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:27
translate french marimovietheaterstartdate_d03e5a70:

    # fr "So what are we watching anyway?"
    fr "Au fait, on va voir quoi ?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:31
translate french marimovietheaterstartdate_346436bf:

    # fr "Oh yeah?"
    fr "Ah oui ?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:32
translate french marimovietheaterstartdate_3aed9093:

    # fr "I love romance movies. As long as they're not too corny."
    fr "J'adore les films romantiques. Tant qu'ils ne sont pas trop mièvres."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:35
translate french marimovietheaterstartdate_337ed84d:

    # fr "Hrm, okay well that sounds fun."
    fr "Hum, d'accord, ça a l'air sympa."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:36
translate french marimovietheaterstartdate_7a1524b8:

    # fr "As long as it isn't just two buff guys slapping their meat together."
    fr "Tant que ce n'est pas juste deux mecs musclés qui se tapent l'un contre l'autre."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:38
translate french marimovietheaterstartdate_d3cf7e4e:

    # fr "Actually, that sounds pretty fun too."
    fr "En fait, ça a l'air plutôt sympa aussi."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:43
translate french marimovietheaterstartdate_d41d8cd9:

    # voice 'voices/mari_really.mp3'
    voice 'voices/mari_really.mp3'

# game/Scenes/Mari/MariDates/marimoviedate.rpy:44
translate french marimovietheaterstartdate_67fd9cd9:

    # fr "Really?"
    fr "Vraiment ?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:45
translate french marimovietheaterstartdate_8b77409f:

    # fr "I don't really do scary movies very well."
    fr "Je ne suis pas très douée pour les films d'horreur."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:46
translate french marimovietheaterstartdate_cb84ad92:

    # fr "I might just have my eyes closed and be holding you through the whole thing."
    fr "Je vais peut-être juste fermer les yeux et te serrer dans mes bras pendant tout le film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:51
translate french marimovietheaterstartdate_321fa232:

    # fr "Oh good, I need a good laugh."
    fr "Oh super, j’ai besoin de rire un bon coup."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:52
translate french marimovietheaterstartdate_76b9da8b:

    # fr "As long as it's not one of those gross-out sex comedies. I'm not really into those."
    fr "Tant que ce n’est pas une de ces comédies sexuelles dégoûtantes. Je ne suis pas vraiment fan de ça."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:56
translate french marimovietheaterstartdate_f3087137:

    # fr "Oh good! You know what I like."
    fr "Oh super ! Tu sais ce que j’aime."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:57
translate french marimovietheaterstartdate_3224e393:

    # fr "I love animated stuff. Especially when it's about talking animals."
    fr "J’adore les films d’animation. Surtout quand ça parle d’animaux qui parlent."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:60
translate french marimovietheaterstartdate_f45af0c0:

    # "There's a little time before the movie starts for us to chat."
    "On a un peu de temps avant le début du film pour discuter."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:64
translate french marimovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Enfin, le film commence et on se tait."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:66
translate french marimovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Elle se penche et me prend la main par-dessus l'accoudoir."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:67
translate french marimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Les bandes-annonces durent environ quinze minutes, puis le film commence vraiment."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:71
translate french marimovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Pendant le film, elle s'appuie sur mon épaule, complètement absorbée par l'histoire."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:73
translate french marimovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Puis, pendant une scène particulièrement romantique, elle lève la tête et pose ses lèvres sur les miennes."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:74
translate french marimovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "On ne regarde pas vraiment le reste du film, on se concentre plutôt sur nos baisers."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:77
translate french marimovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Pendant le film, elle s'appuie contre mon épaule, complètement absorbée par l'histoire."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:80
translate french marimovietheaterstartdate_284094da:

    # "Mari watches the movie, but I'm not really sure how much she likes it."
    "Mari regarde le film, mais je ne sais pas vraiment si elle l'apprécie."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:83
translate french marimovietheaterstartdate_26b74708:

    # "Eventually, she turns towards me and whispers."
    "Finalement, elle se tourne vers moi et me chuchote :"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:84
translate french marimovietheaterstartdate_5aa661f3:

    # fr "I'm not really into this movie. Want to just make out?"
    fr "« Ce film ne m'intéresse pas vraiment. On ne ferait pas mieux de s'embrasser ? »"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:86
translate french marimovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Je me penche vers elle et l'embrasse, et on ne regarde plus vraiment le film, préférant se concentrer l'un sur l'autre."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:89
translate french marimovietheaterstartdate_ae5e6aa0:

    # "To give her some credit, she tries to watch a little bit of the movie."
    "À sa décharge, elle essaie de regarder un peu le film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:90
translate french marimovietheaterstartdate_c601de66:

    # "But by the time the scary parts start, she is pretty much done."
    "Mais dès que les scènes effrayantes commencent, elle en a déjà assez."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:92
translate french marimovietheaterstartdate_fafc8629:

    # "She tucks her head down against me and hides the movie from her sight."
    "Elle blottit sa tête contre moi et cache le film de son regard."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:93
translate french marimovietheaterstartdate_324b6470:

    # "She stays right there, not watching anything for the rest of the movie."
    "Elle reste là, sans rien regarder pendant le reste du film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:96
translate french marimovietheaterstartdate_b27a7e4c:

    # "Mari's eyes are focused on the movie throughout the whole thing."
    "Les yeux de Mari sont rivés sur le film pendant toute la durée de celui-ci."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:97
translate french marimovietheaterstartdate_125a0ff3:

    # "She laughs, she cries, she taps her foot along with the music."
    "Elle rit, elle pleure, elle tape du pied au rythme de la musique."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:98
translate french marimovietheaterstartdate_e4a43b4e:

    # "We have a great time."
    "On passe un super moment."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:101
translate french marimovietheaterstartdate_8f27901e:

    # "The movie is pretty funny all the way through and Mari and I laugh a lot."
    "Le film est assez drôle du début à la fin et Mari et moi, on rit beaucoup."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:104
translate french marimovietheaterstartdate_abcf9a29:

    # "Then somehow that turns into us making out."
    "Puis, d’une manière ou d’une autre, ça nous amène à nous embrasser."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:105
translate french marimovietheaterstartdate_46b84a07:

    # "We don't really watch much of the movie after that."
    "On ne regarde plus vraiment le film après ça."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:106
translate french marimovietheaterstartdate_d855e56b:

    # "Eventually the movie ends and the credits start rolling."
    "Finalement, le film se termine et le générique commence à défiler."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:109
translate french marimovietheaterstartdate_f176d1eb:

    # fr "That was a cute movie."
    fr "C’était un film mignon."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:111
translate french marimovietheaterstartdate_b1836b04:

    # fr "What little I saw of it anyway."
    fr "Du moins, le peu que j’en ai vu."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:112
translate french marimovietheaterstartdate_91db2110:

    # fr "I like what we did even more than the movie."
    fr "J’aime encore plus ce qu’on a fait que le film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:113
translate french marimovietheaterstartdate_e25ed9ba:

    # fr "Thanks for taking me."
    fr "Merci de m’avoir emmenée."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:116
translate french marimovietheaterstartdate_eb286352:

    # fr "Well the movie wasn't really my thing."
    fr "Bon, le film n'était pas vraiment mon truc."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:118
translate french marimovietheaterstartdate_8fc45fba:

    # fr "But seeing it with you made it a lot better."
    fr "Mais le voir avec toi l'a rendu bien meilleur."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:121
translate french marimovietheaterstartdate_c58b0ecd:

    # fr "I'm a big baby, I know."
    fr "Je suis un gros bébé, je sais."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:122
translate french marimovietheaterstartdate_acdb9025:

    # fr "But I hated that. Even when I stopped watching it, the noises were still scary."
    fr "Mais j'ai détesté ça. Même quand j'ai arrêté de regarder, les bruits me faisaient encore peur."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:123
translate french marimovietheaterstartdate_26d0b7c9:

    # pc "I'm sorry, I didn't realize that you disliked horror movies so much."
    pc "Je suis désolé, je ne savais pas que tu n'aimais pas autant les films d'horreur."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:124
translate french marimovietheaterstartdate_30078caa:

    # fr "They just bring back bad memories and make me think about sad things."
    fr "Ils me rappellent juste de mauvais souvenirs et me font penser à des choses tristes."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:127
translate french marimovietheaterstartdate_c3aec289:

    # fr "That movie was so cute! I loved it!"
    fr "Ce film était tellement mignon ! Je l'ai adoré !"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:128
translate french marimovietheaterstartdate_070969bf:

    # fr "Thanks so much for bringing me."
    fr "Merci beaucoup de m'avoir emmenée."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:131
translate french marimovietheaterstartdate_4549f151:

    # fr "That was a fun movie."
    fr "C'était un film sympa."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:133
translate french marimovietheaterstartdate_b1836b04_1:

    # fr "What little I saw of it anyway."
    fr "Du moins, le peu que j'en ai vu."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:134
translate french marimovietheaterstartdate_91db2110_1:

    # fr "I like what we did even more than the movie."
    fr "J'ai encore plus aimé ce qu'on a fait que le film."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:135
translate french marimovietheaterstartdate_233f5bf6:

    # "When the credits start rolling, we hang out and chat through them."
    "Quand le générique commence, on reste ensemble et on discute pendant toute sa durée."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:139
translate french marimovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Une fois le générique terminé, on sort ensemble et on se dirige vers ma voiture."

translate french strings:

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:2
    old "When you are able to ask Mari out on a date, take her to the movie theater."
    new "Quand tu pourras inviter Mari à sortir, emmène-la au cinéma."

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:3
    old "She will only be able to go to the movies in the evening on weekends."
    new "Elle ne pourra aller au cinéma que le soir, le week-end."

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:54
    old "Something animated"
    new "Un film d’animation."

