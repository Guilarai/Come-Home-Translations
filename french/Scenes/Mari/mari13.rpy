    # fr "The big one is Appa, and the little guy is Momo."
    fr "Le grand, c'est Appa, et le petit, c'est Momo."

# game/Scenes/Mari/mari13.rpy:144
translate french mari13rebahelp_b4839da7:

    # rb "Oh my God, I love them!"
    rb "Oh mon Dieu, je les adore !"

# game/Scenes/Mari/mari13.rpy:147
translate french mari13rebahelp_34d27c0e:

    # rb "You didn't tell me that I was fixin' this car for a cute girlfriend of yours, [pcname]."
    rb "Tu ne m'avais pas dit que je réparais cette voiture pour une de tes copines mignonnes, [pcname]."

# game/Scenes/Mari/mari13.rpy:148
