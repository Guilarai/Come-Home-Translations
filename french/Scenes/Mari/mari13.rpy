    # "I give Reba directions to Mari's farm and a few minutes later she meets us there."
    "Je donne à Reba l'itinéraire pour se rendre à la ferme de Mari et, quelques minutes plus tard, elle nous rejoint là-bas."

# game/Scenes/Mari/mari13.rpy:138
translate french mari13rebahelp_05b2461c:

    # rb "Oh my God! Your dogs are {i}so{/i} cute."
    rb "Oh mon Dieu ! Tes chiens sont {i}tellement{/i} mignons."

# game/Scenes/Mari/mari13.rpy:139
translate french mari13rebahelp_22df0ba2:

    # fr "They seem to like you."
    fr "Ils ont l'air de t'apprécier."

# game/Scenes/Mari/mari13.rpy:140
