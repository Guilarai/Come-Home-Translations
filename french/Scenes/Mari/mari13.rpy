    # voice 'voices/mari_shoot1.mp3'
    voice 'voices/mari_shoot1.mp3'

# game/Scenes/Mari/mari13.rpy:169
translate french mari13rebahelp_8f74c366:

    # fr "Aw, shoot. How much is all of that going to cost?"
    fr "Oh, mince. Combien tout ça va coûter ?"

# game/Scenes/Mari/mari13.rpy:170
translate french mari13rebahelp_8f3b3d9a:

    # rb "I can get you a new fuel pump for about $100. New oil filter and oil is like $30. Then just a tank of gas to replace the old junk."
    rb "Je peux te trouver une nouvelle pompe à essence pour environ 100 $. Un nouveau filtre à huile et de l’huile, ça fait environ 30 $. Et puis juste un plein d’essence pour remplacer cette vieille camelote."

# game/Scenes/Mari/mari13.rpy:171
translate french mari13rebahelp_428bb652:

    # rb "And all the labor is on the house, because I like that guy over there, and you seem like a pretty cool chick too."
    rb "Et toute la main-d'œuvre est offerte par la maison, parce que j'aime bien ce type là-bas, et tu as l'air d'être une fille plutôt sympa toi aussi."

# game/Scenes/Mari/mari13.rpy:172
translate french mari13rebahelp_3eeb60d9:

    # rb "Y'all just gotta hang out and keep me company and hand me junk when I ask for it, alright?"
    rb "Vous n'avez qu'à traîner par là, me tenir compagnie et me passer des trucs quand je vous les demande, d'accord ?"

