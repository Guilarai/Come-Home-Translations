    # rb "Yeah, we'll get this truck going and you can drive all over the place."
    rb "Ouais, on va remettre ce pick-up en état et tu pourras rouler partout."

# game/Scenes/Mari/mari13.rpy:185
translate french mari13rebahelp_28f72a61:

    # rb "So you and [pcname]. Are you two serious?"
    rb "Alors toi et [pcname]. Vous êtes sérieux tous les deux ?"

