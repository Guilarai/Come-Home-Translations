# game/Scenes/Mari/MariConversations/maris7.rpy:13
translate french maris7_aa9452c3:

    # fr "Anything outdoors really."
    fr "N'importe quoi en plein air, en fait."

# game/Scenes/Mari/MariConversations/maris7.rpy:14
translate french maris7_23bbfe65:

    # fr "I love walking in the park with you."
    fr "J'adore me promener dans le parc avec toi."

# game/Scenes/Mari/MariConversations/maris7.rpy:15
translate french maris7_ebffc98a:

    # fr "I'd love to go to a big garden somewhere. Or just the lake or something."
    fr "J'adorerais aller dans un grand jardin quelque part. Ou simplement au bord d'un lac, par exemple."

# game/Scenes/Mari/MariConversations/maris7.rpy:16
translate french maris7_7c02732c:

    # fr "Anywhere that's green and alive and has fresh air and birds and breeze."
    fr "N'importe quel endroit verdoyant et vivant, où il y a de l'air frais, des oiseaux et une brise."

# game/Scenes/Mari/MariConversations/maris7.rpy:17
translate french maris7_008c825e:

    # pc "That all sounds wonderful, but what would be the perfect date?"
    pc "Tout ça a l'air merveilleux, mais quel serait le rendez-vous parfait ?"

# game/Scenes/Mari/MariConversations/maris7.rpy:19
translate french maris7_fb3aa226:

    # fr "Hmm… I guess I'd like to go to a beautiful garden with colorful flowers. I think there's one up in Whiterock that I've heard of."
    fr "Hmm… Je pense que j'aimerais aller dans un beau jardin avec des fleurs colorées. Je crois qu'il y en a un à Whiterock dont j'ai entendu parler."

# game/Scenes/Mari/MariConversations/maris7.rpy:20
translate french maris7_15fa15b9:

    # fr "We'd spend the day there, just exploring the place and talking."
    fr "On passerait la journée là-bas, à explorer les lieux et à discuter."

# game/Scenes/Mari/MariConversations/maris7.rpy:21
translate french maris7_768a7b04:

    # fr "Then we'd get something delicious to eat. Something fresh and green."
    fr "Puis on mangerait quelque chose de délicieux. Quelque chose de frais et de vert."

# game/Scenes/Mari/MariConversations/maris7.rpy:23
translate french maris7_0412d35d:

    # fr "Then we'd go back to the farm. I'd do my evening chores…"
    fr "Ensuite, on rentrerait à la ferme. Je ferais mes corvées du soir…"

# game/Scenes/Mari/MariConversations/maris7.rpy:24
translate french maris7_4dc951ac:

    # pc "Your ideal date involves chores?"
    pc "Ton rendez-vous idéal inclut des corvées ?"

# game/Scenes/Mari/MariConversations/maris7.rpy:26
translate french maris7_236034e4:

    # fr "Well somebody has to do them."
    fr "Eh bien, il faut bien que quelqu’un s’en charge."

# game/Scenes/Mari/MariConversations/maris7.rpy:28
translate french maris7_9a5fc24f:

    # fr "Anyway, then we'd go inside, take a shower…"
    fr "Bref, ensuite on rentrerait, on prendrait une douche…"

# game/Scenes/Mari/MariConversations/maris7.rpy:30
translate french maris7_d7effb83:

    # fr "… and do stuff."
    fr "… et on ferait des trucs."

# game/Scenes/Mari/MariConversations/maris7.rpy:31
translate french maris7_97fb7052:

    # pc "Stuff?"
    pc "Des trucs ?"

# game/Scenes/Mari/MariConversations/maris7.rpy:32
translate french maris7_30de1bd2:

    # fr "Yeah. Stuff."
    fr "Ouais. Des trucs."

# game/Scenes/Mari/MariConversations/maris7.rpy:34
translate french maris7_f18990d4:

    # fr "All night."
    fr "Toute la nuit."

# game/Scenes/Mari/MariConversations/maris7.rpy:35
translate french maris7_2fab7edc:

    # pc "Sounds nice."
    pc "Ça a l'air sympa."

# game/Scenes/Mari/MariConversations/maris7.rpy:37
translate french maris7_c6174cde:

    # fr "Yeah, it would be."
    fr "Ouais, ça le serait."

