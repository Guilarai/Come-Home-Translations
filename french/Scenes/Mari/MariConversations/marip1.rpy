    new "Oui, s’il te plaît."

    # game/Scenes/Mari/MariConversations/marip1.rpy:22
    old "Maybe not."
    new "Peut-être pas."

    # game/Scenes/Mari/MariConversations/marip1.rpy:43
    old "That's so awful"
    new "C’est vraiment horrible."

    # game/Scenes/Mari/MariConversations/marip1.rpy:57
    old "Wow, shit luck"
    new "Ouah, quelle malchance."

