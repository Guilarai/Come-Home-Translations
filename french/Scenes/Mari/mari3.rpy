# game/Scenes/Mari/mari3.rpy:12
translate french mari3_d41d8cd9:

    # voice 'voices/mari_heythere.mp3'
    voice 'voices/mari_heythere.mp3'

# game/Scenes/Mari/mari3.rpy:13
translate french mari3_5fec8fcf:

    # fr "Hey there, [pcname]. How are you today?"
    fr "Salut, [pcname]. Comment ça va aujourd'hui ?"

# game/Scenes/Mari/mari3.rpy:14
translate french mari3_b835b9eb:

    # pc "I'm doing great, how's my favorite waitress?"
    pc "Je vais très bien, et ma serveuse préférée ?"

# game/Scenes/Mari/mari3.rpy:15
translate french mari3_334e62bd:

    # fr "Much better now that her favorite customer is here."
    fr "Beaucoup mieux maintenant que son client préféré est là."

# game/Scenes/Mari/mari3.rpy:20
translate french mari3_747e36cd:

    # pc "Mari, there was something I wanted to ask you."
    pc "Mari, j'avais quelque chose à te demander."

# game/Scenes/Mari/mari3.rpy:21
translate french mari3_96d48818:

    # fr "Ask away."
    fr "Vas-y."

# game/Scenes/Mari/mari3.rpy:22
translate french mari3_05be9386:

    # pc "Would you want to go out on a date with me sometime?"
    pc "Tu voudrais sortir avec moi un de ces jours ?"

# game/Scenes/Mari/mari3.rpy:25
translate french mari3_d41d8cd9_1:

    # voice 'voices/mari_idloveto.mp3'
    voice 'voices/mari_idloveto.mp3'

# game/Scenes/Mari/mari3.rpy:26
translate french mari3_ad1c3ebd:

    # fr "Really? I'd love to."
    fr "Vraiment ? J'adorerais."

# game/Scenes/Mari/mari3.rpy:27
translate french mari3_1da24e01:

    # pc "Awesome."
    pc "Génial."

# game/Scenes/Mari/mari3.rpy:29
translate french mari3_008e9d39:

    # fr "I don't get to go out on dates very often, and I do really like you."
    fr "Je n'ai pas souvent l'occasion de sortir, et je t'apprécie vraiment beaucoup."

# game/Scenes/Mari/mari3.rpy:30
translate french mari3_098a6e78:

    # fr "I'm busy a lot, but I'll give you my phone number and maybe we could go out in the evening on a weekend sometime?"
    fr "Je suis très occupée, mais je vais te donner mon numéro de téléphone et on pourrait peut-être sortir un soir de week-end ?"

# game/Scenes/Mari/mari3.rpy:31
translate french mari3_d2954fc0:

    # pc "That sounds great."
    pc "Ça me semble parfait."

# game/Scenes/Mari/mari3.rpy:32
translate french mari3_52d8f6ae:

    # fr "Oh I'm so excited."
    fr "Oh, je suis tellement excitée."

# game/Scenes/Mari/mari3.rpy:34
translate french mari3_e7685f1d:

    # fr "Here's my phone number."
    fr "Voici mon numéro de téléphone."

# game/Scenes/Mari/mari3.rpy:36
translate french mari3_639d3c6f:

    # fr "You can call me any time, but I won't be able to talk while I'm working, and I work a lot!"
    fr "Tu peux m'appeler quand tu veux, mais je ne pourrai pas parler pendant que je travaille, et je travaille beaucoup !"

# game/Scenes/Mari/mari3.rpy:37
translate french mari3_73bf0030:

    # pc "I'll definitely give you a call sometime."
    pc "Je t'appellerai sans faute un de ces jours."

# game/Scenes/Mari/mari3.rpy:38
translate french mari3_c2bff929:

    # fr "Good, I can't wait!"
    fr "Super, j'ai hâte !"

# game/Scenes/Mari/mari3.rpy:39
translate french mari3_910292d4:

    # fr "I better go get your food."
    fr "Je ferais mieux d'aller chercher ton repas."

# game/Scenes/Mari/mari3.rpy:40
translate french mari3_63023601:

    # pc "Okay."
    pc "D'accord."

# game/Scenes/Mari/mari3.rpy:42
translate french mari3_0aa5dfbc:

    # "She starts to walk away, then looks back at me."
    "Elle commence à s'éloigner, puis se retourne vers moi."

# game/Scenes/Mari/mari3.rpy:43
translate french mari3_8f6f1358:

    # fr "Thanks for asking me out. I'm really looking forward to our date."
    fr "Merci de m'avoir invitée à sortir. J'ai vraiment hâte de notre rendez-vous."

# game/Scenes/Mari/mari3.rpy:44
translate french mari3_03eaad50:

    # pc "Me too."
    pc "Moi aussi."

# game/Scenes/Mari/mari3.rpy:45
translate french mari3_7553af6a:

    # "With that, she smiles and leaves to get my food."
    "Sur ces mots, elle sourit et part chercher mon repas."

# game/Scenes/Mari/mari3.rpy:47
translate french mari3_43045d37:

    # "We don't talk much more while I eat and she has to help other customers, but every time she looks at me, she's smiling."
    "On ne parle pas beaucoup pendant que je mange et qu’elle doit s’occuper d’autres clients, mais chaque fois qu’elle me regarde, elle sourit."

# game/Scenes/Mari/mari3.rpy:48
translate french mari3_2d44a908:

    # "The smile is different than usual. More sincere almost."
    "Ce sourire est différent de d’habitude. Presque plus sincère."

# game/Scenes/Mari/mari3.rpy:51
translate french maritip3_474b8780:

    # "I leave 10 dollars on the table."
    "Je laisse 10 dollars sur la table."

# game/Scenes/Mari/mari3.rpy:53
translate french maritip3_bbc6048f:

    # "No need to leave money, I'll give her something better later."
    "Pas besoin de laisser de l'argent, je lui donnerai quelque chose de mieux plus tard."

# game/Scenes/Mari/mari3.rpy:55
translate french maritip3_c56febff:

    # "Then I start to walk out towards my car."
    "Puis je commence à marcher vers ma voiture."

# game/Scenes/Mari/mari3.rpy:58
translate french maritip3_e3c07fca:

    # "Mari stops me though, wrapping her arms around me and pulling me into a hug."
    "Mais Mari m'arrête, m'enlace et me serre dans ses bras."

# game/Scenes/Mari/mari3.rpy:59
translate french maritip3_7db5e01d:

    # fr "I can't wait to see you again."
    fr "J'ai hâte de te revoir."

# game/Scenes/Mari/mari3.rpy:60
translate french maritip3_98e7787f:

    # fr "Be sure you call me."
    fr "N'oublie pas de m'appeler."

# game/Scenes/Mari/mari3.rpy:61
translate french maritip3_5bc44b07:

    # pc "I will."
    pc "Je le ferai."

# game/Scenes/Mari/mari3.rpy:62
translate french maritip3_2e512b95:

    # fr "Okay, take care."
    fr "D'accord, prends soin de toi."

# game/Scenes/Mari/mari3.rpy:65
translate french maritip3_5794a059:

    # "She releases me and I go outside. She's really excited about our date it seems."
    "Elle me lâche et je sors. On dirait qu'elle est vraiment impatiente de notre rendez-vous."

# game/Scenes/Mari/mari3.rpy:66
translate french maritip3_f0d4672c:

    # "I'm excited too. It should be fun."
    "Moi aussi, je suis impatient. Ça devrait être sympa."

