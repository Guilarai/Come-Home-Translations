# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:14
translate french whitneyp5_fa9f186a:

    # wt "No, I would not. Why would I?"
    wt "Non, je ne le ferais pas. Pourquoi le ferais-je ?"

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:16
translate french whitneyp5_ddacf136:

    # wt "Without feelings, sex is merely the stimulation of nerves."
    wt "Sans sentiments, le sexe n'est qu'une simple stimulation des nerfs."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:17
translate french whitneyp5_915b3e45:

    # wt "I can do that myself, or design a device that could perform that task better than any person ever could."
    wt "Je peux le faire moi-même, ou concevoir un appareil qui pourrait accomplir cette tâche mieux que n'importe quelle personne ne le pourrait jamais."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:18
translate french whitneyp5_d0d17975:

    # pc "You could design a toy that would make you feel better than I could?"
    pc "Tu pourrais concevoir un jouet qui te ferait plus de bien que moi ?"

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:20
translate french whitneyp5_da52f778:

    # wt "No, because with you, there are feelings."
    wt "Non, parce qu’avec toi, il y a des sentiments."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:21
translate french whitneyp5_031c731c:

    # wt "I could never design something that could emulate those feelings."
    wt "Je ne pourrais jamais concevoir quelque chose capable d’imiter ces sentiments."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:23
translate french whitneyp5_5e6cc221:

    # wt "Well, I probably could, but I do not have the time to devote to a project like that."
    wt "Eh bien, je le pourrais probablement, mais je n’ai pas le temps de me consacrer à un projet comme celui-là."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:24
translate french whitneyp5_9ab685cf:

    # pc "If you could create a device that simulates love, you could make a lot of people happy."
    pc "Si tu pouvais créer un appareil qui simule l’amour, tu rendrais beaucoup de gens heureux."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:26
translate french whitneyp5_d7e4e942:

    # wt "I'm not concerned with creating things that make people happy. I will leave that to the entertainers."
    wt "Je ne me soucie pas de créer des choses qui rendent les gens heureux. Je laisse ça aux artistes."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:28
translate french whitneyp5_0a7ea3b9:

    # wt "My inventions are for the betterment of humankind."
    wt "Mes inventions visent à améliorer le sort de l’humanité."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:29
translate french whitneyp5_989c3dc9:

    # wt "To help our species survive longer and to lengthen the average lifespan."
    wt "Pour aider notre espèce à survivre plus longtemps et à allonger l’espérance de vie moyenne."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:30
translate french whitneyp5_b62185e1:

    # pc "What's the point of living longer if you're not happy though?"
    pc "Mais à quoi ça sert de vivre plus longtemps si on n’est pas heureux ?"

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:32
translate french whitneyp5_0f6b1f61:

    # wt "Interesting..."
    wt "Intéressant…"

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:33
translate french whitneyp5_a0b8b03d:

    # wt "I'll consider this."
    wt "Je vais y réfléchir."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:35
translate french whitneyp5_bfd42d1e:

    # wt "Right now, I am focused on finding your father."
    wt "Pour l’instant, je me concentre sur la recherche de ton père."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:36
translate french whitneyp5_bf14b6c8:

    # wt "Would you like me to instead divert my time towards making a sex toy that has feelings?"
    wt "Préféreriez-vous que je consacre plutôt mon temps à créer un sextoy doté de sentiments ?"

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:37
translate french whitneyp5_b5702645:

    # pc "It's tempting... but no, we have to find my dad."
    pc "C'est tentant... mais non, nous devons retrouver mon père."

# game/Scenes/Whitney/WhitneyConversations/whitneyp5.rpy:39
translate french whitneyp5_c71fc1fc:

    # wt "I agree. Sex toys can wait."
    wt "Je suis d'accord. Les sextoys peuvent attendre."

