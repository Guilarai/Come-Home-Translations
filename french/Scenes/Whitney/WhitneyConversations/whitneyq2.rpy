# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:12
translate french whitneyq2_29acda57:

    # wt "What are you planning for after college?"
    wt "Qu'est-ce que tu prévois de faire après l'université ?"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:14
translate french whitneyq2_28276084:

    # pc "I'm not sure. Working in a lab somewhere probably. Maybe where my dad works."
    pc "Je ne sais pas trop. Travailler dans un labo quelque part, probablement. Peut-être là où travaille mon père."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:15
translate french whitneyq2_e37a9d5d:

    # wt "That's not a bad idea. They're a good company doing good things, though a bit unimaginative."
    wt "Ce n'est pas une mauvaise idée. C'est une bonne entreprise qui fait de bonnes choses, même si elle manque un peu d'imagination."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:17
translate french whitneyq2_3f970292:

    # wt "I've been thinking about starting my own lab."
    wt "J’ai pensé à monter mon propre laboratoire."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:18
translate french whitneyq2_40ff646e:

    # wt "I've made enough money working for others that I'd like to focus on my own pursuits now."
    wt "J’ai gagné assez d’argent en travaillant pour les autres, j’aimerais maintenant me concentrer sur mes propres projets."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:19
translate french whitneyq2_5838daaa:

    # pc "Stuff like alternate universes?"
    pc "Des trucs comme les univers parallèles ?"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:21
translate french whitneyq2_fbb4f39e:

    # wt "Among other useful things!"
    wt "Entre autres choses utiles !"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:23
translate french whitneyq2_2b6961ab:

    # wt "Curing sickness, solving world hunger, restoring the Earth's environment, instant teleportation, interstellar travel, eternal life."
    wt "Guérir les maladies, résoudre la faim dans le monde, restaurer l’environnement de la Terre, la téléportation instantanée, les voyages interstellaires, la vie éternelle."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:24
translate french whitneyq2_8d5d4423:

    # pc "Wow. So just the little stuff huh?"
    pc "Ouah. Juste des petites choses, hein ?"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:28
translate french whitneyq2_c320ba54:

    # wt "I think so."
    wt "Je crois bien."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:32
translate french whitneyq2_f9fc9074:

    # wt "I'm not mad."
    wt "Je ne suis pas fou."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:33
translate french whitneyq2_5ae98453:

    # wt "Every scientist is considered mad until they accomplish their goals."
    wt "Tous les scientifiques sont considérés comme fous jusqu’à ce qu’ils atteignent leurs objectifs."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:34
translate french whitneyq2_fe5d5afd:

    # wt "I believe that all of these things are possible. Some within our lifetime."
    wt "Je crois que toutes ces choses sont possibles. Certaines de notre vivant."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:36
translate french whitneyq2_453ab0ca:

    # wt "Anyway, I could use a couple of assistants with these projects, if you're interested in pursuing that."
    wt "Quoi qu’il en soit, j’aurais besoin de deux assistants pour ces projets, si ça t’intéresse."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:40
translate french whitneyq2_62d418b5:

    # wt "I'm glad."
    wt "J’en suis ravi."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:41
translate french whitneyq2_214e8d99:

    # wt "I've enjoyed working with you so far and I think that we could do good things together."
    wt "J’ai apprécié travailler avec toi jusqu’à présent et je pense qu’on pourrait faire de grandes choses ensemble."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:43
translate french whitneyq2_6c16cd66:

    # pc "I think so too."
    pc "Je le pense aussi."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:46
translate french whitneyq2_119fcf3f:

    # wt "Yes, please do."
    wt "Oui, n’hésite pas."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:47
translate french whitneyq2_214e8d99_1:

    # wt "I've enjoyed working with you so far and I think that we could do good things together."
    wt "J'ai apprécié travailler avec toi jusqu'à présent et je pense qu'on pourrait faire de belles choses ensemble."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:48
translate french whitneyq2_d4519477:

    # pc "Maybe we could."
    pc "Peut-être bien."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:52
translate french whitneyq2_f9bd4feb:

    # wt "Oh, that's too bad."
    wt "Oh, c'est dommage."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:53
translate french whitneyq2_d452d931:

    # pc "I'm sorry. I'm just not interested."
    pc "Je suis désolé. Ça ne m'intéresse tout simplement pas."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:55
translate french whitneyq2_3fa39adf:

    # wt "That's okay. Let's move on then."
    wt "Ce n'est pas grave. Passons à autre chose alors."

