# game/Scenes/Micha/MichaDates/michaparkdate.rpy:26
translate spanish michaparkstartdate_7d6d0d91:

    # "Mi-Cha and I walk around the trails, chit-chatting for a while."
    "Mi-Cha y yo paseamos por los senderos, charlando un rato."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:34
translate spanish michaparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "Al final, llegamos al banco que hay a mitad del camino."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:40
translate spanish michaparkstartdate_8d76a79c:

    # "We sit next to each other on the bench for a bit, watching the sky change colors as the sun sets."
    "Nos sentamos uno al lado del otro en el banco un rato, viendo cómo el cielo cambia de color a medida que se pone el sol."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:43
translate spanish michaparkstartdate_3dfbfe0f:

    # "We make out. She's nervous, I can tell that she wants more."
    "Nos besamos. Ella está nerviosa, noto que quiere más."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:44
translate spanish michaparkstartdate_af7c35f8:

    # "But we have to head back before it gets too dark."
    "Pero tenemos que volver antes de que oscurezca demasiado."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:47
translate spanish michaparkstartdate_6b4912a9:

    # mc "Do you mind taking me back to my dorm?"
    mc "¿Te importaría llevarme de vuelta a mi residencia?"

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:48
translate spanish michaparkstartdate_a248948f:

    # pc "Of course."
    pc "Por supuesto."

