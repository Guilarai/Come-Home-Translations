# game/Scenes/Lisa/LisaConversations/lisap7.rpy:13
translate portuguese lisap7_94d99c64:

    # sp "Do you think he is going to come back?"
    sp "Achas que ele vai voltar?"

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:14
translate portuguese lisap7_ebe799f9:

    # pc "I'm not sure, but I'm trying."
    pc "Não tenho a certeza, mas estou a tentar."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:16
translate portuguese lisap7_097d9069:

    # sp "Well, {i}if{/i} he comes back, I will ask him nicely if he would pack his things and move out."
    sp "Bem, {i}se{/i} ele voltar, vou pedir-lhe gentilmente para fazer as malas e sair de casa."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:18
translate portuguese lisap7_defaba5c:

    # sp "Technically, the house is his, but I have been paying all the bills since he disappeared."
    sp "Tecnicamente, a casa é dele, mas tenho pago todas as contas desde que ele desapareceu."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:19
translate portuguese lisap7_7e722eaa:

    # sp "I believe I have some legal claim to the house at this point."
    sp "Acho que tenho algum direito legal sobre a casa nesta altura."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:21
translate portuguese lisap7_3be4f3d5:

    # sp "But if he fights too much, I'll probably just leave with Suzy and get an apartment somewhere."
    sp "Mas se ele resistir demasiado, provavelmente vou-me embora com a Suzy e arranjo um apartamento algures."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:24
translate portuguese lisap7_d41d8cd9:

    # voice 'voices/lisa_18_1.mp3'
    voice 'voices/lisa_18_1.mp3'

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:25
translate portuguese lisap7_691527ac:

    # sp "Either way... I am not in a relationship with him anymore."
    sp "De qualquer forma... já não estou numa relação com ele."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:27
translate portuguese lisap7_d41d8cd9_1:

    # voice 'voices/lisa_18_2.mp3'
    voice 'voices/lisa_18_2.mp3'

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:28
translate portuguese lisap7_f5b06ff5:

    # sp "There is no going back to the way things were."
    sp "Não há volta a dar às coisas como eram."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:31
translate portuguese lisap7_d41d8cd9_2:

    # voice 'voices/lisa_18_3.mp3'
    voice 'voices/lisa_18_3.mp3'

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:32
translate portuguese lisap7_e25e29cb:

    # sp "I want to stay with you, [pcname]."
    sp "Quero ficar contigo, [pcname]."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:33
translate portuguese lisap7_e85b9fe2:

    # sp "If your dad comes back, I'll still want to be with you."
    sp "Se o teu pai voltar, vou continuar a querer ficar contigo."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:35
translate portuguese lisap7_99e080fb:

    # sp "It will be weird at first, but no weirder than telling Suzy, and we somehow survived that."
    sp "Vai ser estranho no início, mas não mais estranho do que contar à Suzy, e de alguma forma sobrevivemos a isso."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:37
translate portuguese lisap7_d123a709:

    # sp "Anyways... I hope your father is okay, wherever he is."
    sp "De qualquer forma... espero que o teu pai esteja bem, onde quer que esteja."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:38
translate portuguese lisap7_18bad589:

    # sp "And I'd love to talk to him and ask him some things."
    sp "E adoraria falar com ele e perguntar-lhe algumas coisas."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:40
translate portuguese lisap7_36f2056a:

    # sp "But I'm not going back to him."
    sp "Mas não vou voltar para ele."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:42
translate portuguese lisap7_d41d8cd9_3:

    # voice 'voices/lisa_18_4.mp3'
    voice 'voices/lisa_18_4.mp3'

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:43
translate portuguese lisap7_6b3cf03c:

    # sp "I'm done being treated like a backup plan."
    sp "Cansei-me de ser tratada como um plano B."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:45
translate portuguese lisap7_2988465e:

    # sp "I'm sorry. I know he's your dad. I do care about him and I don't mean to badmouth him this much."
    sp "Desculpa. Eu sei que ele é o teu pai. Eu preocupo-me com ele e não quero falar mal dele assim tanto."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:46
translate portuguese lisap7_6c4342d2:

    # pc "It's okay. I know how he treated you. He deserves it."
    pc "Não faz mal. Eu sei como ele te tratou. Ele merece."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:48
translate portuguese lisap7_e3621c99:

    # sp "Are you going to be okay with us being together, even if he comes back?"
    sp "Vais ficar bem com o facto de estarmos juntos, mesmo que ele volte?"

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:49
translate portuguese lisap7_3bfc4bd4:

    # sp "Or is it too weird for you?"
    sp "Ou é demasiado estranho para ti?"

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:51
translate portuguese lisap7_89e1637d:

    # pc "Everything about this situation with my dad is weird."
    pc "Tudo nesta situação com o meu pai é estranho."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:52
translate portuguese lisap7_e1114729:

    # pc "But me being with you doesn't feel weird at all."
    pc "Mas eu estar contigo não me parece nada estranho."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:53
translate portuguese lisap7_2bfc5c08:

    # pc "It feels perfect."
    pc "Parece perfeito."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:55
translate portuguese lisap7_4a76d6f4:

    # sp "Yeah... it does."
    sp "Sim... parece mesmo."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:56
translate portuguese lisap7_dbd4b8fb:

    # sp "I love you."
    sp "Amo-te."

# game/Scenes/Lisa/LisaConversations/lisap7.rpy:57
translate portuguese lisap7_931fdb2e:

    # pc "I love you too, Lisa."
    pc "Também te amo, Lisa."

