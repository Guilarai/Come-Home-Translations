# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:16
translate portuguese lisasurface2_c72b71ab:

    # pc "No beer or shots?"
    pc "Nem cerveja nem shots?"

# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:17
translate portuguese lisasurface2_53d5d4b7:

    # sp "I'm not a big fan of the taste of most beers and shots get me drunk way too fast."
    sp "Não sou grande fã do sabor da maioria das cervejas e os shots deixam-me bêbada demasiado depressa."

# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:18
translate portuguese lisasurface2_d27b8712:

    # sp "I'm kind of a light weight. One or two shots and I'm out of it."
    sp "Sou um pouco fraco para a bebida. Um ou dois shots e fico fora de mim."

# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:20
translate portuguese lisasurface2_4ee2ab04:

    # sp "And when I get drunk I get, super handsy."
    sp "E quando fico bêbado, fico super pegajoso."

# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:21
translate portuguese lisasurface2_85be51df:

    # sp "Got me in trouble a bit back in my college days."
    sp "Isso meteu-me em sarilhos na época da faculdade."

# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:22
translate portuguese lisasurface2_ae871f39:

    # pc "Oh yeah?"
    pc "Ah, é?"

# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:23
translate portuguese lisasurface2_11f2ea04:

    # sp "Yeah. How do you think Suzy happened?"
    sp "Sim. Como achas que a Suzy aconteceu?"

# game/Scenes/Lisa/LisaConversations/lisasurface2.rpy:24
translate portuguese lisasurface2_285ddc7d:

    # pc "Oh no!"
    pc "Oh, não!"

