# game/Scenes/Lisa/LisaConversations/lisas5.rpy:13
translate portuguese lisas5_1bd10091:

    # sp "That's easy. Suzy of course."
    sp "Isso é fácil. A Suzy, claro."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:14
translate portuguese lisas5_092a2938:

    # sp "That girl means everything to me."
    sp "Aquela menina significa tudo para mim."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:16
translate portuguese lisas5_52473454:

    # sp "She has an attitude sometimes. She gets that from me. But she can be so sweet and she's so smart."
    sp "Às vezes ela tem uma atitude. Herdou isso de mim. Mas ela pode ser tão querida e é tão inteligente."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:17
translate portuguese lisas5_34f51681:

    # sp "I can't wait to see what she does with her life."
    sp "Mal posso esperar para ver o que ela vai fazer da vida."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:18
translate portuguese lisas5_d0ef84f3:

    # sp "She's going to do so much more than I have."
    sp "Ela vai fazer muito mais do que eu fiz."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:20
translate portuguese lisas5_dcb5444e:

    # sp "I'm proud of you too of course, but I can't take credit for you. We barely had a year together before you left for Brazil."
    sp "Também tenho orgulho de ti, claro, mas não posso atribuir-me o mérito por ti. Mal passámos um ano juntos antes de partires para o Brasil."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:21
translate portuguese lisas5_a3c1befd:

    # sp "I know your father was proud of you too though. Just as proud as I am of my Suzy."
    sp "Mas sei que o teu pai também tinha orgulho de ti. Tão orgulhoso quanto eu tenho da minha Suzy."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:22
translate portuguese lisas5_cda2f52e:

    # pc "Thanks, [mom]."
    pc "Obrigado, [mom]."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:24
translate portuguese lisas5_015a459b:

    # sp "You're welcome. Love you, [pcname]."
    sp "De nada. Amo-te, [pcname]."

# game/Scenes/Lisa/LisaConversations/lisas5.rpy:25
translate portuguese lisas5_f785b72d:

    # sp "Love you too, [mom]."
    sp "Também te amo, [mom]."

