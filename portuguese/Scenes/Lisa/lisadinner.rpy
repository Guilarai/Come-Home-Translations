# game/Scenes/Lisa/lisadinner.rpy:3
translate portuguese lisadinner_e20dd2c0:

    # "Usually Lisa would be cooking dinner here on the weekend, but she's not here."
    "Normalmente, a Lisa estaria aqui a preparar o jantar ao fim de semana, mas ela não está aqui."

# game/Scenes/Lisa/lisadinner.rpy:4
translate portuguese lisadinner_7b04e990:

    # "I wonder if she's still upset about before?"
    "Será que ela ainda está chateada com o que aconteceu há pouco?"

# game/Scenes/Lisa/lisadinner.rpy:5
translate portuguese lisadinner_6a8bd90c:

    # "I guess she just needs some more time."
    "Acho que ela só precisa de mais algum tempo."

# game/Scenes/Lisa/lisadinner.rpy:8
translate portuguese lisadinner_17ebb7b6:

    # "Lisa stands in the kitchen, cooking dinner at the stove."
    "A Lisa está na cozinha, a preparar o jantar no fogão."

# game/Scenes/Lisa/lisadinner.rpy:9
translate portuguese lisadinner_622e58a4:

    # "She looks tired, but still turns towards me with a smile."
    "Ela parece cansada, mas mesmo assim vira-se para mim com um sorriso."

# game/Scenes/Lisa/lisadinner.rpy:12
translate portuguese lisadinner_dbdf9d75:

    # sp "Hey honey. You joining me for dinner?"
    sp "Olá, querido. Vens jantar comigo?"

# game/Scenes/Lisa/lisadinner.rpy:21
translate portuguese lisadinner_d0417e78:

    # sp "Okay honey, let me know if you change your mind."
    sp "Está bem, querido, avisa-me se mudares de ideias."

# game/Scenes/Lisa/lisadinner.rpy:67
translate portuguese lisadinnerconversation_18c6396f:

    # sp "I'm glad. It gets lonely eating by myself."
    sp "Fico contente. É solitário comer sozinha."

# game/Scenes/Lisa/lisadinner.rpy:69
translate portuguese lisadinnerconversation_f7385cce:

    # "She returns to the stove and cooks us both dinner."
    "Ela volta para o fogão e prepara o jantar para nós os dois."

# game/Scenes/Lisa/lisadinner.rpy:73
translate portuguese lisadinnerconversation_2aba8403:

    # "Then we sit together in the dining room and have a nice conversation while eating."
    "Depois, sentamo-nos juntos na sala de jantar e temos uma conversa agradável enquanto comemos."

# game/Scenes/Lisa/lisadinner.rpy:76
translate portuguese lisadinnerconversation_ac9094b5:

    # "Afterwards, we go to the kitchen and I help with the dishes."
    "Depois, vamos para a cozinha e eu ajudo a lavar a louça."

# game/Scenes/Lisa/lisadinner.rpy:77
translate portuguese lisadinnerconversation_74aec54b:

    # sp "Thanks for having dinner with me honey. I really enjoyed it."
    sp "Obrigada por jantares comigo, querido. Gostei muito."

# game/Scenes/Lisa/lisadinner.rpy:78
translate portuguese lisadinnerconversation_6ecfecf0:

    # pc "Any time, [mom]."
    pc "Sempre à disposição, [mom]."

# game/Scenes/Lisa/lisadinner.rpy:80
translate portuguese lisadinnerconversation_79c86a4f:

    # sp "Love you, baby."
    sp "Amo-te, querida."

# game/Scenes/Lisa/lisadinner.rpy:81
translate portuguese lisadinnerconversation_ce2ae2bf:

    # pc "Love you too."
    pc "Também te amo."

# game/Scenes/Lisa/lisadinner.rpy:82
translate portuguese lisadinnerconversation_db14aa5a:

    # "We finish up and Lisa goes to her bedroom for the night."
    "Terminamos e a Lisa vai para o quarto para dormir."

