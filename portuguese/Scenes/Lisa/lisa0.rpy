    new "Vê como ela está quando ela estiver na sala à noite durante a semana"

    # game/Scenes/Lisa/lisa0.rpy:20
    old "Check on her"
    new "Vê como ela está"

    # game/Scenes/Lisa/lisa0.rpy:42
    old "I don't think so."
    new "Acho que não."

    # game/Scenes/Lisa/lisa0.rpy:44
    old "A little maybe?"
    new "Talvez um pouco?"

    # game/Scenes/Lisa/lisa0.rpy:60
    old "Go comfort her"
    new "Vai consolá-la"

    # game/Scenes/Lisa/lisa0.rpy:72
