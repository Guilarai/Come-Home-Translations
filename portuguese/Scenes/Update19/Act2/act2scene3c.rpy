# game/Scenes/Update19/Act2/act2scene3c.rpy:29
translate portuguese u19a2s3c_4cc82f21:

    # pc "Hi! Juliana?"
    pc "Olá! Juliana?"

# game/Scenes/Update19/Act2/act2scene3c.rpy:32
translate portuguese u19a2s3c_c5bfcf61:

    # bn "AAH!"
    bn "AAH!"

# game/Scenes/Update19/Act2/act2scene3c.rpy:33
translate portuguese u19a2s3c_77e4a82b:

    # "Startled, she drops her book and her hand shoots out, magic flying from her fingertips towards me."
    "Assustada, ela deixa cair o livro e a sua mão dispara, com magia a voar das pontas dos dedos na minha direção."

# game/Scenes/Update19/Act2/act2scene3c.rpy:36
translate portuguese u19a2s3c_463e8cb9:

    # pc "Shit!"
    pc "Merda!"

# game/Scenes/Update19/Act2/act2scene3c.rpy:37
