translate portuguese u19a2s1c_392b8d63:

    # pc "Dana? What's happening? Who did this to you?"
    pc "Dana? O que se passa? Quem te fez isto?"

# game/Scenes/Update19/Act2/act2scene1c.rpy:30
translate portuguese u19a2s1c_d209c8cd:

    # cw "My betrothed, Terry."
    cw "O meu noivo, o Terry."

# game/Scenes/Update19/Act2/act2scene1c.rpy:31
translate portuguese u19a2s1c_19dbdea6:

    # pc "Ugh, that fucker."
    pc "Ugh, aquele cabrão."

# game/Scenes/Update19/Act2/act2scene1c.rpy:32
translate portuguese u19a2s1c_8ccecee9:

    # cw "Who are you? How did you know my name?"
    cw "Quem é você? Como sabia o meu nome?"

# game/Scenes/Update19/Act2/act2scene1c.rpy:35
translate portuguese u19a2s1c_1911c327:

    # pc "My name is [pcname]... and that's a long story. Where's the key to these things?"
    pc "O meu nome é [pcname]... e isso é uma longa história. Onde está a chave destas coisas?"

# game/Scenes/Update19/Act2/act2scene1c.rpy:36
translate portuguese u19a2s1c_c3f9873f:

    # cw "Terry has it."
    cw "O Terry tem-na."

# game/Scenes/Update19/Act2/act2scene1c.rpy:37
translate portuguese u19a2s1c_b3138b62:

    # pc "Well where is he, so I can knock him out and get it back?"
    pc "Bem, onde é que ele está, para eu o poder nocautear e recuperá-la?"

# game/Scenes/Update19/Act2/act2scene1c.rpy:40
translate portuguese u19a2s1c_51c802e4:

    # cw "You must be a great warrior to think that you can fight Terry the Troll."
    cw "Deves ser um grande guerreiro para pensares que podes lutar contra o Terry, o Troll."

# game/Scenes/Update19/Act2/act2scene1c.rpy:41
translate portuguese u19a2s1c_d473561c:

