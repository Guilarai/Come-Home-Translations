translate portuguese u19a2s1c_bea5e8cb:

    # pc "Hello?"
    pc "Olá?"

# game/Scenes/Update19/Act2/act2scene1c.rpy:17
translate portuguese u19a2s1c_e7263129:

    # "I call out, wondering if whoever is inside would even hear me over their crying."
    "Chamo, perguntando-me se quem quer que esteja lá dentro me ouvirá por entre o choro."

# game/Scenes/Update19/Act2/act2scene1c.rpy:18
translate portuguese u19a2s1c_265a0522:

    # "Then I hear a voice I recognize call back."
    "Então ouço uma voz que reconheço a responder."

# game/Scenes/Update19/Act2/act2scene1c.rpy:19
translate portuguese u19a2s1c_cc59b48e:

    # cw "Hello? Is somebody out there?"
    cw "Olá? Está alguém aí?"

# game/Scenes/Update19/Act2/act2scene1c.rpy:20
translate portuguese u19a2s1c_93e86f9e:

    # pc "Dana?"
    pc "Dana?"

# game/Scenes/Update19/Act2/act2scene1c.rpy:24
translate portuguese u19a2s1c_99c51cff:

    # "I step inside and find the place a mess, covered in filth, a putrid stench in the air. Moldy furs form a bed in the corner and a staircase rises to the second floor."
    "Entro e encontro o lugar uma confusão, coberto de sujidade, com um fedor pútrido no ar. Peles bolorentas formam uma cama num canto e uma escada sobe até ao segundo andar."

# game/Scenes/Update19/Act2/act2scene1c.rpy:25
translate portuguese u19a2s1c_cb391ba1:

    # "Dana is shackled to the wall, completely naked."
    "A Dana está acorrentada à parede, completamente nua."

# game/Scenes/Update19/Act2/act2scene1c.rpy:26
translate portuguese u19a2s1c_2fef227d:

    # cw "Who's there? Please help."
    cw "Quem está aí? Por favor, ajude-me."

