# TODO: Translation updated at 2026-06-02 11:43

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:13
translate portuguese brandip1_db0ed071:

    # fd "Oh gods, no!"
    fd "Oh, meu Deus, não!"

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:15
translate portuguese brandip1_f9756f83:

    # fd "My mom couldn't toast bread and I don't think my dad even knew where the kitchen was."
    fd "A minha mãe não sabia torrar pão e acho que o meu pai nem sabia onde ficava a cozinha."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:16
translate portuguese brandip1_351a9ec7:

    # fd "That's why we ate out for almost every meal."
    fd "É por isso que comíamos fora em quase todas as refeições."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:18
translate portuguese brandip1_9b5ac48c:

    # fd "My parents always had a lot more money than time, so we would order food and either eat at a restaurant or get takeout at home."
    fd "Os meus pais tinham sempre muito mais dinheiro do que tempo, por isso pedíamos comida e ou comíamos num restaurante ou levávamos para casa."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:19
translate portuguese brandip1_5fffdecd:

    # fd "And any big dinner, like Thanksgiving or Christmas, we always had catered."
    fd "E em qualquer jantar importante, como o Dia de Ação de Graças ou o Natal, contratávamos sempre um serviço de catering."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:20
translate portuguese brandip1_272cb526:

    # fd "I don't remember my parents ever cooking a single meal when I was growing up."
    fd "Não me lembro de os meus pais terem cozinhado uma única refeição enquanto eu crescia."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:21
translate portuguese brandip1_8d2952eb:

    # pc "Well what got you into cooking?"
    pc "Bem, o que te levou a interessar-te por cozinhar?"

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:22
translate portuguese brandip1_87b5f7ac:

    # fd "I'd always been kind of interested in food and cooking, and when I got older I discovered Food Network."
    fd "Sempre tive algum interesse por comida e culinária e, quando fiquei mais velho, descobri o Food Network."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:24
translate portuguese brandip1_b593950e:

    # fd "Alton Brown, Rachael Ray, Sunny Anderson, Jamie Oliver - I loved all of those shows."
    fd "Alton Brown, Rachael Ray, Sunny Anderson, Jamie Oliver — adorava todos esses programas."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:25
translate portuguese brandip1_a6bc018d:

    # fd "I'd sit and watch them cook for hours."
    fd "Ficava sentada a vê-los cozinhar durante horas."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:26
translate portuguese brandip1_2b66b9b6:

    # fd "I'd never seen any of that stuff growing up in my house."
    fd "Nunca tinha visto nada disso enquanto crescia em casa."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:27
translate portuguese brandip1_425f47e6:

    # fd "To me, food was like this magical thing that appeared from nothing and was brought to our plates. I had no idea where it came from."
    fd "Para mim, a comida era como uma coisa mágica que aparecia do nada e era servida nos nossos pratos. Não fazia ideia de onde vinha."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:28
translate portuguese brandip1_c803afd9:

    # fd "And then I saw the wizards who were making that magic."
    fd "E depois vi os magos que faziam essa magia."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:29
translate portuguese brandip1_5379ec32:

    # fd "And even better, I could {i}be{/i} one of those wizards!"
    fd "E melhor ainda, eu podia {i}ser{/i} um desses magos!"

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:31
translate portuguese brandip1_ce689ce1:

    # fd "So I started learning how to cook, first for my parents, who were very supportive, and now for myself and my friends."
    fd "Então comecei a aprender a cozinhar, primeiro para os meus pais, que me apoiaram muito, e agora para mim e para os meus amigos."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:32
translate portuguese brandip1_204d6109:

    # pc "Have you ever thought about opening your own restaurant?"
    pc "Já pensaste em abrir o teu próprio restaurante?"

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:34
translate portuguese brandip1_b091d350:

    # fd "Nah, that's not really something that I'm into."
    fd "Não, isso não é bem algo que me interesse."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:36
translate portuguese brandip1_7056ddec:

    # fd "I love cooking for my family and friends, but strangers? No way."
    fd "Adoro cozinhar para a minha família e amigos, mas para estranhos? Nem pensar."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:37
translate portuguese brandip1_8b468e9d:

    # fd "People are really critical about food."
    fd "As pessoas são muito críticas em relação à comida."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:38
translate portuguese brandip1_9af58283:

    # fd "They like things a specific way and if it's not done that way, they think that it's wrong."
    fd "Gostam das coisas de uma forma específica e, se não for feito assim, acham que está errado."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:40
translate portuguese brandip1_8e7b9703:

    # fd "It's like they don't understand that people all have different tastes."
    fd "É como se não compreendessem que todas as pessoas têm gostos diferentes."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:41
translate portuguese brandip1_b6c3a98e:

    # fd "Some Karen would probably complain about a meal that I worked hard on, and I'd end up slapping her."
    fd "Alguma Karen provavelmente queixar-se-ia de uma refeição em que eu me esforcei muito, e eu acabaria por lhe dar uma bofetada."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:42
translate portuguese brandip1_06cbabe4:

    # pc "Isn't that what you do though? Aren't you kind of a food critic?"
    pc "Mas não é isso que fazes? Não és uma espécie de crítica gastronómica?"

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:44
translate portuguese brandip1_3068765f:

    # fd "What? No!"
    fd "O quê? Não!"

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:46
translate portuguese brandip1_a1fa9442:

    # fd "I don't criticize. I only enjoy and uplift."
    fd "Eu não critico. Eu só aprecio e elogio."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:47
translate portuguese brandip1_4544d3b3:

    # fd "If I eat somewhere that I don't enjoy, I just don't put it on my show."
    fd "Se como num sítio de que não gosto, simplesmente não o coloco no meu programa."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:49
translate portuguese brandip1_75b9716a:

    # fd "I only talk about things that I love."
    fd "Só falo de coisas que adoro."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:50
translate portuguese brandip1_52a73082:

    # fd "I've always preferred building people up over tearing them down."
    fd "Sempre preferi encorajar as pessoas em vez de as menosprezar."

# game/Scenes/Brandi/BrandiConversations/brandip1.rpy:51
translate portuguese brandip1_cb3e2843:

    # pc "Sounds like a good policy to me."
    pc "Parece-me uma boa política."

