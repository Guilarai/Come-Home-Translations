translate portuguese brandi2_14197c78:

    # fd "No, not that. Too heavy for a first date. Wow, no I'm not asking him that! Geez, guys!"
    fd "Não, isso não. É demasiado pesado para um primeiro encontro. Uau, não, não vou perguntar-lhe isso! Caramba, pessoal!"

# game/Scenes/Brandi/brandi2.rpy:95
translate portuguese brandi2_7c433d80:

    # fd "Ah, there's a good one."
    fd "Ah, aqui está uma boa."

