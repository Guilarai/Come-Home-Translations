translate portuguese brandi2_dcb21a7c:

    # fd "Just pop the whole thing in there and..."
    fd "É só enfiar tudo na boca e..."

# game/Scenes/Brandi/brandi2.rpy:128
translate portuguese brandi2_b3f6951f:

    # fd "Delicious!"
    fd "Delicioso!"

# game/Scenes/Brandi/brandi2.rpy:129
translate portuguese brandi2_36d64bd9:

    # "Time passes quickly while we eat and before long, we have spent nearly an hour chatting and we are both so full."
    "O tempo passa depressa enquanto comemos e, em pouco tempo, já passámos quase uma hora a conversar e estamos ambos cheios."

