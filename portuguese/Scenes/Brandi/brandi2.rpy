    fd "Olá a todos, o BurgerBuddy está aqui. Ou [pcname], que provavelmente devemos chamá-lo a partir de agora."

# game/Scenes/Brandi/brandi2.rpy:79
translate portuguese brandi2_21079f98:

    # pc "Yes, I'd prefer that."
    pc "Sim, prefiro isso."

# game/Scenes/Brandi/brandi2.rpy:80
translate portuguese brandi2_66c11aab:

