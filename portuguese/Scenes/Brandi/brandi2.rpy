    # fd "Where would you like this relationship to go?"
    fd "Para onde gostarias que esta relação fosse?"

# game/Scenes/Brandi/brandi2.rpy:140
translate portuguese brandi2_c8eaa0d3:

    # fd "Haha! Straight to the point."
    fd "Haha! Direto ao ponto."

# game/Scenes/Brandi/brandi2.rpy:141
translate portuguese brandi2_e9e17cc6:

    # fd "Well, we will see. I like to let things build up a little before we get to that point."
    fd "Bem, vamos ver. Gosto de deixar as coisas amadurecerem um pouco antes de chegarmos a esse ponto."

# game/Scenes/Brandi/brandi2.rpy:142
translate portuguese brandi2_6930b345:

    # fd "But we are definitely heading in that direction."
    fd "Mas estamos definitivamente a caminhar nessa direção."

