    # pc "Well, no. I'm in school for quantum physics actually."
    pc "Bem, não. Na verdade, estou a estudar física quântica."

# game/Scenes/Brandi/brandi2.rpy:109
translate portuguese brandi2_04c1148e:

    # fd "Wow, that's impressive."
    fd "Uau, isso é impressionante."

# game/Scenes/Brandi/brandi2.rpy:110
translate portuguese brandi2_1de87a6b:

    # fd "I dropped out of high school and now I eat food in front of an audience for money."
    fd "Eu desisti do liceu e agora como na frente de um público por dinheiro."

# game/Scenes/Brandi/brandi2.rpy:111
translate portuguese brandi2_037690dc:

    # pc "Hey, whatever pays the bills."
    pc "Ei, o que for preciso para pagar as contas."

