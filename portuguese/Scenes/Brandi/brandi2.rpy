translate portuguese brandi2_350435c4:

    # pc "Okay, sounds good to me."
    pc "Ok, por mim tudo bem."

# game/Scenes/Brandi/brandi2.rpy:118
translate portuguese brandi2_96c0c900:

    # fd "What do you think, [pcname]? Do you like it?"
    fd "O que achas, [pcname]? Gostas?"

# game/Scenes/Brandi/brandi2.rpy:119
translate portuguese brandi2_efb02d33:

    # pc "Yeah it's pretty damn good."
    pc "Sim, está mesmo muito bom."

# game/Scenes/Brandi/brandi2.rpy:120
translate portuguese brandi2_f2d6f866:

    # fd "See? I love this place."
    fd "Vês? Adoro este sítio."

# game/Scenes/Brandi/brandi2.rpy:123
translate portuguese brandi2_add75b21:

    # fd "Now it's my turn."
    fd "Agora é a minha vez."

# game/Scenes/Brandi/brandi2.rpy:124
translate portuguese brandi2_d1a17c3f:

    # fd "I like to start with the balls."
    fd "Gosto de começar pelas bolas."

