    pc "Não tenho irmãos de sangue, mas há a Suzy, acho eu. Ela é a minha [sister]."

# game/Scenes/Brandi/brandi2.rpy:100
translate portuguese brandi2_8266c6d6:

    # pc "What about you?"
    pc "E tu?"

# game/Scenes/Brandi/brandi2.rpy:101
translate portuguese brandi2_35c433bd:

    # fd "Oh yeah, I have two brothers and two sisters. "
    fd "Ah, sim, tenho dois irmãos e duas irmãs. "

