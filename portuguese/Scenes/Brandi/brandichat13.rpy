    voice 'voices/brandichat 13_2.mp3'

# game/Scenes/Brandi/brandichat13.rpy:46
translate portuguese brandichat13_01413bd9:

    # fd "Half the world has them. Your mom has them."
    fd "Metade do mundo tem. A tua mãe tem."

# game/Scenes/Brandi/brandichat13.rpy:47
translate portuguese brandichat13_b27d7d88:

    # fd "That's not the point though."
    fd "Mas não é essa a questão."

# game/Scenes/Brandi/brandichat13.rpy:48
translate portuguese brandichat13_211e3b47:

    # fd "Even if I was a slut. Even if I popped my tits out right here for the views, that has nothing to do with you."
    fd "Mesmo que eu fosse uma vadia. Mesmo que eu mostrasse as mamas aqui mesmo para ganhar visualizações, isso não tem nada a ver contigo."

# game/Scenes/Brandi/brandichat13.rpy:50
translate portuguese brandichat13_d41d8cd9_2:

    # voice 'voices/brandichat 13_3.mp3'
    voice 'voices/brandichat 13_3.mp3'

# game/Scenes/Brandi/brandichat13.rpy:51
translate portuguese brandichat13_38107e93:

    # fd "If you don't like it, leave. But you don't get to decide what I do with my body. Only I do."
    fd "Se não gostas, sai. Mas não és tu que decides o que faço com o meu corpo. Só eu é que decido."

# game/Scenes/Brandi/brandichat13.rpy:52
translate portuguese brandichat13_96e8fa0b:

    # fd "If I want to use my body to make people happy and make some money for myself, then I will."
    fd "Se eu quiser usar o meu corpo para fazer as pessoas felizes e ganhar algum dinheiro para mim, então vou fazê-lo."

# game/Scenes/Brandi/brandichat13.rpy:53
translate portuguese brandichat13_28886f1d:

    # fd "There's nothing wrong with that."
    fd "Não há nada de errado nisso."

# game/Scenes/Brandi/brandichat13.rpy:55
translate portuguese brandichat13_d41d8cd9_3:

    # voice 'voices/brandichat 13_4.mp3'
    voice 'voices/brandichat 13_4.mp3'

# game/Scenes/Brandi/brandichat13.rpy:56
translate portuguese brandichat13_05cbbe5c:

    # fd "Anyway! Die mad. I'm banning you now."
    fd "De qualquer forma! Vai-te lixar. Vou banir-te agora."

# game/Scenes/Brandi/brandichat13.rpy:59
translate portuguese brandichat13_60e04445:

    # fd "Hey guys, I'm sorry for going off like that. Some people just push my buttons sometimes."
    fd "Ei, pessoal, desculpem-me por ter explodido assim. Algumas pessoas simplesmente me irritam às vezes."

# game/Scenes/Brandi/brandichat13.rpy:60
translate portuguese brandichat13_1b80e2dc:

    # fd "Thanks for all the love though. I know not all of you are like that."
    fd "Mas obrigada por todo o carinho. Eu sei que nem todos vocês são assim."

# game/Scenes/Brandi/brandichat13.rpy:61
translate portuguese brandichat13_7c74586d:

    # fd "And, [pcname]! Hey, I didn't see you there at first! Thanks for popping in."
    fd "E, [pcname]! Ei, não te vi ali à primeira vista! Obrigada por apareceres."

# game/Scenes/Brandi/brandichat13.rpy:62
translate portuguese brandichat13_641205bb:

    # fd "I just want to say, support the people that you like, and ignore the ones you don't."
    fd "Só quero dizer: apoiem as pessoas de quem gostam e ignorem aquelas de quem não gostam."

# game/Scenes/Brandi/brandichat13.rpy:63
translate portuguese brandichat13_b51a507a:

    # fd "And if other people are having fun doing something that you don't like, and they're not hurting anybody, just shut up about it and mind your own business."
    fd "E se outras pessoas se estão a divertir a fazer algo de que não gostam, e não estão a magoar ninguém, calem-se e metam-se na vossa vida."

# game/Scenes/Brandi/brandichat13.rpy:64
translate portuguese brandichat13_8bc6e094:

    # fd "Alright, that's it. I'll step down from my soapbox now. It's about time for bed anyway."
    fd "Pronto, já chega. Vou descer do meu pedestal agora. De qualquer forma, já está na hora de ir para a cama."

# game/Scenes/Brandi/brandichat13.rpy:65
translate portuguese brandichat13_ef10a2a5:

    # fd "I hope you all have a great night. I love ya!"
    fd "Espero que tenham todos uma ótima noite. Adoro-vos!"

