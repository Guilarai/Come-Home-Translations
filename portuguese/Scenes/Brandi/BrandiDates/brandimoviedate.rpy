# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:28
translate portuguese brandimovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Chegamos ao cinema e sentamo-nos nas filas de trás."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:30
translate portuguese brandimovietheaterstartdate_5de6c24e:

    # fd "Oh man, I love the movie theater. I don't even care what we're watching."
    fd "Caramba, adoro o cinema. Nem me interessa o que vamos ver."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:31
translate portuguese brandimovietheaterstartdate_4e350aa8:

    # fd "Just the smell of the popcorn and the glow of the screen and the slightly uncomfortable seats is so nostalgic."
    fd "Só o cheiro das pipocas, o brilho do ecrã e os assentos ligeiramente desconfortáveis já são tão nostálgicos."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:32
translate portuguese brandimovietheaterstartdate_72767dd3:

    # fd "Plus it's just fun to cuddle up in the dark with somebody you like."
    fd "Além disso, é simplesmente divertido aconchegar-se no escuro com alguém de quem gostas."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:33
translate portuguese brandimovietheaterstartdate_6cc4cd44:

    # "There's a little time to chat before the movie starts."
    "Há um tempinho para conversar antes do filme começar."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:37
translate portuguese brandimovietheaterstartdate_e073d5a5:

    # "Then the lights dim and we go silent."
    "Depois, as luzes apagam-se e ficamos em silêncio."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:43
translate portuguese brandimovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Ela estica-se e segura a minha mão por cima do apoio de braço."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:44
translate portuguese brandimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Os trailers demoram cerca de quinze minutos, depois o filme começa mesmo."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:47
translate portuguese brandimovietheaterstartdate_222a7d5f:

    # "She leans against me and watches the whole movie, never really taking her eyes off the screen."
    "Ela encosta-se a mim e vê o filme todo, sem tirar os olhos do ecrã."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:48
translate portuguese brandimovietheaterstartdate_1f099f0a:

    # "She seems to be really enjoying it."
    "Ela parece estar a gostar mesmo muito."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:51
translate portuguese brandimovietheaterstartdate_b059763a:

    # "When the movie ends, she sits up and looks at me, smiling."
    "Quando o filme acaba, ela endireita-se e olha para mim, sorrindo."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:52
translate portuguese brandimovietheaterstartdate_3637234b:

    # fd "Wow! That was really good, huh?"
    fd "Uau! Foi mesmo bom, não foi?"

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:53
translate portuguese brandimovietheaterstartdate_56a5dea5:

    # "We hang out and chat throughout the credits."
    "Ficamos juntos e conversamos durante os créditos."

# game/Scenes/Brandi/BrandiDates/brandimoviedate.rpy:58
translate portuguese brandimovietheaterstartdate_21c5f05c:

    # "When the credits end, we go out to my car and I drive her home."
    "Quando os créditos acabam, vamos para o meu carro e eu levo-a a casa."

