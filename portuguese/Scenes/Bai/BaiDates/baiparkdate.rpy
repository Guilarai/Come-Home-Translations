# game/Scenes/Bai/BaiDates/baiparkdate.rpy:33
translate portuguese baiparkstartdate_4053ffc0:

    # "Bai and I walk around the trails, chit-chatting for a while."
    "O Bai e eu caminhamos pelas trilhas, conversando um pouco."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:44
translate portuguese baiparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "Por fim, chegamos ao banco a meio do caminho."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:52
translate portuguese baiparkstartdate_1b78059e:

    # "We sit next to each other for a bit, chatting."
    "Sentamo-nos lado a lado por um bocado, a conversar."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:54
translate portuguese baiparkstartdate_8ab96ed5:

    # "I'm still a little uncomfortable with this, and I'm pretty sure he is too."
    "Ainda me sinto um pouco desconfortável com isto, e tenho quase a certeza de que ele também."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:55
translate portuguese baiparkstartdate_96695859:

    # "Things are a little awkward."
    "O ambiente está um pouco estranho."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:58
translate portuguese baiparkstartdate_fbccb841:

    # "I put my arm around him and we sit in a comfortable silence together, just enjoying being close."
    "Passo o braço à volta dele e ficamos sentados num silêncio confortável, apenas a apreciar a proximidade."

# game/Scenes/Bai/BaiDates/baiparkdate.rpy:59
translate portuguese baiparkstartdate_cf2869ab:

    # "Then, after a while, it's time to head back."
    "Depois de algum tempo, está na hora de voltarmos."

