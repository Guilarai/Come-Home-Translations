# game/Scenes/Suzy/suzy5.rpy:16
translate portuguese suzy5_3c671076:

    # "I sit down in the driver's seat and start the car, not yet decided on how I am going to spend the rest of my night."
    "Sento-me no banco do condutor e ligo o carro, ainda sem decidir como vou passar o resto da noite."

# game/Scenes/Suzy/suzy5.rpy:17
translate portuguese suzy5_ed1fbe56:

    # "Then my phone starts buzzing."
    "Então, o meu telemóvel começa a vibrar."

# game/Scenes/Suzy/suzy5.rpy:21
translate portuguese suzy5_702d39f2:

    # "I'm not sure who it is, but it is a local number."
    "Não sei bem quem é, mas é um número local."

# game/Scenes/Suzy/suzy5.rpy:25
translate portuguese suzy5_bea5e8cb:

    # pc "Hello?"
    pc "Estás aí?"

# game/Scenes/Suzy/suzy5.rpy:26
translate portuguese suzy5_b1036369:

    # ss "Hey [bro], it's me, Suzy."
    ss "Olá [bro], sou eu, a Suzy."

# game/Scenes/Suzy/suzy5.rpy:27
translate portuguese suzy5_813bfe8e:

    # pc "Oh hey, [sis]."
    pc "Ah, olá, [sis]."

# game/Scenes/Suzy/suzy5.rpy:28
translate portuguese suzy5_6cfa6df6:

    # ss "Could you help me with something please?"
    ss "Podes ajudar-me com uma coisa, por favor?"

# game/Scenes/Suzy/suzy5.rpy:29
translate portuguese suzy5_77c062fa:

    # ss "I'm sitting in the supermarket parking lot and my car won't start."
    ss "Estou no parque de estacionamento do supermercado e o meu carro não pega."

# game/Scenes/Suzy/suzy5.rpy:30
translate portuguese suzy5_0c01ea35:

    # ss "I don't know what to do, can you just come help me?"
    ss "Não sei o que fazer, podes vir ajudar-me?"

# game/Scenes/Suzy/suzy5.rpy:31
translate portuguese suzy5_3c4ee749:

    # pc "Sure, I'm close. I'll be there in a minute."
    pc "Claro, estou perto. Chego aí num minuto."

# game/Scenes/Suzy/suzy5.rpy:33
translate portuguese suzy5_d41d8cd9:

    # voice 'voices/suzy_thanks2.mp3'
    voice 'voices/suzy_thanks2.mp3'

# game/Scenes/Suzy/suzy5.rpy:34
translate portuguese suzy5_4ce6f4f0:

    # ss "Thanks."
    ss "Obrigada."

# game/Scenes/Suzy/suzy5.rpy:36
translate portuguese suzy5_cc61d61a:

    # "I hang up and drive over to the supermarket."
    "Desligo e dirijo até ao supermercado."

# game/Scenes/Suzy/suzy5.rpy:39
translate portuguese suzy5_4e12cf19:

    # "I spot Suzy's car pretty quick and park right next to it."
    "Encontro o carro da Suzy rapidamente e estaciono mesmo ao lado dele."

# game/Scenes/Suzy/suzy5.rpy:42
translate portuguese suzy5_a60d89b8:

    # "Suzy runs up to me immediately after I step out of the car."
    "A Suzy corre na minha direção assim que saio do carro."

# game/Scenes/Suzy/suzy5.rpy:43
translate portuguese suzy5_96fd56fd:

    # ss "I don't know what happened!"
    ss "Não sei o que aconteceu!"

# game/Scenes/Suzy/suzy5.rpy:44
translate portuguese suzy5_4ce21989:

    # ss "I just came out of the store after doing some shopping and it won't start!"
    ss "Acabei de sair da loja depois de fazer algumas compras e o carro não pega!"

# game/Scenes/Suzy/suzy5.rpy:45
translate portuguese suzy5_a56c45eb:

    # ss "I can't afford to take it to a mechanic right now. I barely make anything at Java Lava and Mom is broke."
    ss "Não tenho dinheiro para levá-lo a um mecânico agora. Mal ganho alguma coisa no Java Lava e a minha mãe está sem dinheiro."

# game/Scenes/Suzy/suzy5.rpy:48
translate portuguese suzy5_a9852df6:

    # ss "I hope so. I don't know what I'll do if I don't have my car."
    ss "Espero que sim. Não sei o que farei se não tiver o meu carro."

# game/Scenes/Suzy/suzy5.rpy:50
translate portuguese suzy5_1845952a:

    # ss "Will you look at it please?"
    ss "Podes dar uma olhadela, por favor?"

# game/Scenes/Suzy/suzy5.rpy:53
translate portuguese suzy5_da8c2e7f:

    # ss "Yes, please. Fix it, [bro]."
    ss "Sim, por favor. Arranja-o, [bro]."

# game/Scenes/Suzy/suzy5.rpy:56
translate portuguese suzy5_f393635e:

    # ss "I don't!"
    ss "Não sei!"

# game/Scenes/Suzy/suzy5.rpy:58
translate portuguese suzy5_31115693:

    # ss "Can you just see if you can fix it please?"
    ss "Podes apenas ver se consegues arranjá-lo, por favor?"

# game/Scenes/Suzy/suzy5.rpy:59
translate portuguese suzy5_c3f59e51:

    # pc "Yeah, let's see what's up with it."
    pc "Sim, vamos ver o que se passa."

# game/Scenes/Suzy/suzy5.rpy:60
translate portuguese suzy5_4103549c:

    # ss "Thank you, [bro]. I'm freaking out."
    ss "Obrigada, [bro]. Estou a passar-me."

# game/Scenes/Suzy/suzy5.rpy:63
translate portuguese suzy5_5aa7230b:

    # "I pop the hood and look inside for any problems."
    "Abro o capô e procuro por algum problema lá dentro."

# game/Scenes/Suzy/suzy5.rpy:64
translate portuguese suzy5_c9096016:

    # "I'm not really a mechanic or anything and only know a little about cars, but after jiggling a few wires around, I find her battery cable had slid off one of the pegs."
    "Não sou propriamente mecânico nem nada e só sei um pouco sobre carros, mas depois de mexer em alguns fios, descubro que o cabo da bateria dela tinha escorregado de um dos pinos."

# game/Scenes/Suzy/suzy5.rpy:65
translate portuguese suzy5_1ffc433c:

    # "I carefully slide it back down where it is supposed to go and then use one of my keys to tighten the screw so it wouldn't fall off again."
    "Deslizo-o cuidadosamente de volta para onde deve ficar e, em seguida, uso uma das minhas chaves para apertar o parafuso, para que não caia novamente."

# game/Scenes/Suzy/suzy5.rpy:66
translate portuguese suzy5_00654239:

    # pc "Go try to start it again."
    pc "Vai tentar ligá-lo outra vez."

# game/Scenes/Suzy/suzy5.rpy:67
translate portuguese suzy5_5c646e65:

    # ss "Okay."
    ss "Pronto."

# game/Scenes/Suzy/suzy5.rpy:70
translate portuguese suzy5_11b9b96f:

    # "She gets into the driver's side and turns the key and her car starts right up again."
    "Ela entra no lado do condutor, gira a chave e o carro arranca logo à primeira."

# game/Scenes/Suzy/suzy5.rpy:74
translate portuguese suzy5_bcd70141:

    # ss "You did it!"
    ss "Conseguiste!"

# game/Scenes/Suzy/suzy5.rpy:75
translate portuguese suzy5_8b9f1772:

    # ss "Oh my God, thank you so much."
    ss "Meu Deus, muito obrigada."

# game/Scenes/Suzy/suzy5.rpy:76
translate portuguese suzy5_e161b9ae:

    # ss "Best [brother] ever!"
    ss "O melhor [brother] de sempre!"

# game/Scenes/Suzy/suzy5.rpy:79
translate portuguese suzy5_86ca1882:

    # "She rushes up and wraps her arms around me, pulling me into a tight hug."
    "Ela corre na minha direção, abraça-me e aperta-me com força contra si."

# game/Scenes/Suzy/suzy5.rpy:82
translate portuguese suzy5_7eb555a1:

    # "Then she pulls away, but only slightly, staring up at me with a strange look in her eyes."
    "Então ela afasta-se, mas só um pouco, olhando para mim com um olhar estranho nos olhos."

# game/Scenes/Suzy/suzy5.rpy:85
translate portuguese suzy5_842415b0:

    # "Without warning, she leans in and put her lips on mine."
    "Sem aviso, ela inclina-se e encosta os lábios aos meus."

# game/Scenes/Suzy/suzy5.rpy:86
translate portuguese suzy5_8b1faa90:

    # "It is almost a chaste kiss, but not quite. Her hand is on my chest and there is a passion behind it."
    "É quase um beijo casto, mas não totalmente. A mão dela está no meu peito e há uma paixão por trás disso."

# game/Scenes/Suzy/suzy5.rpy:87
translate portuguese suzy5_8e0321b2:

    # "This isn't just a friendly peck. I feel an urge behind it, like she wants more."
    "Isto não é apenas um beijinho de amizade. Sinto um desejo por trás disso, como se ela quisesse mais."

# game/Scenes/Suzy/suzy5.rpy:91
translate portuguese suzy5_34527ef1:

    # ss "Uh, sorry."
    ss "Uh, desculpa."

# game/Scenes/Suzy/suzy5.rpy:92
translate portuguese suzy5_b669988f:

    # ss "I shouldn't have done that, huh?"
    ss "Não devia ter feito isso, pois não?"

# game/Scenes/Suzy/suzy5.rpy:96
translate portuguese suzy5_6cb7ce9a:

    # ss "Really?"
    ss "A sério?"

# game/Scenes/Suzy/suzy5.rpy:97
translate portuguese suzy5_8577d189:

    # pc "No, it was nice."
    pc "Não, foi bom."

# game/Scenes/Suzy/suzy5.rpy:98
translate portuguese suzy5_721098ed:

    # ss "I thought so too."
    ss "Também achei."

# game/Scenes/Suzy/suzy5.rpy:100
translate portuguese suzy5_fe4100b4:

    # ss "Anyway, I should go."
    ss "De qualquer forma, tenho de ir."

# game/Scenes/Suzy/suzy5.rpy:102
translate portuguese suzy5_d41d8cd9_1:

    # voice 'voices/suzy_thanks2.mp3'
    voice 'voices/suzy_thanks2.mp3'

# game/Scenes/Suzy/suzy5.rpy:103
translate portuguese suzy5_2ec2b18b:

    # ss "Thanks again, [bro]."
    ss "Mais uma vez obrigada, [bro]."

# game/Scenes/Suzy/suzy5.rpy:104
translate portuguese suzy5_c46a0b54:

    # pc "Any time."
    pc "Sempre à disposição."

# game/Scenes/Suzy/suzy5.rpy:106
translate portuguese suzy5_bd7daf33:

    # ss "Right. Sorry."
    ss "Certo. Desculpa."

# game/Scenes/Suzy/suzy5.rpy:107
translate portuguese suzy5_55a0a639:

    # ss "I should go."
    ss "Tenho de ir."

# game/Scenes/Suzy/suzy5.rpy:108
translate portuguese suzy5_45b1beab:

    # ss "Thanks for fixing my car."
    ss "Obrigada por arranjares o meu carro."

# game/Scenes/Suzy/suzy5.rpy:112
translate portuguese suzy5_f6f30a26:

    # "With that, she gets into her car and I get into mine and we both drive away."
    "Dito isto, ela entra no carro dela e eu no meu, e ambos partimos."

# game/Scenes/Suzy/suzy5.rpy:113
translate portuguese suzy5_49ed461b:

    # "What was with that kiss?"
    "O que foi aquele beijo?"

# game/Scenes/Suzy/suzy5.rpy:115
translate portuguese suzy5_78e50149:

    # "She definitely seems like she is interested in me. That kiss felt amazing."
    "Ela parece definitivamente estar interessada em mim. Aquele beijo foi incrível."

# game/Scenes/Suzy/suzy5.rpy:116
translate portuguese suzy5_2c26c150:

    # "Somehow, her being my [sister] makes it even hotter."
    "De alguma forma, o facto de ela ser a minha [sister] torna tudo ainda mais excitante."

# game/Scenes/Suzy/suzy5.rpy:117
translate portuguese suzy5_8ea91748:

    # "I wonder if she would go further?"
    "Será que ela iria mais longe?"

# game/Scenes/Suzy/suzy5.rpy:119
translate portuguese suzy5_47e765a1:

    # "She seems like she is actually interested in me romantically."
    "Ela parece estar realmente interessada em mim romanticamente."

# game/Scenes/Suzy/suzy5.rpy:120
translate portuguese suzy5_1ec25cb0:

    # "But, she is my [sister], so we can't do anything like that."
    "Mas, ela é a minha [sister], por isso não podemos fazer nada disso."

# game/Scenes/Suzy/suzy5.rpy:121
translate portuguese suzy5_32823086:

    # "I need to put a stop to this."
    "Tenho de pôr um ponto final nisto."

