# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:45
translate portuguese suzytammys1_2c076b6b:

    # ss "You know those serial killer shows, when the neighbors and co-workers are all like \"He always seemed so nice and normal?\""
