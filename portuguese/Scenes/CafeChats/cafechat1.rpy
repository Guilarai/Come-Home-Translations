# game/Scenes/CafeChats/cafechat1.rpy:6
translate portuguese cafechat1_c5150887:

    # "I hang around the café for a while, looking for anybody who might be up for a chat."
    "Fico por um bocado no café, à procura de alguém que possa estar disposto a conversar."

# game/Scenes/CafeChats/cafechat1.rpy:8
translate portuguese cafechat1_eb82cee3:

    # "A woman comes in alone and orders a coffee, then sits by herself in the corner."
    "Entra uma mulher sozinha, pede um café e senta-se sozinha num canto."

# game/Scenes/CafeChats/cafechat1.rpy:9
translate portuguese cafechat1_b6ba1c27:

    # "She's looking at her phone, but then looks up and around the room."
    "Ela está a olhar para o telemóvel, mas depois levanta os olhos e olha à sua volta."

# game/Scenes/CafeChats/cafechat1.rpy:10
translate portuguese cafechat1_52268ea8:

    # "Our eyes meet momentarily and she smiles at me."
    "Os nossos olhares cruzam-se por um instante e ela sorri para mim."

# game/Scenes/CafeChats/cafechat1.rpy:11
translate portuguese cafechat1_a276a53c:

    # "I take that as a sign to go over and talk to her."
    "Interpreto isso como um sinal para me aproximar e falar com ela."

# game/Scenes/CafeChats/cafechat1.rpy:13
translate portuguese cafechat1_7261b066:

    # "Although she smiles at me, when I start walking over towards her, she immediately seems anxious."
    "Embora ela me sorria, quando começo a caminhar na sua direção, ela parece imediatamente ansiosa."

# game/Scenes/CafeChats/cafechat1.rpy:14
translate portuguese cafechat1_d7a053d7:

    # pc "Hey, I just thought I'd come over and say hi. Can I get you a coffee or anything?"
    pc "Olá, pensei apenas em vir cá dizer olá. Posso oferecer-te um café ou alguma coisa?"

# game/Scenes/CafeChats/cafechat1.rpy:15
translate portuguese cafechat1_f288acdf:

    # "Woman" "Oh no, I'm sorry, I didn't mean to send you any signals."
    "Woman" "Oh não, desculpa, não era minha intenção dar-te sinais."

# game/Scenes/CafeChats/cafechat1.rpy:16
translate portuguese cafechat1_706c714c:

    # pc "Oh it's okay, I just thought maybe we could chat for a bit."
    pc "Oh, não faz mal, só pensei que talvez pudéssemos conversar um pouco."

# game/Scenes/CafeChats/cafechat1.rpy:17
translate portuguese cafechat1_18e49522:

    # "Woman" "No sorry, I'm not interested."
    "Woman" "Não, desculpa, não estou interessada."

# game/Scenes/CafeChats/cafechat1.rpy:18
translate portuguese cafechat1_2974e88a:

    # pc "Not even for just a few minutes."
    pc "Nem mesmo por uns minutos."

# game/Scenes/CafeChats/cafechat1.rpy:19
translate portuguese cafechat1_448eb64d:

    # "Woman" "I'm actually here with somebody."
    "Woman" "Na verdade, estou aqui com alguém."

# game/Scenes/CafeChats/cafechat1.rpy:20
translate portuguese cafechat1_1f34339e:

    # "Other Woman" "Hey babe, is this guy bothering you?"
    "Other Woman" "Ei, querida, este tipo está a incomodar-te?"

# game/Scenes/CafeChats/cafechat1.rpy:25
translate portuguese cafechat1_57c300a7:

    # "Another woman comes up to her and they kiss before sitting in the seat next to each other."
    "Outra mulher aproxima-se dela e elas beijam-se antes de se sentarem lado a lado."

# game/Scenes/CafeChats/cafechat1.rpy:26
translate portuguese cafechat1_fb2f4ae8:

    # pc "No, sorry to bother you. You ladies have a good day."
    pc "Não, desculpem o incómodo. Tenham um bom dia, meninas."

# game/Scenes/CafeChats/cafechat1.rpy:27
translate portuguese cafechat1_c4d76043:

    # "I walk away and leave them to each other."
    "Afastar-me e deixo-as a sós."

# game/Scenes/CafeChats/cafechat1.rpy:29
translate portuguese cafechat1_84475cd1:

    # "Struck out again, but at least this one was nicer than the last."
    "Outra rejeição, mas pelo menos esta foi mais simpática do que a anterior."

# game/Scenes/CafeChats/cafechat1.rpy:35
translate portuguese cafechat1_9c8103c3:

    # "I leave the café and head to class."
    "Saio do café e vou para a aula."

# game/Scenes/CafeChats/cafechat1.rpy:38
translate portuguese cafechat1_f5c89a33:

    # "I leave the café and head back out to my car."
    "Saio do café e volto para o meu carro."

