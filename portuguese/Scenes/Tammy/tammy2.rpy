# game/Scenes/Tammy/tammy2.rpy:12
translate portuguese tammy2_58882cf4:

    # "I spend some time working out with Tammy."
    "Passo algum tempo a treinar com a Tammy."

# game/Scenes/Tammy/tammy2.rpy:13
translate portuguese tammy2_f8739613:

    # "First I spot her."
    "Primeiro, ajudo-a."

# game/Scenes/Tammy/tammy2.rpy:16
translate portuguese tammy2_b03ba21e:

    # "Then she spots me."
    "Depois, ela ajuda-me."

# game/Scenes/Tammy/tammy2.rpy:20
translate portuguese tammy2_f59c8527:

    # "Then we start chatting a bit between reps."
    "Depois, começamos a conversar um pouco entre as séries."

# game/Scenes/Tammy/tammy2.rpy:21
translate portuguese tammy2_e027ab69:

    # tm "You ever think about trying MMA?"
    tm "Já pensaste em experimentar MMA?"

# game/Scenes/Tammy/tammy2.rpy:22
translate portuguese tammy2_08f599b9:

    # pc "MMA? Like fighting?"
    pc "MMA? Tipo lutar?"

# game/Scenes/Tammy/tammy2.rpy:23
translate portuguese tammy2_7ed92c4d:

    # tm "Yeah, like fighting. I train every weekend in the morning."
    tm "Sim, tipo lutar. Treino todos os fins de semana de manhã."

# game/Scenes/Tammy/tammy2.rpy:24
translate portuguese tammy2_690f9781:

    # tm "You could come join me sometime."
    tm "Podes vir comigo um dia destes."

# game/Scenes/Tammy/tammy2.rpy:25
translate portuguese tammy2_50211aa2:

    # pc "You're just looking for an excuse to beat me up."
    pc "Estás só à procura de uma desculpa para me dar uma sova."

# game/Scenes/Tammy/tammy2.rpy:27
translate portuguese tammy2_d669bb2f:

    # "She punches me hard in the arm."
    "Ela dá-me um soco forte no braço."

# game/Scenes/Tammy/tammy2.rpy:28
translate portuguese tammy2_68bd08bc:

    # tm "Ha! I don't need an excuse for that."
    tm "Ha! Não preciso de desculpa para isso."

# game/Scenes/Tammy/tammy2.rpy:29
translate portuguese tammy2_dedf8f6f:

    # pc "Ow! Damn."
    pc "Ai! Bolas."

# game/Scenes/Tammy/tammy2.rpy:31
translate portuguese tammy2_eb4630f0:

    # tm "See that's why you need to come train in MMA. You got a nice body, but you're too soft."
    tm "Vês, é por isso que precisas de vir treinar MMA. Tens um corpo bonito, mas és demasiado mole."

# game/Scenes/Tammy/tammy2.rpy:32
translate portuguese tammy2_eb998a13:

    # pc "You think I have a nice body?"
    pc "Achas que tenho um corpo bonito?"

# game/Scenes/Tammy/tammy2.rpy:33
translate portuguese tammy2_9ac6fb46:

    # tm "Well, yeah."
    tm "Bem, sim."

# game/Scenes/Tammy/tammy2.rpy:34
translate portuguese tammy2_cce51848:

    # pc "Alright, I'll come wrestle with you some time."
    pc "Está bem, vou lá lutar contigo um dia destes."

# game/Scenes/Tammy/tammy2.rpy:35
translate portuguese tammy2_bdefbf8e:

    # tm "Good. I'm looking forward to it. Mornings and Afternoons on the weekends, I'll be here."
    tm "Ótimo. Estou ansioso por isso. De manhã e à tarde nos fins de semana, estarei aqui."

# game/Scenes/Tammy/tammy2.rpy:39
translate portuguese tammy2_7cd89556:

    # "We finish our workout and say goodbye to each other."
    "Terminamos o treino e despedimo-nos."

# game/Scenes/Tammy/tammy2.rpy:41
translate portuguese tammy2_d33670c7:

    # "I have to admit, rolling around on the mat with her has a certain appeal."
    "Tenho de admitir que rebolar no tapete com ela tem um certo encanto."

# game/Scenes/Tammy/tammy2.rpy:42
translate portuguese tammy2_bf0d0df4:

    # "For now though, I leave the gym and go out to my car."
    "Por agora, porém, saio do ginásio e vou para o meu carro."

translate portuguese strings:

    # game/Scenes/Tammy/tammy2.rpy:2
    old "Workout with Tammy on the weekend again."
    new "Treina com a Tammy no fim de semana outra vez."

    # game/Scenes/Tammy/tammy2.rpy:3
    old "Then she will ask if you want to train MMA with her."
    new "Então ela vai perguntar se queres treinar MMA com ela."

