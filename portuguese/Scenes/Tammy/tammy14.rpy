# game/Scenes/Tammy/tammy14.rpy:168
translate portuguese tammy14_494fc97b:

    # pc "Yeah, it's amazing."
    pc "Sim, é incrível."

# game/Scenes/Tammy/tammy14.rpy:171
translate portuguese tammy14_e8b49386:

    # "It doesn't take long, lying like that, for Tammy to fall asleep."
    "Não demora muito, deitada assim, para a Tammy adormecer."

# game/Scenes/Tammy/tammy14.rpy:172
translate portuguese tammy14_815d66b7:

    # "And as soon as she's asleep, she immediately begins snoring loudly."
    "E assim que adormece, começa imediatamente a ressonar alto."

# game/Scenes/Tammy/tammy14.rpy:175
translate portuguese tammy14_055d080f:

    # ss "Dang, she's loud, huh?"
    ss "Caramba, ela ressona alto, não é?"

# game/Scenes/Tammy/tammy14.rpy:176
translate portuguese tammy14_593f6724:

    # "I nod, trying to stay quiet."
    "Aceno com a cabeça, tentando ficar em silêncio."

# game/Scenes/Tammy/tammy14.rpy:177
translate portuguese tammy14_536bf33b:

    # ss "When she's really tired like this, she passes out hard. You could shake her and she's not going to wake up."
    ss "Quando está mesmo cansada assim, adormece profundamente. Podias abaná-la que ela não acordaria."

# game/Scenes/Tammy/tammy14.rpy:178
translate portuguese tammy14_20e84dbf:

    # pc "She deserves a good night sleep."
    pc "Ela merece uma boa noite de sono."

# game/Scenes/Tammy/tammy14.rpy:179
translate portuguese tammy14_e51a7dc2:

    # ss "Yeah. Thanks for being a good boyfriend tonight, [bro]."
    ss "Sim. Obrigada por seres um bom namorado esta noite, [bro]."

# game/Scenes/Tammy/tammy14.rpy:180
translate portuguese tammy14_a248948f:

    # pc "Of course."
    pc "Claro."

# game/Scenes/Tammy/tammy14.rpy:181
translate portuguese tammy14_53a16996:

    # ss "Love you."
    ss "Amo-te."

# game/Scenes/Tammy/tammy14.rpy:182
translate portuguese tammy14_3213fe29:

    # pc "Love you too, [sis]."
    pc "Também te amo, [sis]."

# game/Scenes/Tammy/tammy14.rpy:185
translate portuguese tammy14_87d1006f:

    # "Suzy lies back down again and falls asleep."
    "A Suzy deita-se novamente e adormece."

# game/Scenes/Tammy/tammy14.rpy:188
translate portuguese tammy14_da5d00b9:

    # "Shortly after, despite Tammy's loud snoring, I fall asleep too."
    "Pouco depois, apesar do ronco alto da Tammy, adormeço também."

# game/Scenes/Tammy/tammy14.rpy:189
translate portuguese tammy14_2af8e2e3:

    # "I have great dreams all night, but somehow they don't even compare to my waking life."
    "Tenho sonhos fantásticos a noite toda, mas, de alguma forma, nem se comparam à minha vida acordado."

# game/Scenes/Tammy/tammy14.rpy:192
translate portuguese tammy14_d8050fd9:

    # "I must have slept hard as well, because I don't wake up through the entire night."
    "Devo ter dormido profundamente também, porque não acordo durante toda a noite."

# game/Scenes/Tammy/tammy14.rpy:195
translate portuguese tammy14_6e97274e:

    # "And when I look around in the morning, they are both gone."
    "E quando olho à minha volta de manhã, as duas já se foram."

# game/Scenes/Tammy/tammy14.rpy:201
translate portuguese tammy14_d1a14932:

    # "I get up and go to the bathroom, then walk downstairs."
    "Levanto-me e vou à casa de banho, depois desço as escadas."

# game/Scenes/Tammy/tammy14.rpy:204
translate portuguese tammy14_7279822b:

    # "In the dining room, Suzy greets me with a kiss."
    "Na sala de jantar, a Suzy cumprimenta-me com um beijo."

# game/Scenes/Tammy/tammy14.rpy:205
translate portuguese tammy14_ce46d3ed:

    # ss "There's some breakfast in the kitchen if you want any. Mom made way too much before she left."
    ss "Há pequeno-almoço na cozinha, se quiseres. A mãe fez demasiado antes de sair."

# game/Scenes/Tammy/tammy14.rpy:206
translate portuguese tammy14_03e500eb:

    # pc "Where's Tammy?"
    pc "Onde está a Tammy?"

# game/Scenes/Tammy/tammy14.rpy:207
translate portuguese tammy14_6a080cce:

    # ss "She had to leave early for work. I doubt we'll be seeing her for breakfast very often."
    ss "Ela teve de sair cedo para o trabalho. Duvido que a vejamos muitas vezes ao pequeno-almoço."

# game/Scenes/Tammy/tammy14.rpy:208
translate portuguese tammy14_34f75a54:

    # pc "Oh, okay."
    pc "Ah, está bem."

# game/Scenes/Tammy/tammy14.rpy:211
translate portuguese tammy14_eef7b49f:

    # ss "Did you want to eat breakfast with me... or maybe mess around some?"
    ss "Querias tomar o pequeno-almoço comigo... ou talvez brincar um pouco?"

# game/Scenes/Tammy/tammy14.rpy:215
translate portuguese tammy14_6ae50746:

    # ss "Oh, alright then."
    ss "Ah, está bem então."

# game/Scenes/Tammy/tammy14.rpy:218
translate portuguese tammy14_b9e9893b:

    # ss "I was hoping you would say that."
    ss "Estava à espera que dissesses isso."

# game/Scenes/Tammy/tammy14.rpy:222
translate portuguese tammy14_ca91b2cf:

    # ss "Oh, okay. See you later then, [bro]."
    ss "Ah, está bem. Até logo então, [bro]."

translate portuguese strings:

    # game/Scenes/Tammy/tammy14.rpy:2
    old "After you have gone out on a few dates with Tammy and Suzy together, including going to the ice-cream parlor,"
    new "Depois de teres saído em alguns encontros com a Tammy e a Suzy juntas, incluindo ir à gelataria,"

    # game/Scenes/Tammy/tammy14.rpy:3
    old "and you have talked to them about Tammy moving out of her parents house, this will happen automatically at home at night."
    new "e de teres falado com elas sobre a Tammy sair da casa dos pais, isto acontecerá automaticamente em casa à noite."

