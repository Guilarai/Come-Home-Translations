# game/Scenes/Tammy/TammyMMA/tammymma.rpy:17
translate portuguese tammymmanormal_55eb3e45:

    # tm "All right! I'm glad you came. Let's get to business."
    tm "Muito bem! Ainda bem que vieste. Vamos ao que interessa."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:18
translate portuguese tammymmanormal_095f6c6f:

    # tm "We're going to start with some stand-up. Get you started on the base punching and kicking technique."
    tm "Vamos começar com alguns exercícios em pé. Vou ensinar-te as técnicas básicas de socos e pontapés."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:19
translate portuguese tammymmanormal_bccaba74:

    # pc "You're going to punch me, aren't you?"
    pc "Vais dar-me um soco, não vais?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:21
translate portuguese tammymmanormal_e526c3d8:

    # tm "Oh definitely."
    tm "Oh, com certeza."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:23
translate portuguese tammymmanormal_98c55581:

    # "I get up into the ring with Tammy and she demonstrates punching."
    "Subo ao ringue com a Tammy e ela demonstra os socos."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:24
translate portuguese tammymmanormal_65f9479a:

    # "I try to block, but I just don't have the motions down yet."
    "Tento bloquear, mas ainda não domino os movimentos."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:26
translate portuguese tammymmanormal_295f5a57:

    # "And kicking."
    "E pontapés."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:27
translate portuguese tammymmanormal_70863c7f:

    # "It hurts, but I can tell she's not going full-strength."
    "Dói, mas percebo que ela não está a dar com toda a força."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:29
translate portuguese tammymmanormal_8aa64221:

    # "Then she gives me a chance to try to hit her."
    "Depois, ela dá-me a oportunidade de tentar acertar-lhe."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:30
translate portuguese tammymmanormal_90068145:

    # "But she blocks every punch I throw."
    "Mas ela bloqueia todos os socos que eu dou."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:32
translate portuguese tammymmanormal_dd5027d0:

    # tm "Focus on technique. Don't worry about actually hitting me, just make sure that your movements are correct."
    tm "Concentra-te na técnica. Não te preocupes em acertar-me, certifica-te apenas de que os teus movimentos estão corretos."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:35
translate portuguese tammymmanormal_bfe308ae:

    # "Tammy and I spar in the ring for a while."
    "A Tammy e eu treinamos no ringue por um tempo."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:39
translate portuguese tammymmanormal_0bc42d9a:

    # tm "You did good for a first session."
    tm "Fizeste bem para uma primeira sessão."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:42
translate portuguese tammymmanormal_a242518d:

    # tm "Good job. Keep training with me and you'll be a fighting machine in no time."
    tm "Bom trabalho. Continua a treinar comigo e vais tornar-te uma máquina de combate num instante."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:45
translate portuguese tammymmanormal_cc85c375:

    # "Now I need to hurry and get to school."
    "Agora preciso de me apressar e ir para a escola."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:48
translate portuguese tammymmanormal_7844d429:

    # tm "Want to hit the showers with me?"
    tm "Queres tomar banho comigo?"

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:52
translate portuguese tammymmanormal_f7e04aed:

    # "I feel sore and tired, but it was fun and I did learn a lot."
    "Sinto-me dorida e cansada, mas foi divertido e aprendi muito."

# game/Scenes/Tammy/TammyMMA/tammymma.rpy:53
translate portuguese tammymmanormal_37ff6d3e:

    # "We say our goodbyes and go our separate ways."
    "Despedimo-nos e seguimos caminhos separados."

