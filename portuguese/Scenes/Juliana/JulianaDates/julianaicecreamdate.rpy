    pc "«Tens de ver o espetáculo, porque aí vais perceber que a vertigem vai aumentar, porque é tão perigoso que vais ter de assinar um termo de responsabilidade?»"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:33
translate portuguese julianaicecreamstartdate_3a694dff:

    # bn "Uh... what?"
    bn "Uh... o quê?"

# game/Scenes/Juliana/JulianaDates/julianaicecreamdate.rpy:34
