# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:28
translate portuguese julianaparkstartdate_1271ced5:

    # "Juliana and I walk around the trails, chit-chatting for a while."
    "A Juliana e eu passeamos pelos trilhos, a conversar um pouco."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:36
translate portuguese julianaparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "Por fim, chegamos ao banco a meio do trilho."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:42
translate portuguese julianaparkstartdate_d2cc15d6:

    # "We sit next to each other on the bench for a bit, listening to the morning birds sing."
    "Sentamo-nos lado a lado no banco por um bocado, a ouvir os pássaros a cantar pela manhã."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:44
translate portuguese julianaparkstartdate_7104b1ef:

    # bn "This is really nice."
    bn "Isto é mesmo agradável."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:45
translate portuguese julianaparkstartdate_c417e350:

    # pc "Yeah."
    pc "Sim."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:47
translate portuguese julianaparkstartdate_7bdeb8b7:

    # bn "I really like you, [pcname]. I look forward to any time I get to spend with you."
    bn "Gosto mesmo de ti, [pcname]. Anseio por cada momento que posso passar contigo."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:48
translate portuguese julianaparkstartdate_d7904a68:

    # pc "I like you too, Juliana."
    pc "Também gosto de ti, Juliana."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:49
translate portuguese julianaparkstartdate_cde9a4ac:

    # bn "Do you maybe want to kiss some more? Like we did on my bed?"
    bn "Talvez queiras beijar-me mais um pouco? Como fizemos na minha cama?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:51
translate portuguese julianaparkstartdate_f49a462d:

    # "I lean in and kiss her and she pulls me in deeper, hungry for more."
    "Inclino-me e beijo-a, e ela puxa-me para si com mais intensidade, sedenta por mais."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:52
translate portuguese julianaparkstartdate_78efd588:

    # "She moans into my mouth, barely able to control her hands as they touch my chest and arms."
    "Ela geme na minha boca, mal conseguindo controlar as mãos enquanto elas tocam no meu peito e nos meus braços."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:54
translate portuguese julianaparkstartdate_79d7237e:

    # "I touch her too, keeping my hands away from her more sensitive areas for now. I'm not sure how far she is ready to go and I don't want to pressure her."
    "Eu também a toco, mantendo as mãos afastadas das suas zonas mais sensíveis por agora. Não tenho a certeza até onde ela está disposta a ir e não quero pressioná-la."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:55
translate portuguese julianaparkstartdate_2cb8d2e6:

    # "We kiss like that for a while before finally pulling away."
    "Beijamo-nos assim por um tempo antes de finalmente nos afastarmos."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:57
translate portuguese julianaparkstartdate_5f798c5f:

    # bn "Wow."
    bn "Uau."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:58
translate portuguese julianaparkstartdate_6a1c0d46:

    # bn "I've never felt like that before. It's incredible."
    bn "Nunca me senti assim antes. É incrível."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:59
translate portuguese julianaparkstartdate_d95bd6ed:

    # bn "Does it feel like that for you too?"
    bn "Também te faz sentir assim?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:60
translate portuguese julianaparkstartdate_0c391334:

    # pc "Like what?"
    pc "Como assim?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:61
translate portuguese julianaparkstartdate_cbf3c8a2:

    # bn "Just like fire, spreading all through you."
    bn "Como fogo, a espalhar-se por todo o teu corpo."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:62
translate portuguese julianaparkstartdate_f85c6ac5:

    # bn "Like all my nerves coming alive and dancing in my skin."
    bn "Como se todos os meus nervos ganhassem vida e dançassem na minha pele."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:63
translate portuguese julianaparkstartdate_1ae6abfe:

    # pc "Yeah, it feels like that for me too."
    pc "Sim, também me faz sentir assim."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:64
translate portuguese julianaparkstartdate_e40b3a25:

    # bn "Incredible."
    bn "Incrível."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:65
translate portuguese julianaparkstartdate_7fd26fb6:

    # bn "What time is it?"
    bn "Que horas são?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:66
translate portuguese julianaparkstartdate_d038199e:

    # pc "Just about time for us to head back to school."
    pc "Está quase na hora de voltarmos para a escola."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:67
translate portuguese julianaparkstartdate_bd5f19a8:

    # bn "Yeah, that's what I thought. Let's enjoy this for one more minute though."
    bn "Sim, foi o que pensei. Mas vamos aproveitar isto por mais um minuto."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:68
translate portuguese julianaparkstartdate_08551511:

    # pc "You got it."
    pc "Claro."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:69
translate portuguese julianaparkstartdate_10106d85:

    # "We sit there for another minute, just enjoying the quiet, enjoying the warmth of each other's bodies."
    "Ficamos sentados ali por mais um minuto, apenas a apreciar o silêncio, a apreciar o calor dos nossos corpos."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:70
translate portuguese julianaparkstartdate_da3cd183:

    # "Then it's time to get back to school."
    "Depois, é hora de voltar para a escola."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:77
translate portuguese julianaparkstartdate_ebc1db78:

    # bn "I had a really good time, [pcname]. I hope we can do that again soon."
    bn "Diverti-me imenso, [pcname]. Espero que possamos repetir isto em breve."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:78
translate portuguese julianaparkstartdate_97cc796e:

    # bn "Any time you'd rather go to the park instead of study, just let me know."
    bn "Sempre que preferires ir ao parque em vez de estudar, é só dizeres-me."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:79
translate portuguese julianaparkstartdate_f350b961:

    # bn "There's plenty of other time to study throughout the day."
    bn "Há muito tempo para estudar ao longo do dia."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:80
translate portuguese julianaparkstartdate_f8733479:

    # pc "I will, Juliana. Looking forward to our next date."
    pc "Vou dizer, Juliana. Estou ansioso pelo nosso próximo encontro."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:81
translate portuguese julianaparkstartdate_d8a5a64b:

    # bn "Is that what that was?"
    bn "Foi isso que foi?"

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:82
translate portuguese julianaparkstartdate_c4b7f80e:

    # pc "Sure, I'd call it a date."
    pc "Claro, eu chamaria-lhe um encontro."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:83
translate portuguese julianaparkstartdate_b2c60616:

    # bn "Wow, I just had my first date and I didn't even realize it."
    bn "Uau, acabei de ter o meu primeiro encontro e nem sequer me apercebi."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:84
translate portuguese julianaparkstartdate_3d335832:

    # pc "Not a big deal. There will be plenty more."
    pc "Não faz mal. Haverá muitos mais."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:85
translate portuguese julianaparkstartdate_7c86fcff:

    # bn "Yeah, I guess so. Still, it was incredible."
    bn "Sim, acho que sim. Mesmo assim, foi incrível."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:87
translate portuguese julianaparkstartdate_bed43be6:

    # bn "Well, we better head to class."
    bn "Bem, é melhor irmos para a aula."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:91
translate portuguese julianaparkstartdate_b0662d5f:

    # "I step up to her and pull her in for a kiss before we go."
    "Aproximo-me dela e puxo-a para um beijo antes de irmos."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:92
translate portuguese julianaparkstartdate_d196e134:

    # "Then after a few moments, we pull away once again."
    "Depois de alguns momentos, afastamo-nos mais uma vez."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:94
translate portuguese julianaparkstartdate_92b8b462:

    # bn "I'll see you later, [pcname]."
    bn "Até logo, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:97
translate portuguese julianaparkstartdate_24be2fc8:

    # "I step up to her and pull her in for a hug before we go."
    "Aproximo-me dela e puxo-a para um abraço antes de irmos."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:98
translate portuguese julianaparkstartdate_d196e134_1:

    # "Then after a few moments, we pull away once again."
    "Depois de alguns momentos, afastamo-nos mais uma vez."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:100
translate portuguese julianaparkstartdate_92b8b462_1:

    # bn "I'll see you later, [pcname]."
    bn "Até logo, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:103
translate portuguese julianaparkstartdate_449d1425:

    # pc "Bye Juliana."
    pc "Adeus, Juliana."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:104
translate portuguese julianaparkstartdate_a8de1634:

    # bn "See you later, [pcname]."
    bn "Até logo, [pcname]."

# game/Scenes/Juliana/JulianaDates/julianaparkdate.rpy:105
translate portuguese julianaparkstartdate_3768ae38:

    # "With that, we both go to class."
    "Com isso, ambos vamos para a aula."

