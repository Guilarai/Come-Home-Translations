# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:32
translate portuguese julianamovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Chegamos ao cinema e sentamo-nos nas filas de trás."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:33
translate portuguese julianamovietheaterstartdate_cd1f1d61:

    # bn "What kind of movie are we watching?"
    bn "Que tipo de filme vamos ver?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:37
translate portuguese julianamovietheaterstartdate_9753ecc6:

    # bn "That sounds very nice."
    bn "Isso parece-me muito bom."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:38
translate portuguese julianamovietheaterstartdate_08edcd3e:

    # bn "I like romantic movies."
    bn "Gosto de filmes românticos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:43
translate portuguese julianamovietheaterstartdate_22be6204:

    # bn "Oh really?"
    bn "A sério?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:44
translate portuguese julianamovietheaterstartdate_a7aa68a8:

    # bn "I'm not really interested dumb action movies, but okay."
    bn "Não me interessam muito filmes de ação sem sentido, mas tudo bem."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:50
translate portuguese julianamovietheaterstartdate_a36785e7:

    # bn "Oh really? I don't really like scary movies at all."
    bn "A sério? Não gosto mesmo nada de filmes de terror."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:51
translate portuguese julianamovietheaterstartdate_5b88690f:

    # bn "Unless they're about hauntings, or they have some sort of romance in them."
    bn "A menos que sejam sobre assombrações, ou que tenham algum tipo de romance."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:52
translate portuguese julianamovietheaterstartdate_ffedd8a3:

    # bn "Most horror movies are really dumb."
    bn "A maioria dos filmes de terror é mesmo parva."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:58
translate portuguese julianamovietheaterstartdate_352ba7de:

    # bn "Oh okay."
    bn "Ah, está bem."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:59
translate portuguese julianamovietheaterstartdate_9c6a96f5:

    # bn "I try to enjoy comedies, but I don't always get the jokes."
    bn "Tento gostar de comédias, mas nem sempre percebo as piadas."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:60
translate portuguese julianamovietheaterstartdate_74eb3e05:

    # bn "There's a lot of times that I just don't understand what is supposed to be funny and what's not."
    bn "Há muitas vezes em que simplesmente não percebo o que é suposto ser engraçado e o que não é."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:61
translate portuguese julianamovietheaterstartdate_cf50250b:

    # bn "But I'll try my best to laugh at the parts I'm supposed to."
    bn "Mas vou dar o meu melhor para rir nas partes em que é suposto rir."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:63
translate portuguese julianamovietheaterstartdate_2fcc7df5:

    # "There's a little time before the movie starts for us to chat some."
    "Há um tempinho antes do filme começar para conversarmos um pouco."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:67
translate portuguese julianamovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Finalmente o filme começa e ficamos em silêncio."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:70
translate portuguese julianamovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Ela estende a mão e segura a minha em cima do apoio de braço."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:74
translate portuguese julianamovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Os trailers duram cerca de quinze minutos, depois o filme começa de verdade."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:78
translate portuguese julianamovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Durante o filme, ela encosta-se no meu ombro, envolvendo-se completamente na história."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:80
translate portuguese julianamovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Depois, durante uma cena particularmente romântica, ela levanta a cabeça e encosta os lábios aos meus."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:81
translate portuguese julianamovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "Não prestamos muita atenção ao resto do filme, concentrando-nos, em vez disso, em beijar-nos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:84
translate portuguese julianamovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Durante o filme, ela encosta-se no meu ombro, envolvendo-se completamente na história."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:86
translate portuguese julianamovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Ela parece estar a gostar do filme."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:89
translate portuguese julianamovietheaterstartdate_dcbaecf4:

    # "Juliana watches the movie, but she looks annoyed the entire time."
    "A Juliana vê o filme, mas parece irritada o tempo todo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:92
translate portuguese julianamovietheaterstartdate_40670365:

    # "Eventually, she turns towards me."
    "Por fim, ela vira-se para mim."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:93
translate portuguese julianamovietheaterstartdate_b867ff88:

    # bn "This movie is really bad, isn't it? It might be the worst movie I've ever seen."
    bn "Este filme é mesmo mau, não é? Pode ser o pior filme que já vi."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:94
translate portuguese julianamovietheaterstartdate_e3d0d8a6:

    # "She does not speak quietly, and some people in front of us turn and look at us."
    "Ela não fala baixinho, e algumas pessoas à nossa frente viram-se e olham para nós."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:95
translate portuguese julianamovietheaterstartdate_d58327fc:

    # pc "Do you want to leave?"
    pc "Queres ir embora?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:97
translate portuguese julianamovietheaterstartdate_25b2e9a4:

    # bn "No, can we just kiss or something instead? I don't care about watching this."
    bn "Não, podemos apenas beijar-nos ou algo do género? Não me interessa ver isto."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:98
translate portuguese julianamovietheaterstartdate_4f1735dd:

    # pc "Sounds good to me."
    pc "Por mim, tudo bem."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:100
translate portuguese julianamovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Inclino-me e beijo-a, e não vemos muito mais do filme, concentrando-nos um no outro."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:103
translate portuguese julianamovietheaterstartdate_c1b8c885:

    # "The horror movie was not about hauntings and had no romance in it."
    "O filme de terror não era sobre assombrações e não tinha romance."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:104
translate portuguese julianamovietheaterstartdate_003c9dc3:

    # "I'm pretty sure Juliana hated it."
    "Tenho quase a certeza de que a Juliana detestou."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:105
translate portuguese julianamovietheaterstartdate_27d6edde:

    # "At one point, I even tried holding her hand, but she was not interested."
    "A certa altura, até tentei pegar-lhe na mão, mas ela não estava interessada."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:106
translate portuguese julianamovietheaterstartdate_d58327fc_1:

    # pc "Do you want to leave?"
    pc "Queres ir embora?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:107
translate portuguese julianamovietheaterstartdate_4aa1d16b:

    # bn "We're already too far in. I have to know which of these dumb girls is going to live."
    bn "Já estamos a ver há demasiado tempo. Tenho de saber qual destas miúdas idiotas é que vai sobreviver."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:108
translate portuguese julianamovietheaterstartdate_880b4aa8:

    # pc "Okay..."
    pc "Está bem..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:111
translate portuguese julianamovietheaterstartdate_92b7555a:

    # "At first, I'm not sure that Juliana is going to like the movie at all."
    "No início, não tenho a certeza se a Juliana vai gostar do filme."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:112
translate portuguese julianamovietheaterstartdate_c421db42:

    # "She looks frustrated through the beginning."
    "Ela parece frustrada durante o início."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:113
translate portuguese julianamovietheaterstartdate_4e4b3a2b:

    # "But then..."
    "Mas depois..."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:115
translate portuguese julianamovietheaterstartdate_bd97c290:

    # "During one of the dumb jokes, she bursts into a fit of laughter that seems to go on forever."
    "Durante uma das piadas idiotas, ela entra num ataque de riso que parece não ter fim."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:116
translate portuguese julianamovietheaterstartdate_fa75bbc3:

    # pc "Are you okay?"
    pc "Estás bem?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:117
translate portuguese julianamovietheaterstartdate_5b62109c:

    # bn "Yes. I'm sorry. It's so funny though."
    bn "Sim. Desculpa. Mas é tão engraçado."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:118
translate portuguese julianamovietheaterstartdate_6ecb5d88:

    # bn "It's funny because he farted in a place where it was awkward to fart."
    bn "É engraçado porque ele se peidou num sítio onde era estranho peidar-se."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:119
translate portuguese julianamovietheaterstartdate_b59d1ff2:

    # bn "And he couldn't stop farting!"
    bn "E ele não conseguia parar de se peidar!"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:120
translate portuguese julianamovietheaterstartdate_9ef4273c:

    # "Once she starts laughing, she barely stops throughout the rest of the movie."
    "Assim que começa a rir, mal pára durante o resto do filme."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:124
translate portuguese julianamovietheaterstartdate_e42d81a7:

    # bn "I really liked that. I love when they go through some hardships, but stay together in the end."
    bn "Gostei mesmo muito disso. Adoro quando passam por algumas dificuldades, mas ficam juntos no final."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:125
translate portuguese julianamovietheaterstartdate_fe15de53:

    # bn "Thank you for bringing me. I enjoyed all of it."
    bn "Obrigada por me trazeres. Gostei de tudo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:129
translate portuguese julianamovietheaterstartdate_71eb6066:

    # bn "Well, thanks for bringing me, but maybe not an action movie next time?"
    bn "Bem, obrigado por me levares, mas talvez não um filme de ação da próxima vez?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:130
translate portuguese julianamovietheaterstartdate_6f6931a9:

    # bn "Even the noise of it was giving me a headache."
    bn "Até o barulho estava a dar-me dor de cabeça."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:134
translate portuguese julianamovietheaterstartdate_5bf0a9a9:

    # bn "That was the dumbest thing I've ever seen in my life."
    bn "Foi a coisa mais idiota que já vi na minha vida."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:135
translate portuguese julianamovietheaterstartdate_2f39e364:

    # pc "It was pretty bad."
    pc "Foi bastante mau."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:136
translate portuguese julianamovietheaterstartdate_02a07558:

    # bn "I hated it."
    bn "Odiei."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:137
translate portuguese julianamovietheaterstartdate_09c476ba:

    # bn "No more horror movies. They're all trash."
    bn "Chega de filmes de terror. São todos lixo."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:138
translate portuguese julianamovietheaterstartdate_459e0f19:

    # pc "Okay. No more horror movies."
    pc "Está bem. Chega de filmes de terror."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:141
translate portuguese julianamovietheaterstartdate_850f6df3:

    # bn "That was so funny."
    bn "Isso foi tão engraçado."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:142
translate portuguese julianamovietheaterstartdate_4083c4d8:

    # bn "I'm sorry if I laughed too much."
    bn "Desculpa se ri demais."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:143
translate portuguese julianamovietheaterstartdate_cd4369b1:

    # pc "No, it was fun to see you cut loose like that."
    pc "Não, foi divertido ver-te a soltar-te assim."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:144
translate portuguese julianamovietheaterstartdate_f50c4948:

    # bn "I guess I don't laugh very often, huh?"
    bn "Acho que não rio com muita frequência, não é?"

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:145
translate portuguese julianamovietheaterstartdate_b459f5c7:

    # bn "But when I do... wow, you have to look out."
    bn "Mas quando rio... uau, é melhor teres cuidado."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:146
translate portuguese julianamovietheaterstartdate_985a02fd:

    # "We hang out after the movie and chat during the credits."
    "Ficamos juntos depois do filme e conversamos durante os créditos."

# game/Scenes/Juliana/JulianaDates/julianamoviedate.rpy:150
translate portuguese julianamovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Quando os créditos terminam, saímos juntos e dirigimo-nos para o meu carro."

