translate portuguese adrian15_a29880ae:

    # ath "Do you still main Kirby? I'd love to kick that little pink ball's ass sometime."
    ath "Ainda jogas principalmente com o Kirby? Adoraria dar uma coça naquela bolinha rosa um dia destes."

# game/Scenes/Adrian/adrian15.rpy:212
translate portuguese adrian15_c75ca3d4:

    # gg "You wish."
    gg "Quem te dera."

# game/Scenes/Adrian/adrian15.rpy:213
translate portuguese adrian15_9882e4ae:

    # ath "We might have time to fit in a quick game, if we hurry. It won't take me long to wipe the floor with you."
    ath "Talvez tenhamos tempo para uma partida rápida, se nos apressarmos. Não vou demorar muito a dar-te uma coça."

# game/Scenes/Adrian/adrian15.rpy:214
translate portuguese adrian15_36bb3cc8:

    # gg "Let's go then, bitch!"
    gg "Vamos lá então, cabra!"

# game/Scenes/Adrian/adrian15.rpy:217
translate portuguese adrian15_b7c027eb:

    # "Just then, a police car parks in front of the house and a man in a suit steps out, looking grim and official."
    "Nesse momento, um carro da polícia estaciona em frente à casa e um homem de fato sai, com um ar severo e oficial."

# game/Scenes/Adrian/adrian15.rpy:218
translate portuguese adrian15_b3e6504f:

    # ath "Rain check, I guess. Time to go."
    ath "Fica para outra altura, acho eu. Está na hora de ir."

# game/Scenes/Adrian/adrian15.rpy:221
translate portuguese adrian15_d5f4dd84:

    # ath "I love you, cuz. I'll see you again soon."
    ath "Adoro-te, primo. Vemo-nos em breve."

# game/Scenes/Adrian/adrian15.rpy:222
translate portuguese adrian15_b13e0d25:

    # gg "I love you too."
    gg "Também te adoro."

# game/Scenes/Adrian/adrian15.rpy:223
translate portuguese adrian15_96dc14b2:

    # gg "I hate this so much. I don't want to let you go."
    gg "Odeio tanto isto. Não quero deixar-te ir."

# game/Scenes/Adrian/adrian15.rpy:224
translate portuguese adrian15_1edb5510:

    # ath "I know. We'll be okay though."
    ath "Eu sei. Mas vamos ficar bem."

# game/Scenes/Adrian/adrian15.rpy:225
translate portuguese adrian15_e2fe510e:

    # ath "And when I see you again, we'll hang out for days, okay?"
    ath "E quando te voltar a ver, vamos sair juntos durante dias, está bem?"

# game/Scenes/Adrian/adrian15.rpy:226
translate portuguese adrian15_c5cc5eaf:

    # gg "Okay, but if there's anything I can do to help, please call me."
    gg "Está bem, mas se houver alguma coisa que eu possa fazer para ajudar, por favor, liga-me."

# game/Scenes/Adrian/adrian15.rpy:227
translate portuguese adrian15_20fcca99:

    # ath "I will."
    ath "Vou ligar."

# game/Scenes/Adrian/adrian15.rpy:230
translate portuguese adrian15_170b7c68:

    # ath "And [pcname], it was nice to meet you."
    ath "E [pcname], foi um prazer conhecer-te."

# game/Scenes/Adrian/adrian15.rpy:231
translate portuguese adrian15_61906ded:

    # pc "Nice to meet you too, Athena."
    pc "Prazer em conhecer-te também, Athena."

# game/Scenes/Adrian/adrian15.rpy:235
translate portuguese adrian15_84825cda:

    # "Suddenly, she pulls my hand, yanking me closer, then whispers in my ear."
    "De repente, ela puxa-me pela mão, atraindo-me para mais perto, e depois sussurra-me ao ouvido."

# game/Scenes/Adrian/adrian15.rpy:236
translate portuguese adrian15_46517656:

    # ath "Be good to her. If you hurt my cousin, I will find you."
    ath "Sê bom para ela. Se magoares a minha prima, eu vou encontrar-te."

# game/Scenes/Adrian/adrian15.rpy:237
translate portuguese adrian15_17a1cb32:

    # pc "Uh, I will."
    pc "Uh, vou sim."

# game/Scenes/Adrian/adrian15.rpy:240
translate portuguese adrian15_05763882:

    # ath "Bye, Adrian! Love you!"
    ath "Adeus, Adrian! Adoro-te!"

# game/Scenes/Adrian/adrian15.rpy:241
translate portuguese adrian15_11b6245f:

    # gg "Bye! Love you too!"
    gg "Adeus! Também te adoro!"

# game/Scenes/Adrian/adrian15.rpy:242
translate portuguese adrian15_fd99ecee:

    # ath "Tell your mom I love her too!"
    ath "Diz à tua mãe que também a adoro!"

# game/Scenes/Adrian/adrian15.rpy:243
translate portuguese adrian15_b909935e:

    # gg "I will!"
    gg "Vou dizer!"

# game/Scenes/Adrian/adrian15.rpy:244
translate portuguese adrian15_124dcc1b:

    # ath "I'll kick your pink Kirby ass real soon!"
    ath "Vou dar-te um pontapé no teu rabo rosa de Kirby muito em breve!"

# game/Scenes/Adrian/adrian15.rpy:248
translate portuguese adrian15_4829e0da:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns towards me, tears in her eyes."
    "Assim que a Athena entra no carro e este começa a afastar-se, a Adrian vira-se para mim, com lágrimas nos olhos."

# game/Scenes/Adrian/adrian15.rpy:249
translate portuguese adrian15_5928d159:

    # gg "Ugh, this fucking sucks."
    gg "Ugh, isto é uma merda."

# game/Scenes/Adrian/adrian15.rpy:250
translate portuguese adrian15_72615de3:

    # gg "I'm sorry, [pcname]. I don't much feel like playing games anymore."
    gg "Desculpa, [pcname]. Já não me apetece muito jogar jogos."

# game/Scenes/Adrian/adrian15.rpy:251
translate portuguese adrian15_fd83325a:

    # gg "I'll see you later, okay?"
    gg "Vemo-nos mais tarde, está bem?"

# game/Scenes/Adrian/adrian15.rpy:252
translate portuguese adrian15_e576c8b5:

    # pc "Are you going to be all right."
    pc "Vais ficar bem?"

# game/Scenes/Adrian/adrian15.rpy:253
translate portuguese adrian15_0da71ea1:

    # gg "Yeah. I'll have to be."
    gg "Sim. Vou ter de ficar."

# game/Scenes/Adrian/adrian15.rpy:254
translate portuguese adrian15_4004410a:

    # gg "But I need some time alone now."
    gg "Mas agora preciso de algum tempo sozinha."

# game/Scenes/Adrian/adrian15.rpy:255
translate portuguese adrian15_b21f0baf:

    # pc "No problem. Let me know if I can help. See you later, Adrian."
    pc "Sem problema. Diz-me se eu puder ajudar. Até logo, Adrian."

# game/Scenes/Adrian/adrian15.rpy:256
translate portuguese adrian15_9d092ee2:

    # gg "Thanks, [pcname]. See ya."
    gg "Obrigada, [pcname]. Até logo."

# game/Scenes/Adrian/adrian15.rpy:259
translate portuguese adrian15_25d8780e:

    # "I leave Adrian's house, hoping that she'll be okay."
    "Saio da casa da Adrian, na esperança de que ela fique bem."

# game/Scenes/Adrian/adrian15.rpy:267
translate portuguese adrian15_d9f27044:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns and collapses into my arms, crying against my shoulder."
    "Assim que a Athena entra no carro e este começa a afastar-se, a Adrian vira-se e desaba nos meus braços, a chorar encostada ao meu ombro."

# game/Scenes/Adrian/adrian15.rpy:268
translate portuguese adrian15_0e12d7d2:

    # gg "This fucking sucks!!!"
    gg "Isto é uma merda!!!"

# game/Scenes/Adrian/adrian15.rpy:269
translate portuguese adrian15_182f9ad8:

    # "I rub her back and hold her and let her cry it out."
    "Acaricio-lhe as costas, abraço-a e deixo-a chorar à vontade."

# game/Scenes/Adrian/adrian15.rpy:272
translate portuguese adrian15_8bf9515c:

    # "A few minutes later, she sniffs up her tears and looks at me."
    "Alguns minutos depois, ela enxuga as lágrimas e olha para mim."

# game/Scenes/Adrian/adrian15.rpy:273
translate portuguese adrian15_3d955406:

    # gg "Okay, feeling slightly better."
    gg "Pronto, já me sinto um pouco melhor."

# game/Scenes/Adrian/adrian15.rpy:274
translate portuguese adrian15_58a70a56:

    # gg "I want to go for a ride. Do you want to come with me?"
    gg "Quero dar uma volta. Queres vir comigo?"

# game/Scenes/Adrian/adrian15.rpy:275
translate portuguese adrian15_2b3b24ff:

    # "I think I probably should stay with her, with how upset she is."
    "Acho que provavelmente devia ficar com ela, do jeito que está perturbada."

# game/Scenes/Adrian/adrian15.rpy:276
translate portuguese adrian15_2d17893f:

    # pc "Sure, let's do it, if you're okay to drive?"
    pc "Claro, vamos lá, se estiveres bem para conduzir?"

# game/Scenes/Adrian/adrian15.rpy:277
translate portuguese adrian15_28404c62:

    # gg "Yeah, I'm okay."
    gg "Sim, estou bem."

# game/Scenes/Adrian/adrian15.rpy:280
translate portuguese adrian15_58afc396:

    # gg "Here, I found her old helmet in the storage under the seat. You should probably wear it."
    gg "Toma, encontrei o capacete antigo dela no compartimento debaixo do assento. É melhor usares-o."

# game/Scenes/Adrian/adrian15.rpy:281
translate portuguese adrian15_4fb22de7:

    # pc "Dear lord, this thing is huge."
    pc "Meu Deus, esta coisa é enorme."

# game/Scenes/Adrian/adrian15.rpy:282
translate portuguese adrian15_2409eb5c:

    # gg "That's what she... nevermind, let's just go."
    gg "Foi isso que ela... esquece, vamos lá."

# game/Scenes/Adrian/adrian15.rpy:283
translate portuguese adrian15_9b4e9f4c:

    # pc "You know how to ride this thing?"
    pc "Sabes conduzir isto?"

# game/Scenes/Adrian/adrian15.rpy:284
translate portuguese adrian15_12315e04:

    # gg "Yeah, Athena taught me when I visited her last time. We rode all over the place on it."
    gg "Sim, a Athena ensinou-me quando a visitei da última vez. Andámos por todo o lado nisto."

# game/Scenes/Adrian/adrian15.rpy:285
translate portuguese adrian15_c4bccc9f:

    # gg "I'm the only person she'd ever let drive it."
    gg "Sou a única pessoa a quem ela alguma vez deixou conduzir isto."

# game/Scenes/Adrian/adrian15.rpy:289
translate portuguese adrian15_65c8468c:

    # "I wrap my arms around her and hold on as she pulls out into the street."
    "Envolvo-a com os braços e agarro-me a ela enquanto ela entra na rua."

# game/Scenes/Adrian/adrian15.rpy:290
translate portuguese adrian15_a4cc4d56:

    # pc "Where are we going?"
    pc "Para onde vamos?"

# game/Scenes/Adrian/adrian15.rpy:291
translate portuguese adrian15_33da7917:

    # gg "I just feel like riding for a while. Clear my head, you know."
    gg "Apenas me apetece dar uma volta. Limpar a cabeça, sabes."

# game/Scenes/Adrian/adrian15.rpy:292
translate portuguese adrian15_61f77a4c:

    # pc "Sure."
    pc "Claro."

# game/Scenes/Adrian/adrian15.rpy:294
translate portuguese adrian15_df03bfba:

    # "It feels like we're riding forever. We leave town and take a rarely used highway out towards the lake."
    "Parece que estamos a andar há uma eternidade. Saímos da cidade e apanhamos uma autoestrada pouco usada em direção ao lago."

# game/Scenes/Adrian/adrian15.rpy:295
translate portuguese adrian15_ba48df36:

    # "After a while, I'm not even sure where we are anymore. Hopefully Adrian knows. I guess I have GPS on the phone if we get lost."
    "Passado algum tempo, já nem sei bem onde estamos. Espero que a Adrian saiba. Acho que tenho GPS no telemóvel, caso nos percamos."

# game/Scenes/Adrian/adrian15.rpy:296
translate portuguese adrian15_0bac7b03:

    # "But I don't say anything. I just hold on and let Adrian clear her mind of everything."
    "Mas não digo nada. Limito-me a agarrar-me e a deixar a Adrian esvaziar a mente de tudo."

# game/Scenes/Adrian/adrian15.rpy:297
translate portuguese adrian15_76cd1d73:

    # "She seems calm now, like this is exactly what she needed to get through this."
    "Ela parece calma agora, como se isto fosse exatamente o que precisava para ultrapassar isto."

# game/Scenes/Adrian/adrian15.rpy:298
translate portuguese adrian15_f0b56a2e:

    # "Then, after what must have been at least an hour, she pulls off the highway and drives a little ways up towards the cliffside near the lake."
    "Depois, após o que deve ter sido pelo menos uma hora, ela sai da autoestrada e conduz um pouco mais para cima, em direção à encosta perto do lago."

# game/Scenes/Adrian/adrian15.rpy:301
translate portuguese adrian15_135327af:

    # "We sit and I hold her close, trying to provide whatever comfort I can."
    "Sentamo-nos e eu abraço-a com força, tentando dar-lhe todo o conforto que posso."

# game/Scenes/Adrian/adrian15.rpy:302
translate portuguese adrian15_fa24fdf7:

    # gg "I'm sorry I'm being such a bummer. This was supposed to be a fun day."
    gg "Desculpa por estar a ser tão chata. Era suposto este ser um dia divertido."

# game/Scenes/Adrian/adrian15.rpy:303
translate portuguese adrian15_cfd80ee8:

    # pc "It's okay, Adrian. I'm here for you. Whatever you need."
    pc "Não faz mal, Adrian. Estou aqui para ti. O que precisares."

# game/Scenes/Adrian/adrian15.rpy:304
translate portuguese adrian15_64ee3ae6:

    # gg "Thanks, [pcname]. I just need a friend really."
    gg "Obrigada, [pcname]. Na verdade, só preciso de uma amiga."

# game/Scenes/Adrian/adrian15.rpy:306
translate portuguese adrian15_d41d8cd9:

    # voice 'voices/adrian_whenitransitioned.mp3'
    voice 'voices/adrian_whenitransitioned.mp3'

# game/Scenes/Adrian/adrian15.rpy:307
translate portuguese adrian15_ec81d936:

    # gg "When I transitioned, besides my mom, Athena was the only person who was there for me."
    gg "Quando fiz a transição, além da minha mãe, a Athena foi a única pessoa que esteve ao meu lado."

# game/Scenes/Adrian/adrian15.rpy:309
translate portuguese adrian15_d41d8cd9_1:

    # voice 'voices/adrian_nohesitation.mp3'
    voice 'voices/adrian_nohesitation.mp3'

# game/Scenes/Adrian/adrian15.rpy:310
translate portuguese adrian15_b76e91f4:

    # gg "No hesitation, no questions, just a ton of support and love."
    gg "Sem hesitações, sem perguntas, apenas imenso apoio e amor."

# game/Scenes/Adrian/adrian15.rpy:312
translate portuguese adrian15_d41d8cd9_2:

    # voice 'voices/adrian_shewastheonly.mp3'
    voice 'voices/adrian_shewastheonly.mp3'

# game/Scenes/Adrian/adrian15.rpy:313
translate portuguese adrian15_5be20e3b:

    # gg "She was the only friend I had for a long time."
    gg "Ela foi a única amiga que tive durante muito tempo."

# game/Scenes/Adrian/adrian15.rpy:317
translate portuguese adrian15_d41d8cd9_3:

    # voice 'voices/adrian_untilyou.mp3'
    voice 'voices/adrian_untilyou.mp3'

# game/Scenes/Adrian/adrian15.rpy:318
translate portuguese adrian15_b79560a9:

    # gg "Until you."
    gg "Até apareceres tu."

# game/Scenes/Adrian/adrian15.rpy:320
translate portuguese adrian15_d41d8cd9_4:

    # voice 'voices/adrian_missherlikecrazy.mp3'
    voice 'voices/adrian_missherlikecrazy.mp3'

# game/Scenes/Adrian/adrian15.rpy:321
translate portuguese adrian15_65372d0d:

    # gg "So, I'm going to miss her like crazy, and I'm going to worry about her until I hear from her again."
    gg "Por isso, vou sentir imensas saudades dela e vou ficar preocupada até ter notícias dela."

# game/Scenes/Adrian/adrian15.rpy:323
translate portuguese adrian15_d41d8cd9_5:

    # voice 'voices/adrian_butimsoglad.mp3'
    voice 'voices/adrian_butimsoglad.mp3'

# game/Scenes/Adrian/adrian15.rpy:324
translate portuguese adrian15_4de0338c:

    # gg "But I'm so glad that you're here."
    gg "Mas estou tão feliz por estares aqui."

# game/Scenes/Adrian/adrian15.rpy:326
translate portuguese adrian15_d41d8cd9_6:

    # voice 'voices/adrian_iloveyou1.mp3'
    voice 'voices/adrian_iloveyou1.mp3'

# game/Scenes/Adrian/adrian15.rpy:327
translate portuguese adrian15_9c8fbba1:

    # gg "I love you, [pcname]."
    gg "Amo-te, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:330
translate portuguese adrian15_456cffdf:

    # pc "I love you too, Adrian."
    pc "Também te amo, Adrian."

# game/Scenes/Adrian/adrian15.rpy:333
translate portuguese adrian15_e9e54f9a:

    # "We sit and watch the sun set, holding each other, enjoying the quiet evening."
    "Sentamo-nos a ver o pôr-do-sol, abraçados, a desfrutar da noite tranquila."

# game/Scenes/Adrian/adrian15.rpy:334
translate portuguese adrian15_5a0d166e:

    # "I just want to be whatever she needs now."
    "Só quero ser o que ela precisar agora."

# game/Scenes/Adrian/adrian15.rpy:335
translate portuguese adrian15_46b97a11:

    # "I realize how hard I've fallen for her. I'd do anything to make her happy."
    "Percebo o quanto me apaixonei por ela. Faria qualquer coisa para a fazer feliz."

# game/Scenes/Adrian/adrian15.rpy:338
translate portuguese adrian15_7f8ffd28:

    # "After the sun sets, we drive back to her house."
    "Depois do pôr-do-sol, voltamos de carro para a casa dela."

# game/Scenes/Adrian/adrian15.rpy:341
translate portuguese adrian15_78e6be93:

    # gg "It looks like my mom is home now. I'm going to have to explain everything to her."
    gg "Parece que a minha mãe já está em casa. Vou ter de lhe explicar tudo."

# game/Scenes/Adrian/adrian15.rpy:342
translate portuguese adrian15_f3610339:

    # gg "This is not going to be fun."
    gg "Isto não vai ser divertido."

# game/Scenes/Adrian/adrian15.rpy:343
translate portuguese adrian15_20cd9dd9:

    # pc "Want some backup?"
    pc "Queres ajuda?"

# game/Scenes/Adrian/adrian15.rpy:344
translate portuguese adrian15_0c91a1a8:

    # gg "No, I think I better do this on my own."
    gg "Não, acho que é melhor fazer isto sozinho."

# game/Scenes/Adrian/adrian15.rpy:345
translate portuguese adrian15_cf913627:

    # gg "Thanks for everything though, [pcname]. You've been amazing."
    gg "Mas obrigado por tudo, [pcname]. Foste incrível."

# game/Scenes/Adrian/adrian15.rpy:346
translate portuguese adrian15_c46a0b54:

    # pc "Any time."
    pc "Sempre à disposição."

# game/Scenes/Adrian/adrian15.rpy:347
translate portuguese adrian15_ee13ba27:

    # gg "I'll call you soon, okay?"
    gg "Ligo-te em breve, está bem?"

# game/Scenes/Adrian/adrian15.rpy:350
translate portuguese adrian15_1f2a71e7:

    # pc "Okay. Good night, Adrian."
    pc "Está bem. Boa noite, Adrian."

# game/Scenes/Adrian/adrian15.rpy:351
translate portuguese adrian15_f27d9018:

    # gg "Good night, [pcname]."
    gg "Boa noite, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:352
translate portuguese adrian15_80adb898:

    # "I kiss her goodbye."
    "Dou-lhe um beijo de despedida."

# game/Scenes/Adrian/adrian15.rpy:355
translate portuguese adrian15_0cbac92b:

    # "Then I get in my car and drive away, hoping that everything will be okay."
    "Depois entro no meu carro e vou-me embora, na esperança de que tudo corra bem."

# game/Scenes/Adrian/adrian15.rpy:356
translate portuguese adrian15_339d053a:

    # "And if she needs me, I'll do anything I can to help her."
    "E se ela precisar de mim, farei tudo o que puder para a ajudar."

translate portuguese strings:

    # game/Scenes/Adrian/adrian15.rpy:6
    old "After you have checked out a local arcade with Adrian,"
    new "Depois de teres visitado um salão de jogos local com a Adrian,"

    # game/Scenes/Adrian/adrian15.rpy:7
    old "she will call and invite you to hang out in the afternoon on the weekend."
    new "ela vai ligar-te e convidar-te para saíres à tarde no fim de semana."

    # game/Scenes/Adrian/adrian15.rpy:28
    old "Oh heck yeah"
    new "Claro que sim!"

