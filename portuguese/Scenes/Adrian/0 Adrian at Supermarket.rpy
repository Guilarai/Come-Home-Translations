    pc "Isso seria fantástico."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:55
translate portuguese adrian0_c93436d0:

    # gg "Peachy! I'm available in the evenings and pretty much any time on the weekends."
    gg "Ótimo! Estou disponível à noite e praticamente a qualquer hora nos fins de semana."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:56
translate portuguese adrian0_74405267:

    # gg "Here, I'll give you my phone number and you can just call me when you want me to come over."
    gg "Toma, vou dar-te o meu número de telefone e podes ligar-me quando quiseres que eu vá aí."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:57
translate portuguese adrian0_b6ecd7e5:

    # pc "Sounds good. I'll do that."
    pc "Parece-me bem. Vou fazer isso."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:58
translate portuguese adrian0_4b274f74:

    # "You add Adrian's number to your phone."
    "Adicionas o número do Adrian ao teu telemóvel."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:60
translate portuguese adrian0_a42401cd:

    # pc "Well I better get going. I'll see you later."
    pc "Bem, é melhor eu ir andando. Até logo."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:62
translate portuguese adrian0_d4558b5f:

    # gg "Alrighty. Bye, [pcname]. See you soon."
    gg "Tudo bem. Adeus, [pcname]. Até breve."

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:63
translate portuguese adrian0_9b7b8449:

    # gg "If you happen to see somebody who works here, could you tell them I've been waiting for them to open this case for like half an hour now?"
    gg "Se por acaso vires alguém que trabalhe aqui, podes dizer-lhes que estou à espera que abram esta vitrina há já meia hora?"

# game/Scenes/Adrian/0 Adrian at Supermarket.rpy:64
translate portuguese adrian0_1df08797:

