# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:12
translate portuguese adrianp3_6894797c:

    # gg "He called me on my birthday."
    gg "Ele ligou-me no meu aniversário."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:13
translate portuguese adrianp3_c5d7621d:

    # gg "I didn't answer the phone, so he left a message."
    gg "Não atendi o telefone, por isso ele deixou uma mensagem."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:14
translate portuguese adrianp3_d6e4ff01:

    # gg "\"Just wanted to tell my SON 'Happy Birthday.'\""
    gg "«Só queria desejar ao meu FILHO \"Feliz Aniversário\".»"

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:15
translate portuguese adrianp3_c49453e5:

    # gg "\"Eighteen years old. You're a man now. Time to grow up and start acting like one.\""
    gg "«Dezoito anos. Agora és um homem. Está na hora de crescer e começares a agir como tal.»"

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:16
translate portuguese adrianp3_ce59dba2:

    # pc "Wow."
    pc "Uau."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:17
translate portuguese adrianp3_34a7ea5f:

    # gg "Yeah. He's an asshole. I blocked his number."
    gg "Sim. Ele é um idiota. Bloqueei o número dele."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:18
translate portuguese adrianp3_66af7357:

    # gg "And as far as I know, he hasn't tried to contact me again."
    gg "E, tanto quanto sei, ele não tentou contactar-me novamente."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:20
translate portuguese adrianp3_ca22deec:

    # gg "Mom still has to deal with that side of my family some, but thankfully she keeps me pretty sheltered from it."
    gg "A mãe ainda tem de lidar um pouco com esse lado da minha família, mas, felizmente, ela mantém-me bastante protegido disso."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:21
translate portuguese adrianp3_1003c31f:

    # gg "It's not something I need to even think about."
    gg "Não é algo em que eu precise sequer de pensar."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:23
translate portuguese adrianp3_8a56a79f:

    # gg "Better to just cut these people out of my life and move on."
    gg "É melhor simplesmente cortar essas pessoas da minha vida e seguir em frente."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:25
translate portuguese adrianp3_bc3d8b65:

    # gg "Family isn't who you're born with, it's who loves you and accepts you."
    gg "A família não é aquela com quem nascemos, é aquela que nos ama e nos aceita."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:26
translate portuguese adrianp3_8db25c79:

    # pc "That's a good way of looking at things."
    pc "Essa é uma boa maneira de ver as coisas."

# game/Scenes/Adrian/AdrianConversations/adrianp3.rpy:27
translate portuguese adrianp3_548a3041:

    # gg "Yeah. I'll make a new family."
    gg "Sim. Vou construir uma nova família."

