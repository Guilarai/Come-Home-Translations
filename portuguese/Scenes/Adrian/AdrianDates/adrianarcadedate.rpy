# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:23
translate portuguese adrianarcadestartdate_93cbf6b1:

    # "I drive over to Adrian's house to pick her up, then she gives me directions to get to this arcade she wants to visit."
    "Dirijo até à casa da Adrian para a ir buscar e, depois, ela dá-me indicações para chegar à sala de jogos que quer visitar."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:25
translate portuguese adrianarcadestartdate_ef349499:

    # "I drive over to Adrian's house and pick her up, then we head out to the arcade."
    "Dirijo até à casa da Adrian e vou buscá-la, depois partimos para a sala de jogos."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:30
translate portuguese adrianarcadestartdate_049af941:

    # gg "Wow, look at this place! It's so retro and trashy."
    gg "Uau, olha para este sítio! É tão retro e piroso."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:31
translate portuguese adrianarcadestartdate_ca89a42d:

    # gg "I love it!"
    gg "Adoro!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:32
translate portuguese adrianarcadestartdate_1b8393bf:

    # pc "Is this like the business you want to start?"
    pc "É este o tipo de negócio que queres abrir?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:33
translate portuguese adrianarcadestartdate_cb319d99:

    # gg "Hm, not really. I'm looking to appeal to a younger crowd, with newer games and private playing areas."
    gg "Hum, nem por isso. Estou a pensar em atrair um público mais jovem, com jogos mais recentes e áreas de jogo privadas."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:34
translate portuguese adrianarcadestartdate_1dc6627f:

    # gg "These are all old machines, pretty beat up too. I love them, but I doubt their business is booming here."
    gg "Estas são todas máquinas antigas, e bastante gastas também. Adoro-as, mas duvido que o negócio esteja a dar cartas por aqui."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:35
translate portuguese adrianarcadestartdate_b342ddbc:

    # gg "Anyway..."
    gg "De qualquer forma..."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:36
translate portuguese adrianarcadestartdate_ce26e6ca:

    # gg "Let's go play some games!"
    gg "Vamos jogar uns jogos!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:37
translate portuguese adrianarcadestartdate_5d89bf80:

    # "We head over to the machines."
    "Dirigimo-nos para as máquinas."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:44
translate portuguese adrianarcadestartdate_fcc66601:

    # "We chat while we play games together."
    "Conversamos enquanto jogamos juntos."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:51
translate portuguese adrianarcadestartdate_aa98635a:

    # "It's fun just to hang out with her. She obviously loves this stuff."
    "É divertido só estar com ela. É óbvio que ela adora isto."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:60
translate portuguese adrianarcadestartdate_b0953d82:

    # gg "That was fun. You're pretty good at these old games."
    gg "Foi divertido. És bastante boa nestes jogos antigos."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:61
translate portuguese adrianarcadestartdate_98d42c74:

    # pc "Thanks! I used to play these types of games with my dad as a kid all the time."
    pc "Obrigada! Quando era miúda, jogava sempre este tipo de jogos com o meu pai."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:62
translate portuguese adrianarcadestartdate_fb8d8dab:

    # "After we get our fill, playing most of the games in the place several times, we're both ready to leave."
    "Depois de nos fartarmos, tendo jogado a maioria dos jogos do local várias vezes, estamos ambos prontos para sair."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:66
translate portuguese adrianarcadestartdate_96accbe9:

    # gg "That was fun!"
    gg "Foi divertido!"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:68
translate portuguese adrianarcadestartdate_1e0d4722:

    # pc "Did you get the research you need?"
    pc "Conseguiste a pesquisa de que precisavas?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:69
translate portuguese adrianarcadestartdate_d081eccb:

    # gg "Yeah, I think so."
    gg "Sim, acho que sim."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:72
translate portuguese adrianarcadestartdate_57656827:

    # gg "Want to take me home and research me now?"
    gg "Queres levar-me para casa e pesquisar sobre mim agora?"

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:73
translate portuguese adrianarcadestartdate_82ba066c:

    # pc "That sounds fantastic."
    pc "Isso parece fantástico."

# game/Scenes/Adrian/AdrianDates/adrianarcadedate.rpy:79
translate portuguese adrianarcadestartdate_05218083:

    # "We leave the arcade, then I drive her home and walk her up to her front door."
    "Saímos do salão de jogos, depois levo-a a casa e acompanho-a até à porta de entrada."

