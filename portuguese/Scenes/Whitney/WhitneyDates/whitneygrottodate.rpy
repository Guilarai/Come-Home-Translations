translate portuguese whitneygrottostartdate_77cf85fd:

    # "Whitney and I go out to The Grotto and look over the menus before ordering."
    "A Whitney e eu vamos ao The Grotto e damos uma vista de olhos nos menus antes de pedirmos."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:27
translate portuguese whitneygrottostartdate_358134f0:

    # "After chatting for a while, the waiter brings out the food."
    "Depois de conversarmos um pouco, o empregado traz a comida."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:29
translate portuguese whitneygrottostartdate_484d8b28:

    # "The food is delicious, and conversation with Whitney is always good."
    "A comida está deliciosa e a conversa com a Whitney é sempre boa."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:32
translate portuguese whitneygrottostartdate_cf98ece3:

    # "When we're done eating, we keep chatting for a while, until eventually it's time to leave."
    "Quando terminamos de comer, continuamos a conversar por um tempo, até que finalmente chega a hora de ir embora."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:35
translate portuguese whitneygrottostartdate_d3ad0d0d:

    # "Before we leave, we take in the view one last time, but I can't keep my eyes off of Whitney."
    "Antes de sairmos, apreciamos a vista uma última vez, mas não consigo tirar os olhos da Whitney."

# game/Scenes/Whitney/WhitneyDates/whitneygrottodate.rpy:37
translate portuguese whitneygrottostartdate_6c23e5af:

    # "I lean in and kiss her. How could I resist?"
    "Inclino-me e beijo-a. Como poderia resistir?"

