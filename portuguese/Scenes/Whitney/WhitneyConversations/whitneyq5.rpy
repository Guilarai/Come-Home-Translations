# game/Scenes/Whitney/WhitneyConversations/whitneyq5.rpy:36
translate portuguese whitneyq5_ac897f1d:

    # wt "You are welcome to come work for me in the lab, of course."
    wt "És bem-vinda para vir trabalhar comigo no laboratório, claro."

# game/Scenes/Whitney/WhitneyConversations/whitneyq5.rpy:37
translate portuguese whitneyq5_ede37c91:

    # wt "I could use the extra hands and I can pay well. You're capable enough."
    wt "Preciso de ajuda extra e posso pagar bem. És capaz o suficiente."

# game/Scenes/Whitney/WhitneyConversations/whitneyq5.rpy:39
translate portuguese whitneyq5_047d2aa0:

    # wt "But I hoped that you might move in as well."
    wt "Mas esperava que também pudesses vir morar comigo."

# game/Scenes/Whitney/WhitneyConversations/whitneyq5.rpy:40
translate portuguese whitneyq5_f2d0fed6:

    # wt "We could take a step forward with our relationship... maybe even get married?"
