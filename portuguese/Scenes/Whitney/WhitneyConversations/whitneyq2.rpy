translate portuguese whitneyq2_29acda57:

    # wt "What are you planning for after college?"
    wt "O que estás a planear para depois da faculdade?"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:14
translate portuguese whitneyq2_28276084:

    # pc "I'm not sure. Working in a lab somewhere probably. Maybe where my dad works."
    pc "Não tenho a certeza. Provavelmente trabalhar num laboratório algures. Talvez onde o meu pai trabalha."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:15
translate portuguese whitneyq2_e37a9d5d:

    # wt "That's not a bad idea. They're a good company doing good things, though a bit unimaginative."
    wt "Não é má ideia. É uma boa empresa que faz coisas boas, embora um pouco sem imaginação."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:17
translate portuguese whitneyq2_3f970292:

    # wt "I've been thinking about starting my own lab."
    wt "Tenho pensado em abrir o meu próprio laboratório."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:18
translate portuguese whitneyq2_40ff646e:

    # wt "I've made enough money working for others that I'd like to focus on my own pursuits now."
    wt "Ganhei dinheiro suficiente a trabalhar para outros que agora gostaria de me concentrar nos meus próprios projetos."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:19
translate portuguese whitneyq2_5838daaa:

    # pc "Stuff like alternate universes?"
    pc "Coisas como universos alternativos?"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:21
translate portuguese whitneyq2_fbb4f39e:

    # wt "Among other useful things!"
    wt "Entre outras coisas úteis!"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:23
translate portuguese whitneyq2_2b6961ab:

    # wt "Curing sickness, solving world hunger, restoring the Earth's environment, instant teleportation, interstellar travel, eternal life."
    wt "Curar doenças, resolver a fome no mundo, restaurar o ambiente da Terra, teletransporte instantâneo, viagens interestelares, vida eterna."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:24
translate portuguese whitneyq2_8d5d4423:

    # pc "Wow. So just the little stuff huh?"
    pc "Uau. Então, só as coisinhas, não é?"

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:28
translate portuguese whitneyq2_c320ba54:

    # wt "I think so."
    wt "Acho que sim."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:32
translate portuguese whitneyq2_f9fc9074:

    # wt "I'm not mad."
    wt "Não estou louco."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:33
translate portuguese whitneyq2_5ae98453:

    # wt "Every scientist is considered mad until they accomplish their goals."
    wt "Todos os cientistas são considerados loucos até atingirem os seus objetivos."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:34
translate portuguese whitneyq2_fe5d5afd:

    # wt "I believe that all of these things are possible. Some within our lifetime."
    wt "Acredito que todas estas coisas são possíveis. Algumas ainda durante a nossa vida."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:36
translate portuguese whitneyq2_453ab0ca:

    # wt "Anyway, I could use a couple of assistants with these projects, if you're interested in pursuing that."
    wt "De qualquer forma, precisava de alguns assistentes para estes projetos, se estiveres interessado em seguir por esse caminho."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:40
translate portuguese whitneyq2_62d418b5:

    # wt "I'm glad."
    wt "Fico contente."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:41
translate portuguese whitneyq2_214e8d99:

    # wt "I've enjoyed working with you so far and I think that we could do good things together."
    wt "Tenho gostado de trabalhar contigo até agora e acho que poderíamos fazer coisas boas juntos."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:43
translate portuguese whitneyq2_6c16cd66:

    # pc "I think so too."
    pc "Também acho."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:46
translate portuguese whitneyq2_119fcf3f:

    # wt "Yes, please do."
    wt "Sim, por favor, faz isso."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:47
translate portuguese whitneyq2_214e8d99_1:

    # wt "I've enjoyed working with you so far and I think that we could do good things together."
    wt "Tenho gostado de trabalhar contigo até agora e acho que podemos fazer coisas boas juntos."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:48
translate portuguese whitneyq2_d4519477:

    # pc "Maybe we could."
    pc "Talvez possamos."

# game/Scenes/Whitney/WhitneyConversations/whitneyq2.rpy:52
translate portuguese whitneyq2_f9bd4feb:

    # wt "Oh, that's too bad."
