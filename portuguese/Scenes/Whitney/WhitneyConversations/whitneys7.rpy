# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:14
translate portuguese whitneys7_61555687:

    # wt "Not at all."
    wt "De nada."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:15
translate portuguese whitneys7_ae546df9:

    # wt "I rarely watch the news or pay attention to anything going on in the world."
    wt "Raramente vejo as notícias ou presto atenção ao que se passa no mundo."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:17
translate portuguese whitneys7_be533b9e:

    # wt "There is just too much."
    wt "É simplesmente demasiado."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:19
translate portuguese whitneys7_de01f383:

    # wt "I focus on my projects, and when I do research, it is only about future projects."
    wt "Concentro-me nos meus projetos e, quando faço pesquisa, é apenas sobre projetos futuros."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:20
translate portuguese whitneys7_59cf097c:

    # wt "As long as nothing gets in the way of my work, I have no reason to be distracted by outside things."
    wt "Desde que nada atrapalhe o meu trabalho, não tenho motivos para me distrair com coisas externas."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:21
translate portuguese whitneys7_4c89779a:

    # pc "Do you vote?"
    pc "Vota?"

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:23
translate portuguese whitneys7_04b05e36:

    # wt "No."
    wt "Não."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:25
translate portuguese whitneys7_fd709079:

    # wt "Honestly, I don't even know who the president is right now."
    wt "Sinceramente, nem sequer sei quem é o presidente neste momento."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:26
translate portuguese whitneys7_1f6c4c3c:

    # pc "What!? Really?"
    pc "O quê!? A sério?"

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:28
translate portuguese whitneys7_0e2df47e:

    # wt "I know that it is an old white man, but I cannot remember his name."
    wt "Sei que é um homem branco idoso, mas não me consigo lembrar do nome dele."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:30
translate portuguese whitneys7_28360e1a:

    # wt "I know that voting is very important for many people. It is the one way that they can help make the world better."
    wt "Sei que votar é muito importante para muitas pessoas. É a única forma que têm de ajudar a tornar o mundo melhor."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:32
translate portuguese whitneys7_06529d8d:

    # wt "But I have other ways to help. I will focus on those."
    wt "Mas tenho outras formas de ajudar. Vou concentrar-me nessas."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:33
translate portuguese whitneys7_b499fdd7:

    # pc "I hope that those projects do help the world eventually, then."
    pc "Espero que esses projetos acabem por ajudar o mundo, então."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:35
translate portuguese whitneys7_82d6ff18:

    # wt "How do you know they haven't already?"
    wt "Como sabes que ainda não o fizeram?"

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:36
translate portuguese whitneys7_08a9d3a9:

    # pc "Have they? What have you done?"
    pc "Fizeram? O que é que fizeste?"

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:38
translate portuguese whitneys7_35066eb3:

    # wt "I'm not permitted to talk about them specifically, but yes, I have made some contributions that are already helping the world and I will continue to do so."
    wt "Não estou autorizado a falar sobre eles especificamente, mas sim, fiz algumas contribuições que já estão a ajudar o mundo e vou continuar a fazê-lo."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:39
translate portuguese whitneys7_e9937d74:

    # pc "I just wish I could understand exactly what you do."
    pc "Só gostaria de poder compreender exatamente o que fazes."

# game/Scenes/Whitney/WhitneyConversations/whitneys7.rpy:41
translate portuguese whitneys7_b69744ce:

    # wt "Maybe one day."
    wt "Talvez um dia."

