# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:21
translate portuguese millssurface1_b6be7836:

    # bs "And enjoy my night."
    bs "E aproveito a minha noite."

# game/Scenes/MrsMills/MillsConversation/millssurface1.rpy:22
translate portuguese millssurface1_35743d5e:

    # pc "Okay then."
    pc "Está bem, então."

