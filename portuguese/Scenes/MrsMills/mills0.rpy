translate portuguese mills0_367f3b05:

    # "Sure enough, she is sitting in her chair, rotated towards me, staring directly at me."
    "Efectivamente, ela está sentada na sua cadeira, virada na minha direcção, a olhar directamente para mim."

# game/Scenes/MrsMills/mills0.rpy:97
translate portuguese mills0_1bdeed63:

    # "I continue working and try not to let it bother me."
    "Continuo a trabalhar e tento não deixar que isso me incomode."

# game/Scenes/MrsMills/mills0.rpy:100
translate portuguese mills0_9f676768:

    # "It does bother me a little though."
    "No entanto, incomoda-me um pouco."

# game/Scenes/MrsMills/mills0.rpy:102
translate portuguese mills0_0c2c0972:

