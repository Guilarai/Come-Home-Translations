    pc "Ela não é assim tão má."

# game/Scenes/MrsMills/mills0.rpy:57
translate portuguese mills0_dbed954b:

    # tm "I had a girlfriend that interviewed for her and the old lady just flat out told her that she's not interested in hiring a woman."
    tm "Tive uma amiga que foi a uma entrevista com ela e a velha disse-lhe sem rodeios que não estava interessada em contratar uma mulher."

# game/Scenes/MrsMills/mills0.rpy:58
translate portuguese mills0_d8d899a0:

