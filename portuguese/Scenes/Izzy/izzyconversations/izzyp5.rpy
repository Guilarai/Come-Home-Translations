# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:14
translate portuguese izzyp5_f4d0baa9:

    # gl "Marriage always just seemed like ownership to me."
    gl "O casamento sempre me pareceu uma forma de posse."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:15
translate portuguese izzyp5_a2a6fb65:

    # pc "What do you mean?"
    pc "O que queres dizer?"

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:17
translate portuguese izzyp5_6b0cf353:

    # gl "Well, like one of my cousins is married and one time I was staying over at her house and we were getting ready for bed."
    gl "Bem, uma das minhas primas é casada e, uma vez, eu estava a dormir em casa dela e estávamos a preparar-nos para ir para a cama."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:19
translate portuguese izzyp5_fb14eaf2:

    # gl "My cousin was going to stay up and watch a movie with me and some friends, but her husband told her to get in bed."
    gl "A minha prima ia ficar acordada a ver um filme comigo e alguns amigos, mas o marido disse-lhe para ir para a cama."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:21
translate portuguese izzyp5_56b8b1c2:

    # gl "He told her that he wanted her. That he had \"papers on her pussy.\""
    gl "Ele disse-lhe que a queria. Que tinha «papéis sobre a rata dela»."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:22
translate portuguese izzyp5_fb9284e4:

    # gl "And she did it. She left and went to him. Because he owned her."
    gl "E ela fez isso. Ela saiu e foi ter com ele. Porque ele era dono dela."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:23
translate portuguese izzyp5_ea64528c:

    # pc "That's awful. It doesn't have to be like that though."
    pc "Isso é horrível. Mas não tem de ser assim."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:25
translate portuguese izzyp5_3786e326:

    # gl "I just haven't ever seen any good marriages."
    gl "É que eu nunca vi nenhum casamento bom."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:27
translate portuguese izzyp5_6c959b11:

    # gl "But I'll tell you something, Twig."
    gl "Mas vou dizer-te uma coisa, Twig."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:29
translate portuguese izzyp5_74feb60f:

    # gl "If there's anybody that I'd even consider settling down with, it'd be you."
    gl "Se há alguém com quem eu sequer considerasse assentar, serias tu."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:30
translate portuguese izzyp5_f3f8a6b5:

    # gl "I don't know about marriage, but I do care about you."
    gl "Não sei nada sobre casamento, mas gosto de ti."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:31
translate portuguese izzyp5_3c07eaab:

    # gl "I could see myself with you. For a long time."
    gl "Consigo imaginar-me contigo. Por muito tempo."

# game/Scenes/Izzy/izzyconversations/izzyp5.rpy:32
translate portuguese izzyp5_86a73502:

