translate portuguese izzyarcadedatestart_a324d7e5:

    # gl "So we're going to an arcade? I haven't played any arcade games in forever."
    gl "Então vamos a um salão de jogos? Já não jogo jogos de arcada há séculos."

# game/Scenes/Izzy/IzzyDates/izzyarcadedate.rpy:29
translate portuguese izzyarcadedatestart_d41d8cd9:

    # voice 'voices/izzy_whatsup.mp3'
