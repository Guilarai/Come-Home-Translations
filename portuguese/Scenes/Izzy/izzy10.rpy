    "Older Boy" "Está bem, podes vir sentar-te e ver televisão connosco, mas se tentares alguma coisa, apanhamos-te."

# game/Scenes/Izzy/izzy10.rpy:75
translate portuguese izzy10_94570d10:

    # pc "All right then."
    pc "Está bem, então."

# game/Scenes/Izzy/izzy10.rpy:78
