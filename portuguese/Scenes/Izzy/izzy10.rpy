    # "Stanley" "I don't want sis to go to jail."
    "Stanley" "Não quero que a minha irmã vá para a prisão."

# game/Scenes/Izzy/izzy10.rpy:100
translate portuguese izzy10_8c26bb19:

    # pc "She just got busy with something, but she'll be home soon."
    pc "Ela só ficou ocupada com uma coisa, mas vai voltar para casa em breve."

# game/Scenes/Izzy/izzy10.rpy:101
translate portuguese izzy10_aed5f95e:

    # "Paul" "Really? She's always here when we get off the bus. What'd she get busy with?"
    "Paul" "A sério? Ela está sempre aqui quando saímos do autocarro. Com o que é que ela se ocupou?"

# game/Scenes/Izzy/izzy10.rpy:102
translate portuguese izzy10_0d6ab269:

    # pc "Just some stuff she had to do."
    pc "Apenas algumas coisas que ela tinha de fazer."

# game/Scenes/Izzy/izzy10.rpy:103
translate portuguese izzy10_f0cc05be_1:

    # "Paul" "Yeah, okay."
    "Paul" "Sim, está bem."

# game/Scenes/Izzy/izzy10.rpy:104
