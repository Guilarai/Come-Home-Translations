    # "Paul" "Sis has lots of boyfriends, but she usually doesn't let us meet them."
    "Paul" "A minha irmã tem muitos namorados, mas normalmente não nos deixa conhecê-los."

# game/Scenes/Izzy/izzy10.rpy:88
translate portuguese izzy10_fc1855ec:

    # pc "Yeah, I guess I am. We're friends."
    pc "Sim, acho que sou. Somos amigos."

# game/Scenes/Izzy/izzy10.rpy:89
translate portuguese izzy10_0b6b2f16:

    # "Stanley" "Where is she? Why isn't she at home?"
    "Stanley" "Onde é que ela está? Porque é que não está em casa?"

# game/Scenes/Izzy/izzy10.rpy:92
translate portuguese izzy10_e562930a:

    # pc "Well, the police arrested her. She might be going to jail."
    pc "Bem, a polícia prendeu-a. Ela pode ir para a prisão."

# game/Scenes/Izzy/izzy10.rpy:93
translate portuguese izzy10_9d4dc068:

    # "Paul" "Oh. Like mom."
    "Paul" "Ah. Como a mãe."

# game/Scenes/Izzy/izzy10.rpy:94
translate portuguese izzy10_363102ed:

    # "Stanley" "So we'll never see her again?"
    "Stanley" "Então, nunca mais a vamos ver?"

# game/Scenes/Izzy/izzy10.rpy:95
translate portuguese izzy10_05948c06:

    # "Paul" "Right."
    "Paul" "Exato."

# game/Scenes/Izzy/izzy10.rpy:96
translate portuguese izzy10_db875c8c:

    # pc "I wouldn't say that. We'll just have to wait to see what happens."
    pc "Eu não diria isso. Vamos ter de esperar para ver o que acontece."

# game/Scenes/Izzy/izzy10.rpy:97
translate portuguese izzy10_f0cc05be:

    # "Paul" "Yeah, okay."
    "Paul" "Sim, está bem."

# game/Scenes/Izzy/izzy10.rpy:98
