    # pc "I have to work after school."
    pc "Tenho de trabalhar depois das aulas."

# game/Scenes/Welch/welch8.rpy:16
translate portuguese welch8_828d6de8:

    # sst "That's fine, so do I. The booths are open until seven."
    sst "Não faz mal, eu também. As cabines estão abertas até às sete."

# game/Scenes/Welch/welch8.rpy:23
translate portuguese welch8_7730cc66:

