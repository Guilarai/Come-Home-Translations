# game/Scenes/Welch/welch8.rpy:86
translate portuguese welch8date_09fa6cb0:

    # sst "See how easy that was? I just will never understand why more people don't just go do it."
    sst "Vês como foi fácil? Nunca vou entender porque é que mais gente não vai simplesmente fazê-lo."

# game/Scenes/Welch/welch8.rpy:89
translate portuguese welch8date_2b774f4b:

    # "Back in the car, she puts her hand on my shoulder."
    "De volta ao carro, ela coloca a mão no meu ombro."

