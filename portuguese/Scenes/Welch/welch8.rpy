    pc "Ha! Estás pronta para isto, não estás?"

# game/Scenes/Welch/welch8.rpy:62
translate portuguese welch8date_d1363569:

    # sst "Hell yes I am! I look forward to this every year."
    sst "Claro que estou! Anseio por isto todos os anos."

