    # "She spots me and walks towards the car."
    "Ela repara em mim e caminha em direção ao carro."

# game/Scenes/Welch/welch8.rpy:59
translate portuguese welch8date_19ccb77a:

    # "She gets in the car, looking excited."
    "Entra no carro, com um ar entusiasmado."

# game/Scenes/Welch/welch8.rpy:60
translate portuguese welch8date_02521388:

    # sst "Woo! Let's vote!"
    sst "Uau! Vamos votar!"

# game/Scenes/Welch/welch8.rpy:61
translate portuguese welch8date_0f3cf124:

