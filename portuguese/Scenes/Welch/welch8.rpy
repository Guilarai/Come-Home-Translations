    sst "Está bem, achei que fosse algo que te interessasse."

# game/Scenes/Welch/welch8.rpy:24
translate portuguese welch8_60af7c4c:

    # sst "No problem. See you around then."
    sst "Sem problema. Até logo, então."

# game/Scenes/Welch/welch8.rpy:27
