# game/Scenes/Welch/welchsleepover.rpy:42
translate portuguese welchcoffee_828e685e:

    # sst "Well, you can stay over any time you like. It's worth the risk."
    sst "Bem, podes ficar a dormir aqui sempre que quiseres. Vale a pena o risco."

# game/Scenes/Welch/welchsleepover.rpy:45
translate portuguese welchcoffee_550f71f3:

    # "When we finish our coffee, it's time for me to go."
    "Quando terminamos o café, está na hora de eu ir."

# game/Scenes/Welch/welchsleepover.rpy:47
translate portuguese welchcoffee_98c3bb25:

    # sst "Have a good day, [pcname]. Let's do this again soon."
    sst "Tem um bom dia, [pcname]. Vamos repetir isto em breve."

# game/Scenes/Welch/welchsleepover.rpy:50
translate portuguese welchcoffee_6799ac6f:

    # "I get in my car and leave Nora's house to go on with the rest of my day."
    "Entro no meu carro e saio da casa da Nora para continuar com o resto do meu dia."

