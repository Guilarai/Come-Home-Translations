# game/Scenes/Welch/WelchConversations/welchq4.rpy:12
translate portuguese welchq4_2a2dff69:

    # sst "Are you religious at all, [pcname]?"
    sst "És de alguma forma religioso, [pcname]?"

# game/Scenes/Welch/WelchConversations/welchq4.rpy:13
translate portuguese welchq4_2cf7a593:

    # pc "Not really. I'm a scientist. I believe in science."
    pc "Na verdade, não. Sou um cientista. Acredito na ciência."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:15
translate portuguese welchq4_9a20da1e:

    # sst "Yeah, I'm with you."
    sst "Sim, concordo contigo."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:17
translate portuguese welchq4_4b16e3b4:

    # sst "I'm not just non-religious though. I am anti-religious."
    sst "Mas não sou apenas não-religioso. Sou anti-religioso."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:18
translate portuguese welchq4_23b69273:

    # sst "I don't like religion at all or religious people really either."
    sst "Não gosto nada de religião nem de pessoas religiosas, na verdade."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:19
translate portuguese welchq4_c0922e2d:

    # sst "Religion has caused so many problems in the world. It preys on the weak and the dumb."
    sst "A religião causou tantos problemas no mundo. Aproveita-se dos fracos e dos ignorantes."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:22
translate portuguese welchq4_2858fb31:

    # pc "I don't worry too much about what other people believe."
    pc "Não me preocupo muito com aquilo em que as outras pessoas acreditam."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:23
translate portuguese welchq4_9e4f9fee:

    # sst "I guess."
    sst "Acho que sim."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:24
translate portuguese welchq4_e304dd62:

    # sst "I don't want to tell anybody what to do. I just wish that religious people were the same."
    sst "Não quero dizer a ninguém o que fazer. Só gostava que as pessoas religiosas fossem assim."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:25
translate portuguese welchq4_4cee9e72:

    # sst "Like, do whatever you want, but don't make laws based on your religion and don't try to force me to follow the rules in your 2000 year old book."
    sst "Tipo, faz o que quiseres, mas não crie leis com base na tua religião e não tentes obrigar-me a seguir as regras do teu livro com 2000 anos."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:26
translate portuguese welchq4_9843e33d:

    # sst "I'm all for everybody minding their own business, so long as their business is not harming people I care about."
    sst "Sou totalmente a favor de que cada um se metam na sua vida, desde que a vida deles não prejudique as pessoas de quem gosto."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:30
translate portuguese welchq4_e1639514:

    # sst "Glad to hear we're on the same page."
    sst "Fico contente por saber que estamos na mesma onda."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:31
translate portuguese welchq4_f4d67be7:

    # sst "I don't think I could ever date a religious person."
    sst "Acho que nunca conseguiria namorar com uma pessoa religiosa."

# game/Scenes/Welch/WelchConversations/welchq4.rpy:32
translate portuguese welchq4_c2324f68:

    # sst "We would just be too different. I don't see how I could ever get along with somebody who believes in that bullshit."
    sst "Seríamos simplesmente demasiado diferentes. Não vejo como poderia dar-me bem com alguém que acredita naquelas tretas."

translate portuguese strings:

    # game/Scenes/Welch/WelchConversations/welchq4.rpy:21
    old "To each their own"
    new "Cada um com a sua"

