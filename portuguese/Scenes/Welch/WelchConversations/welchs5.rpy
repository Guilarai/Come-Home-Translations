# game/Scenes/Welch/WelchConversations/welchs5.rpy:44
translate portuguese welchs5_2e65f684:

    # sst "We've talked a lot about it. About how I don't want a romantic relationship with her. How I want to be with a man."
    sst "Já conversámos muito sobre isso. Sobre como não quero uma relação romântica com ela. Como quero estar com um homem."

# game/Scenes/Welch/WelchConversations/welchs5.rpy:46
