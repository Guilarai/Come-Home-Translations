# game/Scenes/Welch/WelchConversations/welchp4.rpy:16
translate portuguese welchp4_ac3f3409:

    # sst "Fuck, I guess I'd get fired."
    sst "Raios, acho que seria despedida."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:18
translate portuguese welchp4_91b3d15e:

    # sst "That would really suck, but I'd figure it out."
    sst "Isso seria uma chatice, mas eu daria um jeito."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:19
translate portuguese welchp4_af9bd906:

    # sst "Flora has been trying to get me to come work with her for a while now."
    sst "A Flora já há algum tempo que tenta convencer-me a ir trabalhar com ela."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:20
translate portuguese welchp4_9039df6d:

    # sst "She's in real estate. Makes a ton of money too. Way more than I do teaching."
    sst "Ela trabalha no imobiliário. Ganha imenso dinheiro também. Muito mais do que eu ganho a dar aulas."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:22
translate portuguese welchp4_38f7effe:

    # sst "But I just love teaching, you know?"
    sst "Mas eu adoro ensinar, percebes?"

# game/Scenes/Welch/WelchConversations/welchp4.rpy:23
translate portuguese welchp4_e5293053:

    # sst "I truly believe that I make a difference. Give young people some guidance. Help them shape society to be something better."
    sst "Acredito sinceramente que faço a diferença. Dou orientação aos jovens. Ajudo-os a moldar a sociedade para que seja melhor."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:25
translate portuguese welchp4_964ddaf9:

    # sst "I'd hate to lose that."
    sst "Detestaria perder isso."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:27
translate portuguese welchp4_d92b8e9b:

    # sst "So I guess I'd try to do anything I could to not get fired."
    sst "Por isso, acho que tentaria fazer tudo o que pudesse para não ser despedida."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:28
translate portuguese welchp4_708e8183:

    # sst "And if I did, I'd go to work with Flora and try to shape society in a different way."
    sst "E se fosse, iria trabalhar com a Flora e tentaria moldar a sociedade de uma forma diferente."

# game/Scenes/Welch/WelchConversations/welchp4.rpy:30
translate portuguese welchp4_c51c7ca0:

    # sst "More volunteer work or something."
    sst "Mais trabalho voluntário ou algo do género."

