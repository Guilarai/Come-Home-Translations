# game/Scenes/Other/tutorial14.rpy:68
translate portuguese tutorial16_32703b7f:

    # rj "... stuff."
    rj "... coisas."

# game/Scenes/Other/tutorial14.rpy:69
translate portuguese tutorial16_f80f19aa:

