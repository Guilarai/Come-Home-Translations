# game/Scenes/Mari/mari1.rpy:16
translate portuguese mari1_64c354b8:

    # fr "Hey there sweetie, good to see you. How are you doing today?"
    fr "Olá, querida, que bom ver-te. Como estás hoje?"

# game/Scenes/Mari/mari1.rpy:19
translate portuguese mari1_223b1496:

    # fr "Good, I'm glad. It's nice to see you in here again, let me know if I can get you anything."
    fr "Ótima, fico contente. É bom ver-te aqui outra vez, avisa-me se precisares de alguma coisa."

# game/Scenes/Mari/mari1.rpy:22
translate portuguese mari1_fe03e5ca:

    # fr "You're such a charmer. Keep going, I like it."
    fr "És tão charmoso. Continua, gosto disso."

# game/Scenes/Mari/mari1.rpy:23
translate portuguese mari1_4d51f194:

    # pc "I mean, the burgers here are great, but I'm really here just to chat with you."
    pc "Quer dizer, os hambúrgueres aqui são ótimos, mas na verdade só vim para conversar contigo."

# game/Scenes/Mari/mari1.rpy:25
translate portuguese mari1_67fd9cd9:

    # fr "Really?"
    fr "A sério?"

# game/Scenes/Mari/mari1.rpy:26
translate portuguese mari1_18128c18:

    # pc "Really."
    pc "A sério."

# game/Scenes/Mari/mari1.rpy:28
translate portuguese mari1_8aa0b3f4:

    # fr "You're so sweet. Thanks for the compliments, but I better get back to work. Let me know if I can get you anything."
    fr "És tão querido. Obrigada pelos elogios, mas é melhor eu voltar ao trabalho. Diz-me se precisares de alguma coisa."

# game/Scenes/Mari/mari1.rpy:29
translate portuguese mari1_c0bafa60:

    # pc "Can I get a straw for my drink?"
    pc "Podes dar-me um canudo para a minha bebida?"

# game/Scenes/Mari/mari1.rpy:31
translate portuguese mari1_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari1.rpy:32
translate portuguese mari1_f2433589:

    # fr "Sure thing, honey."
    fr "Claro, querido."

# game/Scenes/Mari/mari1.rpy:33
translate portuguese mari1_ab35ef2d:

    # "She reaches into her pocket to pull out one of the straws and a dozen more pop out and fall onto the floor, scattering around."
    "Ela enfia a mão no bolso para tirar um dos canudos e mais uma dúzia saltam para fora e caem no chão, espalhando-se por todo o lado."

# game/Scenes/Mari/mari1.rpy:36
translate portuguese mari1_d41d8cd9_2:

    # voice 'voices/mari_shoot2.mp3'
    voice 'voices/mari_shoot2.mp3'

# game/Scenes/Mari/mari1.rpy:37
translate portuguese mari1_aaf7d6fa:

    # fr "Ah shoot, sorry about that."
    fr "Ah, bolas, desculpa lá isso."

# game/Scenes/Mari/mari1.rpy:38
translate portuguese mari1_76e2166e:

    # fr "Just a second, let me get these."
    fr "Só um segundo, deixa-me apanhar isto."

# game/Scenes/Mari/mari1.rpy:40
translate portuguese mari1_29517e2b:

    # "She kneels down and gets on hands and knees on the floor, picking up the straws that had scattered around."
    "Ela ajoelha-se e fica de quatro no chão, a apanhar as palhinhas que se espalharam."

# game/Scenes/Mari/mari1.rpy:41
translate portuguese mari1_fa53362f:

    # fr "I'm so sorry."
    fr "Desculpa lá."

# game/Scenes/Mari/mari1.rpy:44
translate portuguese mari1_6ce37599:

    # fr "I'm so clumsy sometimes."
    fr "Às vezes sou tão desastrada."

# game/Scenes/Mari/mari1.rpy:45
translate portuguese mari1_bdb852f0:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Ela termina rapidamente de apanhar o resto das palhinhas e levanta-se."

# game/Scenes/Mari/mari1.rpy:48
translate portuguese mari1_c84cc9f0:

    # fr "What?"
    fr "O quê?"

# game/Scenes/Mari/mari1.rpy:50
translate portuguese mari1_d41d8cd9_3:

    # voice 'voices/mari_youlikethat.mp3'
    voice 'voices/mari_youlikethat.mp3'

# game/Scenes/Mari/mari1.rpy:51
translate portuguese mari1_50b1ddec:

    # fr "Oh. You like that do you?"
    fr "Oh. Gostas disso, não é?"

# game/Scenes/Mari/mari1.rpy:53
translate portuguese mari1_7fbd7f76:

    # fr "What about this? You like this?"
    fr "E isto? Gostas disto?"

# game/Scenes/Mari/mari1.rpy:54
translate portuguese mari1_9bf0a886:

    # pc "I definitely do."
    pc "Claro que sim."

# game/Scenes/Mari/mari1.rpy:55
translate portuguese mari1_bdb852f0_1:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Ela termina rapidamente de apanhar o resto das palhinhas e levanta-se."

# game/Scenes/Mari/mari1.rpy:57
translate portuguese mari1_2771e6a1:

    # fr "I hope that was worth a little bit more of a tip?"
    fr "Espero que isso tenha valido uma gorjeta um pouco maior?"

# game/Scenes/Mari/mari1.rpy:58
translate portuguese mari1_81450635:

    # pc "Oh I could give you more than the tip."
    pc "Oh, eu podia dar-te mais do que a gorjeta."

# game/Scenes/Mari/mari1.rpy:60
translate portuguese mari1_053e79a0:

    # fr "You're so bad!"
    fr "És tão marota!"

# game/Scenes/Mari/mari1.rpy:63
translate portuguese mari1_bab66bf3:

    # fr "I'll be right back with a straw that hasn't been on the floor."
    fr "Volto já com um canudo que não tenha estado no chão."

# game/Scenes/Mari/mari1.rpy:64
translate portuguese mari1_c8cd6f6b:

    # "She comes back with my straw and then my food shortly after that."
    "Ela volta com o meu canudo e, pouco depois, com a minha comida."

# game/Scenes/Mari/mari1.rpy:65
translate portuguese mari1_2e5f61be:

    # "We don't talk much more, but she gives me a beautiful smile every time I look up at her."
    "Não falamos muito mais, mas ela dá-me um sorriso lindo sempre que olho para ela."

# game/Scenes/Mari/mari1.rpy:69
translate portuguese mari1_e88fc8e1:

    # "When I finish and it's time to leave, she waves at me."
    "Quando termino e está na hora de sair, ela acena-me."

# game/Scenes/Mari/mari1.rpy:71
translate portuguese mari1_d41d8cd9_4:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari1.rpy:72
translate portuguese mari1_7949c609:

    # fr "Thanks for coming in! You have a good night!"
    fr "Obrigada por teres vindo! Tem uma boa noite!"

# game/Scenes/Mari/mari1.rpy:75
translate portuguese maritip2_1ce16e45:

    # "I walk up to her and put a ten-dollar bill into her hand."
    "Aproximo-me dela e coloco uma nota de dez dólares na mão dela."

# game/Scenes/Mari/mari1.rpy:78
translate portuguese maritip2_d41d8cd9:

    # voice 'voices/mari_thankyousomuch.mp3'
    voice 'voices/mari_thankyousomuch.mp3'

# game/Scenes/Mari/mari1.rpy:79
translate portuguese maritip2_1e720979:

    # fr "Thanks so much, you're the best."
    fr "Muito obrigado, és a melhor."

# game/Scenes/Mari/mari1.rpy:81
translate portuguese maritip2_890abf2a:

    # "Without warning, she lunges forward and wraps her arms around me, pulling me into a close hug."
    "Sem aviso, ela lança-se para a frente e envolve-me nos braços, puxando-me para um abraço apertado."

# game/Scenes/Mari/mari1.rpy:82
translate portuguese maritip2_9ba61eed:

    # "She's so warm and soft."
    "Ela é tão quente e suave."

# game/Scenes/Mari/mari1.rpy:83
translate portuguese maritip2_23314f60:

    # "And bonus - she smells like burgers."
    "E ainda por cima — ela cheira a hambúrgueres."

# game/Scenes/Mari/mari1.rpy:84
translate portuguese maritip2_c96f83e2:

    # pc "Well you're a great waitress."
    pc "Bem, és uma excelente empregada de mesa."

# game/Scenes/Mari/mari1.rpy:85
translate portuguese maritip2_d1889969:

    # fr "It's easy when the customers are as nice as you are."
    fr "É fácil quando os clientes são tão simpáticos como tu."

# game/Scenes/Mari/mari1.rpy:86
translate portuguese maritip2_9bc4e48c:

    # fr "Come back and see me again soon, okay?"
    fr "Volta a visitar-me em breve, está bem?"

# game/Scenes/Mari/mari1.rpy:87
translate portuguese maritip2_9782867b:

    # pc "Oh I'm sure I will."
    pc "Oh, tenho a certeza de que voltarei."

# game/Scenes/Mari/mari1.rpy:89
translate portuguese maritip2_fb1fac0d:

    # fr "Have a good night, sweetie."
    fr "Tem uma boa noite, querido."

# game/Scenes/Mari/mari1.rpy:90
translate portuguese maritip2_eb61ef6e:

    # pc "You too."
    pc "Tu também."

# game/Scenes/Mari/mari1.rpy:92
translate portuguese maritip2_3cb27537:

    # "I give her a wave."
    "Aceno-lhe."

# game/Scenes/Mari/mari1.rpy:93
translate portuguese maritip2_739d2b0c:

    # "With that, I go back outside and head to my car."
    "Com isso, volto para a rua e dirijo-me ao meu carro."

