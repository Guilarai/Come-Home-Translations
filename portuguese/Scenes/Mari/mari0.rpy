# game/Scenes/Mari/mari0.rpy:17
translate portuguese mari0_83cd92ec:

    # fr "I'm Mari. I'll be your waitress today."
    fr "Sou a Mari. Vou ser a sua empregada de mesa hoje."

# game/Scenes/Mari/mari0.rpy:18
translate portuguese mari0_0a82c299:

    # fr "You just let me know if you need anything else."
    fr "É só dizeres se precisares de mais alguma coisa."

# game/Scenes/Mari/mari0.rpy:19
translate portuguese mari0_f711eed2:

    # "She gives me a smile and puts the food down on the table."
    "Ela sorri para mim e pousa a comida na mesa."

# game/Scenes/Mari/mari0.rpy:23
translate portuguese mari0_84e54e6e:

    # "She blushes a bit and playfully slaps my shoulder."
    "Ela cora um pouco e dá-me uma palmada brincalhona no ombro."

# game/Scenes/Mari/mari0.rpy:24
translate portuguese mari0_967f0281:

    # fr "You're just a charmer, aren't you?"
    fr "És mesmo um sedutor, não és?"

# game/Scenes/Mari/mari0.rpy:27
translate portuguese mari0_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:28
translate portuguese mari0_9af4e82f:

    # fr "Sure thing!"
    fr "Claro!"

# game/Scenes/Mari/mari0.rpy:31
translate portuguese mari0_d41d8cd9_2:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari0.rpy:32
translate portuguese mari0_22159de4:

    # fr "Sure thing! I'll bring it right out."
    fr "Claro! Vou trazer já."

# game/Scenes/Mari/mari0.rpy:33
translate portuguese mari0_55ee1584:

    # "She runs to the back and gets the ketchup, then quickly returns with it."
    "Ela corre para as traseiras e vai buscar o ketchup, depois volta rapidamente com ele."

# game/Scenes/Mari/mari0.rpy:34
translate portuguese mari0_fe5173b6:

    # fr "Just give me a holler if I can do anything else for you."
    fr "É só chamar-me se eu puder fazer mais alguma coisa por si."

# game/Scenes/Mari/mari0.rpy:37
translate portuguese mari0_d0ec727b:

    # "She walks over to a nearby table, pulls out a rag, and starts wiping it down, bending over just enough to give me a good view of her ass."
    "Ela dirige-se a uma mesa próxima, pega num pano e começa a limpá-la, inclinando-se o suficiente para me dar uma boa vista do seu rabo."

# game/Scenes/Mari/mari0.rpy:40
translate portuguese mari0_8458142b:

    # "And damn, that's a nice ass."
    "E caramba, que rabo bonito."

# game/Scenes/Mari/mari0.rpy:43
translate portuguese mari0_a58a4782:

    # "I eat my food and Mari returns a couple more times to give me a refill on my drink."
    "Como a minha refeição e a Mari volta mais umas vezes para me encher o copo."

# game/Scenes/Mari/mari0.rpy:46
translate portuguese mari0_cc46d500:

    # "Then when I'm finished, I stand up and give her a smile and a wave."
    "Depois, quando termino, levanto-me e dou-lhe um sorriso e um aceno."

# game/Scenes/Mari/mari0.rpy:49
