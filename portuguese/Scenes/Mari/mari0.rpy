translate portuguese mari0_8fafd7cf:

    # fr "Thanks for coming in. You have a good night."
    fr "Obrigada por ter vindo. Tenha uma boa noite."

# game/Scenes/Mari/mari0.rpy:53
translate portuguese marifirsttip_1c31faa0:

