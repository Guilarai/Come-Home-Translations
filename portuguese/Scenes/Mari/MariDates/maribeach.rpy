# game/Scenes/Mari/MariDates/maribeach.rpy:13
translate portuguese maribeachdate_a63d5d5c:

    # fr "The beach sounds amazing! I'll go get in my swimsuit! Come get me."
    fr "A praia parece incrível! Vou ir vestir o meu fato de banho! Vem buscar-me."

# game/Scenes/Mari/MariDates/maribeach.rpy:14
translate portuguese maribeachdate_8caa4a9c:

    # pc "On my way."
    pc "Já vou."

# game/Scenes/Mari/MariDates/maribeach.rpy:21
translate portuguese maribeachdate_40c18b34:

    # "I pick Mari up and we drive out towards the beach."
    "Vou buscar a Mari e dirigimo-nos para a praia."

# game/Scenes/Mari/MariDates/maribeach.rpy:23
translate portuguese maribeachdate_427f3be4:

    # fr "I haven't been to the beach in forever."
    fr "Não vou à praia há séculos."

# game/Scenes/Mari/MariDates/maribeach.rpy:24
translate portuguese maribeachdate_e5624fc2:

    # fr "This is going to be so fun."
    fr "Isto vai ser tão divertido."

# game/Scenes/Mari/MariDates/maribeach.rpy:29
translate portuguese maribeachdate_b9c9e980:

    # pc "You look incredible."
    pc "Estás incrível."

# game/Scenes/Mari/MariDates/maribeach.rpy:30
translate portuguese maribeachdate_8a5a041f:

    # fr "Thanks, honey. The water is so pretty. Let's get in."
    fr "Obrigada, querido. A água está tão bonita. Vamos entrar."

# game/Scenes/Mari/MariDates/maribeach.rpy:33
translate portuguese maribeachdate_93419ef3:

    # "We spend some time swimming around and chatting."
    "Passamos algum tempo a nadar e a conversar."

# game/Scenes/Mari/MariDates/maribeach.rpy:36
translate portuguese maribeachdate_0e1a2c64:

    # "We spend a little longer making out, our bodies pressed against each other underwater."
    "Passamos um pouco mais de tempo a beijar-nos, os nossos corpos pressionados um contra o outro debaixo de água."

# game/Scenes/Mari/MariDates/maribeach.rpy:39
translate portuguese maribeachdate_c4765999:

    # "After a while, we're both tired from swimming and the sun is starting to set, so we lie on the beach and dry off."
    "Passado algum tempo, estamos ambos cansados de nadar e o sol começa a pôr-se, por isso deitamo-nos na praia e secamo-nos."

# game/Scenes/Mari/MariDates/maribeach.rpy:40
translate portuguese maribeachdate_3d2f7709:

    # "We lean back and talk for a while about whatever comes to mind."
    "Recostamo-nos e conversamos um pouco sobre o que nos vem à cabeça."

# game/Scenes/Mari/MariDates/maribeach.rpy:50
translate portuguese maribeachdate_67f91a9e:

    # "When the sun starts to dip below the horizon, we take a moment to watch it together."
    "Quando o sol começa a mergulhar no horizonte, paramos um momento para o vermos juntos."

# game/Scenes/Mari/MariDates/maribeach.rpy:52
translate portuguese maribeachdate_0b6982cc:

    # fr "It's so beautiful."
    fr "É tão bonito."

# game/Scenes/Mari/MariDates/maribeach.rpy:53
translate portuguese maribeachdate_91de8c28:

    # fr "Thanks for bringing me here."
    fr "Obrigado por me trazeres aqui."

# game/Scenes/Mari/MariDates/maribeach.rpy:58
translate portuguese maribeachdate_e10b5f4e:

    # "We kiss and it's like lightning between our lips. It warms me from my heart outward."
    "Beijamo-nos e é como um raio entre os nossos lábios. Aquece-me do coração para fora."

# game/Scenes/Mari/MariDates/maribeach.rpy:63
translate portuguese maribeachdate_4462906b:

    # fr "Are you ready to go back to my place?"
    fr "Estás pronta para ires para minha casa?"

# game/Scenes/Mari/MariDates/maribeach.rpy:64
translate portuguese maribeachdate_61f77a4c:

    # pc "Sure."
    pc "Claro."

# game/Scenes/Mari/MariDates/maribeach.rpy:65
translate portuguese maribeachdate_63a75f93:

    # fr "Good, because I'm ready to get out of this swimsuit. And to get you out of yours."
    fr "Ótimo, porque estou pronto para tirar este fato de banho. E para te tirar o teu."

# game/Scenes/Mari/MariDates/maribeach.rpy:69
translate portuguese maribeachdate_69da3812:

    # "When the sun sets, I drive us back to her house."
    "Quando o sol se põe, conduzo-nos de volta para a casa dela."

# game/Scenes/Mari/MariDates/maribeach.rpy:70
translate portuguese maribeachdate_e3551ef8:

    # fr "So... are you coming inside?"
    fr "Então... vais entrar?"

# game/Scenes/Mari/MariDates/maribeach.rpy:73
translate portuguese maribeachdate_b1aed98f:

    # fr "Good. Let's go."
    fr "Ótimo. Vamos lá."

# game/Scenes/Mari/MariDates/maribeach.rpy:80
translate portuguese maribeachdate_b1aed98f_1:

    # fr "Good. Let's go."
    fr "Ótimo. Vamos lá."

# game/Scenes/Mari/MariDates/maribeach.rpy:88
translate portuguese maribeachdate_92c16c18:

    # fr "Dang, really? Too busy for little ol' me tonight?"
    fr "Caramba, a sério? Estás demasiado ocupado para mim esta noite?"

# game/Scenes/Mari/MariDates/maribeach.rpy:89
translate portuguese maribeachdate_ea7c5dae:

    # fr "Fine. Good night then."
    fr "Tudo bem. Boa noite, então."

# game/Scenes/Mari/MariDates/maribeach.rpy:92
translate portuguese maribeachdate_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "Espero até ela sair e entrar em casa antes de me ir embora."

translate portuguese strings:

    # game/Scenes/Mari/MariDates/maribeach.rpy:3
    old "When you are able to ask Mari out on a date, and you have unlocked the beach through Suzy's path, invite Mari to the beach."
    new "Quando conseguires convidar a Mari para sair e tiveres desbloqueado a praia através do caminho da Suzy, convida a Mari para ir à praia."

    # game/Scenes/Mari/MariDates/maribeach.rpy:4
    old "She is available to date any time before night on the weekends."
    new "Ela está disponível para sair a qualquer hora antes do anoitecer aos fins de semana."

