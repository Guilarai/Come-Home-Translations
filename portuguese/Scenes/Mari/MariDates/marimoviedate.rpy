# game/Scenes/Mari/MariDates/marimoviedate.rpy:26
translate portuguese marimovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Chegamos ao cinema e sentamo-nos nas filas de trás."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:27
translate portuguese marimovietheaterstartdate_d03e5a70:

    # fr "So what are we watching anyway?"
    fr "Então, o que é que vamos ver afinal?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:31
translate portuguese marimovietheaterstartdate_346436bf:

    # fr "Oh yeah?"
    fr "Ah, sim?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:32
translate portuguese marimovietheaterstartdate_3aed9093:

    # fr "I love romance movies. As long as they're not too corny."
    fr "Adoro filmes românticos. Desde que não sejam demasiado piegas."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:35
translate portuguese marimovietheaterstartdate_337ed84d:

    # fr "Hrm, okay well that sounds fun."
    fr "Hum, está bem, isso parece divertido."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:36
translate portuguese marimovietheaterstartdate_7a1524b8:

    # fr "As long as it isn't just two buff guys slapping their meat together."
    fr "Desde que não sejam só dois tipos musculados a bater com os seus «trunfos»."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:38
translate portuguese marimovietheaterstartdate_d3cf7e4e:

    # fr "Actually, that sounds pretty fun too."
    fr "Na verdade, isso também parece bastante divertido."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:43
translate portuguese marimovietheaterstartdate_d41d8cd9:

    # voice 'voices/mari_really.mp3'
    voice 'voices/mari_really.mp3'

# game/Scenes/Mari/MariDates/marimoviedate.rpy:44
translate portuguese marimovietheaterstartdate_67fd9cd9:

    # fr "Really?"
    fr "A sério?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:45
translate portuguese marimovietheaterstartdate_8b77409f:

    # fr "I don't really do scary movies very well."
    fr "Não sou muito boa com filmes de terror."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:46
translate portuguese marimovietheaterstartdate_cb84ad92:

    # fr "I might just have my eyes closed and be holding you through the whole thing."
    fr "Talvez fique com os olhos fechados e te abrace durante todo o filme."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:51
translate portuguese marimovietheaterstartdate_321fa232:

    # fr "Oh good, I need a good laugh."
    fr "Ah, que bom, preciso de dar boas gargalhadas."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:52
translate portuguese marimovietheaterstartdate_76b9da8b:

    # fr "As long as it's not one of those gross-out sex comedies. I'm not really into those."
    fr "Desde que não seja uma daquelas comédias sexuais nojentas. Não curto muito essas."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:56
translate portuguese marimovietheaterstartdate_f3087137:

    # fr "Oh good! You know what I like."
    fr "Ah, que bom! Sabes do que eu gosto."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:57
translate portuguese marimovietheaterstartdate_3224e393:

    # fr "I love animated stuff. Especially when it's about talking animals."
    fr "Adoro coisas animadas. Especialmente quando se trata de animais falantes."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:60
translate portuguese marimovietheaterstartdate_f45af0c0:

    # "There's a little time before the movie starts for us to chat."
    "Ainda temos um tempinho antes do filme começar para conversarmos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:64
translate portuguese marimovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Finalmente o filme começa e ficamos em silêncio."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:66
translate portuguese marimovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Ela estende a mão e segura a minha em cima do apoio de braço."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:67
translate portuguese marimovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Os trailers duram cerca de quinze minutos, depois o filme começa de verdade."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:71
translate portuguese marimovietheaterstartdate_17eefcb1:

    # "During the movie, she leans on my shoulder, really getting into the story."
    "Durante o filme, ela encosta-se no meu ombro, realmente envolvida na história."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:73
translate portuguese marimovietheaterstartdate_1b60b301:

    # "Then during a particularly romantic scene, she raises her head and puts her lips to mine."
    "Então, durante uma cena particularmente romântica, ela levanta a cabeça e encosta os lábios nos meus."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:74
translate portuguese marimovietheaterstartdate_787192bc:

    # "We don't really watch a lot of the rest of the movie, instead focusing on making out."
    "Não prestamos muita atenção ao resto do filme, concentrando-nos em beijar-nos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:77
translate portuguese marimovietheaterstartdate_d17a4ae6:

    # "During the movie, she leans against my shoulder, really getting into the story."
    "Durante o filme, ela encosta-se ao meu ombro, envolvendo-se completamente na história."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:80
translate portuguese marimovietheaterstartdate_284094da:

    # "Mari watches the movie, but I'm not really sure how much she likes it."
    "A Mari vê o filme, mas não tenho a certeza de até que ponto ela gosta."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:83
translate portuguese marimovietheaterstartdate_26b74708:

    # "Eventually, she turns towards me and whispers."
    "Por fim, ela vira-se para mim e sussurra."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:84
translate portuguese marimovietheaterstartdate_5aa661f3:

    # fr "I'm not really into this movie. Want to just make out?"
    fr "Não estou muito interessada neste filme. Queres apenas beijar-me?"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:86
translate portuguese marimovietheaterstartdate_d0a52fcf:

    # "I lean in and kiss her and we don't really watch much else of the movie, instead focusing on each other."
    "Inclino-me e beijo-a e não vemos muito mais do filme, concentrando-nos, em vez disso, um no outro."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:89
translate portuguese marimovietheaterstartdate_ae5e6aa0:

    # "To give her some credit, she tries to watch a little bit of the movie."
    "Para ser justo, ela tenta ver um pouco do filme."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:90
translate portuguese marimovietheaterstartdate_c601de66:

    # "But by the time the scary parts start, she is pretty much done."
    "Mas quando as partes assustadoras começam, ela já está praticamente fora de si."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:92
translate portuguese marimovietheaterstartdate_fafc8629:

    # "She tucks her head down against me and hides the movie from her sight."
    "Ela encosta a cabeça em mim e esconde o filme da sua vista."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:93
translate portuguese marimovietheaterstartdate_324b6470:

    # "She stays right there, not watching anything for the rest of the movie."
    "Ela fica ali mesmo, sem ver nada durante o resto do filme."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:96
translate portuguese marimovietheaterstartdate_b27a7e4c:

    # "Mari's eyes are focused on the movie throughout the whole thing."
    "Os olhos da Mari estão focados no filme durante todo o tempo."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:97
translate portuguese marimovietheaterstartdate_125a0ff3:

    # "She laughs, she cries, she taps her foot along with the music."
    "Ela ri, chora, bate o pé ao ritmo da música."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:98
translate portuguese marimovietheaterstartdate_e4a43b4e:

    # "We have a great time."
    "Divertimo-nos imenso."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:101
translate portuguese marimovietheaterstartdate_8f27901e:

    # "The movie is pretty funny all the way through and Mari and I laugh a lot."
    "O filme é bastante engraçado do início ao fim e a Mari e eu rimos muito."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:104
translate portuguese marimovietheaterstartdate_abcf9a29:

    # "Then somehow that turns into us making out."
    "Depois, de alguma forma, isso transforma-se em nós a beijarmo-nos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:105
translate portuguese marimovietheaterstartdate_46b84a07:

    # "We don't really watch much of the movie after that."
    "Na verdade, não vemos grande parte do filme depois disso."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:106
translate portuguese marimovietheaterstartdate_d855e56b:

    # "Eventually the movie ends and the credits start rolling."
    "Por fim, o filme termina e os créditos começam a rolar."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:109
translate portuguese marimovietheaterstartdate_f176d1eb:

    # fr "That was a cute movie."
    fr "Foi um filme giro."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:111
translate portuguese marimovietheaterstartdate_b1836b04:

    # fr "What little I saw of it anyway."
    fr "Pelo pouco que vi, pelo menos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:112
translate portuguese marimovietheaterstartdate_91db2110:

    # fr "I like what we did even more than the movie."
    fr "Gosto ainda mais do que fizemos do que do filme."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:113
translate portuguese marimovietheaterstartdate_e25ed9ba:

    # fr "Thanks for taking me."
    fr "Obrigado por me levares."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:116
translate portuguese marimovietheaterstartdate_eb286352:

    # fr "Well the movie wasn't really my thing."
    fr "Bem, o filme não era bem o meu género."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:118
translate portuguese marimovietheaterstartdate_8fc45fba:

    # fr "But seeing it with you made it a lot better."
    fr "Mas vê-lo contigo tornou tudo muito melhor."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:121
translate portuguese marimovietheaterstartdate_c58b0ecd:

    # fr "I'm a big baby, I know."
    fr "Sou um grande bebé, eu sei."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:122
translate portuguese marimovietheaterstartdate_acdb9025:

    # fr "But I hated that. Even when I stopped watching it, the noises were still scary."
    fr "Mas detestei aquilo. Mesmo quando parei de ver, os ruídos continuavam a dar-me medo."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:123
translate portuguese marimovietheaterstartdate_26d0b7c9:

    # pc "I'm sorry, I didn't realize that you disliked horror movies so much."
    pc "Desculpa, não me tinha apercebido que detestavas tanto filmes de terror."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:124
translate portuguese marimovietheaterstartdate_30078caa:

    # fr "They just bring back bad memories and make me think about sad things."
    fr "Eles só me trazem más memórias e fazem-me pensar em coisas tristes."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:127
translate portuguese marimovietheaterstartdate_c3aec289:

    # fr "That movie was so cute! I loved it!"
    fr "Aquele filme foi tão giro! Adorei!"

# game/Scenes/Mari/MariDates/marimoviedate.rpy:128
translate portuguese marimovietheaterstartdate_070969bf:

    # fr "Thanks so much for bringing me."
    fr "Muito obrigado por me levares."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:131
translate portuguese marimovietheaterstartdate_4549f151:

    # fr "That was a fun movie."
    fr "Foi um filme divertido."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:133
translate portuguese marimovietheaterstartdate_b1836b04_1:

    # fr "What little I saw of it anyway."
    fr "Pelo pouco que vi, pelo menos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:134
translate portuguese marimovietheaterstartdate_91db2110_1:

    # fr "I like what we did even more than the movie."
    fr "Gosto ainda mais do que fizemos do que do filme."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:135
translate portuguese marimovietheaterstartdate_233f5bf6:

    # "When the credits start rolling, we hang out and chat through them."
    "Quando os créditos começam a rolar, ficamos juntos a conversar durante os créditos."

# game/Scenes/Mari/MariDates/marimoviedate.rpy:139
translate portuguese marimovietheaterstartdate_972891e3:

    # "When the credits end, we walk outside together and out to my car."
    "Quando os créditos acabam, saímos juntos e vamos até ao meu carro."

translate portuguese strings:

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:2
    old "When you are able to ask Mari out on a date, take her to the movie theater."
    new "Quando conseguires convidar a Mari para sair, leva-a ao cinema."

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:3
    old "She will only be able to go to the movies in the evening on weekends."
    new "Ela só poderá ir ao cinema à noite, aos fins de semana."

    # game/Scenes/Mari/MariDates/marimoviedate.rpy:54
    old "Something animated"
    new "Algo de animação."

