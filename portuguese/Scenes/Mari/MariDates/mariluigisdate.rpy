# game/Scenes/Mari/MariDates/mariluigisdate.rpy:28
translate portuguese mariluigisstartdate_1ee44fe2:

    # "Mari and I sit next to each other at one of the booths at Luigi's."
    "A Mari e eu sentamo-nos lado a lado numa das cabines do Luigi's."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:29
translate portuguese mariluigisstartdate_0d18b373:

    # "We are chatting the whole time about this and that."
    "Passamos o tempo todo a conversar sobre isto e aquilo."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:30
translate portuguese mariluigisstartdate_5bdbd1f6:

    # "The waitress comes by and takes our order, we continue talking."
    "A empregada de mesa passa por nós e anota o nosso pedido, continuamos a conversar."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:34
translate portuguese mariluigisstartdate_f9e372f9:

    # "After a short time, the waitress brings our food out to us and we continue talking while we eat."
    "Passado pouco tempo, a empregada traz-nos a comida e continuamos a conversar enquanto comemos."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:37
translate portuguese mariluigisstartdate_54f7ac2e:

    # "We take our time eating while we talk, just enjoying one another's company."
    "Demoramos o nosso tempo a comer enquanto conversamos, apenas a desfrutar da companhia um do outro."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:40
translate portuguese mariluigisstartdate_764eafa0:

    # fr "Good salad, but the service here isn't great huh?"
    fr "A salada está boa, mas o serviço aqui não é grande coisa, pois não?"

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:41
translate portuguese mariluigisstartdate_407731d1:

    # fr "Waiter didn't even face the dang silverware the correct way."
    fr "O empregado nem sequer colocou os talheres na posição correta."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:42
translate portuguese mariluigisstartdate_c54b50c7:

    # pc "Well they can't all be as good as you."
    pc "Bem, nem todos podem ser tão bons como tu."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:44
translate portuguese mariluigisstartdate_a4da275d:

    # fr "Aww..."
    fr "Ah..."

# game/Scenes/Mari/MariDates/mariluigisdate.rpy:48
translate portuguese mariluigisstartdate_360f4aaa:

    # "When we're done with the meal, I pay the waitress and Mari and I walk out to the car together and start back towards her house."
    "Quando terminamos a refeição, pago à empregada e a Mari e eu saímos juntos para o carro e voltamos para a casa dela."

