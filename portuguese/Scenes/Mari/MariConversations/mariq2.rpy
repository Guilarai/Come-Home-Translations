translate portuguese mariq2_6275f344:

    # pc "I do. I'm working at a law office right now as an assistant."
    pc "Tenho. Estou a trabalhar num escritório de advogados neste momento como assistente."

# game/Scenes/Mari/MariConversations/mariq2.rpy:15
