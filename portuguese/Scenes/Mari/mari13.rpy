# game/Scenes/Mari/mari13.rpy:23
translate portuguese mari13_180b4647:

    # fr "I thought maybe if I could get it running again, I could try to learn how to drive."
    fr "Pensei que talvez, se conseguisse pô-la a funcionar novamente, pudesse tentar aprender a conduzir."

