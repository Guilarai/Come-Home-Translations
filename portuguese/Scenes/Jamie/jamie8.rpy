# game/Scenes/Jamie/jamie8.rpy:13
translate portuguese jamie8_98ca1a51:

    # "My phone buzzes in my pocket."
    "O meu telemóvel vibra no bolso."

# game/Scenes/Jamie/jamie8.rpy:15
translate portuguese jamie8_7a608d10:

    # "It's Jamie. I lie on my bed and answer the phone."
    "É a Jamie. Deito-me na cama e atendo o telefone."

# game/Scenes/Jamie/jamie8.rpy:19
translate portuguese jamie8_80c674d7:

    # pc "Hey, Jamie."
    pc "Olá, Jamie."

# game/Scenes/Jamie/jamie8.rpy:20
translate portuguese jamie8_3d698c03:

    # gnd "Hey. You busy?"
    gnd "Olá. Estás ocupado?"

# game/Scenes/Jamie/jamie8.rpy:21
translate portuguese jamie8_4474e21b:

    # pc "Nah. What's up?"
    pc "Não. O que se passa?"

# game/Scenes/Jamie/jamie8.rpy:22
translate portuguese jamie8_34eb8872:

    # gnd "Nothing really. Just wanted to talk to you. Miss you."
    gnd "Nada de especial. Só queria falar contigo. Tenho saudades tuas."

# game/Scenes/Jamie/jamie8.rpy:23
translate portuguese jamie8_71edcec9:

    # pc "Well.. you could come over?"
    pc "Bem... podias vir cá?"

# game/Scenes/Jamie/jamie8.rpy:25
translate portuguese jamie8_a38e761a:

    # gnd "You know I can't really do that. My dad would be so mad."
    gnd "Sabes que não posso fazer isso. O meu pai ficaria furioso."

# game/Scenes/Jamie/jamie8.rpy:26
translate portuguese jamie8_9f0961af:

    # pc "Why? You're an adult. Why does he get a say in what you do?"
    pc "Porquê? És adulta. Porque é que ele tem uma palavra a dizer no que fazes?"

# game/Scenes/Jamie/jamie8.rpy:27
translate portuguese jamie8_57cb5e24:

    # gnd "I know. I just don't want him to be mad."
    gnd "Eu sei. Só não quero que ele fique zangado."

# game/Scenes/Jamie/jamie8.rpy:28
translate portuguese jamie8_0833b2b4:

    # gnd "I'll talk to him soon though, I promise."
    gnd "Mas vou falar com ele em breve, prometo."

# game/Scenes/Jamie/jamie8.rpy:29
translate portuguese jamie8_b1a2e372:

    # gnd "I know I need to. It's just hard, because I know he's not going to like what I have to say."
    gnd "Sei que preciso de o fazer. Só que é difícil, porque sei que ele não vai gostar do que tenho para dizer."

# game/Scenes/Jamie/jamie8.rpy:30
translate portuguese jamie8_6cd88cb3:

    # gnd "And he works so hard, and I love him so much. I just hate to make him upset."
    gnd "E ele trabalha tanto, e eu amo-o tanto. Detesto deixá-lo chateado."

# game/Scenes/Jamie/jamie8.rpy:32
translate portuguese jamie8_dbc86daf:

    # gnd "But you mean so much to me. I don't want to have to keep sneaking around, keeping us a secret."
    gnd "Mas tu significas tanto para mim. Não quero ter de continuar a agir às escondidas, a manter o nosso relacionamento em segredo."

# game/Scenes/Jamie/jamie8.rpy:33
translate portuguese jamie8_aa61dfea:

    # gnd "I just need to build up the courage to do it."
    gnd "Só preciso de reunir coragem para o fazer."

# game/Scenes/Jamie/jamie8.rpy:37
translate portuguese jamie8_07bcbb36:

    # gnd "Thank you. I'm glad. You've been very patient with me."
    gnd "Obrigada. Fico contente. Tens sido muito paciente comigo."

# game/Scenes/Jamie/jamie8.rpy:39
translate portuguese jamie8_a5d0737c:

    # gnd "I'll make it worth it for you, I promise."
    gnd "Vou fazer com que valha a pena para ti, prometo."

# game/Scenes/Jamie/jamie8.rpy:40
translate portuguese jamie8_5de186d8:

    # pc "It's already worth it, Jamie."
    pc "Já vale a pena, Jamie."

# game/Scenes/Jamie/jamie8.rpy:43
translate portuguese jamie8_911c62b3:

    # gnd "You're right. I'm sorry."
    gnd "Tens razão. Desculpa."

# game/Scenes/Jamie/jamie8.rpy:44
translate portuguese jamie8_d5112d06:

    # gnd "You shouldn't have to deal with all of this drama. I know you're dealing with your own things, with your dad missing and all."
    gnd "Não devias ter de lidar com todo este drama. Sei que estás a lidar com os teus próprios problemas, com o teu pai desaparecido e tudo o mais."

# game/Scenes/Jamie/jamie8.rpy:45
translate portuguese jamie8_5a747778:

    # gnd "I should be there for you more."
    gnd "Devia estar mais presente para ti."

# game/Scenes/Jamie/jamie8.rpy:47
translate portuguese jamie8_9d979554:

    # gnd "And I will be. I promise. I'll tell him soon."
    gnd "E estarei. Prometo. Vou contar-lhe em breve."

# game/Scenes/Jamie/jamie8.rpy:49
translate portuguese jamie8_d41d8cd9:

    # voice "voices/jamie_022.mp3"        
    voice "voices/jamie_022.mp3"        

# game/Scenes/Jamie/jamie8.rpy:50
translate portuguese jamie8_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Amo-te, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:56
translate portuguese jamie8_b629d4db:

    # gnd "That feels good to say... and to hear."
    gnd "É bom dizer isto... e ouvi-lo."

# game/Scenes/Jamie/jamie8.rpy:58
translate portuguese jamie8_4d7bfc98:

    # gnd "I really mean it too."
    gnd "E estou mesmo a falar a sério."

# game/Scenes/Jamie/jamie8.rpy:60
translate portuguese jamie8_d41d8cd9_1:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:61
translate portuguese jamie8_8cee1605:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart is growing bigger and bigger until it's close to bursting."
    gnd "Desde que voltaste, tenho sentido isto a crescer, como se o meu coração estivesse a ficar cada vez maior, até estar prestes a rebentar."

# game/Scenes/Jamie/jamie8.rpy:63
translate portuguese jamie8_d41d8cd9_2:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:64
translate portuguese jamie8_55ac6cf8:

    # gnd "I smile every time I think about you, and I find myself thinking about you all the time."
    gnd "Sorrio sempre que penso em ti, e dou por mim a pensar em ti o tempo todo."

# game/Scenes/Jamie/jamie8.rpy:67
translate portuguese jamie8_d41d8cd9_3:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:68
translate portuguese jamie8_a90d9888:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Estou completamente apaixonado por ti, [pcname]. Só queria que soubesses disso."

# game/Scenes/Jamie/jamie8.rpy:69
translate portuguese jamie8_9fc0bac9:

    # pc "I feel the same way, Jamie. You're amazing."
    pc "Sinto o mesmo, Jamie. És incrível."

# game/Scenes/Jamie/jamie8.rpy:71
translate portuguese jamie8_ff198159:

    # gnd "I'm so happy."
    gnd "Estou tão feliz."

# game/Scenes/Jamie/jamie8.rpy:72
translate portuguese jamie8_69aafc54:

    # "We talk a little longer about other less important things, until we're both practically falling asleep on the phone."
    "Falamos um pouco mais sobre outras coisas menos importantes, até que ambos estamos praticamente a adormecer ao telefone."

# game/Scenes/Jamie/jamie8.rpy:74
translate portuguese jamie8_fcdf2655:

    # gnd "I better get some sleep."
    gnd "É melhor eu ir dormir."

# game/Scenes/Jamie/jamie8.rpy:75
translate portuguese jamie8_fdc5f0f0:

    # pc "Yeah, me too."
    pc "Sim, eu também."

# game/Scenes/Jamie/jamie8.rpy:77
translate portuguese jamie8_d41d8cd9_4:

    # voice "voices/jamie_010.mp3"
    voice "voices/jamie_010.mp3"

# game/Scenes/Jamie/jamie8.rpy:78
translate portuguese jamie8_63e5a3ef:

    # gnd "Good night, [pcname]. Love you."
    gnd "Boa noite, [pcname]. Amo-te."

# game/Scenes/Jamie/jamie8.rpy:79
translate portuguese jamie8_727173cd:

    # pc "Love you too, Jamie. Good night."
    pc "Também te amo, Jamie. Boa noite."

# game/Scenes/Jamie/jamie8.rpy:82
translate portuguese jamie8_a25f5d31:

    # gnd "I mean it."
    gnd "Estou a falar a sério."

# game/Scenes/Jamie/jamie8.rpy:84
translate portuguese jamie8_d41d8cd9_5:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:85
translate portuguese jamie8_796c0fbd:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart growing bigger and bigger until it's almost bursting now."
    gnd "Desde que voltaste, tenho sentido isto a crescer, como se o meu coração estivesse a ficar cada vez maior, até estar quase a rebentar agora."

# game/Scenes/Jamie/jamie8.rpy:87
translate portuguese jamie8_d41d8cd9_6:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:88
translate portuguese jamie8_0d1296eb:

    # gnd "I smile every time I think about you, and I find myself thinking about you a lot."
    gnd "Sorrio sempre que penso em ti, e dou por mim a pensar muito em ti."

# game/Scenes/Jamie/jamie8.rpy:90
translate portuguese jamie8_d41d8cd9_7:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:91
translate portuguese jamie8_a90d9888_1:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Estou completamente apaixonado por ti, [pcname]. Só queria que soubesses disso."

# game/Scenes/Jamie/jamie8.rpy:92
translate portuguese jamie8_fb4ce796:

    # pc "Oh, okay. Good to know."
    pc "Oh, está bem. É bom saber."

# game/Scenes/Jamie/jamie8.rpy:94
translate portuguese jamie8_5b0a7e45:

    # "We talk awkwardly a little bit longer about less important things, then there's just silence between us for a while."
    "Falamos um pouco mais, de forma um pouco estranha, sobre coisas menos importantes, depois fica apenas silêncio entre nós por um bocado."

# game/Scenes/Jamie/jamie8.rpy:95
translate portuguese jamie8_fcdf2655_1:

    # gnd "I better get some sleep."
    gnd "É melhor ir dormir."

# game/Scenes/Jamie/jamie8.rpy:96
translate portuguese jamie8_fdc5f0f0_1:

    # pc "Yeah, me too."
    pc "Sim, eu também."

# game/Scenes/Jamie/jamie8.rpy:97
translate portuguese jamie8_76e2f41b:

    # gnd "Okay. Good night, [pcname]."
    gnd "Está bem. Boa noite, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:98
translate portuguese jamie8_6fd39c33:

    # pc "Night!"
    pc "Boa noite!"

