translate portuguese jamietv_63cf1660:

    # gnd "Oh the show's starting."
    gnd "Oh, o programa está a começar."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:22
translate portuguese jamietv_28a9be43:

    # "We sit and watch the show together. It isn't very interesting really."
    "Sentamo-nos e vemos o programa juntos. Na verdade, não é muito interessante."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:23
translate portuguese jamietv_dd69b654:

    # "I think about trying to make a move on her, but she sits on her side of the couch and I sit on mine and she never moves any closer or seems very interested in me at all."
    "Penso em tentar dar-lhe em cima, mas ela senta-se no seu lado do sofá e eu no meu, e ela nunca se aproxima nem parece muito interessada em mim."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:24
translate portuguese jamietv_497776e6:

    # "We chit-chat a little, but nothing interesting really happens."
    "Conversamos um pouco, mas nada de interessante acontece."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:25
translate portuguese jamietv_6d914513:

    # "When the show is over, she leads me to the front door."
    "Quando o programa acaba, ela leva-me até à porta da frente."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:28
translate portuguese jamietv_a182f186:

    # gnd "Thanks for hanging out with me. It was fun."
    gnd "Obrigada por teres saído comigo. Foi divertido."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:29
translate portuguese jamietv_b7756d1b:

    # gnd "We should do it again sometime."
    gnd "Devíamos repetir isto um dia destes."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:30
translate portuguese jamietv_5f22bf29:

    # pc "Yeah sure, sounds good."
    pc "Sim, claro, parece-me bem."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:31
translate portuguese jamietv_36153c03:

    # gnd "Alright, well good night."
    gnd "Muito bem, então boa noite."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:32
translate portuguese jamietv_5c92bc6a:

    # pc "Good night."
    pc "Boa noite."

# game/Scenes/Jamie/JamieTV/jamietv.rpy:34
translate portuguese jamietv_0981f357:

    # "With that, she goes back inside and closes the door and I walk back over my house."
    "Dito isto, ela volta para dentro e fecha a porta, e eu volto para minha casa."

