# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:27
translate portuguese jamiep3_bc820600:

    # gnd "Yeah, at least I have that."
    gnd "Sim, pelo menos tenho isso."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:28
