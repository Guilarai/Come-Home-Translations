# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:16
translate portuguese jamiep3_70c8d02c:

    # gnd "There's a couple of girls in class that I talk to, but we don't really hang out or anything."
    gnd "Há umas duas raparigas na turma com quem converso, mas não saímos juntas nem nada."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:17
translate portuguese jamiep3_a4b86b2a:

    # gnd "It's hard to make friends as an adult - especially when you spend most of your time at home, like I do."
    gnd "É difícil fazer amigos quando se é adulto — especialmente quando se passa a maior parte do tempo em casa, como eu."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:18
translate portuguese jamiep3_6a377a93:

    # gnd "That's why I go to Java Lava to have my coffee every morning."
    gnd "É por isso que vou ao Java Lava tomar o meu café todas as manhãs."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:19
translate portuguese jamiep3_b4b2cc87:

    # gnd "I get lonely."
    gnd "Sinto-me sozinha."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:23
translate portuguese jamiep3_ab221d8d:

    # gnd "I know. That's what my dad says too."
    gnd "Eu sei. É o que o meu pai também diz."

# game/Scenes/Jamie/JamieConversation/jamiep3.rpy:24
translate portuguese jamiep3_1912dfae:

