# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:137
translate portuguese jamiemovietheaterstartdate_bfe93711:

    # pc "Yeah I though it was pretty cool."
    pc "Sim, achei bastante fixe."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:138
translate portuguese jamiemovietheaterstartdate_045099e4:

