# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:147
translate portuguese jamiemovietheaterstartdate_cd12116f:

    # gnd "That movie was SO funny!"
    gnd "Aquele filme foi TÃO engraçado!"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:148
translate portuguese jamiemovietheaterstartdate_e1a20436:

    # gnd "My chest hurts from laughing so much."
    gnd "Dói-me o peito de tanto rir."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:149
translate portuguese jamiemovietheaterstartdate_262d3cf7:

    # gnd "I loved it. Thanks for bringing me."
    gnd "Adorei. Obrigada por me levares."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:151
translate portuguese jamiemovietheaterend_1a39771f:

    # gnd "Want to just sit and chat through the credits?"
