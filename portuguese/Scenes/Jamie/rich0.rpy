# game/Scenes/Jamie/rich0.rpy:11
translate portuguese rich0_cfa93e6c:

    # "I walk over to Jamie's house and knock on the door."
    "Dirijo-me à casa da Jamie e bato à porta."

# game/Scenes/Jamie/rich0.rpy:14
translate portuguese rich0_3517dc2a:

    # "Jamie's dad answers the door and looks at me with a visible snarl."
    "O pai da Jamie abre a porta e olha para mim com um rosnado visível."

# game/Scenes/Jamie/rich0.rpy:15
translate portuguese rich0_f8843cde:

    # pc "Is Jamie home?"
    pc "A Jamie está em casa?"

# game/Scenes/Jamie/rich0.rpy:16
translate portuguese rich0_8dae1bff:

    # jd "Look [pcname], I don't know why you're back and I don't really care, you just leave my Jamie out of it."
    jd "Olha [pcname], não sei porque voltaste e nem me interessa, mas deixa a minha Jamie fora disto."

# game/Scenes/Jamie/rich0.rpy:17
translate portuguese rich0_b43e0748:

    # jd "I don't want you talking to her. I don't want you looking at her. I don't want you even thinking about her."
    jd "Não quero que fales com ela. Não quero que olhes para ela. Não quero que sequer penses nela."

# game/Scenes/Jamie/rich0.rpy:18
translate portuguese rich0_fdac7df1:

    # jd "Now get the hell off my porch and don't come back over here again."
    jd "Agora sai da minha varanda e não voltes mais aqui."

# game/Scenes/Jamie/rich0.rpy:20
translate portuguese rich0_0c9032ac:

    # "Before I can even formulate a response, he slams the door in my face."
    "Antes mesmo de eu conseguir formular uma resposta, ele bate-me a porta na cara."

# game/Scenes/Jamie/rich0.rpy:21
translate portuguese rich0_b20e176c:

    # "I'm so confused. I have no idea what I did to him that made him hate me so much."
    "Estou tão confuso. Não faço ideia do que lhe fiz para ele me odiar tanto."

# game/Scenes/Jamie/rich0.rpy:22
translate portuguese rich0_849077d5:

    # "I'll just have to talk to Jamie sometime when he's not here."
    "Vou ter de falar com a Jamie noutro momento, quando ele não estiver aqui."

translate portuguese strings:

    # game/Scenes/Jamie/rich0.rpy:2
    old "After the first time you hang out with Jamie at her house,"
    new "Depois da primeira vez que te encontrares com a Jamie na casa dela,"

    # game/Scenes/Jamie/rich0.rpy:3
    old "go to Jamie's house on the weekend or in the morning, when her dad is home."
    new "vai à casa da Jamie no fim de semana ou de manhã, quando o pai dela estiver em casa."

