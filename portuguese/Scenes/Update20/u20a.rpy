# game/Scenes/Update20/u20a.rpy:14
translate portuguese u20a_45da60e7:

    # wt "Finally, you're back. Took you long enough."
    wt "Finalmente, estás de volta. Demoraste o teu tempo."

# game/Scenes/Update20/u20a.rpy:15
translate portuguese u20a_fd9e8f88:

    # wt "I really thought I might be going to jail!"
    wt "Cheguei mesmo a pensar que ia para a prisão!"

# game/Scenes/Update20/u20a.rpy:18
translate portuguese u20a_a33db221:

    # pc "How long have I been gone?"
    pc "Há quanto tempo é que estive fora?"

# game/Scenes/Update20/u20a.rpy:19
translate portuguese u20a_e000eef8:

    # wt "Thirty days."
    wt "Trinta dias."

# game/Scenes/Update20/u20a.rpy:22
translate portuguese u20a_8d8b1bd7:

    # pc "THIRTY!?"
    pc "TRINTA!?"

# game/Scenes/Update20/u20a.rpy:23
translate portuguese u20a_d92a0cb0:

    # wt "Yes. It's been a difficult time for me as well."
    wt "Sim. Tem sido um período difícil para mim também."

# game/Scenes/Update20/u20a.rpy:27
translate portuguese u20a_c77aa2a4:

    # wt "Lisa has been very persistent and is nearing her breaking point. I suspect she may involve the police soon."
    wt "A Lisa tem sido muito persistente e está a chegar ao seu limite. Suspeito que ela possa envolver a polícia em breve."

# game/Scenes/Update20/u20a.rpy:28
translate portuguese u20a_c1e86e55:

    # wt "She thinks I killed both you and your dad."
    wt "Ela acha que eu matei tanto a ti como ao teu pai."

# game/Scenes/Update20/u20a.rpy:32
translate portuguese u20a_9a9b3000:

    # wt "Suzy and Tammy have been after me every day. I don't think I could hold them off from calling the police for much longer."
    wt "A Suzy e a Tammy têm-me perseguido todos os dias. Acho que não consigo impedi-las de chamar a polícia por muito mais tempo."

# game/Scenes/Update20/u20a.rpy:33
translate portuguese u20a_24d0649b:

    # wt "They brought in Suzy's mom too, Lisa."
    wt "Elas trouxeram a mãe da Suzy também, a Lisa."

# game/Scenes/Update20/u20a.rpy:34
translate portuguese u20a_c0b726db:

    # wt "They are not happy with me. Tammy has threatened me with physical violence. I'd prefer to avoid that."
    wt "Elas não estão contentes comigo. A Tammy ameaçou-me com violência física. Preferia evitar isso."

# game/Scenes/Update20/u20a.rpy:38
translate portuguese u20a_0904113a:

    # wt "Jamie has been after me every day. I don't think I could hold her off from calling the police for much longer."
    wt "A Jamie tem-me perseguido todos os dias. Acho que não vou conseguir impedir que ela chame a polícia por muito mais tempo."

# game/Scenes/Update20/u20a.rpy:39
