# game/Scenes/Update20/u20a.rpy:117
translate portuguese u20a_e2431baa:

    # pc "Me too. Thanks for all your help, Whitney."
    pc "Eu também. Obrigado por toda a tua ajuda, Whitney."

# game/Scenes/Update20/u20a.rpy:120
translate portuguese u20a_b931c84d:

    # wt "Your car and your cell phone are still here. I hid them out back."
    wt "O teu carro e o teu telemóvel ainda estão aqui. Escondi-os nas traseiras."

# game/Scenes/Update20/u20a.rpy:121
translate portuguese u20a_167b4558:

    # wt "You should go home and notify everyone that you are safe."
    wt "Devias ir para casa e avisar toda a gente de que estás bem."

# game/Scenes/Update20/u20a.rpy:122
translate portuguese u20a_bab6484a:

    # pc "Yeah, I suppose you're right."
    pc "Sim, acho que tens razão."

# game/Scenes/Update20/u20a.rpy:124
translate portuguese u20a_9672a6f0:

    # wt "But I'll want you to fill me in on everything as soon as you're able. I have many questions."
    wt "Mas quero que me contes tudo assim que puderes. Tenho muitas perguntas."

# game/Scenes/Update20/u20a.rpy:125
translate portuguese u20a_a248948f:

    # pc "Of course."
    pc "Claro."

# game/Scenes/Update20/u20a.rpy:128
