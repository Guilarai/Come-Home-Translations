# game/Scenes/Update20/u20d.rpy:2
translate portuguese u20d_57a32b89:

    # "For now, I should go see Jamie."
    "Por agora, tenho de ir ver a Jamie."

# game/Scenes/Update20/u20d.rpy:5
translate portuguese u20d_09cc067a:

    # "I drive home, then walk over to Jamie's house, and ring the doorbell."
    "Conduzo até casa, depois vou a pé até à casa da Jamie e toco à campainha."

# game/Scenes/Update20/u20d.rpy:6
translate portuguese u20d_5240dedf:

    # "It's late and I hate to wake them, but I need to see her."
    "Já é tarde e detesto acordá-los, mas preciso de a ver."

# game/Scenes/Update20/u20d.rpy:9
translate portuguese u20d_65a45c72:

    # jd "[pcname]?"
    jd "[pcname]?"

# game/Scenes/Update20/u20d.rpy:10
translate portuguese u20d_4297141b:

    # jd "What the hell happened to you, son?"
    jd "O que raio te aconteceu, filho?"

# game/Scenes/Update20/u20d.rpy:11
translate portuguese u20d_606da365:

    # jd "I thought you took off again. Jamie's been upset for weeks."
    jd "Pensei que tivesses fugido outra vez. A Jamie está chateada há semanas."

# game/Scenes/Update20/u20d.rpy:12
translate portuguese u20d_61c5bb7a:

    # pc "I'm sorry. I didn't mean to leave for so long. I've been trying to get back."
    pc "Desculpa. Não era minha intenção ficar fora tanto tempo. Tenho tentado voltar."

# game/Scenes/Update20/u20d.rpy:15
translate portuguese u20d_ad0c6ecb:

    # jd "She's going to be happy to see you."
    jd "Ela vai ficar feliz por te ver."

# game/Scenes/Update20/u20d.rpy:16
translate portuguese u20d_a1205e82:

    # jd "Why don't you just go up and see her?"
    jd "Porque não subes a ver como ela está?"

# game/Scenes/Update20/u20d.rpy:17
translate portuguese u20d_02b70148:

    # pc "Thanks, Rich."
    pc "Obrigado, Rich."

# game/Scenes/Update20/u20d.rpy:18
translate portuguese u20d_f246a5a7:

    # jd "Nice beard by the way."
    jd "A barba está gira, já agora."

# game/Scenes/Update20/u20d.rpy:22
translate portuguese u20d_e2bc298b:

    # "I walk quietly up the stairs and into Jamie's room. She's in bed, sleeping."
    "Subo as escadas em silêncio e entro no quarto da Jamie. Ela está na cama, a dormir."

# game/Scenes/Update20/u20d.rpy:25
translate portuguese u20d_a95bfc0c:

    # "Trying not to wake her immediately, I lie next to her and wrap her in my arms."
    "Tentando não a acordar de imediato, deito-me ao lado dela e envolvo-a nos meus braços."

# game/Scenes/Update20/u20d.rpy:28
translate portuguese u20d_c981bd85:

    # "She jolts awake and looks at me, shocked."
    "Ela acorda de sobressalto e olha para mim, chocada."

# game/Scenes/Update20/u20d.rpy:29
translate portuguese u20d_95496a48:

    # gnd "[pcname]? Is it really you?"
    gnd "[pcname]? És mesmo tu?"

# game/Scenes/Update20/u20d.rpy:32
translate portuguese u20d_0f0952fe:

    # "I don't answer. I just pull her close and kiss her deeply."
    "Não respondo. Apenas a puxo para perto de mim e beijo-a profundamente."

# game/Scenes/Update20/u20d.rpy:33
translate portuguese u20d_3375c7eb:

    # gnd "I thought I lost you! I've been so worried."
    gnd "Pensei que te tinha perdido! Estava tão preocupada."

# game/Scenes/Update20/u20d.rpy:36
translate portuguese u20d_de1105f0:

    # gnd "So all of that stuff was true? You really saw your dad?"
    gnd "Então, tudo aquilo era verdade? Viste mesmo o teu pai?"

# game/Scenes/Update20/u20d.rpy:37
translate portuguese u20d_2a9e9f2b:

    # pc "Yeah, I did. It's all true. I'll tell you about it tomorrow."
    pc "Sim, vi. É tudo verdade. Conto-te tudo amanhã."

# game/Scenes/Update20/u20d.rpy:40
translate portuguese u20d_34ae9f69:

    # gnd "I'm just glad you're back."
    gnd "Só estou feliz por estares de volta."

# game/Scenes/Update20/u20d.rpy:41
translate portuguese u20d_25f299a8:

    # gnd "That hair looks awful though."
    gnd "Mas esse cabelo está horrível."

# game/Scenes/Update20/u20d.rpy:44
translate portuguese u20d_f432b969:

    # "I pull her close and kiss her again, feeling her warmth."
    "Puxo-a para perto de mim e beijo-a novamente, sentindo o seu calor."

# game/Scenes/Update20/u20d.rpy:45
translate portuguese u20d_137d3396:

    # gnd "I missed you so much, [pcname]."
    gnd "Tive tantas saudades tuas, [pcname]."

# game/Scenes/Update20/u20d.rpy:46
translate portuguese u20d_12a0fbc0:

    # pc "I missed you too, Jamie."
    pc "Também tive saudades tuas, Jamie."

