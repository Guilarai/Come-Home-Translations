    # "For now, I should go see Bai."
    "Por agora, tenho de ir ver o Bai."

# game/Scenes/Update20/u20n.rpy:5
translate portuguese u20n_5e377e6b:

    # "I drive to Bai's apartment and knock on the door."
    "Dirijo-me ao apartamento do Bai e bato à porta."

# game/Scenes/Update20/u20n.rpy:6
translate portuguese u20n_cd826cbc:

    # "It's late, but I have to see him."
    "É tarde, mas tenho de o ver."

# game/Scenes/Update20/u20n.rpy:10
translate portuguese u20n_435415c3:

    # "After a few moments, Bai opens the door."
    "Passados alguns instantes, o Bai abre a porta."

# game/Scenes/Update20/u20n.rpy:11
translate portuguese u20n_fce568f9:

    # bai "Holy shit, [pcname]! You're back!"
    bai "Caramba, [pcname]! Estás de volta!"

# game/Scenes/Update20/u20n.rpy:14
translate portuguese u20n_7e7c2a33:

    # "I wrap my arms around Bai, pulling him in tight."
    "Envolvo o Bai nos meus braços, apertando-o com força."

# game/Scenes/Update20/u20n.rpy:15
translate portuguese u20n_e660f3f5:

    # bai "I thought that machine killed you!"
    bai "Pensei que aquela máquina te tivesse matado!"

# game/Scenes/Update20/u20n.rpy:16
translate portuguese u20n_52e92c2d:

    # bai "I thought I might never see you again."
    bai "Pensei que talvez nunca mais te visse."

# game/Scenes/Update20/u20n.rpy:19
translate portuguese u20n_e99c4913:

    # bai "So what happened? Did you really go to another universe?"
    bai "Então, o que aconteceu? Foste mesmo para outro universo?"

# game/Scenes/Update20/u20n.rpy:20
translate portuguese u20n_4859fa2f:

    # pc "Yeah, I did. I saw my dad."
    pc "Sim, fui. Vi o meu pai."

# game/Scenes/Update20/u20n.rpy:21
translate portuguese u20n_d8ec5a44:

    # bai "Wow. Are you okay?"
    bai "Uau. Estás bem?"

# game/Scenes/Update20/u20n.rpy:22
translate portuguese u20n_3c3fa8e3:

    # pc "Yeah, I'm great. I'll tell you everything tomorrow, I promise."
    pc "Sim, estou ótimo. Conto-te tudo amanhã, prometo."

# game/Scenes/Update20/u20n.rpy:25
translate portuguese u20n_feac206a:

    # bai "I'm just glad you're back."
    bai "Só estou feliz por estares de volta."

# game/Scenes/Update20/u20n.rpy:26
translate portuguese u20n_03eaad50:

    # pc "Me too."
    pc "Eu também."

# game/Scenes/Update20/u20n.rpy:29
translate portuguese u20n_61ae245c:

    # "He leans in and kisses me softly."
    "Ele inclina-se e beija-me suavemente."

# game/Scenes/Update20/u20n.rpy:30
translate portuguese u20n_8466d1ae:

    # bai "Whoo, damn, you smell pretty bad though."
    bai "Uau, caramba, mas cheiras bastante mal."

# game/Scenes/Update20/u20n.rpy:31
translate portuguese u20n_dfccd340:

    # bai "Let's take a shower and go to bed."
    bai "Vamos tomar um banho e ir para a cama."

