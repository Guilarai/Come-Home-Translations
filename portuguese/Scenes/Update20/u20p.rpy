translate portuguese u20p_1b7a0d04:

    # "For now, I should go see Mi-Cha."
    "Por agora, vou ver a Mi-Cha."

# game/Scenes/Update20/u20p.rpy:6
translate portuguese u20p_6c85aa97:

    # "I drive over to Mi-Cha's dorm and knock on her door, trying to be quiet so I don't wake up anyone else."
    "Dirijo-me ao dormitório da Mi-Cha e bato à porta, tentando não fazer barulho para não acordar mais ninguém."

# game/Scenes/Update20/u20p.rpy:10
translate portuguese u20p_a016dbb5:

    # "After a few moments, Mi-Cha opens the door."
    "Passados alguns instantes, a Mi-Cha abre a porta."

# game/Scenes/Update20/u20p.rpy:11
translate portuguese u20p_78132b1d:

    # mc "[pcname]! Oh my God, it's you!"
    mc "[pcname]! Meu Deus, és tu!"

# game/Scenes/Update20/u20p.rpy:14
translate portuguese u20p_29857b39:

    # "She practically leaps into my arms, wrapping me in a tight embrace."
    "Ela praticamente salta para os meus braços, envolvendo-me num abraço apertado."

# game/Scenes/Update20/u20p.rpy:15
translate portuguese u20p_daf29bbf:

    # mc "I missed you so much!"
    mc "Tive tantas saudades tuas!"

# game/Scenes/Update20/u20p.rpy:16
translate portuguese u20p_48732134:

    # pc "I missed you too, Mi-Cha."
    pc "Também senti a tua falta, Mi-Cha."

# game/Scenes/Update20/u20p.rpy:19
translate portuguese u20p_6c2a8295:

    # mc "What happened? Did the thing you were trying to do work?"
    mc "O que aconteceu? Aquilo que estavas a tentar fazer resultou?"

# game/Scenes/Update20/u20p.rpy:20
translate portuguese u20p_f4fa6482:

    # pc "Yes it did. I didn't mean to be gone so long, but it worked."
    pc "Sim, resultou. Não era minha intenção ficar fora tanto tempo, mas resultou."

# game/Scenes/Update20/u20p.rpy:21
translate portuguese u20p_48ae30e6:

    # pc "I'll tell you all about it tomorrow."
    pc "Conto-te tudo amanhã."

# game/Scenes/Update20/u20p.rpy:22
translate portuguese u20p_556bcc63:

    # mc "But you are here now? You won't leave me again?"
    mc "Mas agora estás aqui? Não me vais deixar outra vez?"

# game/Scenes/Update20/u20p.rpy:23
translate portuguese u20p_39bfeeda:

    # pc "No, I'm not going anywhere."
    pc "Não, não vou a lado nenhum."

# game/Scenes/Update20/u20p.rpy:26
translate portuguese u20p_8253f92f:

    # mc "I am so glad you came home."
    mc "Estou tão feliz por teres voltado para casa."

# game/Scenes/Update20/u20p.rpy:27
translate portuguese u20p_6d3a55c4:

    # mc "I didn't know what to do without you."
    mc "Não sabia o que fazer sem ti."

# game/Scenes/Update20/u20p.rpy:30
translate portuguese u20p_b55a59c5:

    # "She leans in and kisses me softly."
    "Ela inclina-se e beija-me suavemente."

# game/Scenes/Update20/u20p.rpy:31
translate portuguese u20p_d17bdb85:

    # mc "I love you so much."
    mc "Amo-te tanto."

# game/Scenes/Update20/u20p.rpy:32
translate portuguese u20p_5735beae:

    # pc "I love you too, Mi-Cha."
    pc "Também te amo, Mi-Cha."

