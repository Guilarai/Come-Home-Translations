# game/Scenes/Update20/u20l.rpy:3
translate portuguese u20l_c0cbad5f:

    # "For now, I should go see Brandi."
    "Por agora, tenho de ir ver a Brandi."

# game/Scenes/Update20/u20l.rpy:6
translate portuguese u20l_6783b0e6:

    # "I drive to Brandi's apartment and knock on her door."
    "Conduzo até ao apartamento da Brandi e bato à porta."

# game/Scenes/Update20/u20l.rpy:7
translate portuguese u20l_7043290e:

    # "It's late, but I hope she'll still be awake. I have to see her."
    "É tarde, mas espero que ela ainda esteja acordada. Tenho de a ver."

# game/Scenes/Update20/u20l.rpy:11
translate portuguese u20l_1ccac3d3:

    # "After a few moments, Brandi opens the door."
    "Passados alguns instantes, a Brandi abre a porta."

# game/Scenes/Update20/u20l.rpy:12
translate portuguese u20l_4a243063:

    # fd "Holy shit, [pcname]! You're back!"
    fd "Caramba, [pcname]! Estás de volta!"

# game/Scenes/Update20/u20l.rpy:15
translate portuguese u20l_ad7d3606:

    # "I wrap my arms around Brandi, pulling her in tight."
    "Abraço a Brandi com força, puxando-a para mim."

# game/Scenes/Update20/u20l.rpy:16
translate portuguese u20l_e1a3df9c:

    # fd "I thought that machine killed you!"
    fd "Pensei que aquela máquina te tivesse matado!"

# game/Scenes/Update20/u20l.rpy:17
translate portuguese u20l_ebe2f7cf:

    # fd "I thought I was never going to see you again!"
    fd "Pensei que nunca mais te fosse ver!"

# game/Scenes/Update20/u20l.rpy:20
translate portuguese u20l_946b2987:

    # fd "What happened to you? Did you really go to another world, like you said?"
    fd "O que te aconteceu? Foste mesmo para outro mundo, como disseste?"

# game/Scenes/Update20/u20l.rpy:21
translate portuguese u20l_aac4f177:

    # pc "Yeah, I did. I saw my dad again. It was... a lot."
    pc "Sim, fui. Voltei a ver o meu pai. Foi... muito intenso."

# game/Scenes/Update20/u20l.rpy:22
translate portuguese u20l_34a96f57:

    # fd "Wow, I can't believe it. Are you okay?"
    fd "Uau, não consigo acreditar. Estás bem?"

# game/Scenes/Update20/u20l.rpy:23
translate portuguese u20l_3c3fa8e3:

    # pc "Yeah, I'm great. I'll tell you everything tomorrow, I promise."
    pc "Sim, estou ótimo. Conto-te tudo amanhã, prometo."

# game/Scenes/Update20/u20l.rpy:26
translate portuguese u20l_4188b1fa:

    # fd "I'm just so glad you're back."
    fd "Estou tão feliz por estares de volta."

# game/Scenes/Update20/u20l.rpy:27
translate portuguese u20l_80452f29:

    # fd "You're going to have to cut that hair though. Big oof."
    fd "Vais ter de cortar esse cabelo, no entanto. Ufa."

# game/Scenes/Update20/u20l.rpy:30
translate portuguese u20l_7d64063d:

    # "She kisses me softly, her lips warm and inviting."
    "Ela beija-me suavemente, os seus lábios quentes e convidativos."

# game/Scenes/Update20/u20l.rpy:31
translate portuguese u20l_392f9f2c:

    # fd "I'm so happy you came home."
    fd "Estou tão feliz por teres voltado para casa."

# game/Scenes/Update20/u20l.rpy:32
translate portuguese u20l_4d7d812c:

    # fd "Let's get you in the shower. You smell like a horse."
    fd "Vamos levar-te para o duche. Cheiras a cavalo."

