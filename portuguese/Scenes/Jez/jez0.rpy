# game/Scenes/Jez/jez0.rpy:103
translate portuguese questionsfirst_dd371cb0:

    # det "We could not find the keys for the car though. I assume he took them with him, wherever he went."
    det "No entanto, não conseguimos encontrar as chaves do carro. Presumo que ele as tenha levado consigo, para onde quer que tenha ido."

# game/Scenes/Jez/jez0.rpy:104
