    # pc "He was a quantum engineer."
    pc "Ele era engenheiro quântico."

# game/Scenes/Jez/jez0.rpy:85
translate portuguese questionsfirst_83365159:

    # det "I'm not really sure what that is."
    det "Não sei bem o que isso é."

