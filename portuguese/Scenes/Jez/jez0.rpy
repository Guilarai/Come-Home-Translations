translate portuguese questionsfirst_43128ee3:

    # pc "Yes, he's been working for them for over 20 years."
    pc "Sim, trabalhava para eles há mais de 20 anos."

# game/Scenes/Jez/jez0.rpy:89
translate portuguese questionsfirst_521e679d:

    # det "And he worked from home on his computer, correct?"
    det "E trabalhava a partir de casa no seu computador, certo?"

# game/Scenes/Jez/jez0.rpy:90
translate portuguese questionsfirst_10525e06:

    # pc "Yes. He had been working in their laboratory here in Skyhill, but when the lab closed five years ago, he began doing all his work remotely."
    pc "Sim. Ele trabalhava no laboratório deles aqui em Skyhill, mas quando o laboratório fechou há cinco anos, começou a fazer todo o seu trabalho remotamente."

# game/Scenes/Jez/jez0.rpy:92
translate portuguese questionsfirst_1ff9fb4d:

    # det "Do you know anything about what kind of work he was doing?"
    det "Sabe alguma coisa sobre o tipo de trabalho que ele fazia?"

