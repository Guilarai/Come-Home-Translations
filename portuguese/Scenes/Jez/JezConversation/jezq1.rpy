translate portuguese jezq1_0006598b:

    # det "Would it bother you if I slept with other guys?"
    det "Incomodava-te se eu dormisse com outros rapazes?"

# game/Scenes/Jez/JezConversation/jezq1.rpy:30
translate portuguese jezq1_b1557034:

    # pc "No, not really."
    pc "Não, nem por isso."

# game/Scenes/Jez/JezConversation/jezq1.rpy:32
translate portuguese jezq1_7dffffd9:

    # det "Really?"
