translate portuguese jezq1_ac6b7431:

    # det "It's really good to hear."
    det "É muito bom ouvir isso."

# game/Scenes/Jez/JezConversation/jezq1.rpy:38
translate portuguese jezq1_23ddb1c2:

    # det "But as long as you're giving me some time and affection and you're there for me when I need you, I don't need anybody else."
    det "Mas desde que me dês algum tempo e carinho e estejas lá para mim quando precisar de ti, não preciso de mais ninguém."

# game/Scenes/Jez/JezConversation/jezq1.rpy:39
translate portuguese jezq1_3ae8217d:

    # det "At least for now."
    det "Pelo menos por agora."

# game/Scenes/Jez/JezConversation/jezq1.rpy:41
translate portuguese jezq1_57122677:

    # det "Eventually, I would like somebody reliable, who is mine and only mine."
