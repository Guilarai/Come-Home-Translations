translate portuguese jez13_877b07f6:

    # "I call out, but I still don't hear any answer."
    "Chamo, mas continuo sem ouvir resposta."

# game/Scenes/Jez/jez13.rpy:48
translate portuguese jez13_d12b4849:

    # "I can hear something inside though. Running water."
    "No entanto, consigo ouvir algo lá dentro. Água a correr."

# game/Scenes/Jez/jez13.rpy:49
translate portuguese jez13_7dad49af:

    # pc "Jez? Are you okay?"
    pc "Jez? Estás bem?"

# game/Scenes/Jez/jez13.rpy:52
translate portuguese jez13_fcc96292:

    # "Nervous, I walk inside."
    "Nervoso, entro."

