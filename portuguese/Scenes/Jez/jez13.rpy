    # det "You did wonderful."
    det "Saíste-te maravilhosamente."

# game/Scenes/Jez/jez13.rpy:287
translate portuguese jez13_2a95c68b:

    # det "Seriously, [pcname]. Thank you for everything."
    det "A sério, [pcname]. Obrigado por tudo."

