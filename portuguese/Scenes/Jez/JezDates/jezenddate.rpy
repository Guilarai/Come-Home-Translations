translate portuguese jezenddate_687d0176:

    # det "So, do you want to come back to my place for a while?"
    det "Então, queres ir a minha casa por um bocadinho?"

# game/Scenes/Jez/JezDates/jezenddate.rpy:9
translate portuguese jezenddate_30d6b817:

    # det "Mamá's got Javi for a bit. We could spend some time together."
    det "A mamã ficou com o Javi por um tempo. Podíamos passar algum tempo juntos."

# game/Scenes/Jez/JezDates/jezenddate.rpy:12
translate portuguese jezenddate_3ba845d3:

    # det "Good, let's go."
    det "Ótimo, vamos lá."

# game/Scenes/Jez/JezDates/jezenddate.rpy:15
translate portuguese jezenddate_588b9a6e:

    # "We get in our cars and I follow her back to her house, where we quickly make our way inside to her bedroom."
    "Entramos nos nossos carros e sigo-a até à casa dela, onde rapidamente entramos e nos dirigimos para o quarto dela."

# game/Scenes/Jez/JezDates/jezenddate.rpy:19
translate portuguese jezenddate_77b42da9:

    # det "Oh, alright then. Well I had a nice date anyway. I'll see you later, [pcname]."
    det "Ah, tudo bem então. Bem, tive um encontro agradável de qualquer forma. Até logo, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:21
translate portuguese jezenddate_b4d69820:

    # "I lean in and we kiss, my arms wrapped around her."
    "Inclino-me e beijamo-nos, com os meus braços à volta dela."

# game/Scenes/Jez/JezDates/jezenddate.rpy:22
translate portuguese jezenddate_3091dff1:

    # pc "Bye, Jez. See you again soon."
    pc "Adeus, Jez. Até breve."

# game/Scenes/Jez/JezDates/jezenddate.rpy:25
translate portuguese jezenddate_f48c2630:

    # "She leaves, and I go back out to my car and drive away."
    "Ela sai, e eu volto para o meu carro e vou-me embora."

# game/Scenes/Jez/JezDates/jezenddate.rpy:29
translate portuguese jezenddate_716db417:

    # det "I had a really good time. I'm looking forward to doing this again soon."
    det "Diverti-me imenso. Estou ansioso por repetir isto em breve."

# game/Scenes/Jez/JezDates/jezenddate.rpy:30
translate portuguese jezenddate_03eaad50:

    # pc "Me too."
    pc "Eu também."

# game/Scenes/Jez/JezDates/jezenddate.rpy:33
translate portuguese jezenddate_398aacb4:

    # det "I'd invite you over to my place, but I'm not quite ready for my son to meet you yet."
    det "Convidava-te para ires a minha casa, mas ainda não estou preparada para que o meu filho te conheça."

# game/Scenes/Jez/JezDates/jezenddate.rpy:34
translate portuguese jezenddate_70367ea3:

    # det "I don't want him to get confused by male figures being in his life for only a short time."
    det "Não quero que ele fique confuso com a presença de figuras masculinas na sua vida apenas por um curto período de tempo."

# game/Scenes/Jez/JezDates/jezenddate.rpy:35
translate portuguese jezenddate_6cf8b822:

    # det "I want to make sure that this thing between me and you is real before we do that. I hope you understand."
    det "Quero ter a certeza de que isto entre nós é real antes de fazermos isso. Espero que compreendas."

# game/Scenes/Jez/JezDates/jezenddate.rpy:36
translate portuguese jezenddate_cca20d9e:

    # pc "I do understand."
    pc "Eu compreendo."

# game/Scenes/Jez/JezDates/jezenddate.rpy:38
translate portuguese jezenddate_3239d4cf:

    # det "Thanks."
    det "Obrigado."

# game/Scenes/Jez/JezDates/jezenddate.rpy:41
