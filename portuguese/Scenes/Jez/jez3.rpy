# game/Scenes/Jez/jez3.rpy:18
translate portuguese jez3_d41d8cd9:

    # voice 'voices/jez_answering.mp3'
    voice 'voices/jez_answering.mp3'

# game/Scenes/Jez/jez3.rpy:19
translate portuguese jez3_6673062e:

    # det "Detective Rodriguez."
    det "Detetive Rodriguez."

# game/Scenes/Jez/jez3.rpy:20
translate portuguese jez3_416b4b28:

    # pc "Hello, this is [pcname]."
    pc "Olá, é o [pcname]."

# game/Scenes/Jez/jez3.rpy:22
translate portuguese jez3_d41d8cd9_1:

    # voice 'voices/jez_hey.mp3'
    voice 'voices/jez_hey.mp3'

# game/Scenes/Jez/jez3.rpy:23
translate portuguese jez3_5f1522eb:

    # det "Hey, [pcname]. What's up?"
    det "Olá, [pcname]. Como estás?"

# game/Scenes/Jez/jez3.rpy:24
translate portuguese jez3_eb667b3e:

    # pc "I had some new information about my dad's case. I was able to get into his laptop."
    pc "Tenho novas informações sobre o caso do meu pai. Consegui aceder ao portátil dele."

# game/Scenes/Jez/jez3.rpy:25
translate portuguese jez3_a1187622:

    # pc "I found a bunch of e-mails between him and this Whitney person."
    pc "Encontrei vários e-mails entre ele e uma tal Whitney."

# game/Scenes/Jez/jez3.rpy:26
translate portuguese jez3_d2f98bdb:

    # det "Hey, [pcname]. Hold on a second."
    det "Olá, [pcname]. Espera um segundo."

# game/Scenes/Jez/jez3.rpy:28
translate portuguese jez3_77774b9f:

    # det "I'll be honest with you. I've had a really bad day and I have a migraine from hell."
    det "Vou ser sincero contigo. Tive um dia péssimo e estou com uma enxaqueca de morrer."

# game/Scenes/Jez/jez3.rpy:29
translate portuguese jez3_b0a1faa8:

    # det "Your voice on this phone is making my head pound. What do you say we meet up in person."
    det "A tua voz ao telefone está a fazer a minha cabeça latejar. Que tal encontrarmo-nos pessoalmente?"

# game/Scenes/Jez/jez3.rpy:30
translate portuguese jez3_7cfb0b0e:

    # det "Do you know where The Pit is?"
    det "Sabes onde fica o The Pit?"

# game/Scenes/Jez/jez3.rpy:31
translate portuguese jez3_5a003c29:

    # pc "The bar downtown?"
    pc "O bar no centro da cidade?"

# game/Scenes/Jez/jez3.rpy:32
translate portuguese jez3_c60f38c7:

    # det "That's it. Want to meet me there and have this conversation over drinks?"
    det "Exatamente. Queres encontrar-te comigo lá e ter esta conversa enquanto bebemos um copo?"

# game/Scenes/Jez/jez3.rpy:33
translate portuguese jez3_a5c9c049:

    # det "I could really use a drink."
    det "Estou mesmo a precisar de uma bebida."

# game/Scenes/Jez/jez3.rpy:36
translate portuguese jez3_2ba5f0eb:

    # det "Great, I'll be there in two."
    det "Ótimo, chego aí em dois minutos."

# game/Scenes/Jez/jez3.rpy:38
translate portuguese jez3_cd4d07e3:

    # det "Come on man, give me a break."
    det "Vá lá, meu, dá-me um desconto."

# game/Scenes/Jez/jez3.rpy:39
translate portuguese jez3_84d27d16:

    # det "I just got finished working a 24-hour shift."
    det "Acabei de fazer um turno de 24 horas."

# game/Scenes/Jez/jez3.rpy:40
translate portuguese jez3_cd598c64:

    # pc "Alright, I'll be there in five minutes."
    pc "Está bem, chego aí em cinco minutos."

# game/Scenes/Jez/jez3.rpy:41
translate portuguese jez3_2ba5f0eb_1:

    # det "Great, I'll be there in two."
    det "Ótimo, chego aí em dois minutos."

# game/Scenes/Jez/jez3.rpy:44
translate portuguese jez3_d1ed5b1b:

    # "She hangs up and I quickly get ready and head out to the car."
    "Ela desliga e eu preparo-me rapidamente e dirijo-me para o carro."

# game/Scenes/Jez/jez3.rpy:45
translate portuguese jez3_5ddb21e5:

    # "Only a few minutes later, I park in front of the bar."
    "Apenas alguns minutos depois, estaciono em frente ao bar."

# game/Scenes/Jez/jez3.rpy:47
translate portuguese jez3_23e3b6db:

    # "I walk in and am met with a cloud of cigarette smoke, the dull roar of conversation, and a jukebox playing some rock song I've never heard."
    "Entro e sou recebido por uma nuvem de fumo de cigarro, o murmúrio abafado das conversas e uma jukebox a tocar uma música de rock que nunca ouvi."

# game/Scenes/Jez/jez3.rpy:48
translate portuguese jez3_64d6327f:

    # "It takes a few moments for me to notice Detective Rodriguez waving at me from a booth in the back of the bar."
    "Demoro alguns instantes a reparar na detetive Rodriguez a acenar-me de uma mesa no fundo do bar."

# game/Scenes/Jez/jez3.rpy:49
translate portuguese jez3_398f4ad8:

    # "I walk over and sit down across from her."
    "Aproximo-me e sento-me à sua frente."

# game/Scenes/Jez/jez3.rpy:53
translate portuguese jez3_71bded69:

    # det "Thanks for meeting me here. I know it's not very professional, but I need a drink real bad and I hate drinking alone."
    det "Obrigada por te encontrares comigo aqui. Sei que não é muito profissional, mas preciso mesmo de uma bebida e detesto beber sozinha."

# game/Scenes/Jez/jez3.rpy:54
translate portuguese jez3_ac23b499:

    # det "I ordered you a beer too. You're twenty-one, right?"
    det "Pedi-te uma cerveja também. Tens vinte e um anos, certo?"

# game/Scenes/Jez/jez3.rpy:55
translate portuguese jez3_c2113814:

    # pc "Twenty-two."
    pc "Vinte e dois."

# game/Scenes/Jez/jez3.rpy:56
translate portuguese jez3_da9af380:

    # det "Good. Drink up then."
    det "Ótimo. Então bebe."

# game/Scenes/Jez/jez3.rpy:59
translate portuguese jez3_899cb188:

    # "I take a drink of the beer in front of me. It's nice and smooth."
    "Dou um gole na cerveja à minha frente. É boa e suave."

# game/Scenes/Jez/jez3.rpy:62
translate portuguese jez3_cfdfe09b:

    # pc "I'm just here to talk."
    pc "Estou aqui apenas para conversar."

# game/Scenes/Jez/jez3.rpy:64
translate portuguese jez3_a023156a:

    # det "So I'm just going to be drinking alone anyway. So be it."
    det "Então, vou acabar por beber sozinha de qualquer maneira. Que seja."

# game/Scenes/Jez/jez3.rpy:68
translate portuguese jez3_e5c2530c:

    # det "Okay, so you got into your dad's laptop and found some correspondence?"
    det "Ok, então entraste no portátil do teu pai e encontraste alguma correspondência?"

# game/Scenes/Jez/jez3.rpy:69
translate portuguese jez3_66708b9a:

    # pc "Yeah, and it's crazy."
    pc "Sim, e é de loucos."

# game/Scenes/Jez/jez3.rpy:70
translate portuguese jez3_08461fea:

    # det "Give me the summary. You can send the entire thing over to my e-mail later."
    det "Resume-me a história. Podes enviar-me tudo por e-mail mais tarde."

# game/Scenes/Jez/jez3.rpy:71
translate portuguese jez3_2af7a240:

    # pc "Well the gist is that he and Whitney were planning a trip."
    pc "Bem, o essencial é que ele e a Whitney estavam a planear uma viagem."

# game/Scenes/Jez/jez3.rpy:72
translate portuguese jez3_b2a62e0b:

    # det "So he did run off with her?"
    det "Então ele fugiu com ela?"

# game/Scenes/Jez/jez3.rpy:73
translate portuguese jez3_d0c263e4:

    # pc "No, he was the only one going on this trip."
    pc "Não, ele era o único que ia nessa viagem."

# game/Scenes/Jez/jez3.rpy:74
translate portuguese jez3_2908401f:

    # det "Okay, so where did he go?"
    det "Ok, então para onde é que ele foi?"

# game/Scenes/Jez/jez3.rpy:75
translate portuguese jez3_0a1d6430:

    # pc "I'm not sure, but the strangest part is how he got there."
    pc "Não tenho a certeza, mas a parte mais estranha é como é que ele chegou lá."

# game/Scenes/Jez/jez3.rpy:76
translate portuguese jez3_09d6eafc:

    # det "Explain."
    det "Explica."

# game/Scenes/Jez/jez3.rpy:77
translate portuguese jez3_61000743:

    # pc "He built some sort of device. I found it in the basement. It looks like a hula hoop."
    pc "Ele construiu uma espécie de dispositivo. Encontrei-o na cave. Parece um arco de hula-hoop."

# game/Scenes/Jez/jez3.rpy:79
translate portuguese jez3_b0e7f9ea:

    # det "What? You lost me."
    det "O quê? Não estou a perceber."

# game/Scenes/Jez/jez3.rpy:80
translate portuguese jez3_40d85287:

    # pc "I don't know how to explain it. It looks like a hoop. He and Whitney built it together. When it's activated, it's supposed to transport you somewhere."
    pc "Não sei como explicar. Parece um arco. Ele e a Whitney construíram-no juntos. Quando é ativado, é suposto transportar-te para algum lugar."

# game/Scenes/Jez/jez3.rpy:81
translate portuguese jez3_1f06310c:

    # pc "He needed the diamonds to activate it. That's why he stole them."
    pc "Ele precisava dos diamantes para o ativar. Foi por isso que os roubou."

# game/Scenes/Jez/jez3.rpy:82
translate portuguese jez3_35f3019c:

    # det "And the meth too?"
    det "E a metanfetamina também?"

# game/Scenes/Jez/jez3.rpy:83
translate portuguese jez3_ff210007:

    # pc "Right. He used the meth to speed his heart rate up so his heart didn't stop during the transportation."
    pc "Exato. Ele usou a metanfetamina para acelerar o ritmo cardíaco, para que o coração não parasse durante o transporte."

# game/Scenes/Jez/jez3.rpy:84
translate portuguese jez3_22ea6d6f:

    # det "You know this is the dumbest fucking thing I've ever heard right?"
    det "Sabes que isto é a coisa mais idiota que já ouvi, certo?"

# game/Scenes/Jez/jez3.rpy:85
translate portuguese jez3_a2fed6c2:

    # pc "I'm just telling you what they were talking about."
    pc "Só te estou a contar o que eles estavam a discutir."

# game/Scenes/Jez/jez3.rpy:87
translate portuguese jez3_1b198a7a:

    # det "Well I did look into the diamond theft."
    det "Bem, eu investiguei o roubo dos diamantes."

# game/Scenes/Jez/jez3.rpy:88
translate portuguese jez3_0768d1c5:

    # det "There was a jewelry store over in Whiterock that was broken into only a few days before your dad went missing."
    det "Houve um assalto a uma joalharia em Whiterock apenas alguns dias antes do teu pai desaparecer."

# game/Scenes/Jez/jez3.rpy:89
translate portuguese jez3_727a0b8a:

    # det "It was just like you described. The security was disabled for only a minute."
    det "Foi tal e qual como descreveste. O sistema de segurança ficou desativado apenas por um minuto."

# game/Scenes/Jez/jez3.rpy:90
translate portuguese jez3_75b55784:

    # det "The thief entered through the back door, walked in, took two three-carat diamond rings, then walked back out."
    det "O ladrão entrou pela porta das traseiras, entrou, levou dois anéis de diamantes de três quilates e depois saiu."

# game/Scenes/Jez/jez3.rpy:91
translate portuguese jez3_a0cd13f9:

    # det "Security kicked back on. There would have been no trace that anybody was even there, except the rings were gone."
    det "O sistema de segurança voltou a ativar-se. Não teria ficado qualquer vestígio de que alguém tivesse estado lá, exceto que os anéis tinham desaparecido."

# game/Scenes/Jez/jez3.rpy:92
translate portuguese jez3_a595c814:

    # pc "So he did it."
    pc "Então foi ele que o fez."

# game/Scenes/Jez/jez3.rpy:93
translate portuguese jez3_2cf2afa7:

    # det "It seems that way."
    det "Parece que sim."

# game/Scenes/Jez/jez3.rpy:94
translate portuguese jez3_7b6c844b:

    # pc "Any clue where he got the meth?"
    pc "Alguma pista de onde ele arranjou a metanfetamina?"

# game/Scenes/Jez/jez3.rpy:96
translate portuguese jez3_6063143c:

    # det "God, there's no telling. That shit is all over Skyhill."
    det "Meu Deus, não há como saber. Aquela porcaria está por toda a Skyhill."

# game/Scenes/Jez/jez3.rpy:97
translate portuguese jez3_399bdc0f:

    # pc "Really?"
    pc "A sério?"

# game/Scenes/Jez/jez3.rpy:99
translate portuguese jez3_94032961:

    # det "Yes. That's what I've been working on. That's my primary job."
    det "Sim. É nisso que tenho andado a trabalhar. É o meu trabalho principal."

# game/Scenes/Jez/jez3.rpy:100
translate portuguese jez3_91bebae5:

    # det "We know a few dealers and we can find people who buy meth."
    det "Conhecemos alguns traficantes e conseguimos encontrar pessoas que compram metanfetamina."

# game/Scenes/Jez/jez3.rpy:101
translate portuguese jez3_ec847758:

    # det "But we can't seem to locate where the shit is coming from. Somebody around here is cooking it, and I don't know where."
    det "Mas não conseguimos localizar de onde vem aquela porcaria. Alguém por aqui está a fabricá-la, e eu não sei onde."

# game/Scenes/Jez/jez3.rpy:102
translate portuguese jez3_ea875425:

    # pc "I had no idea it was that bad around here."
    pc "Não fazia ideia de que a situação por aqui era assim tão má."

# game/Scenes/Jez/jez3.rpy:103
translate portuguese jez3_49c82960:

    # det "Yeah. So I'm not sure exactly where your dad got it at, but I've been questioning people."
    det "Sim. Por isso, não tenho a certeza de onde é que o teu pai a arranjou, mas tenho andado a interrogar pessoas."

# game/Scenes/Jez/jez3.rpy:104
translate portuguese jez3_5d188bd8:

    # det "Look [pcname], it sounds to me like your dad was having some sort of psychotic break."
    det "Olha [pcname], parece-me que o teu pai estava a ter algum tipo de surto psicótico."

# game/Scenes/Jez/jez3.rpy:105
translate portuguese jez3_7a8cf8a1:

    # det "Teleporting hula-hoops, diamond theft, using meth to speed up your heart rate."
    det "Teleportar bambolês, roubo de diamantes, usar metanfetamina para acelerar o ritmo cardíaco."

# game/Scenes/Jez/jez3.rpy:106
translate portuguese jez3_8ebd5686:

    # det "That sounds like a bunch of nonsense to me."
    det "Isso parece-me um monte de disparates."

# game/Scenes/Jez/jez3.rpy:107
translate portuguese jez3_c417e350:

    # pc "Yeah."
    pc "Sim."

# game/Scenes/Jez/jez3.rpy:108
translate portuguese jez3_4c3ec6a3:

    # det "But the more we dig into it, the more likely we're going to find him."
    det "Mas quanto mais investigarmos, mais provável é encontrá-lo."

# game/Scenes/Jez/jez3.rpy:109
translate portuguese jez3_e004b1ab:

    # det "So keep digging."
    det "Por isso, continua a investigar."

# game/Scenes/Jez/jez3.rpy:110
translate portuguese jez3_58f0fc2d:

    # det "Send me the info that you found on the laptop and I'll see if I can find this Whitney person."
    det "Envia-me a informação que encontraste no portátil e eu vou ver se consigo encontrar essa tal Whitney."

# game/Scenes/Jez/jez3.rpy:111
translate portuguese jez3_955d194d:

    # det "Assuming that she's real and not somebody that your dad made up."
    det "Partindo do princípio de que ela é real e não alguém que o teu pai inventou."

# game/Scenes/Jez/jez3.rpy:112
translate portuguese jez3_25bfd7d2:

    # pc "It seems like she's real to me, based on the e-mails."
    pc "A mim parece-me que ela é real, com base nos e-mails."

# game/Scenes/Jez/jez3.rpy:113
translate portuguese jez3_2fc85b75:

    # det "Alright. Well let's find her."
    det "Tudo bem. Bem, vamos encontrá-la."

# game/Scenes/Jez/jez3.rpy:114
translate portuguese jez3_e70c1658:

    # pc "I could e-mail her from Dad's laptop."
    pc "Eu poderia enviar-lhe um e-mail a partir do portátil do pai."

# game/Scenes/Jez/jez3.rpy:116
translate portuguese jez3_3997e2c3:

    # det "That's not a bad idea. Give it a shot. Start up a conversation with her, see if you can find out more about her."
    det "Não é má ideia. Tenta. Inicia uma conversa com ela, vê se consegues descobrir mais sobre ela."

# game/Scenes/Jez/jez3.rpy:117
translate portuguese jez3_4d9bef33:

    # det "And let me know anything you find."
    det "E avisa-me de tudo o que descobrires."

# game/Scenes/Jez/jez3.rpy:119
translate portuguese jez3_5bc44b07:

    # pc "I will."
    pc "Vou avisar."

# game/Scenes/Jez/jez3.rpy:121
translate portuguese jez3_b734eba7:

    # det "Thanks for meeting me here. I needed this."
    det "Obrigado por te encontrares comigo aqui. Eu precisava disto."

# game/Scenes/Jez/jez3.rpy:122
translate portuguese jez3_ba520f30:

    # det "Now I have to get home. I haven't seen my kid in two days."
    det "Agora tenho de ir para casa. Não vejo o meu filho há dois dias."

# game/Scenes/Jez/jez3.rpy:123
translate portuguese jez3_ce82357f:

    # pc "You have a kid?"
    pc "Tem um filho?"

# game/Scenes/Jez/jez3.rpy:125
translate portuguese jez3_71fc0e0c:

    # det "Yeah, Javi. He's seven. My mom's taking care of him right now."
    det "Sim, o Javi. Tem sete anos. A minha mãe está a tomar conta dele neste momento."

# game/Scenes/Jez/jez3.rpy:126
translate portuguese jez3_798c23ff:

    # det "You surprised that I have a kid?"
    det "Está surpreendido por eu ter um filho?"

# game/Scenes/Jez/jez3.rpy:130
translate portuguese jez3_632e262d:

    # det "Thanks. I had him when I was 17."
    det "Obrigada. Tive-o quando tinha 17 anos."

# game/Scenes/Jez/jez3.rpy:133
translate portuguese jez3_ae370b70:

    # det "I'm not. You don't have to be married to have a kid, you know."
    det "Não estou. Não é preciso estar casada para ter um filho, sabe."

# game/Scenes/Jez/jez3.rpy:134
translate portuguese jez3_2356fff3:

    # pc "Right, I didn't mean anything by it."
    pc "Certo, não quis dizer nada com isso."

# game/Scenes/Jez/jez3.rpy:137
translate portuguese jez3_a82f6cf9:

    # det "Oh, I thought you seemed surprised."
    det "Oh, achei que parecia surpreendido."

# game/Scenes/Jez/jez3.rpy:139
translate portuguese jez3_12633b63:

    # det "Anyway, I better get home."
    det "De qualquer forma, é melhor ir para casa."

# game/Scenes/Jez/jez3.rpy:140
translate portuguese jez3_d0fa7dfb:

    # det "I'll see you later, [pcname]."
    det "Até logo, [pcname]."

# game/Scenes/Jez/jez3.rpy:141
translate portuguese jez3_7b4cad00:

    # pc "Bye Detective Rodriguez."
    pc "Adeus, detetive Rodriguez."

# game/Scenes/Jez/jez3.rpy:144
translate portuguese jez3_d41d8cd9_2:

    # voice 'voices/jez_3_1.mp3'
    voice 'voices/jez_3_1.mp3'

# game/Scenes/Jez/jez3.rpy:145
translate portuguese jez3_e7adfac5:

    # det "You can call me Jez, okay? That's my first name."
    det "Podes chamar-me Jez, está bem? É o meu primeiro nome."

# game/Scenes/Jez/jez3.rpy:146
translate portuguese jez3_db79b546:

    # pc "Okay. Bye Jez."
    pc "Está bem. Adeus, Jez."

# game/Scenes/Jez/jez3.rpy:151
translate portuguese jez3_d41d8cd9_3:

    # voice 'voices/jez_goodnight.mp3'
    voice 'voices/jez_goodnight.mp3'

# game/Scenes/Jez/jez3.rpy:152
translate portuguese jez3_2f6a1cc2:

    # det "Good night."
    det "Boa noite."

# game/Scenes/Jez/jez3.rpy:155
translate portuguese jez3_40a94195:

    # "She stands up and walks out of the bar. I sit there alone for a few minutes, thinking about our conversation."
    "Ela levanta-se e sai do bar. Fico ali sentado sozinho por alguns minutos, a pensar na nossa conversa."

# game/Scenes/Jez/jez3.rpy:156
translate portuguese jez3_06361269:

    # "She thinks Dad was crazy. I'm not so sure."
    "Ela acha que o pai era louco. Não tenho tanta certeza."

# game/Scenes/Jez/jez3.rpy:157
translate portuguese jez3_d8c1ec54:

    # "The things in his notes and in his conversations with Whitney were wild, but there is so much there that seems true."
    "As coisas nas notas dele e nas conversas com a Whitney eram loucas, mas há tanta coisa ali que parece verdadeira."

# game/Scenes/Jez/jez3.rpy:158
translate portuguese jez3_3da12785:

    # "Whitney definitely seems like a real person. I just need to find out who she is."
    "A Whitney parece mesmo uma pessoa real. Só preciso de descobrir quem ela é."

# game/Scenes/Jez/jez3.rpy:159
translate portuguese jez3_8298e18a:

    # "Then maybe I can find out where my dad went."
    "Então talvez consiga descobrir para onde o meu pai foi."

# game/Scenes/Jez/jez3.rpy:160
translate portuguese jez3_bc8a9774:

    # "Eventually, I stand up and walk out of the bar, then head home for the night."
    "Por fim, levanto-me e saio do bar, depois vou para casa passar a noite."

translate portuguese strings:

    # game/Scenes/Jez/jez3.rpy:2
    old "You need to get into your dad's computer. Talk to Adrian about it. She's been at the grocery store trying to find a new game."
    new "Tens de aceder ao computador do teu pai. Fala com a Adrian sobre isso. Ela está na mercearia a tentar encontrar um jogo novo."

