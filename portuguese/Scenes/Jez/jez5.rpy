# game/Scenes/Jez/jez5.rpy:13
translate portuguese jez5_450455fc:

    # "It's Detective Rodriguez. I wonder if she's found something out about my dad."
    "É a detetive Rodriguez. Será que ela descobriu alguma coisa sobre o meu pai?"

# game/Scenes/Jez/jez5.rpy:16
translate portuguese jez5_bea5e8cb:

    # pc "Hello?"
    pc "Estás?"

# game/Scenes/Jez/jez5.rpy:18
translate portuguese jez5_d41d8cd9:

    # voice 'voices/jez_hey.mp3'
    voice 'voices/jez_hey.mp3'

# game/Scenes/Jez/jez5.rpy:19
translate portuguese jez5_31f304d3:

    # det "Hey, [pcname]."
    det "Olá, [pcname]."

# game/Scenes/Jez/jez5.rpy:20
translate portuguese jez5_704218da:

    # pc "Did you find anything?"
    pc "Descobriste alguma coisa?"

# game/Scenes/Jez/jez5.rpy:22
translate portuguese jez5_dd220c64:

    # det "What? Oh! About your dad?"
    det "O quê? Ah! Sobre o teu pai?"

# game/Scenes/Jez/jez5.rpy:24
translate portuguese jez5_e8fe8a8c:

    # det "Oh God, no I'm sorry. I wasn't calling about your dad, but I can understand why you'd think that."
    det "Meu Deus, não, desculpa. Não estava a ligar por causa do teu pai, mas percebo porque é que pensaste isso."

# game/Scenes/Jez/jez5.rpy:25
translate portuguese jez5_1559f8f9:

    # det "With me being a detective and on your dad's case and all."
    det "Sendo eu detetive e estando no caso do teu pai e tudo mais."

# game/Scenes/Jez/jez5.rpy:26
translate portuguese jez5_8c3ac124:

    # det "God, I'm a horrible detective aren't I?"
    det "Meu Deus, sou uma detetive horrível, não sou?"

# game/Scenes/Jez/jez5.rpy:27
translate portuguese jez5_a807c23e:

    # pc "No, I don't think so. What did you call for then?"
    pc "Não, acho que não. Então, por que ligaste?"

# game/Scenes/Jez/jez5.rpy:30
translate portuguese jez5_d41d8cd9_1:

    # voice 'voices/jez_5_1.mp3'
    voice 'voices/jez_5_1.mp3'

# game/Scenes/Jez/jez5.rpy:31
translate portuguese jez5_0a63889f:

    # det "Well, I had kind of a rough day and I wanted to talk to somebody."
    det "Bem, tive um dia meio difícil e queria conversar com alguém."

# game/Scenes/Jez/jez5.rpy:33
translate portuguese jez5_d41d8cd9_2:

    # voice 'voices/jez_5_2.mp3'
    voice 'voices/jez_5_2.mp3'

# game/Scenes/Jez/jez5.rpy:34
translate portuguese jez5_ea09e714:

    # det "And you were nice to me in the past, when we went out for drinks."
    det "E foste simpático comigo no passado, quando saímos para beber uns copos."

# game/Scenes/Jez/jez5.rpy:36
translate portuguese jez5_d41d8cd9_3:

    # voice 'voices/jez_5_3.mp3'
    voice 'voices/jez_5_3.mp3'

# game/Scenes/Jez/jez5.rpy:37
translate portuguese jez5_307d2b53:

    # det "And I don't really have anybody else to talk to."
    det "E não tenho mais ninguém com quem conversar."

# game/Scenes/Jez/jez5.rpy:39
translate portuguese jez5_d41d8cd9_4:

    # voice 'voices/jez_5_4.mp3'
    voice 'voices/jez_5_4.mp3'

# game/Scenes/Jez/jez5.rpy:40
translate portuguese jez5_0f2cd5d3:

    # det "So I was wondering if you would want to just talk some?"
    det "Por isso, estava a pensar se gostarias de conversar um pouco?"

# game/Scenes/Jez/jez5.rpy:46
translate portuguese jez5_47059538:

    # det "You're right. This was a mistake, I'm sorry."
    det "Tens razão. Isto foi um erro, desculpa."

# game/Scenes/Jez/jez5.rpy:47
translate portuguese jez5_ec16f7c0:

    # det "I won't bother you any more until I have information on your dad."
    det "Não te vou incomodar mais até ter informações sobre o teu pai."

# game/Scenes/Jez/jez5.rpy:48
translate portuguese jez5_07fc1b9f:

    # det "Bye, [pcname]."
    det "Adeus, [pcname]."

# game/Scenes/Jez/jez5.rpy:52
translate portuguese jez5_5429a27f:

    # "She hangs up and I lie down to go to sleep."
    "Ela desliga e eu deito-me para dormir."

# game/Scenes/Jez/jez5.rpy:53
translate portuguese jez5_ceaf3431:

    # "I can hardly believe that she wants to call me and dump her problems on me. Don't I have enough of my own to deal with?"
    "Mal consigo acreditar que ela me quer ligar para despejar os problemas dela em cima de mim. Não tenho já problemas suficientes para lidar?"

# game/Scenes/Jez/jez5.rpy:54
translate portuguese jez5_0a396100:

    # "I mean, my dad is missing and it doesn't seem like she's doing much of anything to find him."
    "Quer dizer, o meu pai está desaparecido e não parece que ela esteja a fazer grande coisa para o encontrar."

# game/Scenes/Jez/jez5.rpy:55
translate portuguese jez5_a9441b54:

    # "Maybe I was a little harsh with her, but she needs to do her damn job."
    "Talvez tenha sido um pouco dura com ela, mas ela precisa de fazer o raio do trabalho dela."

# game/Scenes/Jez/jez5.rpy:56
translate portuguese jez5_437235da:

    # "I fall asleep, still upset about the whole thing."
    "Adormeço, ainda chateada com toda esta situação."

# game/Scenes/Jez/jez5.rpy:62
translate portuguese jez5_9f04dd80:

    # det "My Chief is yelling at me all the time because I haven't been able to track down this meth manufacturer."
    det "O meu chefe está sempre a gritar comigo porque não consegui localizar este fabricante de metanfetamina."

# game/Scenes/Jez/jez5.rpy:63
translate portuguese jez5_2edb985d:

    # det "It's like, I'm trying. There's only so much I can do."
    det "É que eu estou a tentar. Mas há um limite para o que posso fazer."

# game/Scenes/Jez/jez5.rpy:64
translate portuguese jez5_d637e4b1:

    # det "I spend most of my day on stakeouts watching drug handoffs."
    det "Passo a maior parte do dia em vigílias, a observar entregas de droga."

# game/Scenes/Jez/jez5.rpy:65
translate portuguese jez5_b65d63fc:

    # det "Or interrogating people, trying to push them into telling me something."
    det "Ou a interrogar pessoas, a tentar forçá-las a dizer-me alguma coisa."

# game/Scenes/Jez/jez5.rpy:66
translate portuguese jez5_e4fde77f:

    # det "But nobody's giving anything up and I'm running out of leads."
    det "Mas ninguém está a revelar nada e estou a ficar sem pistas."

# game/Scenes/Jez/jez5.rpy:67
translate portuguese jez5_45b6d6aa:

    # det "There's only two detectives on this case. A big meth ring and just two of us."
    det "Só há dois detetives neste caso. Uma grande rede de metanfetamina e apenas nós os dois."

# game/Scenes/Jez/jez5.rpy:68
translate portuguese jez5_77a9cef6:

    # det "I mean Skyhill is a small town, so I get it, but I need more help here."
    det "Quer dizer, Skyhill é uma cidade pequena, por isso eu entendo, mas preciso de mais ajuda aqui."

# game/Scenes/Jez/jez5.rpy:69
translate portuguese jez5_72d52a4d:

    # det "I wish we could call in the state police, or the FBI or something, but the Chief won't have it. Says we have to handle this ourselves."
    det "Gostava que pudéssemos chamar a polícia estadual, ou o FBI ou algo assim, mas o chefe não deixa. Diz que temos de tratar disto sozinhos."

# game/Scenes/Jez/jez5.rpy:70
translate portuguese jez5_d8b3de1e:

    # det "But there's only so much I can do. I have other cases too - like your dad's - that I'm having to neglect because of this meth thing."
    det "Mas há um limite para o que posso fazer. Também tenho outros casos — como o do teu pai — que estou a ter de negligenciar por causa desta coisa da metanfetamina."

# game/Scenes/Jez/jez5.rpy:72
translate portuguese jez5_88d7e875:

    # det "And today I had to raid the house of this methhead."
    det "E hoje tive de fazer uma rusga à casa desta viciada em metanfetamina."

# game/Scenes/Jez/jez5.rpy:73
translate portuguese jez5_d5874b9e:

    # det "It was horrible. This woman, her house was disgusting. Her baby, a three-year-old girl, was sitting in the middle of a bunch of filth naked."
    det "Foi horrível. A casa desta mulher estava nojenta. A filha dela, uma menina de três anos, estava sentada nua no meio de um monte de imundície."

# game/Scenes/Jez/jez5.rpy:74
translate portuguese jez5_2823a872:

    # det "And I had to take this child, who was screaming and crying that she didn't want to leave her mom, and give the child to protective services."
    det "E tive de levar esta criança, que gritava e chorava porque não queria deixar a mãe, e entregá-la aos serviços de proteção."

# game/Scenes/Jez/jez5.rpy:75
translate portuguese jez5_e5dd6ea8:

    # det "The girl will probably have a better life in foster care than she would have with her mother, but who knows. She could end up with some abusive assholes or something."
    det "A menina provavelmente terá uma vida melhor num lar de acolhimento do que teria com a mãe, mas quem sabe. Ela pode acabar com uns idiotas abusivos ou algo do género."

# game/Scenes/Jez/jez5.rpy:76
translate portuguese jez5_5e97fe72:

    # det "That little girl's life is messed up no matter what happens now."
    det "A vida daquela menina está arruinada, aconteça o que acontecer agora."

# game/Scenes/Jez/jez5.rpy:77
translate portuguese jez5_a1286de7:

    # det "And it just makes me so sad."
    det "E isso deixa-me tão triste."

# game/Scenes/Jez/jez5.rpy:78
translate portuguese jez5_89052a8b:

    # pc "I'm sorry. That's awful."
    pc "Desculpa. Isso é horrível."

# game/Scenes/Jez/jez5.rpy:80
translate portuguese jez5_97380cd0:

    # det "So I get the woman back to the station and start interrogating her."
    det "Então, levo a mulher para a esquadra e começo a interrogá-la."

# game/Scenes/Jez/jez5.rpy:81
translate portuguese jez5_3e4784a1:

    # det "She's going to jail for at least five years for possession, probably will get a child endangerment charge as well, but she won't give up her dealer."
    det "Ela vai para a prisão por pelo menos cinco anos por posse de drogas, provavelmente também vai ser acusada de colocar a criança em risco, mas não quer delatar o traficante."

# game/Scenes/Jez/jez5.rpy:82
translate portuguese jez5_19e09092:

    # det "I don't fucking get it."
    det "Não percebo nada disto."

# game/Scenes/Jez/jez5.rpy:83
translate portuguese jez5_59760784:

    # det "She's scared that something will happen to her family if she snitches."
    det "Ela tem medo que algo aconteça à família dela se a delatar."

# game/Scenes/Jez/jez5.rpy:84
translate portuguese jez5_c0f63ffe:

    # det "Spits in my face, calls me a pig. I wanted to beat her fucking head in."
    det "Cuspiu-me na cara, chamou-me porco. Apetecia-me partir-lhe a porra da cabeça."

# game/Scenes/Jez/jez5.rpy:85
translate portuguese jez5_c36e96d1:

    # det "Then I get chewed out by the Chief because I didn't get anything out of her."
    det "Depois, o chefe repreendeu-me porque não consegui tirar-lhe nada."

# game/Scenes/Jez/jez5.rpy:87
translate portuguese jez5_2288ac26:

    # det "And that was my day."
    det "E foi assim o meu dia."

# game/Scenes/Jez/jez5.rpy:88
translate portuguese jez5_2074c381:

    # det "I'm just so tired of all of it. I want to find this meth manufacturer and shut that shit down."
    det "Estou tão cansado de tudo isto. Quero encontrar este fabricante de metanfetamina e acabar com aquela merda."

# game/Scenes/Jez/jez5.rpy:90
translate portuguese jez5_3a7bef84:

    # "I think about telling her about the bunker that Izzy had sent me to."
    "Penso em contar-lhe sobre o bunker para onde o Izzy me mandou."

# game/Scenes/Jez/jez5.rpy:91
translate portuguese jez5_35c47a4d:

    # "But I'm not sure that is really what she's looking for."
    "Mas não tenho a certeza se é mesmo isso que ela quer saber."

# game/Scenes/Jez/jez5.rpy:92
translate portuguese jez5_7dda6c8a:

    # "Plus, I'm not sure if me and Izzy might get in some serious trouble for our part in whatever they were doing."
    "Além disso, não sei se eu e o Izzy podemos meter-nos em sérios sarilhos por causa do nosso envolvimento no que quer que eles estivessem a fazer."

# game/Scenes/Jez/jez5.rpy:93
translate portuguese jez5_9fcbf4b8:

    # "I may tell Jez about it later, but for now I stay quiet."
    "Talvez conte à Jez mais tarde, mas por agora fico calado."

# game/Scenes/Jez/jez5.rpy:95
translate portuguese jez5_6387c117:

    # "I think about telling her about the bunker that Reba had taken me to."
    "Penso em contar-lhe sobre o bunker para onde a Reba me levou."

# game/Scenes/Jez/jez5.rpy:96
translate portuguese jez5_35c47a4d_1:

    # "But I'm not sure that is really what she's looking for."
    "Mas não tenho a certeza se é mesmo isso que ela quer saber."

# game/Scenes/Jez/jez5.rpy:97
translate portuguese jez5_306cf091:

    # "Plus, I'm not sure if Reba might get in some serious trouble for our part in whatever they were doing."
    "Além disso, não tenho a certeza se a Reba pode meter-se em sérios problemas por causa do nosso envolvimento no que quer que fosse que eles estavam a fazer."

# game/Scenes/Jez/jez5.rpy:98
translate portuguese jez5_9fcbf4b8_1:

    # "I may tell Jez about it later, but for now I stay quiet."
    "Talvez conte à Jez mais tarde, mas por agora vou ficar calada."

# game/Scenes/Jez/jez5.rpy:99
translate portuguese jez5_a3049ca4:

    # det "Anyway, thanks for listening to me vent."
    det "De qualquer forma, obrigada por me ouvires desabafar."

# game/Scenes/Jez/jez5.rpy:100
translate portuguese jez5_732596c5:

    # det "I needed to get all that off my chest."
    det "Precisava de desabafar tudo isso."

# game/Scenes/Jez/jez5.rpy:101
translate portuguese jez5_d957ecb7:

    # pc "You feeling better now?"
    pc "Sentes-te melhor agora?"

# game/Scenes/Jez/jez5.rpy:103
translate portuguese jez5_880af095:

    # det "A little, yeah."
    det "Um pouco, sim."

# game/Scenes/Jez/jez5.rpy:104
translate portuguese jez5_566089d7:

    # det "You're a pretty good listener, [pcname]. Thank you."
    det "És uma boa ouvinte, [pcname]. Obrigada."

# game/Scenes/Jez/jez5.rpy:105
translate portuguese jez5_c46a0b54:

    # pc "Any time."
    pc "Quando quiseres."

# game/Scenes/Jez/jez5.rpy:107
translate portuguese jez5_1d1792a8:

    # det "I can be a good listener too, if you ever want to chat."
    det "Eu também sei ouvir bem, se alguma vez quiseres conversar."

# game/Scenes/Jez/jez5.rpy:108
translate portuguese jez5_d87a672d:

    # det "You could call me at nights and we could just talk or something."
    det "Podes ligar-me à noite e podemos simplesmente conversar ou algo do género."

# game/Scenes/Jez/jez5.rpy:110
translate portuguese jez5_b7c62ab4:

    # pc "That sounds good. I'll do that."
    pc "Parece-me bem. Vou fazer isso."

# game/Scenes/Jez/jez5.rpy:112
translate portuguese jez5_fc19b673:

    # det "Good."
    det "Ótimo."

# game/Scenes/Jez/jez5.rpy:114
translate portuguese jez5_d41d8cd9_5:

    # voice 'voices/jez_5_5.mp3'
    voice 'voices/jez_5_5.mp3'

# game/Scenes/Jez/jez5.rpy:115
translate portuguese jez5_22567fb7:

    # det "Okay, [pcname], I better get to bed. Thanks for listening to me."
    det "Pronto, [pcname], é melhor ir para a cama. Obrigada por me ouvires."

# game/Scenes/Jez/jez5.rpy:117
translate portuguese jez5_d41d8cd9_6:

    # voice 'voices/jez_5_6.mp3'
    voice 'voices/jez_5_6.mp3'

# game/Scenes/Jez/jez5.rpy:118
translate portuguese jez5_22b369a9:

    # det "I'll talk to you later."
    det "Falo contigo mais tarde."

# game/Scenes/Jez/jez5.rpy:119
translate portuguese jez5_31e08f47:

    # pc "Okay, good night, Jez."
    pc "Está bem, boa noite, Jez."

# game/Scenes/Jez/jez5.rpy:121
translate portuguese jez5_d41d8cd9_7:

    # voice 'voices/jez_night.mp3'
    voice 'voices/jez_night.mp3'

# game/Scenes/Jez/jez5.rpy:122
translate portuguese jez5_8669dcbe:

    # det "Night."
    det "Boa noite."

# game/Scenes/Jez/jez5.rpy:125
translate portuguese jez5_52d6e3cf:

    # "We hang up and I get ready for bed."
    "Desligamos e eu preparo-me para ir para a cama."

# game/Scenes/Jez/jez5.rpy:126
translate portuguese jez5_73bafe8e:

    # "It must be hard having to deal with the things that she deals with, see the things that she sees every day."
    "Deve ser difícil lidar com as coisas com que ela lida, ver as coisas que ela vê todos os dias."

# game/Scenes/Jez/jez5.rpy:127
translate portuguese jez5_63d39c7b:

    # "I like that she is opening up to me though, becoming more friendly."
    "Mas gosto que ela se esteja a abrir comigo, a tornar-se mais amigável."

# game/Scenes/Jez/jez5.rpy:128
translate portuguese jez5_00f887ed:

    # "I actually really like her."
    "Na verdade, gosto mesmo muito dela."

# game/Scenes/Jez/jez5.rpy:129
translate portuguese jez5_c6ddf2e1:

    # "I fall asleep thinking about how I'd like to spend more time with her. Hopefully we'll get a chance soon."
    "Adormeço a pensar em como gostaria de passar mais tempo com ela. Espero que tenhamos uma oportunidade em breve."

