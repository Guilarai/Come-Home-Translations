    "Aquele treino com a Tammy dá jeito. Este tipo não é nada comparado com os socos que ela me deu."

# game/Scenes/Reba/reba8.rpy:219
translate portuguese reba8mudding_6c41ac4b:

    # "I easily step outside of his punch and prepare to dodge whatever he has to follow it up with."
    "Esquivo-me facilmente do soco dele e preparo-me para desviar o que quer que ele venha a seguir."

# game/Scenes/Reba/reba8.rpy:222
translate portuguese reba8mudding_d02d2a53:

    # "Before he can throw another one though, Reba jumps between us."
    "Antes que ele consiga dar outro, porém, a Reba salta entre nós."

# game/Scenes/Reba/reba8.rpy:223
translate portuguese reba8mudding_53c501af_1:

    # rb "No! Stop fighting!"
    rb "Não! Parem de lutar!"

# game/Scenes/Reba/reba8.rpy:224
translate portuguese reba8mudding_ace0e755:

