    "Todo aquele treino com a Tammy dá jeito. Este tipo não é nada comparado com os socos que ela me deu."

# game/Scenes/Reba/reba8.rpy:203
translate portuguese reba8mudding_781f13e4:

    # "I step into the punch, knocking his hand to the side and countering with a right hook to the side of his jaw. It lands with a satisfying crack."
    "Eu avanço para o soco, desviando a mão dele para o lado e contra-atacando com um gancho de direita na mandíbula. Acertou com um estalido satisfatório."

# game/Scenes/Reba/reba8.rpy:206
translate portuguese reba8mudding_510db655:

    # "I go in for another punch, but Reba jumps between us."
    "Lanço-me para outro soco, mas a Reba salta entre nós."

# game/Scenes/Reba/reba8.rpy:207
translate portuguese reba8mudding_53c501af:

    # rb "No! Stop fighting!"
    rb "Não! Parem de lutar!"

# game/Scenes/Reba/reba8.rpy:208
translate portuguese reba8mudding_ceeca70d:

    # mk "I'm gonna fucking kill him, get out of my way!"
    mk "Vou matá-lo, sai da minha frente!"

# game/Scenes/Reba/reba8.rpy:209
