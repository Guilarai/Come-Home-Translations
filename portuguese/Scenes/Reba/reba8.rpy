    rb "Não, não vais!"

# game/Scenes/Reba/reba8.rpy:210
translate portuguese reba8mudding_d9fe3e76:

    # pc "She's right, if you come at me again I'm going to lay you out."
    pc "Ela tem razão, se voltares a vir para cima de mim, vou derrubar-te."

# game/Scenes/Reba/reba8.rpy:211
