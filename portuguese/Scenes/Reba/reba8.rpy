    mk "Este idiota precisa de uma lição!"

# game/Scenes/Reba/reba8.rpy:225
translate portuguese reba8mudding_64d142d4:

    # pc "I didn't do anything."
    pc "Eu não fiz nada."

# game/Scenes/Reba/reba8.rpy:226
translate portuguese reba8mudding_c9511b36:

    # mk "You're trying to fuck my sister!"
    mk "Estás a tentar foder a minha irmã!"

# game/Scenes/Reba/reba8.rpy:227
translate portuguese reba8mudding_a40a4d44:

    # rb "We didn't do nothing, Mickey! Stop!"
    rb "Não fizemos nada, Mickey! Parem!"

# game/Scenes/Reba/reba8.rpy:228
translate portuguese reba8mudding_54567e75_1:

    # rb "Just go, [pcname]. I'll talk to you later."
    rb "Vai-te embora, [pcname]. Falo contigo mais tarde."

# game/Scenes/Reba/reba8.rpy:229
translate portuguese reba8mudding_61f77a4c_1:

