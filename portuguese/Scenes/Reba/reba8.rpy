translate portuguese reba8mudding_a3c096b9:

    # "I try to get my hands up, but I have no experience with fighting and I don't know what I'm doing."
    "Tento levantar as mãos, mas não tenho experiência em lutas e não sei o que estou a fazer."

# game/Scenes/Reba/reba8.rpy:235
translate portuguese reba8mudding_29541e19:

    # "I nearly fall to the ground when Mickey's fist lands cleanly with my jaw, making my head rock back."
    "Quase caio no chão quando o punho do Mickey acerta em cheio no meu queixo, fazendo a minha cabeça balançar para trás."

# game/Scenes/Reba/reba8.rpy:238
translate portuguese reba8mudding_7167e5de:

    # "I manage to stay on my feet and turn expecting another punch to come up at me, but Reba steps between us."
    "Consigo manter-me de pé e viro-me, à espera de outro soco, mas a Reba coloca-se entre nós."

# game/Scenes/Reba/reba8.rpy:239
translate portuguese reba8mudding_53c501af_2:

    # rb "No! Stop fighting!"
    rb "Não! Parem de lutar!"

# game/Scenes/Reba/reba8.rpy:240
translate portuguese reba8mudding_1cc87b7a:

    # mk "Get out of my way Reba! I'm going to kick his ass!"
    mk "Sai da frente, Reba! Vou dar-lhe uma sova!"

# game/Scenes/Reba/reba8.rpy:241
translate portuguese reba8mudding_b0ef0d77:

    # rb "No! Mickey don't, he didn't do anything!"
    rb "Não! Mickey, não, ele não fez nada!"

# game/Scenes/Reba/reba8.rpy:242
translate portuguese reba8mudding_c7a337dd:

    # mk "He's out here trying to fuck you."
    mk "Ele está aqui a tentar foder-te."

# game/Scenes/Reba/reba8.rpy:243
