# TODO: Translation updated at 2026-06-02 11:43

# game/Scenes/Reba/RebaConversations/rebas1.rpy:14
translate portuguese rebas1_703a7a1f:

    # rb "Well you've met Mama and Mickey."
    rb "Bem, já conheceste a mamã e o Mickey."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:15
translate portuguese rebas1_96542516:

    # rb "Mama used to be a teacher. Now she's on disability. Bad knees."
    rb "A mamã era professora. Agora está na reforma por invalidez. Tem problemas nos joelhos."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:17
translate portuguese rebas1_a876459e:

    # rb "And Mickey. Ugh."
    rb "E o Mickey. Ugh."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:18
translate portuguese rebas1_e06598b6:

    # rb "I love my brother, but he drives me bananas."
    rb "Adoro o meu irmão, mas ele deixa-me louca."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:19
translate portuguese rebas1_a078429c:

    # rb "He's just always messing things up, gettin' into trouble, causing problems."
    rb "Ele está sempre a estragar tudo, a meter-se em sarilhos, a causar problemas."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:21
translate portuguese rebas1_8f0c1d05:

    # rb "Mama says he's got too much of Daddy in him."
    rb "A mamã diz que ele tem demasiado do papá nele."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:22
translate portuguese rebas1_de773d17:

    # rb "And he acts like he's Daddy too, always trying to tell me what to do."
    rb "E ele age como se fosse o papá também, sempre a tentar dizer-me o que fazer."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:23
translate portuguese rebas1_6e032bd6:

    # rb "Just want to clobber him sometimes."
    rb "Às vezes só me apetece dar-lhe uma sova."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:24
translate portuguese rebas1_fa340cd0:

    # pc "And your dad? He's in prison?"
    pc "E o teu pai? Ele está na prisão?"

# game/Scenes/Reba/RebaConversations/rebas1.rpy:26
translate portuguese rebas1_2ef44ad1:

    # rb "No, Daddy's in heaven."
    rb "Não, o papá está no céu."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:27
translate portuguese rebas1_6c6d9416:

    # pc "Oh, I'm sorry."
    pc "Oh, desculpa."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:28
translate portuguese rebas1_096f84a0:

    # rb "He got sick in prison. Died there. It was real hard on Mama. On me and Mickey too, of course, but Mama took it real bad."
    rb "Ele adoeceu na prisão. Morreu lá. Foi muito difícil para a mamã. Para mim e para o Mickey também, claro, mas a mamã levou-o muito a peito."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:30
translate portuguese rebas1_aa778eb3:

    # rb "That's when she stopped working, gained all the weight, pretty much sits in front of the television now and doesn't do much."
    rb "Foi aí que ela deixou de trabalhar, engordou imenso, agora passa a maior parte do tempo sentada em frente à televisão e não faz grande coisa."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:31
translate portuguese rebas1_58925e02:

    # rb "So I dropped out of school so that I could help make money. 19 years old now and still in the same place."
    rb "Por isso, desisti da escola para poder ajudar a ganhar dinheiro. Tenho 19 anos agora e continuo na mesma situação."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:32
translate portuguese rebas1_2b85a0c1:

    # pc "Not happy about that?"
    pc "Não estás contente com isso?"

# game/Scenes/Reba/RebaConversations/rebas1.rpy:34
translate portuguese rebas1_8ac2576b:

    # rb "No. Not really."
    rb "Não. Na verdade, não."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:35
translate portuguese rebas1_91097140:

    # rb "But I can't just leave Mama."
    rb "Mas não posso simplesmente abandonar a mamã."

# game/Scenes/Reba/RebaConversations/rebas1.rpy:36
translate portuguese rebas1_d3a89021:

    # rb "She... and Mickey... are all that I have."
    rb "Ela... e o Mickey... são tudo o que tenho."

