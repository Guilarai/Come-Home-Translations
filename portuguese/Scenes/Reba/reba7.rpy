    rb "Então vemo-nos este sábado. Manda-me uma mensagem com a tua morada e eu passo por aí para te ir buscar de manhã."

# game/Scenes/Reba/reba7.rpy:65
translate portuguese reba7decline_1e6b2d49:

    # rb "We'll just be staying one night, so just bring a set of clothes and some swim trunks. I'll bring the food and supplies."
    rb "Vamos ficar apenas uma noite, por isso traz só uma muda de roupa e um fato de banho. Eu levo a comida e os mantimentos."

# game/Scenes/Reba/reba7.rpy:66
