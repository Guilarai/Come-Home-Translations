    rb "Queres um pouco de diversão?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:24
translate portuguese rebadateend_f4be2d3d:

    # rb "Good, because I {i}really{/i} do too. Let's go."
    rb "Ótimo, porque eu {i}também{/i} quero mesmo. Vamos lá."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:28
translate portuguese rebadateend_ed307571:

