# TODO: Translation updated at 2026-06-02 11:43

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:29
translate portuguese rebamovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Chegamos ao cinema e sentamo-nos nas filas de trás."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:30
translate portuguese rebamovietheaterstartdate_29279ffb:

    # rb "So what are we watching anyway?"
    rb "Então, afinal, o que é que vamos ver?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:34
translate portuguese rebamovietheaterstartdate_bb40bd64:

    # rb "Oh yeah?"
    rb "Ah, sim?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:36
translate portuguese rebamovietheaterstartdate_efb601e5:

    # rb "I hope it's the sexy kind. Where they get all sweaty and the lighting is dim, then it pans away right before they start going at it."
    rb "Espero que seja daqueles sensuais. Onde ficam todos suados e a iluminação é fraca, e depois a câmara se afasta mesmo antes de eles começarem a fazer-se."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:37
translate portuguese rebamovietheaterstartdate_516fc9fb:

    # rb "Is it that kind of romantic?"
    rb "É desse tipo de romance?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:38
translate portuguese rebamovietheaterstartdate_f9e1c11e:

    # pc "Um, I don't know? Maybe?"
    pc "Hum, não sei? Talvez?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:42
translate portuguese rebamovietheaterstartdate_e0c6223d:

    # rb "Yeah! Big macho guys with guns and explosions! I love that stuff!"
    rb "Sim! Tipos grandes e machos com armas e explosões! Adoro essas coisas!"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:46
translate portuguese rebamovietheaterstartdate_832a0115:

    # rb "Oh yeah? I'm not really into scary movies much. They never seem to really be scary to me."
    rb "Ah, é? Não curto muito filmes de terror. Eles nunca parecem ser realmente assustadores para mim."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:47
translate portuguese rebamovietheaterstartdate_10e4b7a7:

    # rb "But I'll give it a try. It'll give me an excuse to cuddle up next to you, at least."
    rb "Mas vou dar uma chance. Pelo menos vai me dar uma desculpa para me aconchegar ao teu lado."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:51
translate portuguese rebamovietheaterstartdate_eb93d29d:

    # rb "Oh God, you're going to hear my horse laugh then."
    rb "Ah, meu Deus, vais ouvir a minha risada estrondosa então."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:53
translate portuguese rebamovietheaterstartdate_6cc4cd44:

    # "There's a little time to chat before the movie starts."
    "Há um tempinho para conversar antes do filme começar."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:57
translate portuguese rebamovietheaterstartdate_592835a4:

    # "Finally the movie starts up and we go silent."
    "Finalmente o filme começa e ficamos em silêncio."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:59
translate portuguese rebamovietheaterstartdate_fd60e14c:

    # "She reaches over and holds my hand on top of the arm rest."
    "Ela estica-se e segura a minha mão em cima do apoio de braço."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:60
translate portuguese rebamovietheaterstartdate_aee76b2d:

    # "The trailers take up about fifteen minutes, then the movie really gets started."
    "Os trailers demoram cerca de quinze minutos, depois o filme começa mesmo."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:62
translate portuguese rebamovietheaterstartdate_610dce56:

    # "She seems to be liking the movie okay."
    "Ela parece estar a gostar do filme."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:64
translate portuguese rebamovietheaterstartdate_1e52f74a:

    # "During the movie, she leans against my shoulder, looking happy, if a little bored."
    "Durante o filme, ela encosta-se ao meu ombro, parecendo feliz, embora um pouco entediada."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:67
translate portuguese rebamovietheaterstartdate_e7628aae:

    # "Reba really gets into the movie. When there's a big action scene, she's even mimicking punches and cheering at the explosions."
    "A Reba entra mesmo no filme. Quando há uma grande cena de ação, ela até imita socos e aplaude as explosões."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:69
translate portuguese rebamovietheaterstartdate_8197bbed:

    # "Reba looks bored through most of the movie."
    "A Reba parece aborrecida durante a maior parte do filme."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:71
translate portuguese rebamovietheaterstartdate_2bff2bcf:

    # "She leans against my shoulder and watches silently. Even the jump scares that make me jolt a bit don't seem to have any effect on her."
    "Ela encosta-se ao meu ombro e assiste em silêncio. Nem mesmo os sustos que me fazem sobressaltar um pouco parecem ter qualquer efeito nela."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:74
translate portuguese rebamovietheaterstartdate_427a223e:

    # "Reba laughs pretty frequently throughout the movie. At first, just little chuckles, but then her laughs turn into loud horse-like whinnies."
    "A Reba ri-se com bastante frequência ao longo do filme. No início, são apenas risadinhas, mas depois as suas gargalhadas transformam-se em relinchos altos, parecidos com os de um cavalo."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:75
translate portuguese rebamovietheaterstartdate_8c6a087e:

    # "A few of the people in seats nearby turn and look at us."
    "Algumas pessoas nos lugares ao nosso redor viram-se e olham para nós."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:76
translate portuguese rebamovietheaterstartdate_65ecd1be:

    # "I'm a little embarrassed at first, but fuck them, she's having a good time and I love that."
    "Fico um pouco envergonhado no início, mas que se lixem, ela está a divertir-se e eu adoro isso."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:79
translate portuguese rebamovietheaterstartdate_65588a69:

    # rb "That movie was cute. I wish there was a little bit more of the adult stuff in it though, you know?"
    rb "Aquele filme foi giro. Mas gostava que tivesse um pouco mais de coisas para adultos, percebes?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:80
translate portuguese rebamovietheaterstartdate_73b7e285:

    # rb "Thanks for bringing me."
    rb "Obrigado por me trazeres."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:83
translate portuguese rebamovietheaterstartdate_0ffc7e30:

    # rb "That movie was freaking awesome!"
    rb "Aquele filme foi incrível!"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:85
translate portuguese rebamovietheaterstartdate_06b31029:

    # rb "Like when he went wham, blam, kapow, krakaTHOOM!"
    rb "Tipo quando ele fez «wham, blam, kapow, krakaTHOOM»!"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:87
translate portuguese rebamovietheaterstartdate_f9b2297b:

    # rb "I loved it! Thanks for bringing me."
    rb "Adorei! Obrigado por me trazeres."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:90
translate portuguese rebamovietheaterstartdate_6f921b8c:

    # rb "Wow that was boring. Horror movies just don't do anything for me. Everybody is so dang stupid."
    rb "Uau, isso foi aborrecido. Os filmes de terror não me dizem nada. São todos tão estúpidos."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:91
translate portuguese rebamovietheaterstartdate_a692f6a1:

    # rb "Let's watch something different next time. Horror movies are dumb."
    rb "Da próxima vez, vamos ver outra coisa. Os filmes de terror são uma treta."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:94
translate portuguese rebamovietheaterstartdate_4449a4f2:

    # rb "Sorry for laughing so hard. It was really funny though, right?"
    rb "Desculpa ter-me rido tanto. Mas foi mesmo engraçado, não foi?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:95
translate portuguese rebamovietheaterstartdate_e8d58dda:

    # pc "Yeah it was. Your laugh made me laugh even harder."
    pc "Sim, foi. O teu riso fez-me rir ainda mais."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:96
translate portuguese rebamovietheaterstartdate_19609177:

    # rb "I know, it's an annoying laugh, but it's mine. Can't do anything for it, ya know?"
    rb "Eu sei, é um riso irritante, mas é o meu. Não posso fazer nada quanto a isso, sabes?"

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:99
translate portuguese rebamovietheaterstartdate_233f5bf6:

    # "When the credits start rolling, we hang out and chat through them."
    "Quando os créditos começam a rolar, ficamos por lá a conversar enquanto passam."

# game/Scenes/Reba/RebaDates/rebamoviedate.rpy:103
translate portuguese rebamovietheaterstartdate_029f1c23:

    # "Then when the screen goes black, we walk outside together to my car."
    "Depois, quando o ecrã fica preto, saímos juntos para o meu carro."

