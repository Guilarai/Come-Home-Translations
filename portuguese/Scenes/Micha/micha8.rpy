    # mc "Hello, [pcname]."
    mc "Olá, [pcname]."

# game/Scenes/Micha/micha8.rpy:16
translate portuguese micha8_f481dcaa:

    # pc "Hi, Mi-Cha. How are you?"
    pc "Olá, Mi-Cha. Como estás?"

# game/Scenes/Micha/micha8.rpy:17
translate portuguese micha8_72cb11f5:

    # mc "I am good, thank you."
    mc "Estou bem, obrigado."

# game/Scenes/Micha/micha8.rpy:19
translate portuguese micha8_bdbd1fa8:

    # mc "I want to tell you that I enjoyed our coffee date."
    mc "Quero dizer-te que gostei do nosso encontro para tomar café."

# game/Scenes/Micha/micha8.rpy:20
translate portuguese micha8_8a7120da:

    # mc "I apologize for rushing off early and would like to again another sometime."
    mc "Peço desculpa por ter saído apressadamente e gostaria de repetir outra altura."

# game/Scenes/Micha/micha8.rpy:21
translate portuguese micha8_3171636b:

    # mc "If you would like to this evening?"
    mc "Se quiseres esta noite?"

# game/Scenes/Micha/micha8.rpy:25
translate portuguese micha8_2d186b97:

    # mc "Good. I will meet you in the Skyhill Cafe this evening then."
    mc "Ótimo. Encontro-te no Skyhill Cafe esta noite, então."

# game/Scenes/Micha/micha8.rpy:29
translate portuguese micha8_2f88594e:

    # mc "Oh. Okay. Yes, I'm sure you're busy."
    mc "Oh. Está bem. Sim, tenho a certeza de que estás ocupada."

# game/Scenes/Micha/micha8.rpy:31
translate portuguese micha8_08d0510d:

    # mc "Enjoy your visit with Mrs. Spann."
    mc "Aproveita a tua visita com a Sra. Spann."

# game/Scenes/Micha/micha8.rpy:32
