    # mc "I am. So happy."
    mc "Sou. Tão feliz."

# game/Scenes/Micha/micha18.rpy:201
translate portuguese micha18_d41d8cd9_13:

    # voice 'voices/micha_18_14.mp3'
    voice 'voices/micha_18_14.mp3'

