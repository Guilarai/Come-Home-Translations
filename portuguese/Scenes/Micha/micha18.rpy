    # mc "I don't know. I will talk to Mrs. Spann about it. She knows better than me."
    mc "Não sei. Vou falar com a Sra. Spann sobre isso. Ela sabe melhor do que eu."

# game/Scenes/Micha/micha18.rpy:171
translate portuguese micha18_d41d8cd9_7:

    # voice 'voices/micha_18_8.mp3'
    voice 'voices/micha_18_8.mp3'

