translate portuguese micha7_fa4d4666:

    # pc "What would you like, Mi-Cha? I'll pay. Anything you want."
    pc "O que gostaria, Mi-Cha? Eu pago. O que quiser."

# game/Scenes/Micha/micha7.rpy:62
translate portuguese micha7_816eccbd:

    # mc "You first, please."
    mc "Você primeiro, por favor."

# game/Scenes/Micha/micha7.rpy:63
translate portuguese micha7_c24a94ff:

    # pc "Okay. I'll have a hot vanilla latte."
    pc "Está bem. Vou querer um latte quente de baunilha."

# game/Scenes/Micha/micha7.rpy:64
translate portuguese micha7_0515f2bf:

    # mc "I will have the same."
    mc "Eu vou querer o mesmo."

# game/Scenes/Micha/micha7.rpy:65
translate portuguese micha7_a4c27a52:

    # bn "Sure thing. Two hot vanilla lattes coming right up."
    bn "Claro. Dois lattes quentes de baunilha já estão a caminho."

# game/Scenes/Micha/micha7.rpy:68
translate portuguese micha7_9e1b5b12:

    # "We wait for our drinks, I pay, then we go to a table and sit down."
    "Esperamos pelas nossas bebidas, eu pago e depois vamos para uma mesa e sentamo-nos."

# game/Scenes/Micha/micha7.rpy:69
translate portuguese micha7_c8eefb91:

    # "Mi-Cha doesn't say anything, just looking down at her coffee and smiling nervously."
    "A Mi-Cha não diz nada, apenas olha para o café e sorri nervosamente."

# game/Scenes/Micha/micha7.rpy:74
translate portuguese micha7_2aebf130:

    # mc "Very good, thank you."
    mc "Muito bom, obrigado."

# game/Scenes/Micha/micha7.rpy:80
translate portuguese micha7_2aebf130_1:

    # mc "Very good, thank you."
    mc "Muito bom, obrigado."

