# game/Scenes/Micha/micha7.rpy:11
translate portuguese micha7a_be31aa9e:

    # "I spend some time talking to Gertrude about the things that have been on my mind. Then when I am about to leave and head to class, she stops me."
    "Passo algum tempo a falar com a Gertrude sobre as coisas que me têm andado na cabeça. Depois, quando estou prestes a sair e a dirigir-me para a aula, ela impede-me."

# game/Scenes/Micha/micha7.rpy:12
translate portuguese micha7a_039a0a46:

    # sc "Hey, before you leave, I wanted to tell you that I talked to Mi-Cha about you."
    sc "Ei, antes de ires embora, queria dizer-te que falei com a Mi-Cha sobre ti."

# game/Scenes/Micha/micha7.rpy:13
translate portuguese micha7a_ae871f39:

    # pc "Oh yeah?"
    pc "Ah, sim?"

# game/Scenes/Micha/micha7.rpy:14
translate portuguese micha7a_13380f5e:

    # sc "She's very shy, but I talked her into having a little coffee meet-up with you. Can you meet her this evening?"
    sc "Ela é muito tímida, mas convenci-a a marcar um encontro para tomar um café contigo. Podes encontrar-te com ela esta noite?"

# game/Scenes/Micha/micha7.rpy:18
translate portuguese micha7a_5ec9bea1:

    # sc "Great! I'll let her know to meet you in the school café this evening."
    sc "Ótimo! Vou dizer-lhe para se encontrar contigo no café da escola esta noite."

# game/Scenes/Micha/micha7.rpy:19
translate portuguese micha7a_a8af18a8:

    # pc "Cool, I'm looking forward to it."
    pc "Fixe, estou ansioso por isso."

# game/Scenes/Micha/micha7.rpy:20
translate portuguese micha7a_e4769446:

    # sc "Okay, I'll see you later, [pcname]."
    sc "Está bem, até logo, [pcname]."

# game/Scenes/Micha/micha7.rpy:23
translate portuguese micha7a_9669528e:

    # "Later..."
    "Até logo..."

# game/Scenes/Micha/micha7.rpy:29
translate portuguese micha7a_6750acb1:

    # sc "Oh, I'm sorry. I thought you were."
    sc "Oh, desculpa. Pensei que fosses."

# game/Scenes/Micha/micha7.rpy:30
translate portuguese micha7a_9f1153c2:

    # sc "Okay then. She'll be disappointed, but I'll let her know."
    sc "Está bem, então. Ela vai ficar desapontada, mas vou avisá-la."

# game/Scenes/Micha/micha7.rpy:31
translate portuguese micha7a_9c57fd84:

    # sc "I'll see you later, [pcname]."
    sc "Até logo, [pcname]."

# game/Scenes/Micha/micha7.rpy:39
translate portuguese micha7_617439f0:

    # "I head over to the café for my coffee date with Mi-Cha."
    "Dirijo-me ao café para o meu encontro com a Mi-Cha."

# game/Scenes/Micha/micha7.rpy:44
translate portuguese micha7_046f6d25:

    # "When I walk into the café, I spot Mi-Cha sitting alone at one of the tables. She sees me immediately, as if she has been staring at the door waiting for me to enter."
    "Quando entro no café, vejo a Mi-Cha sentada sozinha numa das mesas. Ela vê-me imediatamente, como se estivesse a olhar para a porta à espera que eu entrasse."

# game/Scenes/Micha/micha7.rpy:47
translate portuguese micha7_715a3be9:

    # "She immediately stands and walks up towards me."
    "Ela levanta-se imediatamente e caminha na minha direção."

# game/Scenes/Micha/micha7.rpy:49
translate portuguese micha7_d41d8cd9:

    # voice 'voices/micha_7_1.mp3'
    voice 'voices/micha_7_1.mp3'

# game/Scenes/Micha/micha7.rpy:50
translate portuguese micha7_b81c6f86:

    # mc "Hello, [pcname]. My name is Mi-Cha. It is very nice to meet you."
    mc "Olá, [pcname]. O meu nome é Mi-Cha. É um prazer conhecer-te."

# game/Scenes/Micha/micha7.rpy:51
translate portuguese micha7_65b65cd2:

    # pc "Hi, Mi-Cha. We've met already in the lobby remember?"
    pc "Olá, Mi-Cha. Já nos conhecemos no átrio, lembras-te?"

# game/Scenes/Micha/micha7.rpy:53
translate portuguese micha7_d41d8cd9_1:

    # voice 'voices/micha_yes1.mp3'
    voice 'voices/micha_yes1.mp3'

# game/Scenes/Micha/micha7.rpy:54
translate portuguese micha7_076877b6:

    # mc "Yes, I remember."
    mc "Sim, lembro-me."

# game/Scenes/Micha/micha7.rpy:55
translate portuguese micha7_1d573332:

    # pc "Do you want a coffee?"
    pc "Quer um café?"

# game/Scenes/Micha/micha7.rpy:57
translate portuguese micha7_bf8efb1f:

    # "She doesn't say anything in response, instead just nodding her head slightly."
    "Ela não diz nada em resposta, limitando-se a acenar ligeiramente com a cabeça."

# game/Scenes/Micha/micha7.rpy:60
translate portuguese micha7_b6487666:

    # bn "Hi there. What can I get for you?"
    bn "Olá. O que lhe posso servir?"

