    mc "Lamento imenso, mas gostaria de ir agora."

# game/Scenes/Micha/micha7.rpy:157
translate portuguese micha7_bb0eeaf4:

    # mc "Thank you."
    mc "Obrigada."

# game/Scenes/Micha/micha7.rpy:158
