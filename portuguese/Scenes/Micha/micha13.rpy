translate portuguese micha13_80adb898:

    # "I kiss her goodbye."
    "Dou-lhe um beijo de despedida."

# game/Scenes/Micha/micha13.rpy:80
translate portuguese micha13_bed52260:

    # "If I had time, I'd do more."
    "Se tivesse tempo, faria mais."

# game/Scenes/Micha/micha13.rpy:83
