    # mc "Thank you, [pcname]."
    mc "Obrigada, [pcname]."

# game/Scenes/Micha/micha13.rpy:63
translate portuguese micha13_e3b6df4e:

    # pc "Do you feel better now?"
    pc "Sentes-te melhor agora?"

# game/Scenes/Micha/micha13.rpy:64
translate portuguese micha13_c324b928:

    # mc "Yes. I feel much better now."
    mc "Sim. Sinto-me muito melhor agora."

# game/Scenes/Micha/micha13.rpy:65
