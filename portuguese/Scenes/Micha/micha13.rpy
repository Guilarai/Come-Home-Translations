    mc "Sim, [mcsir]."

# game/Scenes/Micha/micha13.rpy:56
translate portuguese micha13_536da0ad:

    # mc "I will keep dancing. For you."
    mc "Vou continuar a dançar. Por ti."

# game/Scenes/Micha/micha13.rpy:57
translate portuguese micha13_f07574ec:

    # pc "Good."
    pc "Ótimo."

