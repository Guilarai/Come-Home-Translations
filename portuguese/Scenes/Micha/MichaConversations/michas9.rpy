# game/Scenes/Micha/MichaConversations/michas9.rpy:17
translate portuguese michas9_ed976aba:

    # mc "There are multiple reasons."
    mc "Há várias razões."

# game/Scenes/Micha/MichaConversations/michas9.rpy:19
translate portuguese michas9_bf08e48d:

    # mc "I like America. I have always wanted to live here."
    mc "Gosto da América. Sempre quis viver aqui."

# game/Scenes/Micha/MichaConversations/michas9.rpy:21
translate portuguese michas9_65fd7022:

    # mc "Korea is very nice, but America is the land of opportunity."
    mc "A Coreia é muito agradável, mas a América é a terra das oportunidades."

# game/Scenes/Micha/MichaConversations/michas9.rpy:23
translate portuguese michas9_4094fdf6:

    # mc "Here, you can be anything that you want to be."
    mc "Aqui, podes ser tudo o que quiseres."

# game/Scenes/Micha/MichaConversations/michas9.rpy:25
translate portuguese michas9_dfd6858c:

    # mc "If I go home, I will be married to somebody who I have never met."
    mc "Se voltar para casa, vou casar com alguém que nunca conheci."

# game/Scenes/Micha/MichaConversations/michas9.rpy:26
translate portuguese michas9_75f2de85:

    # mc "I will work a job that I do not love."
    mc "Vou ter um emprego que não adoro."

# game/Scenes/Micha/MichaConversations/michas9.rpy:28
translate portuguese michas9_428d4fca:

    # mc "And I will not dance anymore."
    mc "E não vou dançar mais."

# game/Scenes/Micha/MichaConversations/michas9.rpy:30
translate portuguese michas9_c1091f3a:

    # mc "The longer I stay here in America, the more I realize that I do not want that."
    mc "Quanto mais tempo fico aqui na América, mais percebo que não quero isso."

# game/Scenes/Micha/MichaConversations/michas9.rpy:32
translate portuguese michas9_49f2c979:

    # mc "I like that my parents help me make decisions. I like being told what to do."
    mc "Gosto que os meus pais me ajudem a tomar decisões. Gosto que me digam o que fazer."

# game/Scenes/Micha/MichaConversations/michas9.rpy:34
translate portuguese michas9_8c22cf46:

    # mc "But sometimes, I want to be able to say \"No! I'll do what {i}I{/i} want.\""
    mc "Mas, às vezes, quero poder dizer «Não! Vou fazer o que {i}eu{/i} quero.»"

# game/Scenes/Micha/MichaConversations/michas9.rpy:36
translate portuguese michas9_f16c9db7:

    # mc "I want to stay here."
    mc "Quero ficar aqui."

# game/Scenes/Micha/MichaConversations/michas9.rpy:38
translate portuguese michas9_d59ae8ff:

    # mc "I want to work at a job that I love."
    mc "Quero ter um emprego que adore."

# game/Scenes/Micha/MichaConversations/michas9.rpy:40
translate portuguese michas9_b89dabfd:

    # mc "I want to marry a man that I love."
    mc "Quero casar com um homem que amo."

# game/Scenes/Micha/MichaConversations/michas9.rpy:42
translate portuguese michas9_61b942ac:

    # mc "And I want to dance!"
    mc "E quero dançar!"

# game/Scenes/Micha/MichaConversations/michas9.rpy:43
translate portuguese michas9_c5ada324:

    # pc "Whatever happens, I hope that you never stop dancing, Mi-Cha."
    pc "Aconteça o que acontecer, espero que nunca deixes de dançar, Mi-Cha."

# game/Scenes/Micha/MichaConversations/michas9.rpy:44
translate portuguese michas9_a91a8d92:

    # mc "I hope so too. I don't want to stop."
    mc "Também espero isso. Não quero parar."

