# game/Scenes/Micha/MichaConversations/michas4.rpy:15
translate portuguese michas4_cb1615b7:

    # mc "My father chose it. I don't know why he chose this place in particular."
    mc "Foi o meu pai que escolheu. Não sei porque é que ele escolheu este lugar em particular."

# game/Scenes/Micha/MichaConversations/michas4.rpy:17
translate portuguese michas4_7558e3ed:

    # mc "I believe he was given a list of places that would accept me, despite my poor grades..."
    mc "Acho que lhe deram uma lista de lugares que me aceitariam, apesar das minhas notas fracas..."

# game/Scenes/Micha/MichaConversations/michas4.rpy:18
translate portuguese michas4_6f225033:

    # mc "...and Skyhill University was the highest rated school that I qualified for."
    mc "...e a Universidade de Skyhill era a escola com melhor classificação para a qual eu me qualificava."

# game/Scenes/Micha/MichaConversations/michas4.rpy:20
translate portuguese michas4_e2c5e502:

    # mc "Which says something about how poor my grades were."
    mc "O que diz muito sobre o quão fracas eram as minhas notas."

# game/Scenes/Micha/MichaConversations/michas4.rpy:22
translate portuguese michas4_db3fe301:

    # mc "I'm sorry! I don't mean to dishonor this school!"
    mc "Desculpem! Não quero desonrar esta escola!"

# game/Scenes/Micha/MichaConversations/michas4.rpy:24
translate portuguese michas4_736c172d:

    # mc "It is a good school and I am happy to be given the opportunity to study here."
    mc "É uma boa escola e estou feliz por ter a oportunidade de estudar aqui."

# game/Scenes/Micha/MichaConversations/michas4.rpy:26
translate portuguese michas4_4ec300b0:

    # mc "When I talk to my friends back home though, none of them have ever heard of Skyhill. They think that I am making the place up."
    mc "Mas quando falo com os meus amigos lá de casa, nenhum deles nunca ouviu falar de Skyhill. Acham que estou a inventar o lugar."

# game/Scenes/Micha/MichaConversations/michas4.rpy:28
translate portuguese michas4_65bfb7d2:

    # mc "So... I know that it is wrong to lie, but I tell them that I am attending Harvard."
    mc "Então... sei que é errado mentir, mas digo-lhes que estou a estudar em Harvard."

# game/Scenes/Micha/MichaConversations/michas4.rpy:29
translate portuguese michas4_839ed9b8:

    # pc "Haha! Really?"
    pc "Haha! A sério?"

# game/Scenes/Micha/MichaConversations/michas4.rpy:31
translate portuguese michas4_2064101c:

    # mc "Yes. It is funny, isn't it?"
    mc "Sim. É engraçado, não é?"

# game/Scenes/Micha/MichaConversations/michas4.rpy:32
translate portuguese michas4_862bf897:

    # pc "It's hilarious."
    pc "É hilariante."

# game/Scenes/Micha/MichaConversations/michas4.rpy:33
translate portuguese michas4_1e5e09e7:

    # mc "I'm glad you think so. I thought so too."
    mc "Fico contente por achares isso. Também achei."

# game/Scenes/Micha/MichaConversations/michas4.rpy:35
translate portuguese michas4_9b17ca88:

    # mc "They all believe me too. I tell them that I am very popular and that I have a boyfriend also."
    mc "Eles também acreditam todos em mim. Digo-lhes que sou muito popular e que também tenho namorado."

# game/Scenes/Micha/MichaConversations/michas4.rpy:38
translate portuguese michas4_facfa516:

    # mc "Which part?"
    mc "Que parte?"

# game/Scenes/Micha/MichaConversations/michas4.rpy:39
translate portuguese michas4_b7770814:

    # pc "That you have a boyfriend. Since I'm your boyfriend."
    pc "A de teres namorado. Já que eu sou o teu namorado."

# game/Scenes/Micha/MichaConversations/michas4.rpy:41
translate portuguese michas4_a4fcb7ef:

    # mc "Oh!"
    mc "Oh!"

# game/Scenes/Micha/MichaConversations/michas4.rpy:42
translate portuguese michas4_9a78c4c6:

    # mc "Yes, I guess you are."
    mc "Sim, acho que és."

# game/Scenes/Micha/MichaConversations/michas4.rpy:45
translate portuguese michas4_c4a23117:

    # mc "I know. I am awful sometimes."
    mc "Eu sei. Às vezes sou horrível."

# game/Scenes/Micha/MichaConversations/michas4.rpy:46
translate portuguese michas4_2f03ca34:

    # pc "It's still funny though."
    pc "Mas mesmo assim é engraçado."

# game/Scenes/Micha/MichaConversations/michas4.rpy:48
translate portuguese michas4_9331e107:

    # mc "Yes it is."
    mc "Sim, é."

