# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:24
translate portuguese michamovietheaterstartdate_929c1af5:

    # "I head over to the movie theater to meet Mi-Cha."
    "Dirijo-me ao cinema para me encontrar com a Mi-Cha."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:27
translate portuguese michamovietheaterstartdate_53aa213e:

    # "I meet Mi-Cha in the movie theater parking lot."
    "Encontro-me com a Mi-Cha no parque de estacionamento do cinema."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:29
translate portuguese michamovietheaterstartdate_1696084c:

    # pc "You look very cute."
    pc "Estás muito gira."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:32
translate portuguese michamovietheaterstartdate_d41d8cd9:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:33
translate portuguese michamovietheaterstartdate_bb0eeaf4:

    # mc "Thank you."
    mc "Obrigada."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:34
translate portuguese michamovietheaterstartdate_17670cf3:

    # mc "You look nice also."
    mc "Também estás com bom aspeto."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:37
translate portuguese michamovietheaterstartdate_88edd4ad:

    # "Then we go inside and sit in the back."
    "Depois entramos e sentamo-nos lá atrás."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:39
translate portuguese michamovietheaterstartdate_90b2b501:

    # "She's so quiet. I should try to start up a conversation."
    "Ela está tão calada. Devia tentar puxar conversa."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:44
translate portuguese michamovietheaterstartdate_56f38f5f:

    # "The movie starts and we go quiet."
    "O filme começa e ficamos em silêncio."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:45
translate portuguese michamovietheaterstartdate_0a855fcc:

    # "Throughout the movie, it feels like she starts to relax some."
    "Ao longo do filme, parece que ela começa a relaxar um pouco."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:47
translate portuguese michamovietheaterstartdate_914a9aa2:

    # "It's a fun movie and she's nice company, if a little quiet."
    "É um filme divertido e ela é boa companhia, apesar de um pouco calada."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:49
translate portuguese michamovietheaterstartdate_0edfdae0:

    # "When it ends, she turns to me."
    "Quando acaba, ela vira-se para mim."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:51
translate portuguese michamovietheaterstartdate_bab5119d:

    # mc "Did you like the movie?"
    mc "Gostaste do filme?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:52
translate portuguese michamovietheaterstartdate_f4477343:

    # pc "Yeah I enjoyed it."
    pc "Sim, gostei."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:53
translate portuguese michamovietheaterstartdate_e4993620:

    # mc "Me too. I thought it was very good."
    mc "Eu também. Achei muito bom."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:54
translate portuguese michamovietheaterstartdate_365db8f9:

    # "We hang out during the credits and chat a little bit more."
    "Ficamos por lá durante os créditos e conversamos um pouco mais."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:59
translate portuguese michamovietheaterstartdate_63e18d0b:

    # "When the credits end, we go outside to the parking lot and stand near her car."
    "Quando os créditos acabam, saímos para o parque de estacionamento e ficamos perto do carro dela."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:60
translate portuguese michamovietheaterstartdate_725fffe9:

    # mc "I had a very good time. Thank you for taking me."
    mc "Diverti-me imenso. Obrigado por me levares."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:61
translate portuguese michamovietheaterstartdate_07c9c5ab:

    # pc "You're welcome."
    pc "De nada."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:65
translate portuguese michamovietheaterstartdate_5f014a7b:

    # "She rushes up to me, leans up and gives me a tiny peck of a kiss on the mouth, our lips barely touching."
    "Ela corre na minha direção, inclina-se e dá-me um beijinho na boca, os nossos lábios mal se tocando."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:67
translate portuguese michamovietheaterstartdate_5ac477c2:

    # "Then she pulls back once again."
    "Depois, afasta-se mais uma vez."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:68
translate portuguese michamovietheaterstartdate_50afc9a0:

    # mc "Okay goodbye, [pcname]."
    mc "Ok, adeus, [pcname]."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:70
translate portuguese michamovietheaterstartdate_0488daa1:

    # "And before I can say anything in response, she rushes to her car, starts it up, and drives away."
    "E antes que eu consiga dizer alguma coisa em resposta, ela corre para o carro, liga-o e vai-se embora."

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:72
translate portuguese michamovietheaterstartdate_6cbf222e:

    # "Well, I guess we're making some progress at least?"
    "Bem, acho que estamos a fazer algum progresso, pelo menos?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:78
translate portuguese michamovietheaterstartdate_2674be8c:

    # mc "Would you mind taking me back to my dorm?"
    mc "Importas-te de me levar de volta ao meu dormitório?"

# game/Scenes/Micha/MichaDates/michamovietheaterdate.rpy:79
translate portuguese michamovietheaterstartdate_a274c9a4:

    # pc "Of course not."
    pc "Claro que não."

