    # con "I don't really either. I think I've had this pack for a year or so."
    con "Na verdade, eu também não. Acho que tenho este maço há um ano ou assim."

# game/Scenes/Connie/connie15.rpy:212
translate portuguese connie15_98da17ed:

    # con "Right now, after that, a cigarette hits just right."
    con "Neste momento, depois daquilo, um cigarro cai mesmo bem."

# game/Scenes/Connie/connie15.rpy:213
translate portuguese connie15_596c0f44:

    # con "You know, besides my husband, you're the first man I've had sex with in fifty years."
    con "Sabes, além do meu marido, és o primeiro homem com quem fiz sexo em cinquenta anos."

# game/Scenes/Connie/connie15.rpy:214
translate portuguese connie15_6a75940e:

    # pc "Really? You and Jackson never had anything?"
    pc "A sério? Tu e o Jackson nunca tiveram nada?"

# game/Scenes/Connie/connie15.rpy:215
translate portuguese connie15_03c8c55b:

    # con "Naw, he's like a brother to me. He's never looked at me like that."
    con "Não, ele é como um irmão para mim. Nunca olhou para mim dessa forma."

# game/Scenes/Connie/connie15.rpy:216
translate portuguese connie15_42e3bab3:

    # con "Nobody ever really looks at me like that."
    con "Ninguém olha realmente para mim dessa forma."

# game/Scenes/Connie/connie15.rpy:219
translate portuguese connie15_bab07018:

    # pc "I don't see why not. You're a good looking woman."
    pc "Não vejo por que não. És uma mulher bonita."

# game/Scenes/Connie/connie15.rpy:220
translate portuguese connie15_2a7d9ea2:

    # con "I try, but nobody is interested in an old lady."
    con "Eu tento, mas ninguém está interessado numa senhora idosa."

# game/Scenes/Connie/connie15.rpy:221
translate portuguese connie15_f0f40b8d:

    # con "You got to use it while you're young, you know? Else you end up stuck in an old body, all alone."
    con "Tens de aproveitar enquanto és jovem, sabes? Senão acabas presa num corpo velho, completamente sozinha."

# game/Scenes/Connie/connie15.rpy:222
translate portuguese connie15_007fbff2:

    # pc "You have regrets?"
    pc "Tens arrependimentos?"

# game/Scenes/Connie/connie15.rpy:223
translate portuguese connie15_79491ffd:

    # con "Oh, no. Not really."
    con "Oh, não. Na verdade, não."

# game/Scenes/Connie/connie15.rpy:224
translate portuguese connie15_bf42fbfd:

    # con "My husband was good to me. We had a lot of really good years."
    con "O meu marido era bom para mim. Tivemos muitos anos realmente bons."

# game/Scenes/Connie/connie15.rpy:227
translate portuguese connie15_8fb15acf:

    # con "And that man was just as gifted as you are in bed."
    con "E aquele homem era tão dotado na cama como tu."

# game/Scenes/Connie/connie15.rpy:228
translate portuguese connie15_acf7a854:

    # con "God, I miss him."
    con "Meu Deus, sinto a falta dele."

# game/Scenes/Connie/connie15.rpy:231
translate portuguese connie15_25ac1736:

    # pc "Did you have any children?"
    pc "Tiveste filhos?"

# game/Scenes/Connie/connie15.rpy:232
translate portuguese connie15_4575dead:

    # con "One. A boy. Chase."
    con "Um. Um rapaz. O Chase."

# game/Scenes/Connie/connie15.rpy:233
translate portuguese connie15_5b0fb844:

    # con "He died over in Afghanistan."
    con "Ele morreu no Afeganistão."

# game/Scenes/Connie/connie15.rpy:234
translate portuguese connie15_6c6d9416_1:

    # pc "Oh, I'm sorry."
    pc "Oh, lamento."

# game/Scenes/Connie/connie15.rpy:237
translate portuguese connie15_0fa6aba4_1:

    # con "It's okay."
    con "Não faz mal."

# game/Scenes/Connie/connie15.rpy:238
translate portuguese connie15_d075efd8:

    # con "Sometimes I feel like I died too..."
    con "Às vezes sinto que também morri..."

# game/Scenes/Connie/connie15.rpy:239
translate portuguese connie15_454cba6d:

    # con "... and I'm just stuck here, waiting for my turn to go meet them."
    con "... e estou apenas presa aqui, à espera da minha vez de ir ter com eles."

# game/Scenes/Connie/connie15.rpy:242
translate portuguese connie15_19979052:

    # con "Thank you for making me feel alive for a little while."
    con "Obrigada por me fazeres sentir viva por um bocadinho."

# game/Scenes/Connie/connie15.rpy:243
translate portuguese connie15_2911487b:

    # con "You're a good kid."
    con "És um bom rapaz."

# game/Scenes/Connie/connie15.rpy:246
translate portuguese connie15_109a5d63:

    # con "I think you and Brandi make a very nice couple."
    con "Acho que tu e a Brandi formam um casal muito bonito."

# game/Scenes/Connie/connie15.rpy:247
translate portuguese connie15_68f01008:

    # con "You should consider settling down with her."
    con "Devias pensar em assentar com ela."

# game/Scenes/Connie/connie15.rpy:248
translate portuguese connie15_19e05b84:

    # con "I see you coming into Jackson's with different girls."
    con "Vejo-te a entrar no Jackson's com raparigas diferentes."

# game/Scenes/Connie/connie15.rpy:249
translate portuguese connie15_fedfc4a9:

    # con "You're young. That's a good thing. Experiment."
    con "És jovem. Isso é bom. Experimenta."

# game/Scenes/Connie/connie15.rpy:250
translate portuguese connie15_ec119d97:

    # con "But eventually, I hope you'll pick a girl and start a life and a family with her."
    con "Mas, eventualmente, espero que escolhas uma rapariga e comeces uma vida e uma família com ela."

# game/Scenes/Connie/connie15.rpy:251
translate portuguese connie15_1dc28a58:

    # con "And I hope you'll make each other very happy."
    con "E espero que se façam muito felizes um ao outro."

# game/Scenes/Connie/connie15.rpy:252
translate portuguese connie15_a40b7cd5:

    # pc "Thanks, Connie."
    pc "Obrigado, Connie."

# game/Scenes/Connie/connie15.rpy:253
translate portuguese connie15_0fd31492:

    # con "All right, that's enough reminiscing. Time to get dressed."
    con "Muito bem, já chega de recordações. Está na hora de me vestir."

# game/Scenes/Connie/connie15.rpy:256
translate portuguese connie15_2f1120e6:

    # "Before I leave, she hands me a tin full of chocolate chip cookies."
    "Antes de sair, ela entrega-me uma lata cheia de bolachas com pepitas de chocolate."

# game/Scenes/Connie/connie15.rpy:257
translate portuguese connie15_189fa119:

    # con "I made these for Jackson, but he can have the next batch. You enjoy. You earned them."
    con "Fiz estes para o Jackson, mas ele pode ficar com a próxima fornada. Aproveita. Mereceste-os."

# game/Scenes/Connie/connie15.rpy:258
translate portuguese connie15_25e0f073:

    # con "Thanks again for making my day."
    con "Mais uma vez, obrigado por alegrares o meu dia."

# game/Scenes/Connie/connie15.rpy:259
translate portuguese connie15_a351accf:

    # con "I don't think we'll do this again, but I'm glad to have spent some time with you."
    con "Acho que não vamos repetir isto, mas fico contente por ter passado algum tempo contigo."

# game/Scenes/Connie/connie15.rpy:260
translate portuguese connie15_a9da76fd:

    # pc "Me too, Connie."
    pc "Eu também, Connie."

# game/Scenes/Connie/connie15.rpy:261
translate portuguese connie15_c6512378:

    # con "You take care."
    con "Cuida-te."

# game/Scenes/Connie/connie15.rpy:264
translate portuguese connie15_18c0b69c:

    # "I leave Connie's house and drive away."
    "Saio da casa da Connie e vou-me embora de carro."

# game/Scenes/Connie/connie15.rpy:265
translate portuguese connie15_313c822e:

    # "I hope she'll be okay. She's a sweet lady."
    "Espero que ela fique bem. É uma senhora adorável."

# game/Scenes/Connie/connie15.rpy:266
translate portuguese connie15_f74a794a:

    # "And she gives a killer gummer."
    "E ela dá uns beijos de morrer."

