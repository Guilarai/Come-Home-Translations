# game/Scenes/Kendra/KendraConversations/kendras7.rpy:11
translate portuguese kendras7_8fd41e03:

    # sg "Pretty good. I'm an only child. My parents are always all over me."
    sg "Muito bom. Sou filho único. Os meus pais estão sempre em cima de mim."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:12
translate portuguese kendras7_eee1fc6b:

    # sg "I have to check in with them constantly or they worry."
    sg "Tenho de lhes dar notícias constantemente, senão ficam preocupados."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:13
translate portuguese kendras7_9a201c87:

    # pc "But you're an adult."
    pc "Mas tu és adulto."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:14
translate portuguese kendras7_e62a3877:

    # sg "Yeah. 18. But I still live with them."
    sg "Sim. Tenho 18 anos. Mas ainda vivo com eles."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:15
translate portuguese kendras7_9d123d9e:

    # sg "And they just worry about me a lot."
    sg "E eles preocupam-se muito comigo."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:16
translate portuguese kendras7_b2a4a8aa:

    # sg "So every hour or so when I'm out, I send them a text to let them know I'm okay."
    sg "Por isso, mais ou menos de hora a hora, quando estou fora, mando-lhes uma mensagem para lhes dizer que estou bem."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:17
translate portuguese kendras7_835b214c:

    # sg "We get along pretty good, but they're a little stuffy and old."
    sg "Damo-nos muito bem, mas eles são um pouco caretas e antiquados."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:19
translate portuguese kendras7_58264177:

    # sg "They don't like me dying my hair, they don't want me taking risks – skateboarding, skiing, bungee jumping."
    sg "Não gostam que eu pinte o cabelo, não querem que eu corra riscos – andar de skate, esquiar, fazer bungee jumping."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:20
translate portuguese kendras7_2566c179:

    # pc "That sounds like all the things that you love to do."
    pc "Isso parece ser tudo o que adoras fazer."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:22
translate portuguese kendras7_2641b38a:

    # sg "It is."
    sg "É mesmo."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:23
translate portuguese kendras7_788e5c52:

    # sg "If it were their choice though, I'd be at home in my room all day."
    sg "Se fosse por eles, eu estaria em casa no meu quarto o dia todo."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:24
translate portuguese kendras7_4d38f99e:

    # sg "Or married, with a nine-to-five job and a kid on the way."
    sg "Ou casada, com um emprego das nove às cinco e um filho a caminho."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:26
translate portuguese kendras7_9baced8d:

    # sg "They're both actors and they used to be hippies, but now they're all formal and boring."
    sg "Eles são ambos atores e costumavam ser hippies, mas agora são todos formais e chatos."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:27
translate portuguese kendras7_27852007:

    # sg "But I still love them and I know they love me."
    sg "Mas eu ainda os amo e sei que eles me amam."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:28
translate portuguese kendras7_108fbd18:

    # pc "Sometimes that's all you can ask for."
    pc "Às vezes, é tudo o que se pode pedir."

# game/Scenes/Kendra/KendraConversations/kendras7.rpy:30
translate portuguese kendras7_a5870bba:

    # sg "Yeah. It's not so bad."
    sg "Sim. Não é assim tão mau."

