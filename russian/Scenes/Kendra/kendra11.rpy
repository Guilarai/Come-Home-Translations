    sg "Либо я умру и разbiję тебе сердце. Либо, что еще хуже, я окажусь парализованной, и ты почувствуешь, что должен обо мне заботиться."

# game/Scenes/Kendra/kendra11.rpy:66
translate russian kendra11_d41d8cd9_1:

    # voice "voices/kendra_dontwanttohurtyou.wav"
    voice "voices/kendra_dontwanttohurtyou.wav"

