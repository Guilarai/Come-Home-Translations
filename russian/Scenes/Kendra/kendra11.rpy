    # sg "Thank you for everything, [pcname]. Seriously."
    sg "Спасибо за все, [pcname]. Серьезно."

# game/Scenes/Kendra/kendra11.rpy:102
translate russian kendra11_e5dc6217:

    # sg "You are my best friend."
    sg "Ты мой лучший друг."

# game/Scenes/Kendra/kendra11.rpy:103
