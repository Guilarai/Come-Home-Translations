translate russian micha18_06801be0:

    # mc "I am. So happy."
    mc "Я счастлива. Очень счастлива."

# game/Scenes/Micha/micha18.rpy:201
translate russian micha18_d41d8cd9_13:

    # voice 'voices/micha_18_14.mp3'
    voice 'voices/micha_18_14.mp3'

# game/Scenes/Micha/micha18.rpy:202
translate russian micha18_bb0eeaf4:

    # mc "Thank you."
    mc "Спасибо."

# game/Scenes/Micha/micha18.rpy:204
translate russian micha18_d41d8cd9_14:

    # voice 'voices/micha_18_15.mp3'
    voice 'voices/micha_18_15.mp3'

# game/Scenes/Micha/micha18.rpy:205
translate russian micha18_4d562fad:

    # mc "Even if we are not together forever. You have changed me."
    mc "Даже если мы не будем вместе навсегда. Ты изменил меня."

# game/Scenes/Micha/micha18.rpy:207
translate russian micha18_d41d8cd9_15:

    # voice 'voices/micha_18_16.mp3'
    voice 'voices/micha_18_16.mp3'

# game/Scenes/Micha/micha18.rpy:208
translate russian micha18_4a1f6929:

    # mc "I am better because of you."
    mc "Я стала лучше благодаря тебе."

# game/Scenes/Micha/micha18.rpy:211
translate russian micha18_b3c8f504:

    # "We stay there for a while, until it's time for her to get back to her dorm and for me to get back home."
    "Мы остаемся там еще на некоторое время, пока не приходит время ей возвращаться в общежитие, а мне — домой."

# game/Scenes/Micha/micha18.rpy:212
translate russian micha18_0f7e558a:

    # "When we say goodbye, it's harder this time."
    "Когда мы прощаемся, на этот раз это сложнее."

# game/Scenes/Micha/micha18.rpy:213
translate russian micha18_0fce2cbe:

    # "It gets harder every time."
    "С каждым разом становится все сложнее."

