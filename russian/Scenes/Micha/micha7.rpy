translate russian micha7_6305b1a7:

    # mc "Is it okay if I leave?"
    mc "Можно я уйду?"

# game/Scenes/Micha/micha7.rpy:151
translate russian micha7_d7eacc92:

    # mc "I know better than to be so forward."
    mc "Я знаю, что не стоит быть такой напористой."

