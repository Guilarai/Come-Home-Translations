    # mc "Thank you."
    mc "Спасибо."

# game/Scenes/Micha/micha7.rpy:158
translate russian micha7_c5f761de:

    # mc "I'm very sorry."
    mc "Мне очень жаль."

# game/Scenes/Micha/micha7.rpy:161
translate russian micha7_3ac8722a:

    # pc "There's no reason to apologize. You haven't done anything wrong."
    pc "Тебе не за что извиняться. Ты ничего плохого не сделала."

# game/Scenes/Micha/micha7.rpy:163
translate russian micha7_d41d8cd9_5:

    # voice 'voices/micha_thankyou1.mp3'
    voice 'voices/micha_thankyou1.mp3'

