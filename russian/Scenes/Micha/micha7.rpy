    # mc "You do?"
    mc "Правда?"

# game/Scenes/Micha/micha7.rpy:94
translate russian micha7_423fa223:

    # pc "Sure. That's why I asked Gertrude to set up this date."
    pc "Конечно. Поэтому я и попросил Гертруду устроить это свидание."

# game/Scenes/Micha/micha7.rpy:95
translate russian micha7_6af12bd8:

    # mc "This is a date?"
    mc "Это свидание?"

# game/Scenes/Micha/micha7.rpy:96
translate russian micha7_c1f89784:

    # pc "A coffee date, yeah."
    pc "Да, свидание за кофе."

