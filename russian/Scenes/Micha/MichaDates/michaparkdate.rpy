# game/Scenes/Micha/MichaDates/michaparkdate.rpy:26
translate russian michaparkstartdate_7d6d0d91:

    # "Mi-Cha and I walk around the trails, chit-chatting for a while."
    "Мы с Ми-Ча гуляем по тропинкам, болтая о том о сём."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:34
translate russian michaparkstartdate_236ab045:

    # "Eventually, we reach the bench halfway along the trail."
    "В конце концов, мы доходим до скамейки, расположенной на полпути."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:40
translate russian michaparkstartdate_8d76a79c:

    # "We sit next to each other on the bench for a bit, watching the sky change colors as the sun sets."
    "Мы сидим рядом на скамейке, наблюдая, как небо меняет цвета на закате."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:43
translate russian michaparkstartdate_3dfbfe0f:

    # "We make out. She's nervous, I can tell that she wants more."
    "Мы целуемся. Она нервничает, я вижу, что она хочет большего."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:44
translate russian michaparkstartdate_af7c35f8:

    # "But we have to head back before it gets too dark."
    "Но нам нужно возвращаться, пока не стемнело."

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:47
translate russian michaparkstartdate_6b4912a9:

    # mc "Do you mind taking me back to my dorm?"
    mc "Не мог бы ты отвести меня обратно в общежитие?"

# game/Scenes/Micha/MichaDates/michaparkdate.rpy:48
translate russian michaparkstartdate_a248948f:

    # pc "Of course."
    pc "Конечно."

translate russian strings:

    # game/Scenes/Micha/MichaDates/michaparkdate.rpy:2
    old "After you have walked Mi-Cha to her dorm once and wished upon a star, you will be able to take her to the park."
    new "После того как ты один раз проводишь Ми-Ча до ее общежития и загадаешь желание, глядя на звезду, ты сможешь пригласить ее в парк."

    # game/Scenes/Micha/MichaDates/michaparkdate.rpy:3
    old "Call her in the evening and ask her to go to the park."
    new "Позвони ей вечером и предложи пойти в парк."

