# game/Scenes/Micha/MichaDates/michaarcadedate.rpy:143
translate russian michaarcadestartdate_6c3d27ae:

    # "After a while, we leave together and I drive her back to the dorms."
    "Через некоторое время мы уходим вместе, и я отвожу ее обратно в общежитие."

# game/Scenes/Micha/MichaDates/michaarcadedate.rpy:144
translate russian michaarcadestartdate_fdab3f40:

    # mc "Would you come inside and spend some time with me?"
    mc "Не хочешь зайти и провести со мной немного времени?"

# game/Scenes/Micha/MichaDates/michaarcadedate.rpy:149
translate russian michaarcadestartdate_bc4fd44d:

    # mc "Oh, okay."
