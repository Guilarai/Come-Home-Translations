translate russian micha8_5f9760c9:

    # "Before I go to Gertrude's office, Mi-Cha stops me in the lobby."
    "Прежде чем я пойду в кабинет Гертруды, Ми-Ча останавливает меня в холле."

# game/Scenes/Micha/micha8.rpy:15
translate russian micha8_ed6bde86:

    # mc "Hello, [pcname]."
    mc "Привет, [pcname]."

# game/Scenes/Micha/micha8.rpy:16
translate russian micha8_f481dcaa:

    # pc "Hi, Mi-Cha. How are you?"
    pc "Привет, Ми-Ча. Как дела?"

# game/Scenes/Micha/micha8.rpy:17
translate russian micha8_72cb11f5:

    # mc "I am good, thank you."
    mc "Хорошо, спасибо."

# game/Scenes/Micha/micha8.rpy:19
translate russian micha8_bdbd1fa8:

    # mc "I want to tell you that I enjoyed our coffee date."
    mc "Я хотела сказать, что мне понравилось наше свидание за кофе."

# game/Scenes/Micha/micha8.rpy:20
translate russian micha8_8a7120da:

    # mc "I apologize for rushing off early and would like to again another sometime."
    mc "Прости, что я так поспешила уйти, и хотела бы повторить это когда-нибудь."

# game/Scenes/Micha/micha8.rpy:21
translate russian micha8_3171636b:

    # mc "If you would like to this evening?"
    mc "Может, сегодня вечером?"

# game/Scenes/Micha/micha8.rpy:25
translate russian micha8_2d186b97:

    # mc "Good. I will meet you in the Skyhill Cafe this evening then."
    mc "Хорошо. Тогда встретимся сегодня вечером в кафе «Скайхилл»."

# game/Scenes/Micha/micha8.rpy:29
translate russian micha8_2f88594e:

    # mc "Oh. Okay. Yes, I'm sure you're busy."
    mc "О. Ладно. Да, я уверена, что ты занята."

# game/Scenes/Micha/micha8.rpy:31
translate russian micha8_08d0510d:

    # mc "Enjoy your visit with Mrs. Spann."
    mc "Приятного общения с миссис Спанн."

# game/Scenes/Micha/micha8.rpy:32
translate russian micha8_32a03447:

    # pc "Okay. I'll see you later, Mi-Cha."
    pc "Хорошо. Увидимся позже, Ми-Ча."

translate russian strings:

