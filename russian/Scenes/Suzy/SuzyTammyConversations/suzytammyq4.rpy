# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq4.rpy:26
translate russian suzytammyq4_c3f4814d:

    # ss "You two could get married and I could live with you."
    ss "Вы двое могли бы пожениться, а я мог бы жить с вами."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq4.rpy:28
