# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:34
translate russian suzytammyq3_4664af7e:

    # pc "For sure."
    pc "Конечно."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:36
translate russian suzytammyq3_75e9486a:

    # tm "So are you though, babe. I can't see how anybody would choose me over you."
    tm "Но ты тоже, детка. Я не понимаю, как кто-то мог бы выбрать меня вместо тебя."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:38
translate russian suzytammyq3_42af3cf3:

    # ss "Face it, cupcake. You're super hot."
