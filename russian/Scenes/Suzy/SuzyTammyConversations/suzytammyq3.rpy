# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:40
translate russian suzytammyq3_17f3d5cb:

    # tm "I don't want to talk about this anymore. It makes me feel bad."
    tm "Я не хочу больше об этом говорить. Мне от этого плохо."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:41
translate russian suzytammyq3_de2782f9:

    # pc "Okay, let's just move on then."
    pc "Ладно, тогда давай просто перейдем к чему-то другому."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:44
translate russian suzytammyq3_f0d7c9d9:

