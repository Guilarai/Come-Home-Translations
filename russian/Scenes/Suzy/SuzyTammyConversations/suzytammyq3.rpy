# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:54
translate russian suzytammyq3_3b59b879:

    # ss "Me too. Making decisions sucks. Just do all the things."
    ss "Я тоже. Принимать решения — это отстой. Просто делай все."

