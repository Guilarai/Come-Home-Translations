# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:48
translate russian suzytammyq3_9534b5b8:

    # pc "You're both amazing and gorgeous and sexy. I don't want to choose."
    pc "Вы обе потрясающие, великолепные и сексуальные. Я не хочу выбирать."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:50
translate russian suzytammyq3_4bd6ab2e:

    # ss "Aw, I'll accept it, but only because you called me gorgeous."
    ss "Ой, я соглашусь с этим, но только потому, что ты назвала меня великолепной."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:52
translate russian suzytammyq3_f36f83f0:

