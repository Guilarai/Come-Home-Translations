    # tm "Thanks, babe. Anybody would choose you over me though."
    tm "Спасибо, малыш. Но любой выбрал бы тебя, а не меня."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:25
translate russian suzytammyq3_ac12eba9:

