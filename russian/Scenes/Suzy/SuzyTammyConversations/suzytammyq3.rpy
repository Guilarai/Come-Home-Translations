# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:26
translate russian suzytammyq3_55946d3a:

    # ss "This is a mean conversation. I don't want to keep talking about it."
    ss "Это жестокий разговор. Я не хочу больше об этом говорить."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:27
translate russian suzytammyq3_37f942b9:

    # pc "Okay, let's move on then."
    pc "Ладно, тогда давай перейдем к чему-нибудь другому."

# game/Scenes/Suzy/SuzyTammyConversations/suzytammyq3.rpy:30
translate russian suzytammyq3_70d30f23:

