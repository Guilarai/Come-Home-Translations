    ss "Я так и знала!"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:28
translate russian suzytammys1_754b07cd:

    # tm "What are you talking about? What do you know?"
    tm "О чем ты говоришь? Что ты знаешь?"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:29
translate russian suzytammys1_6d3f5bbb:

    # pc "I can't say any more!"
    pc "Я не могу сказать больше!"

# game/Scenes/Suzy/SuzyTammyConversations/suzytammys1.rpy:31
translate russian suzytammys1_e3b699f1:

