# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:18
translate russian suzytammyicecreamdate_4ffc27b3:

    # "When Suzy is ready, we leave and meet Tammy at the ice cream parlor."
    "Когда Сьюзи будет готова, мы уйдем и встретимся с Тэмми в кафе-мороженом."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:21
translate russian suzytammyicecreamdate_52a33e67:

    # ss "Oh my God, they have coconut. I want that please."
    ss "О боже, у них есть кокосовое. Я хочу это, пожалуйста."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:22
translate russian suzytammyicecreamdate_26a56ba4:

    # tm "I'll get the cappuccino chocolate chunk frozen yogurt."
    tm "Я возьму замороженный йогурт с кусочками шоколада и капучино."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:23
translate russian suzytammyicecreamdate_4dc17a69:

    # ss "Don't you get enough coffee at work? I kinda hate the smell of it now."
    ss "Тебе не хватает кофе на работе? Я сейчас как-то ненавижу его запах."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:24
translate russian suzytammyicecreamdate_d1ff38f6:

    # tm "I think I'm the opposite. I love it. The smell, the taste, everything."
    tm "А у меня наоборот. Я его обожаю. И запах, и вкус, и все."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:25
translate russian suzytammyicecreamdate_10f4b187:

    # ss "Blech!"
    ss "Фу!"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:31
translate russian suzytammyicecreamdate_a716a63e:

    # "We sit down and enjoy our ice cream and chat for a while."
    "Мы садимся, наслаждаемся мороженым и немного болтаем."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:39
translate russian suzytammyicecreamdate_d478079d:

    # "When the ice cream is gone, our conversation slows down."
    "Когда мороженое заканчивается, разговор стихает."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:41
translate russian suzytammyicecreamdate_76de8536:

    # tm "Well, it's getting late. I better head home."
    tm "Ну, уже поздно. Мне лучше пойти домой."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:43
translate russian suzytammyicecreamdate_6e8b8aa4:

    # ss "Aw, you don't want to come back to the house with us?"
    ss "Ой, ты не хочешь пойти с нами домой?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:44
translate russian suzytammyicecreamdate_a1afa737:

    # tm "I can't, baby. Sorry."
    tm "Не могу, детка. Извини."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:49
translate russian suzytammyicecreamdate_7661b3c0:

    # tm "I had fun though. Love you both. Have a good night without me."
    tm "Но мне было весело. Люблю вас обоих. Хорошего вечера без меня."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:52
translate russian suzytammyicecreamdate_38516bbc:

    # ss "Oh, we will."
    ss "О, будет."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:53
translate russian suzytammyicecreamdate_fb8e986c:

    # pc "But not as much fun as if you were there too."
    pc "Но не так весело, как если бы ты была с нами."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:56
translate russian suzytammyicecreamdate_05f57ea7:

    # "Tammy leaves, then Suzy and I drive back home."
    "Тэмми уходит, а потом мы с Сьюзи едем домой."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:61
translate russian suzytammyicecreamdate_d41d8cd9:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:62
translate russian suzytammyicecreamdate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Похоже, мама уже спит. Так что, хочешь закончить свидание здесь, или пойти в твою комнату и закончить его как положено?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:65
translate russian suzytammyicecreamdate_b9e9893b:

    # ss "I was hoping you would say that."
    ss "Я надеялась, что ты это скажешь."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:68
translate russian suzytammyicecreamdate_60c94072:

    # "We quietly go upstairs together, go into my bedroom, and lock the door."
    "Мы тихо поднимаемся наверх вместе, заходим в мою спальню и закрываем дверь на ключ."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:71
translate russian suzytammyicecreamdate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Ладно, у меня было веселое свидание, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:72
translate russian suzytammyicecreamdate_1fea12f8:

    # ss "Sleep well. I'll see you tomorrow."
    ss "Спи хорошо. Увидимся завтра."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:79
translate russian suzytammyicecreamdate_65007bab:

    # tm "I don't know about you two, but I'm ready to head back home."
    tm "Не знаю, как вы двое, но я готова возвращаться домой."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:80
translate russian suzytammyicecreamdate_f89287b0:

    # ss "That sounds good to me. You ready to take this date back to the house, [bro]?"
    ss "Мне это подходит. Готова отвезти это свидание домой, [bro]?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:81
translate russian suzytammyicecreamdate_a400a310:

    # pc "Sure, let's go home."
    pc "Конечно, пойдем домой."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:86
translate russian suzytammyicecreamdate_d41d8cd9_1:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:87
translate russian suzytammyicecreamdate_643c2201_1:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Похоже, мама уже спит. Так что, хочешь закончить свидание здесь или подняться в твою комнату и закончить его как положено?"

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:90
translate russian suzytammyicecreamdate_df8719cf:

    # tm "Fuck yes."
    tm "Черт, да."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:93
translate russian suzytammyicecreamdate_60c94072_1:

    # "We quietly go upstairs together, go into my bedroom, and lock the door."
    "Мы тихо поднимаемся наверх вместе, заходим в мою спальню и закрываем дверь на ключ."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:97
translate russian suzytammyicecreamdate_acfb634b_1:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Ладно, ну, у меня было веселое свидание, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:98
translate russian suzytammyicecreamdate_be17834a:

    # tm "Yeah, me too."
    tm "Да, у меня тоже."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:99
translate russian suzytammyicecreamdate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "Спи хорошо. Увидимся завтра."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:100
translate russian suzytammyicecreamdate_d35669a0:

    # tm "Good night, [pcname]."
    tm "Спокойной ночи, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammyicecreamdate.rpy:103
translate russian suzytammyicecreamdate_d747330a:

    # "They go up to Suzy's bedroom, leaving me to decide what I want to do with my night."
    "Они поднимаются в спальню Сьюзи, оставляя меня решать, чем я хочу заняться сегодня вечером."

