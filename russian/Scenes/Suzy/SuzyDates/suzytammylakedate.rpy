translate russian suzytammylakedate_022e3346:

    # tm "What are you going to do about it, skinny?"
    tm "И что ты с этим сделаешь, худышка?"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:38
translate russian suzytammylakedate_4508b549:

    # tm "Aah!"
    tm "Ааа!"

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:41
translate russian suzytammylakedate_5e934eef:

    # "They hit the water with a huge splash, then come up laughing."
    "Они с огромным всплеском падают в воду, а потом выныривают, смеясь."

# game/Scenes/Suzy/SuzyDates/suzytammylakedate.rpy:42
translate russian suzytammylakedate_a94b5451:

    # tm "Frank and beans!"
