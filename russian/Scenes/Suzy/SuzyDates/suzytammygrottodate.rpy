translate russian suzytammygrottodate_edef91a3:

    # "We get ready and go out to The Grotto together."
    "Мы собираемся и вместе отправляемся в «Гротто»."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:19
translate russian suzytammygrottodate_a118cb72:

    # ss "I love this place."
    ss "Я обожаю это место."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:21
translate russian suzytammygrottodate_f556393a:

    # tm "Me too. Thanks for taking us, [pcname]."
    tm "Я тоже. Спасибо, что привел нас, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:23
translate russian suzytammygrottodate_ad1121f0:

    # ss "Yeah, thanks [bro]."
    ss "Да, спасибо, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:25
translate russian suzytammygrottodate_a91a4522:

    # "We chat while we eat and enjoy the atmosphere."
    "Мы болтаем, пока едим, и наслаждаемся атмосферой."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:33
translate russian suzytammygrottodate_a306e385:

    # "After we eat, we dance to a couple of songs."
    "После еды мы танцуем под пару песен."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:36
translate russian suzytammygrottodate_ffb49b98:

    # "Fuck, they're gorgeous. I can't help but to stare at them and wonder how I got to be so lucky."
    "Черт, они просто потрясающие. Я не могу не смотреть на них и не задаваться вопросом, как мне так повезло."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:39
translate russian suzytammygrottodate_7909898e:

    # ss "You ready to take us home, [bro]?"
    ss "Ты готов отвезти нас домой, [bro]?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:40
translate russian suzytammygrottodate_3dae9d31:

    # pc "Uh, yeah... we should go."
    pc "Э-э, да... нам пора."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:46
translate russian suzytammygrottodate_d41d8cd9:

    # voice 'voices/suzy_enditproperly.mp3'
    voice 'voices/suzy_enditproperly.mp3'

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:47
translate russian suzytammygrottodate_643c2201:

    # ss "Looks like Mom is already asleep. So, do you want to end the date here, or head up to your room and end it properly?"
    ss "Похоже, мама уже спит. Так что, хочешь закончить свидание здесь или подняться в твою комнату и закончить его как положено?"

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:50
translate russian suzytammygrottodate_df8719cf:

    # tm "Fuck yes."
    tm "Черт, да."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:53
translate russian suzytammygrottodate_621e1461:

    # "We quietly walk upstairs together, go into my bedroom, and lock the door."
    "Мы тихо поднимаемся наверх вместе, заходим в мою спальню и закрываем дверь на ключ."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:58
translate russian suzytammygrottodate_acfb634b:

    # ss "Okay, well I had a fun date, [bro]."
    ss "Ладно, у меня было веселое свидание, [bro]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:59
translate russian suzytammygrottodate_be17834a:

    # tm "Yeah, me too."
    tm "Да, у меня тоже."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:60
translate russian suzytammygrottodate_644a5289:

    # ss "Sleep well. See you tomorrow."
    ss "Спи хорошо. Увидимся завтра."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:61
translate russian suzytammygrottodate_d35669a0:

    # tm "Good night, [pcname]."
    tm "Спокойной ночи, [pcname]."

# game/Scenes/Suzy/SuzyDates/suzytammygrottodate.rpy:64
translate russian suzytammygrottodate_d747330a:

    # "They go up to Suzy's bedroom, leaving me to decide what I want to do with my night."
    "Они поднимаются в спальню Сьюзи, оставляя меня решать, чем я хочу заняться сегодня вечером."

