# game/Scenes/Suzy/suzy1.rpy:13
translate russian suzy1_b52dca5a:

    # "I go to the kitchen and make a plate with what's left, then sit down across from her at the table."
    "Я иду на кухню, накладываю себе тарелку из того, что осталось, а потом сажусь напротив нее за столом."

# game/Scenes/Suzy/suzy1.rpy:14
translate russian suzy1_c4e96a72:

    # "She puts her phone away and looks up at me."
    "Она убирает телефон и смотрит на меня."

# game/Scenes/Suzy/suzy1.rpy:17
translate russian suzy1_43f2e75d:

    # ss "So how's it been going [bro]?"
    ss "Ну, как дела [bro]?"

# game/Scenes/Suzy/suzy1.rpy:18
translate russian suzy1_d48b3188:

    # pc "Pretty good, I guess."
    pc "Неплохо, наверное."

# game/Scenes/Suzy/suzy1.rpy:19
translate russian suzy1_c84b49b4:

    # ss "Have you found out anything about Dad?"
    ss "Ты что-нибудь узнала о папе?"

# game/Scenes/Suzy/suzy1.rpy:20
translate russian suzy1_0b7558fc:

    # pc "Not yet."
    pc "Пока нет."

# game/Scenes/Suzy/suzy1.rpy:22
translate russian suzy1_e47fa0f8:

    # ss "I miss him."
    ss "Я скучаю по нему."

# game/Scenes/Suzy/suzy1.rpy:23
translate russian suzy1_0b941cef:

    # pc "You got along with him well?"
    pc "Вы хорошо ладили?"

# game/Scenes/Suzy/suzy1.rpy:24
translate russian suzy1_0442c0e0:

    # ss "Yeah."
    ss "Да."

# game/Scenes/Suzy/suzy1.rpy:25
translate russian suzy1_d244b907:

    # ss "I mean, we didn't spend a lot of time together. He was down in that basement a lot."
    ss "То есть, мы не проводили много времени вместе. Он часто сидел в том подвале."

# game/Scenes/Suzy/suzy1.rpy:26
translate russian suzy1_34edb007:

    # ss "But he would have breakfast with me every morning before school. He was funny. He'd make me laugh every day."
    ss "Но каждое утро перед школой он завтракал со мной. Он был веселым. Он заставлял меня смеяться каждый день."

# game/Scenes/Suzy/suzy1.rpy:27
translate russian suzy1_85af114e:

    # pc "Kind of like this, huh?"
    pc "Примерно так, да?"

# game/Scenes/Suzy/suzy1.rpy:29
translate russian suzy1_226f4904:

    # ss "I said he was funny, not obnoxious. Plus, he wore pants. Why are you walking around in your boxers?"
    ss "Я сказала, что он был забавным, а не отвратительным. К тому же он носил штаны. Почему ты ходишь в одних боксерках?"

# game/Scenes/Suzy/suzy1.rpy:30
translate russian suzy1_4cc016bf:

    # pc "It's morning, I don't want to get dressed yet. You can eat breakfast in your underwear if you want."
    pc "Утро, я пока не хочу одеваться. Можешь завтракать в нижнем белье, если хочешь."

# game/Scenes/Suzy/suzy1.rpy:31
translate russian suzy1_bd01965a:

    # ss "Yeah, I bet you'd like that. You'd just stare at me the whole time."
    ss "Да, я уверена, тебе бы это понравилось. Ты бы просто все время на меня пялился."

# game/Scenes/Suzy/suzy1.rpy:35
translate russian suzy1_d7a0aba4:

    # ss "You're such a perv."
    ss "Ты такой извращенец."

# game/Scenes/Suzy/suzy1.rpy:38
translate russian suzy1_0ca3339d:

    # ss "You're such a jerk."
    ss "А ты такая дура."

# game/Scenes/Suzy/suzy1.rpy:39
translate russian suzy1_a976ce63:

    # pc "Besides, you act like you don't stare at me when I'm in my boxers."
    pc "К тому же, ты ведешь себя так, будто не смотришь на меня, когда я в боксерках."

# game/Scenes/Suzy/suzy1.rpy:40
translate russian suzy1_23992985:

    # ss "What!? I do not!"
    ss "Что!? Я не смотрю!"

# game/Scenes/Suzy/suzy1.rpy:41
translate russian suzy1_25e7a80f:

    # pc "Come on now [sis], I've seen you."
    pc "Да ладно тебе [sis], я видела тебя."

# game/Scenes/Suzy/suzy1.rpy:43
translate russian suzy1_873662ce:

    # ss "You're out of your mind. I've never stared at you. Like you have anything to stare at anyways."
    ss "Ты с ума сошла. Я никогда на тебя не смотрел. Как будто тебе вообще есть на что смотреть."

# game/Scenes/Suzy/suzy1.rpy:44
translate russian suzy1_6e7bc529:

    # pc "Oh I don't have anything to stare at?"
    pc "О, у меня не на что смотреть?"

# game/Scenes/Suzy/suzy1.rpy:45
translate russian suzy1_ec7a8238:

    # ss "Nope."
    ss "Нет."

# game/Scenes/Suzy/suzy1.rpy:48
translate russian suzy1_7745b76d:

    # ss "Yeah, whatever."
    ss "Да, как скажешь."

# game/Scenes/Suzy/suzy1.rpy:51
translate russian suzy1_24166e5d:

    # ss "No! I don't want to see!"
    ss "Нет! Я не хочу смотреть!"

# game/Scenes/Suzy/suzy1.rpy:52
translate russian suzy1_483160a9:

    # ss "Sit down. Stop playing around."
    ss "Садись. Хватит дурачиться."

# game/Scenes/Suzy/suzy1.rpy:53
translate russian suzy1_ce7899d2:

    # pc "I'm not playing. I'll show you."
    pc "Я не дурачусь. Я тебе покажу."

# game/Scenes/Suzy/suzy1.rpy:54
translate russian suzy1_626bbd17:

    # ss "I don't want to see it. I believe you have something there, but I don't want to see it."
    ss "Я не хочу это видеть. Я верю, что у тебя там что-то есть, но я не хочу это видеть."

# game/Scenes/Suzy/suzy1.rpy:55
translate russian suzy1_c1226f21:

    # ss "Put it away, sit down."
    ss "Убери это, садись."

# game/Scenes/Suzy/suzy1.rpy:56
translate russian suzy1_02b8ec2b:

    # pc "Alright, I'm sitting."
    pc "Ладно, я сажусь."

# game/Scenes/Suzy/suzy1.rpy:58
translate russian suzy1_c7580a8a:

    # ss "You're such a weirdo."
    ss "Ты такая странная."

# game/Scenes/Suzy/suzy1.rpy:59
translate russian suzy1_086a625f:

    # "We spend the rest of the breakfast talking about school and work and joking around."
    "Остаток завтрака мы проводим, разговаривая о школе и работе и шутя."

# game/Scenes/Suzy/suzy1.rpy:60
translate russian suzy1_74d7aff9:

    # "Then we finish eating and it's time to go to school."
    "Потом мы заканчиваем есть, и пора идти в школу."

# game/Scenes/Suzy/suzy1.rpy:65
translate russian suzy1_74b357a7:

    # ss "Have a good day [bro]. See you later."
    ss "Хорошего дня [bro]. Увидимся позже."

# game/Scenes/Suzy/suzy1.rpy:66
translate russian suzy1_7dee10c4:

    # pc "Bye [sis]."
    pc "Пока [sis]."

# game/Scenes/Suzy/suzy1.rpy:71
translate russian suzy1_015cad61:

    # "She leaves for school and I follow right after her."
    "Она уходит в школу, а я следую за ней."

translate russian strings:

    # game/Scenes/Suzy/suzy1.rpy:2
    old "Have breakfast with Suzy again, after you have patched things up with her."
    new "Позавтракай снова с Сьюзи, после того как помиришься с ней."

