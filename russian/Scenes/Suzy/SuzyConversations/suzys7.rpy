    pc "Звучит потрясающе."

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:28
translate russian suzys7_ee1aba2e:

    # ss "I'm not talking about doing this with you, of course."
    ss "Я, конечно, не говорю о том, чтобы делать это с тобой."

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:29
translate russian suzys7_c264ecd8:

    # pc "No?"
    pc "Нет?"

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:30
translate russian suzys7_5e236ce4:

    # ss "No! Don't be weird! You're my [brother]!"
