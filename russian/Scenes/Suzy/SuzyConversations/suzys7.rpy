# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:19
translate russian suzys7_ec7049b7:

    # ss "Swimming, tanning, making out in the sand."
    ss "Плавать, загорать, целоваться на песке."

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:21
translate russian suzys7_2da59617:

    # ss "Then at night, starting a fire, roast some hot dogs or something..."
    ss "А ночью разжечь костёр, пожарить хот-доги или что-то в этом роде..."

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:23
translate russian suzys7_a1eafcca:

    # ss "Mess around under the stars."
    ss "Порезвиться под звездами."

# game/Scenes/Suzy/SuzyConversations/suzys7.rpy:24
translate russian suzys7_fb86b185:

