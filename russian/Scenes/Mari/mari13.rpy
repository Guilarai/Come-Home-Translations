# game/Scenes/Mari/mari13.rpy:69
translate russian mari13_380064ab:

    # rj "Okay then! No complaining online that you missed it!"
    rj "Ладно, тогда! Только не жалуйтесь в интернете, что пропустили это!"

# game/Scenes/Mari/mari13.rpy:71
translate russian mari13_e431e7a9:

    # rj "I'll leave and let you get back to the game now! Have fun!"
