# game/Scenes/Mari/MariConversations/maris4.rpy:20
translate russian maris4_311961b2:

    # fr "I think I'd rather just watch cartoons, you know?"
    fr "Думаю, я лучше просто посмотрю мультики, понимаешь?"

# game/Scenes/Mari/MariConversations/maris4.rpy:22
translate russian maris4_4b210c47:

    # fr "What about you? Do you like sports?"
    fr "А ты? Тебе нравится спорт?"

# game/Scenes/Mari/MariConversations/maris4.rpy:27
translate russian maris4_d41d8cd9:

    # voice 'voices/mari_ohcool1.mp3'
