translate russian maris4_1f958b5b:

    # fr "That's cool. I love it when people are passionate about things, even if it's something I'm not really into."
    fr "Это круто. Мне нравится, когда люди увлечены чем-то, даже если это не то, что мне нравится."

# game/Scenes/Mari/MariConversations/maris4.rpy:32
translate russian maris4_d41d8cd9_1:

