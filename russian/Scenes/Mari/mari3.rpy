# game/Scenes/Mari/mari3.rpy:12
translate russian mari3_d41d8cd9:

    # voice 'voices/mari_heythere.mp3'
    voice 'voices/mari_heythere.mp3'

# game/Scenes/Mari/mari3.rpy:13
translate russian mari3_5fec8fcf:

    # fr "Hey there, [pcname]. How are you today?"
    fr "Привет, [pcname]. Как у тебя дела сегодня?"

# game/Scenes/Mari/mari3.rpy:14
translate russian mari3_b835b9eb:

    # pc "I'm doing great, how's my favorite waitress?"
    pc "У меня все отлично, а как дела у моей любимой официантки?"

# game/Scenes/Mari/mari3.rpy:15
translate russian mari3_334e62bd:

    # fr "Much better now that her favorite customer is here."
    fr "Намного лучше, теперь, когда здесь мой любимый клиент."

# game/Scenes/Mari/mari3.rpy:20
translate russian mari3_747e36cd:

    # pc "Mari, there was something I wanted to ask you."
    pc "Мари, я хотел тебя кое о чем спросить."

# game/Scenes/Mari/mari3.rpy:21
translate russian mari3_96d48818:

    # fr "Ask away."
    fr "Спрашивай."

# game/Scenes/Mari/mari3.rpy:22
translate russian mari3_05be9386:

    # pc "Would you want to go out on a date with me sometime?"
    pc "Не хотела бы ты как-нибудь пойти со мной на свидание?"

# game/Scenes/Mari/mari3.rpy:25
translate russian mari3_d41d8cd9_1:

    # voice 'voices/mari_idloveto.mp3'
    voice 'voices/mari_idloveto.mp3'

# game/Scenes/Mari/mari3.rpy:26
translate russian mari3_ad1c3ebd:

    # fr "Really? I'd love to."
    fr "Правда? С удовольствием."

# game/Scenes/Mari/mari3.rpy:27
translate russian mari3_1da24e01:

    # pc "Awesome."
    pc "Здорово."

# game/Scenes/Mari/mari3.rpy:29
translate russian mari3_008e9d39:

    # fr "I don't get to go out on dates very often, and I do really like you."
    fr "Я не так часто хожу на свидания, и ты мне действительно нравишься."

# game/Scenes/Mari/mari3.rpy:30
translate russian mari3_098a6e78:

    # fr "I'm busy a lot, but I'll give you my phone number and maybe we could go out in the evening on a weekend sometime?"
    fr "Я очень занята, но я дам тебе свой номер телефона, и, может быть, мы сможем как-нибудь выйти вечером в выходные?"

# game/Scenes/Mari/mari3.rpy:31
translate russian mari3_d2954fc0:

    # pc "That sounds great."
    pc "Звучит отлично."

# game/Scenes/Mari/mari3.rpy:32
translate russian mari3_52d8f6ae:

    # fr "Oh I'm so excited."
    fr "О, я так взволнован."

# game/Scenes/Mari/mari3.rpy:34
translate russian mari3_e7685f1d:

    # fr "Here's my phone number."
    fr "Вот мой номер телефона."

# game/Scenes/Mari/mari3.rpy:36
translate russian mari3_639d3c6f:

    # fr "You can call me any time, but I won't be able to talk while I'm working, and I work a lot!"
    fr "Можешь звонить мне в любое время, но я не смогу разговаривать, пока работаю, а я работаю очень много!"

# game/Scenes/Mari/mari3.rpy:37
translate russian mari3_73bf0030:

    # pc "I'll definitely give you a call sometime."
    pc "Обязательно позвоню тебе как-нибудь."

# game/Scenes/Mari/mari3.rpy:38
translate russian mari3_c2bff929:

    # fr "Good, I can't wait!"
    fr "Хорошо, не могу дождаться!"

# game/Scenes/Mari/mari3.rpy:39
translate russian mari3_910292d4:

    # fr "I better go get your food."
    fr "Мне лучше пойти за твоим заказом."

# game/Scenes/Mari/mari3.rpy:40
translate russian mari3_63023601:

    # pc "Okay."
    pc "Хорошо."

# game/Scenes/Mari/mari3.rpy:42
translate russian mari3_0aa5dfbc:

    # "She starts to walk away, then looks back at me."
    "Она начинает уходить, потом оглядывается на меня."

# game/Scenes/Mari/mari3.rpy:43
translate russian mari3_8f6f1358:

    # fr "Thanks for asking me out. I'm really looking forward to our date."
    fr "Спасибо, что пригласил меня на свидание. Я очень жду нашего свидания."

# game/Scenes/Mari/mari3.rpy:44
translate russian mari3_03eaad50:

    # pc "Me too."
    pc "Я тоже."

# game/Scenes/Mari/mari3.rpy:45
translate russian mari3_7553af6a:

    # "With that, she smiles and leaves to get my food."
    "С этими словами она улыбается и уходит за моим заказом."

# game/Scenes/Mari/mari3.rpy:47
translate russian mari3_43045d37:

    # "We don't talk much more while I eat and she has to help other customers, but every time she looks at me, she's smiling."
    "Мы почти не разговариваем, пока я ем, а она обслуживает других посетителей, но каждый раз, когда она смотрит на меня, она улыбается."

# game/Scenes/Mari/mari3.rpy:48
translate russian mari3_2d44a908:

    # "The smile is different than usual. More sincere almost."
    "Эта улыбка отличается от обычной. Почти более искренняя."

# game/Scenes/Mari/mari3.rpy:51
translate russian maritip3_474b8780:

    # "I leave 10 dollars on the table."
    "Я оставляю на столе 10 долларов."

# game/Scenes/Mari/mari3.rpy:53
translate russian maritip3_bbc6048f:

    # "No need to leave money, I'll give her something better later."
    "Не нужно оставлять деньги, я позже дам ей что-нибудь получше."

# game/Scenes/Mari/mari3.rpy:55
translate russian maritip3_c56febff:

    # "Then I start to walk out towards my car."
    "Затем я направляюсь к своей машине."

# game/Scenes/Mari/mari3.rpy:58
translate russian maritip3_e3c07fca:

    # "Mari stops me though, wrapping her arms around me and pulling me into a hug."
    "Но Мари останавливает меня, обнимает и прижимает к себе."

# game/Scenes/Mari/mari3.rpy:59
translate russian maritip3_7db5e01d:

    # fr "I can't wait to see you again."
    fr "Не могу дождаться, когда снова тебя увижу."

# game/Scenes/Mari/mari3.rpy:60
translate russian maritip3_98e7787f:

    # fr "Be sure you call me."
    fr "Обязательно позвони мне."

# game/Scenes/Mari/mari3.rpy:61
translate russian maritip3_5bc44b07:

    # pc "I will."
    pc "Позвоню."

# game/Scenes/Mari/mari3.rpy:62
translate russian maritip3_2e512b95:

    # fr "Okay, take care."
    fr "Хорошо, береги себя."

# game/Scenes/Mari/mari3.rpy:65
translate russian maritip3_5794a059:

    # "She releases me and I go outside. She's really excited about our date it seems."
    "Она отпускает меня, и я выхожу на улицу. Похоже, она действительно в восторге от нашего свидания."

# game/Scenes/Mari/mari3.rpy:66
translate russian maritip3_f0d4672c:

    # "I'm excited too. It should be fun."
    "Я тоже взволнован. Должно быть весело."

translate russian strings:

    # game/Scenes/Mari/mari3.rpy:2
    old "After you helped Mari by giving her a ride home,"
    new "После того, как ты поможешь Мари, подвезя ее домой,"

    # game/Scenes/Mari/mari3.rpy:3
    old "go get a burger at Jackson Burger while she's working and ask her out."
    new "пойди съешь гамбургер в «Джексон Бургер», пока она на работе, и пригласи ее на свидание."

    # game/Scenes/Mari/mari3.rpy:52
    old "I'll give her the tip later"
    new "Я дам ей чаевые позже."

    # game/Scenes/Mari/mari3.rpy:71
    old "Just eat"
    new "Просто ешь."

