# game/Scenes/Mari/mari1.rpy:15
translate russian mari1_d41d8cd9:

    # voice 'voices/mari_heysweetie.mp3'
    voice 'voices/mari_heysweetie.mp3'

# game/Scenes/Mari/mari1.rpy:16
translate russian mari1_64c354b8:

    # fr "Hey there sweetie, good to see you. How are you doing today?"
    fr "Привет, милая, рада тебя видеть. Как у тебя дела сегодня?"

# game/Scenes/Mari/mari1.rpy:19
translate russian mari1_223b1496:

    # fr "Good, I'm glad. It's nice to see you in here again, let me know if I can get you anything."
    fr "Хорошо, я рада. Приятно снова видеть тебя здесь, дай знать, если я могу что-нибудь для тебя сделать."

# game/Scenes/Mari/mari1.rpy:22
translate russian mari1_fe03e5ca:

    # fr "You're such a charmer. Keep going, I like it."
    fr "Ты такой очаровашка. Продолжай, мне нравится."

# game/Scenes/Mari/mari1.rpy:23
translate russian mari1_4d51f194:

    # pc "I mean, the burgers here are great, but I'm really here just to chat with you."
    pc "Я имею в виду, гамбургеры здесь отличные, но на самом деле я здесь только для того, чтобы поболтать с тобой."

# game/Scenes/Mari/mari1.rpy:25
translate russian mari1_67fd9cd9:

    # fr "Really?"
    fr "Правда?"

# game/Scenes/Mari/mari1.rpy:26
translate russian mari1_18128c18:

    # pc "Really."
    pc "Правда."

# game/Scenes/Mari/mari1.rpy:28
translate russian mari1_8aa0b3f4:

    # fr "You're so sweet. Thanks for the compliments, but I better get back to work. Let me know if I can get you anything."
    fr "Ты такой милый. Спасибо за комплименты, но мне лучше вернуться к работе. Дай знать, если тебе что-нибудь нужно."

# game/Scenes/Mari/mari1.rpy:29
translate russian mari1_c0bafa60:

    # pc "Can I get a straw for my drink?"
    pc "Можно мне соломинку для напитка?"

# game/Scenes/Mari/mari1.rpy:31
translate russian mari1_d41d8cd9_1:

    # voice marisurething
    voice marisurething

# game/Scenes/Mari/mari1.rpy:32
translate russian mari1_f2433589:

    # fr "Sure thing, honey."
    fr "Конечно, милый."

# game/Scenes/Mari/mari1.rpy:33
translate russian mari1_ab35ef2d:

    # "She reaches into her pocket to pull out one of the straws and a dozen more pop out and fall onto the floor, scattering around."
    "Она запускает руку в карман, чтобы достать одну соломинку, и еще с десяток выскакивают и падают на пол, разлетевшись вокруг."

# game/Scenes/Mari/mari1.rpy:36
translate russian mari1_d41d8cd9_2:

    # voice 'voices/mari_shoot2.mp3'
    voice 'voices/mari_shoot2.mp3'

# game/Scenes/Mari/mari1.rpy:37
translate russian mari1_aaf7d6fa:

    # fr "Ah shoot, sorry about that."
    fr "Ах, черт, извини."

# game/Scenes/Mari/mari1.rpy:38
translate russian mari1_76e2166e:

    # fr "Just a second, let me get these."
    fr "Подожди секунду, я их соберу."

# game/Scenes/Mari/mari1.rpy:40
translate russian mari1_29517e2b:

    # "She kneels down and gets on hands and knees on the floor, picking up the straws that had scattered around."
    "Она опускается на колени и ползет по полу, собирая разлетевшиеся соломинки."

# game/Scenes/Mari/mari1.rpy:41
translate russian mari1_fa53362f:

    # fr "I'm so sorry."
    fr "Мне так жаль."

# game/Scenes/Mari/mari1.rpy:44
translate russian mari1_6ce37599:

    # fr "I'm so clumsy sometimes."
    fr "Я иногда такая неуклюжая."

# game/Scenes/Mari/mari1.rpy:45
translate russian mari1_bdb852f0:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Она быстро собирает остальные соломинки и встает."

# game/Scenes/Mari/mari1.rpy:48
translate russian mari1_c84cc9f0:

    # fr "What?"
    fr "Что?"

# game/Scenes/Mari/mari1.rpy:50
translate russian mari1_d41d8cd9_3:

    # voice 'voices/mari_youlikethat.mp3'
    voice 'voices/mari_youlikethat.mp3'

# game/Scenes/Mari/mari1.rpy:51
translate russian mari1_50b1ddec:

    # fr "Oh. You like that do you?"
    fr "О. Тебе это нравится?"

# game/Scenes/Mari/mari1.rpy:53
translate russian mari1_7fbd7f76:

    # fr "What about this? You like this?"
    fr "А это? Тебе это нравится?"

# game/Scenes/Mari/mari1.rpy:54
translate russian mari1_9bf0a886:

    # pc "I definitely do."
    pc "Определенно нравится."

# game/Scenes/Mari/mari1.rpy:55
translate russian mari1_bdb852f0_1:

    # "She quickly finishes grabbing the rest of the straws and stands back up."
    "Она быстро собирает остальные соломинки и встает."

# game/Scenes/Mari/mari1.rpy:57
translate russian mari1_2771e6a1:

    # fr "I hope that was worth a little bit more of a tip?"
    fr "Надеюсь, это стоило чуть большего чаевых?"

# game/Scenes/Mari/mari1.rpy:58
translate russian mari1_81450635:

    # pc "Oh I could give you more than the tip."
    pc "О, я могла бы дать тебе больше, чем чаевые."

# game/Scenes/Mari/mari1.rpy:60
translate russian mari1_053e79a0:

    # fr "You're so bad!"
    fr "Ты такая плохая!"

# game/Scenes/Mari/mari1.rpy:63
translate russian mari1_bab66bf3:

    # fr "I'll be right back with a straw that hasn't been on the floor."
    fr "Я сейчас вернусь с соломинкой, которая не лежала на полу."

# game/Scenes/Mari/mari1.rpy:64
translate russian mari1_c8cd6f6b:

    # "She comes back with my straw and then my food shortly after that."
    "Она возвращается с моей соломинкой, а вскоре после этого — с моей едой."

# game/Scenes/Mari/mari1.rpy:65
translate russian mari1_2e5f61be:

    # "We don't talk much more, but she gives me a beautiful smile every time I look up at her."
    "Мы больше не разговариваем, но она дарит мне прекрасную улыбку каждый раз, когда я смотрю на нее."

# game/Scenes/Mari/mari1.rpy:69
translate russian mari1_e88fc8e1:

    # "When I finish and it's time to leave, she waves at me."
    "Когда я заканчиваю и пора уходить, она машет мне рукой."

# game/Scenes/Mari/mari1.rpy:71
translate russian mari1_d41d8cd9_4:

    # voice 'voices/mari_thanksgoodnight.mp3'
    voice 'voices/mari_thanksgoodnight.mp3'

# game/Scenes/Mari/mari1.rpy:72
translate russian mari1_7949c609:

    # fr "Thanks for coming in! You have a good night!"
    fr "Спасибо, что зашли! Хорошего вечера!"

# game/Scenes/Mari/mari1.rpy:75
translate russian maritip2_1ce16e45:

    # "I walk up to her and put a ten-dollar bill into her hand."
    "Я подхожу к ней и кладу ей в руку десятку."

# game/Scenes/Mari/mari1.rpy:78
translate russian maritip2_d41d8cd9:

    # voice 'voices/mari_thankyousomuch.mp3'
    voice 'voices/mari_thankyousomuch.mp3'

# game/Scenes/Mari/mari1.rpy:79
translate russian maritip2_1e720979:

    # fr "Thanks so much, you're the best."
    fr "Большое спасибо, ты лучшая."

# game/Scenes/Mari/mari1.rpy:81
translate russian maritip2_890abf2a:

    # "Without warning, she lunges forward and wraps her arms around me, pulling me into a close hug."
    "Без предупреждения она наклоняется вперед, обнимает меня и прижимает к себе."

# game/Scenes/Mari/mari1.rpy:82
translate russian maritip2_9ba61eed:

    # "She's so warm and soft."
    "Она такая теплая и мягкая."

# game/Scenes/Mari/mari1.rpy:83
translate russian maritip2_23314f60:

    # "And bonus - she smells like burgers."
    "И бонус — от нее пахнет гамбургерами."

# game/Scenes/Mari/mari1.rpy:84
translate russian maritip2_c96f83e2:

    # pc "Well you're a great waitress."
    pc "Ну, ты отличная официантка."

# game/Scenes/Mari/mari1.rpy:85
translate russian maritip2_d1889969:

    # fr "It's easy when the customers are as nice as you are."
    fr "Это легко, когда клиенты такие же милые, как ты."

# game/Scenes/Mari/mari1.rpy:86
translate russian maritip2_9bc4e48c:

    # fr "Come back and see me again soon, okay?"
    fr "Заходи ко мне еще, ладно?"

# game/Scenes/Mari/mari1.rpy:87
translate russian maritip2_9782867b:

    # pc "Oh I'm sure I will."
    pc "О, я обязательно зайду."

# game/Scenes/Mari/mari1.rpy:89
translate russian maritip2_fb1fac0d:

    # fr "Have a good night, sweetie."
    fr "Хорошего вечера, милый."

# game/Scenes/Mari/mari1.rpy:90
translate russian maritip2_eb61ef6e:

    # pc "You too."
    pc "Тебе тоже."

# game/Scenes/Mari/mari1.rpy:92
translate russian maritip2_3cb27537:

    # "I give her a wave."
    "Я машу ей рукой."

# game/Scenes/Mari/mari1.rpy:93
translate russian maritip2_739d2b0c:

    # "With that, I go back outside and head to my car."
    "На этом я выхожу на улицу и направляюсь к своей машине."

