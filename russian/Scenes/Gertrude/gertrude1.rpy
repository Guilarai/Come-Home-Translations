    old "Not as much as I'd like to be"
    new "Не так часто, как хотелось бы"

    # game/Scenes/Gertrude/gertrude1.rpy:24
    old "That doesn't seem appropriate"
    new "Это кажется неуместным"

    # game/Scenes/Gertrude/gertrude1.rpy:34
    old "I understand"
    new "Я понимаю"

    # game/Scenes/Gertrude/gertrude1.rpy:37
    old "So have lots of sex?"
