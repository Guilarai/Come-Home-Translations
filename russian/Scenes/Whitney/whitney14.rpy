translate russian rjwhitneywarning_06b7e2ed:

    # pc "What!?"
    pc "Что!?"

# game/Scenes/Whitney/whitney14.rpy:261
translate russian rjwhitneywarning_20183cb0:

    # wt "Just grab the whole box and get back to the van, now!"
    wt "Просто хватай всю коробку и беги обратно к фургону, сейчас же!"

