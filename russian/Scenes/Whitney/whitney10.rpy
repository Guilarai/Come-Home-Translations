# game/Scenes/Whitney/whitney10.rpy:10
translate russian whitney10_be5af3f7:

    # "My phone buzzes in my pocket. It's Whitney calling."
    "В кармане зазвенел мой телефон. Это звонит Уитни."

# game/Scenes/Whitney/whitney10.rpy:15
translate russian whitney10_cabe2426:

    # pc "Hey, Whitney. What's up?"
    pc "Привет, Уитни. Как дела?"

# game/Scenes/Whitney/whitney10.rpy:16
translate russian whitney10_b9006bbe:

    # wt "Oh hey. Are you busy?"
    wt "О, привет. Ты занят?"

# game/Scenes/Whitney/whitney10.rpy:17
translate russian whitney10_bc1428f9:

    # pc "Not really."
    pc "Не особо."

# game/Scenes/Whitney/whitney10.rpy:19
translate russian whitney10_87d76db1:

    # wt "I have this craving for that burger place we went to before. Would you want to go get dinner with me again?"
    wt "Мне очень хочется в тот бургерный, куда мы ходили раньше. Не хочешь снова пойти со мной поужинать?"

# game/Scenes/Whitney/whitney10.rpy:20
translate russian whitney10_240f7709:

    # pc "Are you asking me out on a date?"
    pc "Ты приглашаешь меня на свидание?"

# game/Scenes/Whitney/whitney10.rpy:22
translate russian whitney10_b86f93de:

    # wt "You can call it whatever you like. I just want a burger."
    wt "Называй это как хочешь. Я просто хочу бургер."

# game/Scenes/Whitney/whitney10.rpy:23
translate russian whitney10_91e1bb14:

    # wt "And your company is nice as well."
    wt "И твоя компания тоже приятна."

# game/Scenes/Whitney/whitney10.rpy:27
translate russian whitney10_7c538ce6:

    # wt "Great! I'll drive over and pick you up at your place in about half an hour."
    wt "Отлично! Я подъеду и заберу тебя от дома примерно через полчаса."

# game/Scenes/Whitney/whitney10.rpy:28
translate russian whitney10_ac8c00ba:

    # pc "Sounds good. See you then."
    pc "Звучит хорошо. Увидимся."

# game/Scenes/Whitney/whitney10.rpy:29
translate russian whitney10_2c71ca5c:

    # "We hang up and I go home and get ready."
    "Мы вешаем трубку, я иду домой и готовлюсь."

# game/Scenes/Whitney/whitney10.rpy:33
translate russian whitney10_2aaf9014:

    # wt "Oh, okay then."
    wt "О, ладно."

# game/Scenes/Whitney/whitney10.rpy:34
translate russian whitney10_f7a5b1c0:

    # wt "Well, if you want to sometime, just give me a call in the evening. I'm usually free."
    wt "Ну, если захочешь как-нибудь, просто позвони мне вечером. Я обычно свободна."

# game/Scenes/Whitney/whitney10.rpy:35
translate russian whitney10_bf0c9413:

    # pc "Okay, Whitney. Talk to you later."
    pc "Ладно, Уитни. Поговорим позже."

# game/Scenes/Whitney/whitney10.rpy:36
translate russian whitney10_a7e7a8bf:

    # wt "Bye, [pcname]."
    wt "Пока, [pcname]."

