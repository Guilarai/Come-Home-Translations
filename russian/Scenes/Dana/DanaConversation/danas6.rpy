# game/Scenes/Dana/DanaConversation/danas6.rpy:26
translate russian danas6_37abdbfa:

    # pc "Well I think that you should be proud anyway."
    pc "Ну, я думаю, что ты все равно должен гордиться."

# game/Scenes/Dana/DanaConversation/danas6.rpy:27
translate russian danas6_9e02f2bc:

    # pc "It's something that you set out to do, you worked really hard to make it happen, and you succeeded."
    pc "Это то, к чему ты стремился, ты очень усердно работал, чтобы это произошло, и у тебя получилось."

# game/Scenes/Dana/DanaConversation/danas6.rpy:28
translate russian danas6_4d8257d6:

    # pc "It's a big deal."
    pc "Это большая сделка."

# game/Scenes/Dana/DanaConversation/danas6.rpy:30
translate russian danas6_19e18fd7:

    # cw "Thanks, [pcname]. You're right."
    cw "Спасибо, [pcname]. Ты прав."

# game/Scenes/Dana/DanaConversation/danas6.rpy:31
translate russian danas6_c3de2ed1:

