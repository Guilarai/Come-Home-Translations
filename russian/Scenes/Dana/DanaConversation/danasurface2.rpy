# game/Scenes/Dana/DanaConversation/danasurface2.rpy:13
translate russian danasurface2_adb78891:

    # pc "Do you have any pets?"
    pc "У тебя есть домашние животные?"

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:14
translate russian danasurface2_69bf2a77:

    # cw "No, no pets."
    cw "Нет, нет."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:16
translate russian danasurface2_f1e7f090:

    # cw "I wouldn't mind having a dog - a big one that I could hug and cuddle with."
    cw "Я бы не прочь завести собаку — большую, которую можно обнимать и с которой можно ласкаться."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:17
translate russian danasurface2_72be5411:

    # cw "I had a big fluffy Great Pyrenees growing up named Khan. He was my favorite thing."
    cw "Когда я росла, у меня был большой пушистый пиренейский мастиф по кличке Хан. Он был моим самым любимым существом."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:20
translate russian danasurface2_0084a7fa:

    # cw "But Terry, my fiancé, is allergic to dogs. And cats. So no pets."
    cw "Но у Терри, моего жениха, аллергия на собак. И на кошек. Так что никаких домашних животных."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:21
translate russian danasurface2_e161b952:

    # pc "Maybe one day."
    pc "Может, когда-нибудь."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:23
translate russian danasurface2_d9e8daa4:

    # cw "Maybe."
    cw "Может быть."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:25
translate russian danasurface2_4789760b:

    # cw "Although, no, I guess not, since I'm marrying Terry and will be with him forever."
    cw "Хотя, нет, наверное, нет, ведь я выхожу замуж за Терри и буду с ним навсегда."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:26
translate russian danasurface2_b3875e3a:

    # cw "He's always going to be allergic to dogs, so that means no dogs for me."
    cw "У него всегда будет аллергия на собак, а это значит, что у меня не будет собак."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:28
translate russian danasurface2_5388797f:

    # cw "That's okay though."
    cw "Но ничего страшного."

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:29
translate russian danasurface2_75ed006d:

    # pc "Maybe a turtle?"
    pc "Может, черепаха?"

# game/Scenes/Dana/DanaConversation/danasurface2.rpy:31
translate russian danasurface2_5cff00b8:

    # cw "Haha, maybe!"
    cw "Ха-ха, может быть!"

