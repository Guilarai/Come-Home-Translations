translate russian welch2b_ee8add67:

    # pc "Yeah, I've been there before."
    pc "Да, я там бывал."

# game/Scenes/Welch/welch2.rpy:125
translate russian welch2b_d251e37e:

    # sst "Cool."
    sst "Круто."

# game/Scenes/Welch/welch2.rpy:127
translate russian welch2b_ae39c542:

    # sst "If you just go down this road and take a left on McCalister, it's right there on the right."
    sst "Если просто пойти по этой дороге и повернуть налево на Маккалистер, он будет прямо там, справа."

# game/Scenes/Welch/welch2.rpy:128
translate russian welch2b_238bde54:

    # pc "Got it."
    pc "Понял."

# game/Scenes/Welch/welch2.rpy:129
translate russian welch2b_512d4e0a:

    # sst "You're old enough to drink, right?"
    sst "Ты уже достаточно взрослый, чтобы пить, да?"

# game/Scenes/Welch/welch2.rpy:130
translate russian welch2b_bc442d20:

    # pc "I'm 22."
    pc "Мне 22."

# game/Scenes/Welch/welch2.rpy:131
translate russian welch2b_a97b46de:

    # sst "Okay, good."
    sst "Хорошо, отлично."

# game/Scenes/Welch/welch2.rpy:134
translate russian welch2b_b500092e:

    # "I drive us over to The Pit and we walk inside and to the back together, where a group of her friends are already sitting."
    "Я подвожу нас к «The Pit», мы входим и вместе идем вглубь зала, где уже сидит группа ее друзей."

# game/Scenes/Welch/welch2.rpy:137
translate russian welch2b_282981a2:

    # "I sit next to her in the crowded bar and we order some drinks."
    "Я сажусь рядом с ней в переполненном баре, и мы заказываем выпивку."

# game/Scenes/Welch/welch2.rpy:138
translate russian welch2b_32770ccf:

    # sst "Thanks for coming out to the protest everybody. That was fun right?"
    sst "Спасибо всем, что пришли на протест. Было весело, правда?"

# game/Scenes/Welch/welch2.rpy:139
translate russian welch2b_f3c8a7a0:

    # sst "Hopefully we did some good today. If not, we'll keep bothering him until he does the right thing."
    sst "Надеюсь, мы сегодня сделали что-то хорошее. Если нет, будем донимать его, пока он не поступит правильно."

# game/Scenes/Welch/welch2.rpy:140
translate russian welch2b_e4307059:

