# game/Scenes/Welch/welchphone.rpy:91
translate russian welchphone_00837f1a:

    # sst "Well, it was good talking to you, [pcname]. I'll talk to you later, okay?"
    sst "Ну, было приятно поговорить с тобой, [pcname]. Поговорим позже, ладно?"

# game/Scenes/Welch/welchphone.rpy:92
translate russian welchphone_39cd78d0:

