    sst "Так что, хочешь зайти ко мне на некоторое время?"

# game/Scenes/Welch/WelchDates/welchdateend.rpy:9
translate russian welchdateend_1d32f548:

    # sst "Good. Let's just leave separately, and I'll meet you at the house."
