    sst "Ты и Эдриан."

# game/Scenes/Welch/WelchConversations/welchp2.rpy:36
translate russian welchp2_b7e6ebc6:

    # sst "Anyway, I know I should wait until you graduate. It's a {i}really{/i} bad idea to get involved with a student."
    sst "В любом случае, я знаю, что мне следует подождать, пока ты не закончишь школу. Вступать в отношения со школьником — это {i}действительно{/i} плохая идея."

# game/Scenes/Welch/WelchConversations/welchp2.rpy:38
translate russian welchp2_637b9991:

