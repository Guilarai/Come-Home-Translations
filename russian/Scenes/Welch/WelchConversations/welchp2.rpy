    sst "Это так глупо. Не могу поверить, что я это сделала."

# game/Scenes/Welch/WelchConversations/welchp2.rpy:24
translate russian welchp2_b4cc7836:

    # sst "Did you always have a crush on me, like Jeremy did?"
    sst "Ты всегда был в меня влюблён, как Джереми?"

# game/Scenes/Welch/WelchConversations/welchp2.rpy:28
translate russian welchp2_4cb217e1:

