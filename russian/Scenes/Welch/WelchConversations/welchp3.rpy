# TODO: Translation updated at 2026-06-02 09:57

# game/Scenes/Welch/WelchConversations/welchp3.rpy:14
translate russian welchp3_2afd835a:

    # sst "Ugh, that was a mess."
    sst "Фу, это был кошмар."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:16
translate russian welchp3_efac1d79:

    # sst "We got married too early. Before I knew who he really was."
    sst "Мы поженились слишком рано. До того, как я поняла, кто он на самом деле."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:17
translate russian welchp3_114eb40f:

    # sst "Before I knew who {i}I{/i} really was."
    sst "До того, как я поняла, кто {i}я{/i} на самом деле."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:19
translate russian welchp3_3b2551fd:

    # sst "Back then, I was a church-going, submissive, meek, quiet woman."
    sst "Тогда я была церковной, покорной, кроткой, тихой женщиной."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:20
translate russian welchp3_ceb73f99:

    # sst "Naive. Easily controllable."
    sst "Наивной. Легко поддающейся контролю."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:22
translate russian welchp3_86448b59:

    # sst "And he was the type of man who was attracted to that type of woman."
    sst "А он был тем типом мужчины, которого привлекали именно такие женщины."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:23
translate russian welchp3_e03890c3:

    # sst "He wanted me subservient to him."
    sst "Он хотел, чтобы я была ему подчиненной."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:24
translate russian welchp3_c0048870:

    # sst "He wanted to own me. Like I was his property."
    sst "Он хотел владеть мной. Как будто я была его собственностью."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:26
translate russian welchp3_e9c91aa3:

    # sst "And for a while, I let him."
    sst "И какое-то время я позволяла ему это."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:27
translate russian welchp3_5af5dd50:

    # sst "I did everything he wanted me to do. Took care of him like a good wife should."
    sst "Я делала все, что он хотел. Заботилась о нем, как должна хорошая жена."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:28
translate russian welchp3_5d3e47bd:

    # sst "If I didn't do exactly what he wanted me to do, he would get very upset with me."
    sst "Если я не делала именно то, что он хотел, он очень злился на меня."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:29
translate russian welchp3_046cc9dc:

    # sst "The abuse started mental, then got physical in our third year of marriage."
    sst "Насилие началось с психологического, а на третьем году нашего брака перешло в физическое."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:30
translate russian welchp3_f4ff49aa:

    # pc "I'm so sorry."
    pc "Мне так жаль."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:32
translate russian welchp3_fb4b2a44:

    # sst "It's okay. I'm over it. It's so far behind me now that I've disconnected from those emotions a lot."
    sst "Все в порядке. Я уже пережила это. Это так далеко позади, что я уже почти отстранилась от тех эмоций."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:33
translate russian welchp3_45b6cd5e:

    # sst "Flora actually helped me get away. Pulled me out of all of it."
    sst "Флора, собственно, помогла мне уйти. Вытащила меня из всего этого."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:35
translate russian welchp3_36f70b84:

    # sst "She's such a good friend. I'm so lucky that I had her."
    sst "Она такая хорошая подруга. Мне так повезло, что она у меня была."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:36
translate russian welchp3_b151b7a2:

    # sst "And I pressed charges against him. He went to jail for a while."
    sst "И я подала на него в суд. Он на некоторое время сел в тюрьму."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:37
translate russian welchp3_3ad6d20f:

    # sst "I think he's working for some tech company in California now."
    sst "Думаю, сейчас он работает в какой-то технологической компании в Калифорнии."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:38
translate russian welchp3_e70c1557:

    # pc "He's not causing you any trouble anymore?"
    pc "Он больше не доставляет тебе неприятностей?"

# game/Scenes/Welch/WelchConversations/welchp3.rpy:40
translate russian welchp3_8ed71562:

    # sst "No. He's a coward."
    sst "Нет. Он трус."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:41
translate russian welchp3_1276a89f:

    # sst "He was always so scared of Flora. And eventually, he became scared of me too."
    sst "Он всегда так боялся Флоры. А со временем стал бояться и меня."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:42
translate russian welchp3_a743359b:

    # sst "He didn't know how to deal with a woman who would fight back."
    sst "Он не знал, как справиться с женщиной, которая давала отпор."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:43
translate russian welchp3_32233872:

    # pc "Well I'm happy that you got away from all of that."
    pc "Ну, я рада, что ты ушла от всего этого."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:45
translate russian welchp3_c3a3d08a:

    # sst "Thanks. Me too."
    sst "Спасибо. Я тоже."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:47
translate russian welchp3_7697db95:

    # sst "I look back on who I was back then and I just want to hug her and show her how good life can be."
    sst "Я оглядываюсь на ту, кем я была тогда, и просто хочу обнять ее и показать, насколько хороша может быть жизнь."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:49
translate russian welchp3_1321c0f5:

    # sst "I love my life now."
    sst "Я люблю свою жизнь сейчас."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:50
translate russian welchp3_4cfcb512:

    # sst "I love myself."
    sst "Я люблю себя."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:51
translate russian welchp3_3fcdcf91:

    # pc "You are pretty great."
    pc "Ты просто классная."

# game/Scenes/Welch/WelchConversations/welchp3.rpy:52
translate russian welchp3_3ef0232d:

    # sst "Fuck yeah, I am!"
    sst "Еще бы, я такая!"

