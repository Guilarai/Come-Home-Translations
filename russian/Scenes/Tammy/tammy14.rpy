translate russian tammy14_ebcc9f51:

    # ss "It's so sexy, all three of us being able to sleep together like this any night we want to."
    ss "Это так сексуально, что мы все трое можем спать вместе так, когда захотим."

# game/Scenes/Tammy/tammy14.rpy:168
translate russian tammy14_494fc97b:

    # pc "Yeah, it's amazing."
    pc "Да, это потрясающе."

# game/Scenes/Tammy/tammy14.rpy:171
translate russian tammy14_e8b49386:

