    ss "Не угрожай мне удовольствием!"

# game/Scenes/Tammy/tammy14.rpy:162
translate russian tammy14_3ce42e73:

    # tm "Haha, I'm too tired for this right now."
    tm "Ха-ха, я сейчас слишком устала для этого."

# game/Scenes/Tammy/tammy14.rpy:163
