    tm "Похоже, скоро закроются. Наверное, нам лучше уходить."

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:51
translate russian tammycafestartdate_4dfe2e92:

    # tm "How about you take me home now and we see if Suzy is up for some fun?"
    tm "Как насчет того, чтобы ты отвез меня домой, и мы посмотрим, готова ли Сьюзи к веселью?"

# game/Scenes/Tammy/TammyDates/tammycafedate.rpy:56
