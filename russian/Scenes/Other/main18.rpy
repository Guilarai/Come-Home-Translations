    # et "I don't think so, [pcname]. Pete and I are kind of busy today."
    et "Не думаю, [pcname]. Мы с Питом сегодня заняты."

# game/Scenes/Other/main18.rpy:1966
translate russian main18mcgee_eb3dda76:

