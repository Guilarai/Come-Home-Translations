translate russian main18mcgee_9e9e1601:

    # pc "Yeah. Okay."
    pc "Да. Ладно."

# game/Scenes/Other/main18.rpy:1970
translate russian main18mcgee_6cc3d260:

    # "I hang up... I guess I'll have to call somebody else."
    "Я вешаю трубку... Похоже, придется позвонить кому-нибудь еще."

# game/Scenes/Other/main18.rpy:1977
