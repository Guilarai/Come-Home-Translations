# TODO: Translation updated at 2026-06-02 09:57

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:13
translate russian jamietv2_fd039b16:

    # "I walk up to Jamie's door and knock."
    "я подошел к двери Джейми и постучал."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:14
translate russian jamietv2_fdad75c4:

    # "I wait a bit for her to answer and after a few moments, I almost walk away thinking that she isn't home or is busy or something."
    "Я немного подождал, пока она откроет, и через несколько секунд уже почти уходил, думая, что ее нет дома или она занята или что-то в этом роде."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:19
translate russian jamietv2_56b288a0:

    # "Then, just when I am about to leave, she opens the door."
    "Но как раз в тот момент, когда я уже собирался уходить, она открыла дверь."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:20
translate russian jamietv2_348b659c:

    # gnd "Hey sorry, I must have fell asleep on the couch."
    gnd "Эй, извини, наверное, я заснула на диване."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:21
translate russian jamietv2_85e15039:

    # pc "Oh I'm sorry, I didn't mean to wake you. Was just wondering if you wanted to hang out?"
    pc "Ой, прости, я не хотела тебя разбудить. Просто подумала, не хочешь ли ты погулять?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:22
translate russian jamietv2_8cddc873:

    # gnd "Sure, want to come watch TV with me?"
    gnd "Конечно, хочешь посмотреть со мной телевизор?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:23
translate russian jamietv2_6eafa1e5:

    # pc "Are you sure? You look pretty tired."
    pc "Ты уверена? Ты выглядишь довольно уставшей."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:24
translate russian jamietv2_d5f53ad3:

    # gnd "I'm exhausted, but I'd still like to spend some time with you."
    gnd "Я вымоталась, но всё равно хотела бы провести с тобой немного времени."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:25
translate russian jamietv2_35743d5e:

    # pc "Okay then."
    pc "Ладно, тогда."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:26
translate russian jamietv2_d6443097:

    # "We walk inside and sit down on her couch to watch TV together."
    "Мы заходим в дом и садимся на её диван, чтобы вместе посмотреть телевизор."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:29
translate russian jamietv2_4eefcd41:

    # pc "You not been sleeping well?"
    pc "Ты плохо спишь?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:30
translate russian jamietv2_d3a1e5f8:

    # gnd "I've just been studying a lot. It's been tough."
    gnd "Я просто много училась. Было тяжело."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:31
translate russian jamietv2_6d7e76b4:

    # pc "Tell me about it."
    pc "И не говори."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:32
translate russian jamietv2_56872787:

    # gnd "But I'm glad to spend some time with you, even if I'm sleepy."
    gnd "Но я рада провести с тобой время, даже если я сонная."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:37
translate russian jamietv2_c7a75159:

    # gnd "Are you implying I'm not cute when I'm not sleepy?"
    gnd "Ты намекаешь, что я не милая, когда не сонная?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:38
translate russian jamietv2_4db958a5:

    # pc "What? No."
    pc "Что? Нет."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:39
translate russian jamietv2_cf0825c6:

    # gnd "I'm just kidding. Thanks, you're sweet."
    gnd "Я просто шучу. Спасибо, ты милый."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:42
translate russian jamietv2_175d3768:

    # gnd "What? Are you serious?"
    gnd "Что? Ты серьезно?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:43
translate russian jamietv2_61f77a4c:

    # pc "Sure."
    pc "Конечно."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:44
translate russian jamietv2_f3a7bdd3:

    # gnd "That's probably not a good idea. My dad might actually kill you."
    gnd "Это, наверное, не лучшая идея. Мой папа может тебя убить."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:45
translate russian jamietv2_796397b3:

    # pc "It might be worth the risk."
    pc "Может, риск того стоит."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:46
translate russian jamietv2_34f266ea:

    # gnd "You're crazy!"
    gnd "Ты с ума сошла!"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:49
translate russian jamietv2_d13864ee:

    # gnd "But no, let's just watch TV."
    gnd "Но нет, давай просто посмотрим телевизор."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:52
translate russian jamietv2_8105064d:

    # "She smiles at me and we both turn towards the TV and watch the show."
    "Она улыбается мне, и мы оба поворачиваемся к телевизору и смотрим передачу."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:55
translate russian jamietv2_e4b4fe92:

    # "After the first commercial break, I hear her snoring softly and a moment later, she leans over and lays her head on my shoulder."
    "После первого рекламного перерыва я слышу, как она тихонько храпит, а через мгновение она наклоняется и кладет голову мне на плечо."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:56
translate russian jamietv2_72d126bc:

    # "I sit there like that, feeling her warm weight against me, smelling the scent of her shampoo. It's nice."
    "Я сижу так, чувствуя ее теплый вес на себе, вдыхая аромат ее шампуня. Это приятно."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:57
translate russian jamietv2_a7276863:

    # "I watch the rest of the show, letting her sleep on my shoulder until the credits roll."
    "Я смотрю остаток передачи, позволяя ей спать на моем плече, пока не появятся титры."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:60
translate russian jamietv2_aced7ae5:

    # "The music playing during the credits wakes her and she opens her eyes and looks up at me, putting her hand on my chest."
    "Музыка, играющая во время титров, будит её, и она открывает глаза, смотрит на меня и кладёт руку мне на грудь."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:61
translate russian jamietv2_222fe902:

    # gnd "Oh man, I missed the whole thing."
    gnd "О боже, я всё пропустила."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:62
translate russian jamietv2_7289beae:

    # pc "Yeah, I'll have to fill you in later."
    pc "Да, придётся тебе потом всё рассказать."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:63
translate russian jamietv2_d912edc5:

    # gnd "You could have woke me up."
    gnd "Ты мог бы меня разбудить."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:66
translate russian jamietv2_fd8175bb:

    # gnd "I definitely did."
    gnd "Я точно пытался."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:68
translate russian jamietv2_7b910158:

    # gnd "You're so silly."
    gnd "Ты такой глупый."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:69
translate russian jamietv2_d404c590:

    # gnd "Do you really think I'm cute?"
    gnd "Ты действительно думаешь, что я милая?"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:70
translate russian jamietv2_2951ed74:

    # pc "Definitely."
    pc "Безусловно."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:71
translate russian jamietv2_d2d7ae9c:

    # gnd "I think you're cute too."
    gnd "Я тоже думаю, что ты милая."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:72
translate russian jamietv2_e8e9a7f7:

    # "Once again, her dad picks the worst moment to open the door and walk in."
    "И снова её отец выбирает самый неподходящий момент, чтобы открыть дверь и войти."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:73
translate russian jamietv2_9da07a83:

    # "Jamie leans away from me and stands up."
    "Джейми отклоняется от меня и встает."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:79
translate russian jamietv2_d41d8cd9:

    # voice "voices/jamie_011.mp3"
    voice "voices/jamie_011.mp3"

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:80
translate russian jamietv2_25b98dfa:

    # gnd "Hey, Daddy."
    gnd "Привет, папа."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:81
translate russian jamietv2_20dcad47:

    # jd "Send him home."
    jd "Отправь его домой."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:82
translate russian jamietv2_f2596c67:

    # "Her dad doesn't say anything else and instead walks past us and into the kitchen."
    "Её отец больше ничего не говорит, а просто проходит мимо нас на кухню."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:86
translate russian jamietv2_84d4365c:

    # gnd "He must have had a bad day."
    gnd "У него, наверное, был плохой день."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:87
translate russian jamietv2_b44cf649:

    # pc "I should probably go."
    pc "Мне, наверное, пора."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:88
translate russian jamietv2_a6870bf2:

    # gnd "Yeah, I'm sorry."
    gnd "Да, прости."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:89
translate russian jamietv2_b219d344:

    # pc "It's okay."
    pc "Ничего страшного."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:92
translate russian jamietv2_36b8ae4f:

    # gnd "Thanks for coming over tonight. I had a good time."
    gnd "Спасибо, что зашел сегодня вечером. Мне было приятно."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:93
translate russian jamietv2_041dfd87:

    # pc "More like you had a good nap."
    pc "Скорее, тебе было приятно вздремнуть."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:94
translate russian jamietv2_b762e00f:

    # gnd "That too. Your shoulder is very comfy."
    gnd "И это тоже. Твое плечо очень удобное."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:98
translate russian jamietv2_4bbcc4b9:

    # gnd "I might take you up on that."
    gnd "Может, я воспользуюсь твоим предложением."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:100
translate russian jamietv2_f9097bdf:

    # gnd "I'm sure they'll show re-runs all week."
    gnd "Уверена, всю неделю будут показывать повторы."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:101
translate russian jamietv2_dfc3c586:

    # pc "Alright, well I better head home."
    pc "Ладно, мне лучше пойти домой."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:103
translate russian jamietv2_ecb1e778:

    # gnd "Okay, [pcname]. See you again soon."
    gnd "Хорошо, [pcname]. Увидимся скоро."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:104
translate russian jamietv2_209b1712:

    # pc "See ya."
    pc "Увидимся."

# game/Scenes/Jamie/JamieTV/jamietv2.rpy:105
translate russian jamietv2_1557defd:

    # "With that, she goes back inside and I walk back over to my house."
    "С этими словами она возвращается в дом, а я иду обратно к себе."

translate russian strings:

    # game/Scenes/Jamie/JamieTV/jamietv2.rpy:2
    old "A few days after the first time you watch TV with her, ."
    new "Через несколько дней после того, как ты впервые посмотрел с ней телевизор, ."

