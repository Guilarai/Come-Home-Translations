translate russian jamiemoviedate_ddd48024:

    # gnd "Give me just a few minutes to get ready."
    gnd "Дай мне пару минут, чтобы приготовиться."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:33
translate russian jamiemovietheaterstartdate_0f1c479d:

    # "We get to the theater and get seats in the back."
    "Мы приходим в кинотеатр и занимаем места в задних рядах."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:34
translate russian jamiemovietheaterstartdate_c9878d77:

    # gnd "So what are we watching anyway?"
    gnd "Так что мы вообще смотрим?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:38
translate russian jamiemovietheaterstartdate_b4720e01:

    # gnd "Oh, I like it."
    gnd "О, мне нравится."

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:39
translate russian jamiemovietheaterstartdate_45ba22b9:

    # gnd "Trying to put me in the mood huh?"
    gnd "Пытаешься настроить меня на нужный лад, да?"

# game/Scenes/Jamie/JamieDates/jamiemoviedate.rpy:44
