# game/Scenes/Jamie/JamieDates/jamiedate.rpy:29
translate russian jamiedate0_f7556ea0:

    # gnd "I was just going to say that if you tell me where you want to go, I'll drive my own car and meet you there."
    gnd "Я просто хотела сказать, что если ты скажешь, куда хочешь пойти, я приеду на своей машине и встречу тебя там."

# game/Scenes/Jamie/JamieDates/jamiedate.rpy:30
