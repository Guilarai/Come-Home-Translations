translate russian jamie8_796c0fbd:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart growing bigger and bigger until it's almost bursting now."
    gnd "С тех пор, как ты вернулся, я чувствую, как это нарастает, будто мое сердце становится все больше и больше, пока не готово разорваться."

# game/Scenes/Jamie/jamie8.rpy:87
translate russian jamie8_d41d8cd9_6:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:88
translate russian jamie8_0d1296eb:

    # gnd "I smile every time I think about you, and I find myself thinking about you a lot."
    gnd "Я улыбаюсь каждый раз, когда думаю о тебе, и я часто о тебе думаю."

# game/Scenes/Jamie/jamie8.rpy:90
translate russian jamie8_d41d8cd9_7:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:91
translate russian jamie8_a90d9888_1:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Я полностью влюблена в тебя, [pcname]. Я просто хотела, чтобы ты это знал."

# game/Scenes/Jamie/jamie8.rpy:92
translate russian jamie8_fb4ce796:

    # pc "Oh, okay. Good to know."
    pc "О, ладно. Хорошо знать."

# game/Scenes/Jamie/jamie8.rpy:94
translate russian jamie8_5b0a7e45:

    # "We talk awkwardly a little bit longer about less important things, then there's just silence between us for a while."
    "Мы еще немного неловко болтаем о менее важных вещах, потом между нами наступает тишина."

# game/Scenes/Jamie/jamie8.rpy:95
translate russian jamie8_fcdf2655_1:

    # gnd "I better get some sleep."
    gnd "Мне лучше пойти спать."

# game/Scenes/Jamie/jamie8.rpy:96
translate russian jamie8_fdc5f0f0_1:

    # pc "Yeah, me too."
    pc "Да, мне тоже."

# game/Scenes/Jamie/jamie8.rpy:97
translate russian jamie8_76e2f41b:

    # gnd "Okay. Good night, [pcname]."
    gnd "Ладно. Спокойной ночи, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:98
translate russian jamie8_6fd39c33:

    # pc "Night!"
    pc "Спокойной ночи!"

# game/Scenes/Jamie/jamie8.rpy:99
translate russian jamie8_39ca4ede:

    # "I hang up and go to sleep."
    "Я вешаю трубку и ложусь спать."

