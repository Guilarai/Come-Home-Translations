# game/Scenes/Jamie/jamie8.rpy:13
translate russian jamie8_98ca1a51:

    # "My phone buzzes in my pocket."
    "Мой телефон вибрирует в кармане."

# game/Scenes/Jamie/jamie8.rpy:15
translate russian jamie8_7a608d10:

    # "It's Jamie. I lie on my bed and answer the phone."
    "Это Джейми. Я лежу на кровати и беру трубку."

# game/Scenes/Jamie/jamie8.rpy:19
translate russian jamie8_80c674d7:

    # pc "Hey, Jamie."
    pc "Привет, Джейми."

# game/Scenes/Jamie/jamie8.rpy:20
translate russian jamie8_3d698c03:

    # gnd "Hey. You busy?"
    gnd "Привет. Ты занят?"

# game/Scenes/Jamie/jamie8.rpy:21
translate russian jamie8_4474e21b:

    # pc "Nah. What's up?"
    pc "Нет. В чем дело?"

# game/Scenes/Jamie/jamie8.rpy:22
translate russian jamie8_34eb8872:

    # gnd "Nothing really. Just wanted to talk to you. Miss you."
    gnd "Ничего особенного. Просто хотела поговорить с тобой. Скучаю."

# game/Scenes/Jamie/jamie8.rpy:23
translate russian jamie8_71edcec9:

    # pc "Well.. you could come over?"
    pc "Ну... ты могла бы зайти?"

# game/Scenes/Jamie/jamie8.rpy:25
translate russian jamie8_a38e761a:

    # gnd "You know I can't really do that. My dad would be so mad."
    gnd "Ты же знаешь, что я не могу этого сделать. Мой папа будет в ярости."

# game/Scenes/Jamie/jamie8.rpy:26
translate russian jamie8_9f0961af:

    # pc "Why? You're an adult. Why does he get a say in what you do?"
    pc "Почему? Ты же взрослая. Почему он решает, что тебе делать?"

# game/Scenes/Jamie/jamie8.rpy:27
translate russian jamie8_57cb5e24:

    # gnd "I know. I just don't want him to be mad."
    gnd "Я знаю. Просто не хочу, чтобы он злился."

# game/Scenes/Jamie/jamie8.rpy:28
translate russian jamie8_0833b2b4:

    # gnd "I'll talk to him soon though, I promise."
    gnd "Но я скоро с ним поговорю, обещаю."

# game/Scenes/Jamie/jamie8.rpy:29
translate russian jamie8_b1a2e372:

    # gnd "I know I need to. It's just hard, because I know he's not going to like what I have to say."
    gnd "Я знаю, что нужно. Просто это сложно, потому что я знаю, что ему не понравится то, что я скажу."

# game/Scenes/Jamie/jamie8.rpy:30
translate russian jamie8_6cd88cb3:

    # gnd "And he works so hard, and I love him so much. I just hate to make him upset."
    gnd "И он так много работает, а я его так люблю. Просто ненавижу расстраивать его."

# game/Scenes/Jamie/jamie8.rpy:32
translate russian jamie8_dbc86daf:

    # gnd "But you mean so much to me. I don't want to have to keep sneaking around, keeping us a secret."
    gnd "Но ты так много для меня значишь. Я не хочу больше скрываться, держать наши отношения в секрете."

# game/Scenes/Jamie/jamie8.rpy:33
translate russian jamie8_aa61dfea:

    # gnd "I just need to build up the courage to do it."
    gnd "Мне просто нужно набраться смелости, чтобы это сделать."

# game/Scenes/Jamie/jamie8.rpy:37
translate russian jamie8_07bcbb36:

    # gnd "Thank you. I'm glad. You've been very patient with me."
    gnd "Спасибо. Я рада. Ты был со мной очень терпелив."

# game/Scenes/Jamie/jamie8.rpy:39
translate russian jamie8_a5d0737c:

    # gnd "I'll make it worth it for you, I promise."
    gnd "Я оправдаю твои ожидания, обещаю."

# game/Scenes/Jamie/jamie8.rpy:40
translate russian jamie8_5de186d8:

    # pc "It's already worth it, Jamie."
    pc "Это уже того стоит, Джейми."

# game/Scenes/Jamie/jamie8.rpy:43
translate russian jamie8_911c62b3:

    # gnd "You're right. I'm sorry."
    gnd "Ты прав. Прости."

# game/Scenes/Jamie/jamie8.rpy:44
translate russian jamie8_d5112d06:

    # gnd "You shouldn't have to deal with all of this drama. I know you're dealing with your own things, with your dad missing and all."
    gnd "Тебе не пришлось бы иметь дело со всей этой драмой. Я знаю, что у тебя свои проблемы, с пропавшим отцом и всем остальным."

# game/Scenes/Jamie/jamie8.rpy:45
translate russian jamie8_5a747778:

    # gnd "I should be there for you more."
    gnd "Я должен быть рядом с тобой чаще."

# game/Scenes/Jamie/jamie8.rpy:47
translate russian jamie8_9d979554:

    # gnd "And I will be. I promise. I'll tell him soon."
    gnd "И я буду. Обещаю. Я скоро ему скажу."

# game/Scenes/Jamie/jamie8.rpy:49
translate russian jamie8_d41d8cd9:

    # voice "voices/jamie_022.mp3"        
    voice "voices/jamie_022.mp3"        

# game/Scenes/Jamie/jamie8.rpy:50
translate russian jamie8_f9831d1e:

    # gnd "I love you, [pcname]."
    gnd "Я люблю тебя, [pcname]."

# game/Scenes/Jamie/jamie8.rpy:56
translate russian jamie8_b629d4db:

    # gnd "That feels good to say... and to hear."
    gnd "Приятно это говорить... и слышать."

# game/Scenes/Jamie/jamie8.rpy:58
translate russian jamie8_4d7bfc98:

    # gnd "I really mean it too."
    gnd "Я действительно так думаю."

# game/Scenes/Jamie/jamie8.rpy:60
translate russian jamie8_d41d8cd9_1:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

# game/Scenes/Jamie/jamie8.rpy:61
translate russian jamie8_8cee1605:

    # gnd "Ever since you came back, I've been feeling it building up, like my heart is growing bigger and bigger until it's close to bursting."
    gnd "С тех пор, как ты вернулся, я чувствую, как это нарастает, как будто мое сердце становится все больше и больше, пока не готово разорваться."

# game/Scenes/Jamie/jamie8.rpy:63
translate russian jamie8_d41d8cd9_2:

    # voice "voices/jamie_020.mp3"
    voice "voices/jamie_020.mp3"

# game/Scenes/Jamie/jamie8.rpy:64
translate russian jamie8_55ac6cf8:

    # gnd "I smile every time I think about you, and I find myself thinking about you all the time."
    gnd "Я улыбаюсь каждый раз, когда думаю о тебе, и я замечаю, что думаю о тебе постоянно."

# game/Scenes/Jamie/jamie8.rpy:67
translate russian jamie8_d41d8cd9_3:

    # voice "voices/jamie_021.mp3"
    voice "voices/jamie_021.mp3"

# game/Scenes/Jamie/jamie8.rpy:68
translate russian jamie8_a90d9888:

    # gnd "I'm completely in love with you, [pcname]. I just wanted you to know that."
    gnd "Я полностью влюблена в тебя, [pcname]. Я просто хотела, чтобы ты это знал."

# game/Scenes/Jamie/jamie8.rpy:69
translate russian jamie8_9fc0bac9:

    # pc "I feel the same way, Jamie. You're amazing."
    pc "Я чувствую то же самое, Джейми. Ты потрясающий."

# game/Scenes/Jamie/jamie8.rpy:71
translate russian jamie8_ff198159:

    # gnd "I'm so happy."
    gnd "Я так счастлива."

# game/Scenes/Jamie/jamie8.rpy:72
translate russian jamie8_69aafc54:

    # "We talk a little longer about other less important things, until we're both practically falling asleep on the phone."
    "Мы еще немного болтаем о других, менее важных вещах, пока оба практически не засыпаем у телефона."

# game/Scenes/Jamie/jamie8.rpy:74
translate russian jamie8_fcdf2655:

    # gnd "I better get some sleep."
    gnd "Мне лучше пойти спать."

# game/Scenes/Jamie/jamie8.rpy:75
translate russian jamie8_fdc5f0f0:

    # pc "Yeah, me too."
    pc "Да, мне тоже."

# game/Scenes/Jamie/jamie8.rpy:77
translate russian jamie8_d41d8cd9_4:

    # voice "voices/jamie_010.mp3"
    voice "voices/jamie_010.mp3"

# game/Scenes/Jamie/jamie8.rpy:78
translate russian jamie8_63e5a3ef:

    # gnd "Good night, [pcname]. Love you."
    gnd "Спокойной ночи, [pcname]. Люблю тебя."

# game/Scenes/Jamie/jamie8.rpy:79
translate russian jamie8_727173cd:

    # pc "Love you too, Jamie. Good night."
    pc "Я тоже тебя люблю, Джейми. Спокойной ночи."

# game/Scenes/Jamie/jamie8.rpy:82
translate russian jamie8_a25f5d31:

    # gnd "I mean it."
    gnd "Я серьезно."

# game/Scenes/Jamie/jamie8.rpy:84
translate russian jamie8_d41d8cd9_5:

    # voice "voices/jamie_019.mp3"
    voice "voices/jamie_019.mp3"

