    # gg "Yeah. See you there."
    gg "Да. Увидимся там."

# game/Scenes/School/SocialStudies/ss1.rpy:89
translate russian ss1_54ca6c92:

    # "Eventually, Ms. Welch finishes her lecture and I go on to the next class."
    "В конце концов, мисс Уэлч заканчивает лекцию, и я иду на следующий урок."

# game/Scenes/School/SocialStudies/ss1.rpy:90
translate russian ss1_470e54a6:

    # "Nothing else interesting happens the rest of the day, then I head to work."
