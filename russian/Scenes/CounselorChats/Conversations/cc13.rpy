# game/Scenes/CounselorChats/Conversations/cc13.rpy:12
translate russian cc13_14c081a9:

    # sc "I need to talk to you about something."
    sc "Мне нужно с тобой поговорить."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:13
translate russian cc13_c5f20c44:

    # sc "A rumor has been going around that you have been having sex with a teacher."
    sc "Ходит слух, что ты занимаешься сексом с учителем."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:14
translate russian cc13_e89e0515:

    # pc "Oh really?"
    pc "Правда?"

# game/Scenes/CounselorChats/Conversations/cc13.rpy:16
translate russian cc13_cfd3f1f1:

    # sc "Yes. I don't want to get into details, and I don't want you to confirm or deny it."
    sc "Да. Я не хочу вдаваться в подробности, и я не хочу, чтобы ты это подтверждала или опровергала."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:17
translate russian cc13_f54f89e3:

    # sc "I just want to warn you."
    sc "Я просто хочу тебя предупредить."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:18
translate russian cc13_50a8a170:

    # sc "You could be putting your diploma in jeopardy, along with the teacher's job."
    sc "Ты можешь поставить под угрозу свой аттестат, а также работу учителя."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:20
translate russian cc13_efd8b6cc:

    # sc "So as your counselor, I have to strongly suggest that, if this rumor is true, you end this relationship."
    sc "Поэтому, как твой консультант, я настоятельно рекомендую тебе, если этот слух правдивый, прекратить эти отношения."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:21
translate russian cc13_b4dece47:

    # sc "It can only bring harm."
    sc "Это может принести только вред."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:22
translate russian cc13_4c93bce8:

    # pc "What about me and you?"
    pc "А как насчет нас с тобой?"

# game/Scenes/CounselorChats/Conversations/cc13.rpy:24
translate russian cc13_a0c6b3c0:

    # sc "That's a little different."
    sc "Это немного другое дело."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:25
translate russian cc13_a3b40c83:

    # sc "It's still technically against the rules."
    sc "Технически это все равно против правил."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:26
translate russian cc13_466d02ac:

    # sc "I would still get fired if it was discovered, especially since we are doing things here in my office."
    sc "Меня все равно уволят, если это обнаружится, особенно учитывая, что мы занимаемся этим здесь, в моем кабинете."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:28
translate russian cc13_0b00c4ec:

    # sc "But it would probably not cause you to lose your diploma, since I don't assign grades to you."
    sc "Но это, вероятно, не приведет к потере твоего диплома, так как я не ставлю тебе оценки."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:30
translate russian cc13_aab27f9e:

    # sc "I'm just worried about your success."
    sc "Я просто беспокоюсь о твоем успехе."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:32
translate russian cc13_63a948a4:

    # pc "Thanks for looking out for me."
    pc "Спасибо, что заботишься обо мне."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:33
translate russian cc13_c935f597:

    # pc "I'll think about it and keep your advice in mind."
    pc "Я подумаю об этом и приму твой совет во внимание."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:34
translate russian cc13_d9dd5654:

    # sc "Please do."
    sc "Пожалуйста, сделай это."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:35
translate russian cc13_08618ece:

    # sc "Anyway, you should get to class."
    sc "В любом случае, тебе пора на урок."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:36
translate russian cc13_66b35acb:

    # pc "Okay, talk to you later Gertrude."
    pc "Хорошо, поговорим позже, Гертруда."

# game/Scenes/CounselorChats/Conversations/cc13.rpy:37
translate russian cc13_984d8ab7:

    # sc "Bye, hun. Have a good day."
    sc "Пока, милая. Хорошего дня."

translate russian strings:

