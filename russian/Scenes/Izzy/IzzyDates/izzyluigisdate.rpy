# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:27
translate russian izzyluigisdatestart_528b32f8:

    # gl "Hey Twig. I've never been to this place before. Is it good?"
    gl "Привет, Твиг. Я никогда раньше не была в этом месте. Оно хорошее?"

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:28
translate russian izzyluigisdatestart_60666a62:

    # pc "Yeah, they have great pizza. Or anything Italian. I love it."
    pc "Да, у них отличная пицца. Или любая итальянская еда. Я обожаю это."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:29
translate russian izzyluigisdatestart_892088c7:

    # gl "Fuck, some good pizza sounds good."
    gl "Черт, хорошая пицца звучит неплохо."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:32
translate russian izzyluigisdatestart_d41d8cd9:

    # voice 'voices/izzy_whatsup.mp3'
    voice 'voices/izzy_whatsup.mp3'

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:33
translate russian izzyluigisdatestart_7abda82a:

    # gl "What's up, Twig. Let's go get some fucking pizza."
    gl "Как дела, Твиг. Пойдем, покушаем чертову пиццу."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:37
translate russian izzyluigisdatestart_008f10b6:

    # gl "Wow, this place is a little more fancy than I expected."
    gl "Вау, это место немного более шикарное, чем я ожидала."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:38
translate russian izzyluigisdatestart_8fffd4a0:

    # gl "Maybe I should have put on some makeup or something."
    gl "Может, мне стоило накраситься или что-то в этом роде."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:39
translate russian izzyluigisdatestart_560798c7:

    # pc "You look great. Don't worry about it."
    pc "Ты отлично выглядишь. Не переживай об этом."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:41
translate russian izzyluigisdatestart_5efd3620:

    # gl "Alright then. Thanks, Twig."
    gl "Ладно, тогда. Спасибо, Твиг."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:45
translate russian izzyluigisdatestart_868de71e:

    # "We sit at the booth and order a pizza."
    "Мы садимся за столик и заказываем пиццу."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:46
translate russian izzyluigisdatestart_a675496b:

    # "We start talking and don't stop the whole time we're there."
    "Мы начинаем разговаривать и не перестаем все время, пока мы там."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:53
translate russian izzyluigisdatestart_d0143732:

    # "When we're done eating, I drive Izzy back to her house."
    "Когда мы доедаем, я отвожу Иззи домой."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:54
translate russian izzyluigisdatestart_2a5b6b89:

    # "I pull into her driveway and she turns to look at me."
    "Я заезжаю на ее подъездную дорожку, и она поворачивается, чтобы посмотреть на меня."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:56
translate russian izzyluigisdatestart_6dd86d8c:

    # gl "So, do you want to come inside and fuck a little?"
    gl "Ну, хочешь зайти и немного потрахаться?"

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:63
translate russian izzyluigisdatestart_dcbc938c:

    # gl "Cool, let's go."
    gl "Круто, пошли."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:66
translate russian izzyluigisdatestart_dcbc938c_1:

    # gl "Cool, let's go."
    gl "Круто, пошли."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:69
translate russian izzyluigisdatestart_a9bda5cf:

    # gl "Damn, a girl can hope. Thanks for the food anyway, Twig. See ya later."
    gl "Черт, девчонка может надеяться. В любом случае, спасибо за еду, Твиг. Увидимся позже."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:70
translate russian izzyluigisdatestart_63fc4244:

    # pc "Bye, Izzy."
    pc "Пока, Иззи."

# game/Scenes/Izzy/IzzyDates/izzyluigisdate.rpy:73
translate russian izzyluigisdatestart_8b93ebfd:

    # "I wait until she gets out and walks into her house before I drive away."
    "Я жду, пока она выйдет и войдет в дом, прежде чем уехать."

