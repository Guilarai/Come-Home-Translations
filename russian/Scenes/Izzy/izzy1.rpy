translate russian izzy1_d20e163b:

    # gl "Where you going, twig-boy?"
    gl "Куда ты, хлюпик?"

# game/Scenes/Izzy/izzy1.rpy:25
translate russian izzy1_7d2401c7:

    # pc "Twig-boy?"
    pc "Хлюпик?"

# game/Scenes/Izzy/izzy1.rpy:27
