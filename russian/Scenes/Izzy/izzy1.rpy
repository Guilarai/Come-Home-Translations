    # voice 'voices/izzy_1_5.mp3'
    voice 'voices/izzy_1_5.mp3'

# game/Scenes/Izzy/izzy1.rpy:43
translate russian izzy1_f6a69cf1:

    # gl "Anyways, we ain't no city council and we ain't an open forum."
    gl "В любом случае, мы не городской совет и не открытый форум."

# game/Scenes/Izzy/izzy1.rpy:45
translate russian izzy1_d41d8cd9_5:

    # voice 'voices/izzy_1_6.mp3'
    voice 'voices/izzy_1_6.mp3'

# game/Scenes/Izzy/izzy1.rpy:46
translate russian izzy1_671e7cca:

    # gl "So you ain't welcome here. Get it, Twig?"
    gl "Так что тебе здесь не рады. Понял, Хлопья?"

# game/Scenes/Izzy/izzy1.rpy:51
translate russian izzytwigtalk_bc94c85f:

    # gl "You back, Twig?"
    gl "Ты вернулся, Хлопья?"

# game/Scenes/Izzy/izzy1.rpy:52
translate russian izzytwigtalk_5e16b4dd:

    # gl "I told you that you ain't welcome here."
    gl "Я же сказала, что тебе здесь не рады."

# game/Scenes/Izzy/izzy1.rpy:56
translate russian izzytwigtalk_19da926c:

    # gl "Good. Get the fuck out of here, Twig."
    gl "Хорошо. Убирайся отсюда, Хлопья."

# game/Scenes/Izzy/izzy1.rpy:59
translate russian izzytwigtalk_03a3489c:

    # "I turn and walk away. After I take a few steps I can hear them all laughing. It's humiliating."
    "Я поворачиваюсь и ухожу. Пройдя несколько шагов, я слышу, как они все смеются. Это унизительно."

# game/Scenes/Izzy/izzy1.rpy:60
translate russian izzytwigtalk_6aa25614:

    # "Maybe I'll try again some other time, but for now I just want to get out of here."
    "Может, я попробую еще раз в другой раз, но пока я просто хочу убраться отсюда."

# game/Scenes/Izzy/izzy1.rpy:70
translate russian izzytwigtalk_ea29e717:

    # gl "Oh, is that what you think?"
    gl "О, так ты думаешь?"

# game/Scenes/Izzy/izzy1.rpy:71
translate russian izzytwigtalk_4f1631c8:

    # gl "Fine. Moose, grab him."
    gl "Ладно. Мус, хватай его."

# game/Scenes/Izzy/izzy1.rpy:72
translate russian izzytwigtalk_c7045d3c:

    # moose "You got it, girl."
    moose "Понял, девочка."

# game/Scenes/Izzy/izzy1.rpy:75
translate russian izzytwigtalk_bfacd7f0:

    # "With unnatural speed for his size, the big man charges towards me, arms out."
    "С ненормальной для своего размера скоростью этот огромный мужик бросается на меня с распростертыми руками."

# game/Scenes/Izzy/izzy1.rpy:77
translate russian izzytwigtalk_d623de1c:

    # "Without even thinking about it, I turn and run the other way."
    "Даже не задумываясь, я поворачиваюсь и бегу в другую сторону."

# game/Scenes/Izzy/izzy1.rpy:78
translate russian izzytwigtalk_c857d906:

    # "He gives chase for a bit, but then gives up and goes back to the others."
    "Он немного гонится за мной, но потом сдается и возвращается к остальным."

# game/Scenes/Izzy/izzy1.rpy:81
translate russian izzytwigtalk_2a2c5fa4:

    # "I don't stop though. I just showed how much of a pussy I am by running there and now I can't just go back and face them again."
    "Я, однако, не останавливаюсь. Я только что показал, какой я трус, убежав оттуда, и теперь не могу просто вернуться и снова столкнуться с ними."

# game/Scenes/Izzy/izzy1.rpy:82
translate russian izzytwigtalk_224c9c2b:

    # gl "That's right, keep running, Twig!"
    gl "Вот так, беги дальше, Твиг!"

# game/Scenes/Izzy/izzy1.rpy:83
translate russian izzytwigtalk_67906573:

    # "She yells after me, taunting me as I head back towards my car."
    "Она кричит мне вслед, дразня меня, пока я возвращаюсь к своей машине."

# game/Scenes/Izzy/izzy1.rpy:84
translate russian izzytwigtalk_45a42840:

    # "Maybe if I was more confident, I could stand my ground, but for now I just want to get out of here."
    "Может, если бы я был более уверен в себе, я смог бы постоять за себя, но пока я просто хочу убраться отсюда."

# game/Scenes/Izzy/izzy1.rpy:85
translate russian izzytwigtalk_9a4f14d6:

    # "I could probably boost my confidence by chatting up random strangers at the school café. That seems like the most obvious way."
    "Я, наверное, мог бы повысить свою уверенность, завязав разговор с случайными незнакомцами в школьном кафе. Это кажется самым очевидным способом."

