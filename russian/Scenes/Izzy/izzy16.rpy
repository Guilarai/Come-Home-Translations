    gl "Ты действительно хороший парень, ты знаешь об этом?"

# game/Scenes/Izzy/izzy16.rpy:335
translate russian izzy16_677ee242:

    # pc "Yeah, you're not so bad yourself."
    pc "Да, ты сама неплохая."

# game/Scenes/Izzy/izzy16.rpy:336
translate russian izzy16_6d52d3a6:

