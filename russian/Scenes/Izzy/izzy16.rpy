    pc "А, ничего страшного. Думаю, мы все знали, к чему это приведет."

# game/Scenes/Izzy/izzy16.rpy:330
translate russian izzy16_4abf1190:

    # gl "Thanks for sharing. I really enjoyed it."
    gl "Спасибо, что поделился. Мне очень понравилось."

# game/Scenes/Izzy/izzy16.rpy:331
translate russian izzy16_53a29a41:

    # pc "I know you did. I did too."
    pc "Я знаю, что понравилось. Мне тоже."

# game/Scenes/Izzy/izzy16.rpy:334
translate russian izzy16_e914bfdc:

