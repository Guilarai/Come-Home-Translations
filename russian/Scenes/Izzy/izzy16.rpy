    "Мы прощаемся с ними, и они выходят из дома, направляясь к машине Мэл."

# game/Scenes/Izzy/izzy16.rpy:327
translate russian izzy16_e4961fdc:

    # gl "Well... that was a fun game night."
    gl "Ну... это был веселый игровой вечер."

# game/Scenes/Izzy/izzy16.rpy:328
translate russian izzy16_31907f49:

