    "Не проходит и минуты, как мы оба засыпаем."

# game/Scenes/Izzy/izzy16.rpy:352
translate russian izzy16_1cee6238:

    # "I wake up to the sound of my phone alarm in the morning."
    "Утром я просыпаюсь под звук будильника в телефоне."

# game/Scenes/Izzy/izzy16.rpy:355
translate russian izzy16_bc4ff6d9:

    # pc "Hey, Izzy. I have to go."
    pc "Привет, Иззи. Мне пора."

# game/Scenes/Izzy/izzy16.rpy:356
translate russian izzy16_4511aa4e:

    # gl "Oh okay, baby."
    gl "О, ладно, малыш."

# game/Scenes/Izzy/izzy16.rpy:357
translate russian izzy16_475c67d1:

    # gl "Hope you have a good day. Thanks for staying over."
    gl "Надеюсь, у тебя будет хороший день. Спасибо, что остался на ночь."

# game/Scenes/Izzy/izzy16.rpy:360
translate russian izzy16_f4a8219d:

    # pc "I'll talk to you later."
    pc "Поговорим позже."

# game/Scenes/Izzy/izzy16.rpy:361
translate russian izzy16_923d4965:

