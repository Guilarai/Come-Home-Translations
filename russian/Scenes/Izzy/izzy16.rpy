    gl "Может быть. Просто так подумала."

# game/Scenes/Izzy/izzy16.rpy:341
translate russian izzy16_fc71e7f9:

    # gl "You staying the night?"
    gl "Ты останешься на ночь?"

# game/Scenes/Izzy/izzy16.rpy:342
translate russian izzy16_3e51dd6a:

    # pc "Yeah, I'll stay."
    pc "Да, останусь."

# game/Scenes/Izzy/izzy16.rpy:346
translate russian izzy16_c6a7da14:

    # "We go back to her bed and lie down together."
