# game/Scenes/Izzy/izzy16.rpy:315
translate russian izzy16_7d7db393:

    # gl "He's treating me very good."
    gl "Он относится ко мне очень хорошо."

# game/Scenes/Izzy/izzy16.rpy:316
translate russian izzy16_5a5bf303:

    # moose "Good."
    moose "Хорошо."

# game/Scenes/Izzy/izzy16.rpy:319
