    gl "Ладно."

# game/Scenes/Izzy/izzy16.rpy:364
translate russian izzy16_7db1b4d7:

    # "As I'm walking away, I hear her say, almost too low to make out the words..."
    "Когда я ухожу, я слышу, как она говорит, почти так тихо, что слова едва разборчивы..."

# game/Scenes/Izzy/izzy16.rpy:365
translate russian izzy16_968ee224:

    # gl "Love you, Twig."
    gl "Люблю тебя, Твиг."

