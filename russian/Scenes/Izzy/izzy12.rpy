translate russian izzy12_ec7ea0db:

    # gl "Hey, Twig. You busy?"
    gl "Привет, Твиг. Ты занят?"

# game/Scenes/Izzy/izzy12.rpy:18
translate russian izzy12_54f66403:

    # pc "Not really, what's up?"
    pc "Не особо, в чем дело?"

# game/Scenes/Izzy/izzy12.rpy:20
translate russian izzy12_e79156a7:

    # gl "There's a movie I want to see. Thought maybe you'd want to come with me?"
    gl "Есть один фильм, который я хочу посмотреть. Думала, может, ты захочешь пойти со мной?"

# game/Scenes/Izzy/izzy12.rpy:21
translate russian izzy12_8ceccd75:

    # pc "You want to go on a date?"
    pc "Ты хочешь пойти на свидание?"

# game/Scenes/Izzy/izzy12.rpy:23
translate russian izzy12_ec53909b:

    # gl "I just want to go see a movie. You can call it whatever you want."
    gl "Я просто хочу пойти посмотреть фильм. Называй это как хочешь."

# game/Scenes/Izzy/izzy12.rpy:24
translate russian izzy12_64ec2086:

    # pc "You know you're going to have to wear some clothes right?"
    pc "Ты же знаешь, что тебе придется одеться, да?"

# game/Scenes/Izzy/izzy12.rpy:26
translate russian izzy12_33a6163c:

    # gl "Funny. Are we going, or what?"
    gl "Забавно. Мы идем или как?"

# game/Scenes/Izzy/izzy12.rpy:27
translate russian izzy12_659d5d45:

    # pc "Yeah, I'll come pick you up."
    pc "Да, я за тобой заеду."

# game/Scenes/Izzy/izzy12.rpy:28
translate russian izzy12_3b30cb95:

    # gl "Cool. See you when you get here."
    gl "Круто. Увидимся, когда ты приедешь."

