# game/Scenes/Jez/jez3.rpy:16
translate russian jez3_b7d0283a:

    # "Detective Rodriguez picks up the phone after a single ring, as if she had been holding her phone in her hand."
    "Детектив Родригес снимает трубку после одного гудка, как будто держала телефон в руке."

# game/Scenes/Jez/jez3.rpy:18
translate russian jez3_d41d8cd9:

    # voice 'voices/jez_answering.mp3'
    voice 'voices/jez_answering.mp3'

# game/Scenes/Jez/jez3.rpy:19
translate russian jez3_6673062e:

    # det "Detective Rodriguez."
    det "Детектив Родригес."

# game/Scenes/Jez/jez3.rpy:20
translate russian jez3_416b4b28:

    # pc "Hello, this is [pcname]."
    pc "Привет, это [pcname]."

# game/Scenes/Jez/jez3.rpy:22
translate russian jez3_d41d8cd9_1:

    # voice 'voices/jez_hey.mp3'
    voice 'voices/jez_hey.mp3'

# game/Scenes/Jez/jez3.rpy:23
translate russian jez3_5f1522eb:

    # det "Hey, [pcname]. What's up?"
    det "Привет, [pcname]. Как дела?"

# game/Scenes/Jez/jez3.rpy:24
translate russian jez3_eb667b3e:

    # pc "I had some new information about my dad's case. I was able to get into his laptop."
    pc "У меня появилась новая информация по делу моего отца. Мне удалось зайти в его ноутбук."

# game/Scenes/Jez/jez3.rpy:25
translate russian jez3_a1187622:

    # pc "I found a bunch of e-mails between him and this Whitney person."
    pc "Я нашла кучу писем между ним и некой Уитни."

# game/Scenes/Jez/jez3.rpy:26
translate russian jez3_d2f98bdb:

    # det "Hey, [pcname]. Hold on a second."
    det "Эй, [pcname]. Подожди секунду."

# game/Scenes/Jez/jez3.rpy:28
translate russian jez3_77774b9f:

    # det "I'll be honest with you. I've had a really bad day and I have a migraine from hell."
    det "Буду с тобой честна. У меня был ужасный день, и у меня просто адская мигрень."

# game/Scenes/Jez/jez3.rpy:29
translate russian jez3_b0a1faa8:

    # det "Your voice on this phone is making my head pound. What do you say we meet up in person."
    det "От твоего голоса в трубке у меня голова раскалывается. Как насчет того, чтобы встретиться лично?"

# game/Scenes/Jez/jez3.rpy:30
translate russian jez3_7cfb0b0e:

    # det "Do you know where The Pit is?"
    det "Ты знаешь, где находится «The Pit»?"

# game/Scenes/Jez/jez3.rpy:31
translate russian jez3_5a003c29:

    # pc "The bar downtown?"
    pc "Бар в центре города?"

# game/Scenes/Jez/jez3.rpy:32
translate russian jez3_c60f38c7:

    # det "That's it. Want to meet me there and have this conversation over drinks?"
    det "Именно. Хочешь встретиться со мной там и поговорить за рюмкой?"

# game/Scenes/Jez/jez3.rpy:33
translate russian jez3_a5c9c049:

    # det "I could really use a drink."
    det "Мне бы сейчас не помешал выпить."

# game/Scenes/Jez/jez3.rpy:36
translate russian jez3_2ba5f0eb:

    # det "Great, I'll be there in two."
    det "Отлично, я буду там через две минуты."

# game/Scenes/Jez/jez3.rpy:38
translate russian jez3_cd4d07e3:

    # det "Come on man, give me a break."
    det "Да ладно тебе, дай мне передохнуть."

# game/Scenes/Jez/jez3.rpy:39
translate russian jez3_84d27d16:

    # det "I just got finished working a 24-hour shift."
    det "Я только что закончил 24-часовую смену."

# game/Scenes/Jez/jez3.rpy:40
translate russian jez3_cd598c64:

    # pc "Alright, I'll be there in five minutes."
    pc "Ладно, я буду там через пять минут."

# game/Scenes/Jez/jez3.rpy:41
translate russian jez3_2ba5f0eb_1:

    # det "Great, I'll be there in two."
    det "Отлично, я буду там через две минуты."

# game/Scenes/Jez/jez3.rpy:44
translate russian jez3_d1ed5b1b:

    # "She hangs up and I quickly get ready and head out to the car."
    "Она вешает трубку, я быстро собираюсь и выхожу к машине."

# game/Scenes/Jez/jez3.rpy:45
translate russian jez3_5ddb21e5:

    # "Only a few minutes later, I park in front of the bar."
    "Всего через несколько минут я паркуюсь перед баром."

# game/Scenes/Jez/jez3.rpy:47
translate russian jez3_23e3b6db:

    # "I walk in and am met with a cloud of cigarette smoke, the dull roar of conversation, and a jukebox playing some rock song I've never heard."
    "Я вхожу и попадаю в облако сигаретного дыма, тусклый гул разговоров и музыкальный автомат, играющий какую-то рок-песню, которую я никогда не слышал."

# game/Scenes/Jez/jez3.rpy:48
translate russian jez3_64d6327f:

    # "It takes a few moments for me to notice Detective Rodriguez waving at me from a booth in the back of the bar."
    "Мне требуется несколько секунд, чтобы заметить детектива Родригес, махающую мне рукой из кабинки в задней части бара."

# game/Scenes/Jez/jez3.rpy:49
translate russian jez3_398f4ad8:

    # "I walk over and sit down across from her."
    "Я подхожу и сажусь напротив нее."

# game/Scenes/Jez/jez3.rpy:53
translate russian jez3_71bded69:

    # det "Thanks for meeting me here. I know it's not very professional, but I need a drink real bad and I hate drinking alone."
    det "Спасибо, что согласилась встретиться здесь. Я знаю, это не очень профессионально, но мне очень хочется выпить, а я ненавижу пить в одиночестве."

# game/Scenes/Jez/jez3.rpy:54
translate russian jez3_ac23b499:

    # det "I ordered you a beer too. You're twenty-one, right?"
    det "Я заказала тебе пиво тоже. Тебе двадцать один, верно?"

# game/Scenes/Jez/jez3.rpy:55
translate russian jez3_c2113814:

    # pc "Twenty-two."
    pc "Двадцать два."

# game/Scenes/Jez/jez3.rpy:56
translate russian jez3_da9af380:

    # det "Good. Drink up then."
    det "Хорошо. Тогда пей."

# game/Scenes/Jez/jez3.rpy:59
translate russian jez3_899cb188:

    # "I take a drink of the beer in front of me. It's nice and smooth."
    "Я делаю глоток пива, стоящего передо мной. Оно приятное и мягкое."

# game/Scenes/Jez/jez3.rpy:62
translate russian jez3_cfdfe09b:

    # pc "I'm just here to talk."
    pc "Я здесь просто поговорить."

# game/Scenes/Jez/jez3.rpy:64
translate russian jez3_a023156a:

    # det "So I'm just going to be drinking alone anyway. So be it."
    det "Значит, я все равно буду пить в одиночестве. Ну и ладно."

# game/Scenes/Jez/jez3.rpy:68
translate russian jez3_e5c2530c:

    # det "Okay, so you got into your dad's laptop and found some correspondence?"
    det "Ладно, так ты залезла в ноутбук своего отца и нашла какую-то переписку?"

# game/Scenes/Jez/jez3.rpy:69
translate russian jez3_66708b9a:

    # pc "Yeah, and it's crazy."
    pc "Да, и это просто безумие."

# game/Scenes/Jez/jez3.rpy:70
translate russian jez3_08461fea:

    # det "Give me the summary. You can send the entire thing over to my e-mail later."
    det "Расскажи вкратце. Полный текст можешь прислать мне на почту позже."

# game/Scenes/Jez/jez3.rpy:71
translate russian jez3_2af7a240:

    # pc "Well the gist is that he and Whitney were planning a trip."
    pc "Ну, суть в том, что он и Уитни планировали поездку."

# game/Scenes/Jez/jez3.rpy:72
translate russian jez3_b2a62e0b:

    # det "So he did run off with her?"
    det "Так он сбежал с ней?"

# game/Scenes/Jez/jez3.rpy:73
translate russian jez3_d0c263e4:

    # pc "No, he was the only one going on this trip."
    pc "Нет, он был единственным, кто собирался в эту поездку."

# game/Scenes/Jez/jez3.rpy:74
translate russian jez3_2908401f:

    # det "Okay, so where did he go?"
    det "Ладно, так куда он уехал?"

# game/Scenes/Jez/jez3.rpy:75
translate russian jez3_0a1d6430:

    # pc "I'm not sure, but the strangest part is how he got there."
    pc "Я не уверена, но самое странное — это то, как он туда добрался."

# game/Scenes/Jez/jez3.rpy:76
translate russian jez3_09d6eafc:

    # det "Explain."
    det "Объясни."

# game/Scenes/Jez/jez3.rpy:77
translate russian jez3_61000743:

    # pc "He built some sort of device. I found it in the basement. It looks like a hula hoop."
    pc "Он сконструировал какое-то устройство. Я нашла его в подвале. Оно похоже на хула-хуп."

# game/Scenes/Jez/jez3.rpy:79
translate russian jez3_b0e7f9ea:

    # det "What? You lost me."
    det "Что? Я не понимаю."

# game/Scenes/Jez/jez3.rpy:80
translate russian jez3_40d85287:

    # pc "I don't know how to explain it. It looks like a hoop. He and Whitney built it together. When it's activated, it's supposed to transport you somewhere."
    pc "Я не знаю, как это объяснить. Оно похоже на обруч. Он и Уитни сделали его вместе. Когда его активировать, оно должно перенести тебя куда-то."

# game/Scenes/Jez/jez3.rpy:81
translate russian jez3_1f06310c:

    # pc "He needed the diamonds to activate it. That's why he stole them."
    pc "Ему нужны были алмазы, чтобы его активировать. Вот почему он их украл."

# game/Scenes/Jez/jez3.rpy:82
translate russian jez3_35f3019c:

    # det "And the meth too?"
    det "И метамфетамин тоже?"

# game/Scenes/Jez/jez3.rpy:83
translate russian jez3_ff210007:

    # pc "Right. He used the meth to speed his heart rate up so his heart didn't stop during the transportation."
    pc "Да. Он использовал метамфетамин, чтобы ускорить сердцебиение, чтобы его сердце не остановилось во время перемещения."

# game/Scenes/Jez/jez3.rpy:84
translate russian jez3_22ea6d6f:

    # det "You know this is the dumbest fucking thing I've ever heard right?"
    det "Ты же понимаешь, что это самая идиотская херня, которую я когда-либо слышал, да?"

# game/Scenes/Jez/jez3.rpy:85
translate russian jez3_a2fed6c2:

    # pc "I'm just telling you what they were talking about."
    pc "Я просто рассказываю тебе, о чем они говорили."

# game/Scenes/Jez/jez3.rpy:87
translate russian jez3_1b198a7a:

    # det "Well I did look into the diamond theft."
    det "Ну, я действительно расследовал кражу алмазов."

# game/Scenes/Jez/jez3.rpy:88
translate russian jez3_0768d1c5:

    # det "There was a jewelry store over in Whiterock that was broken into only a few days before your dad went missing."
    det "В Уайтроке был ювелирный магазин, в который вломились всего за несколько дней до исчезновения твоего отца."

# game/Scenes/Jez/jez3.rpy:89
translate russian jez3_727a0b8a:

    # det "It was just like you described. The security was disabled for only a minute."
    det "Все было именно так, как ты описал. Система безопасности была отключена всего на минуту."

# game/Scenes/Jez/jez3.rpy:90
translate russian jez3_75b55784:

    # det "The thief entered through the back door, walked in, took two three-carat diamond rings, then walked back out."
    det "Вор вошел через заднюю дверь, прошел внутрь, взял два кольца с бриллиантами по три карата, а потом вышел."

# game/Scenes/Jez/jez3.rpy:91
translate russian jez3_a0cd13f9:

    # det "Security kicked back on. There would have been no trace that anybody was even there, except the rings were gone."
    det "Система безопасности снова включилась. Не осталось бы никаких следов того, что там кто-то был, если бы не исчезнувшие кольца."

# game/Scenes/Jez/jez3.rpy:92
translate russian jez3_a595c814:

    # pc "So he did it."
    pc "Значит, это он."

# game/Scenes/Jez/jez3.rpy:93
translate russian jez3_2cf2afa7:

    # det "It seems that way."
    det "Похоже на то."

# game/Scenes/Jez/jez3.rpy:94
translate russian jez3_7b6c844b:

    # pc "Any clue where he got the meth?"
    pc "Есть какие-нибудь зацепки, где он достал метамфетамин?"

# game/Scenes/Jez/jez3.rpy:96
translate russian jez3_6063143c:

    # det "God, there's no telling. That shit is all over Skyhill."
    det "Боже, кто его знает. Эта дрянь повсюду в Скайхилле."

# game/Scenes/Jez/jez3.rpy:97
translate russian jez3_399bdc0f:

    # pc "Really?"
    pc "Правда?"

# game/Scenes/Jez/jez3.rpy:99
translate russian jez3_94032961:

    # det "Yes. That's what I've been working on. That's my primary job."
    det "Да. Я как раз над этим работаю. Это моя основная задача."

# game/Scenes/Jez/jez3.rpy:100
translate russian jez3_91bebae5:

    # det "We know a few dealers and we can find people who buy meth."
    det "Мы знаем нескольких дилеров и можем найти тех, кто покупает метамфетамин."

# game/Scenes/Jez/jez3.rpy:101
translate russian jez3_ec847758:

    # det "But we can't seem to locate where the shit is coming from. Somebody around here is cooking it, and I don't know where."
    det "Но мы никак не можем определить, откуда эта дрянь поступает. Кто-то здесь его варит, и я не знаю, где."

# game/Scenes/Jez/jez3.rpy:102
translate russian jez3_ea875425:

    # pc "I had no idea it was that bad around here."
    pc "Я и понятия не имел, что здесь все так плохо."

# game/Scenes/Jez/jez3.rpy:103
translate russian jez3_49c82960:

    # det "Yeah. So I'm not sure exactly where your dad got it at, but I've been questioning people."
    det "Да. Так что я не уверен, где именно твой отец его достал, но я допрашивал людей."

# game/Scenes/Jez/jez3.rpy:104
translate russian jez3_5d188bd8:

    # det "Look [pcname], it sounds to me like your dad was having some sort of psychotic break."
    det "Слушай [pcname], мне кажется, у твоего отца был какой-то психотический срыв."

# game/Scenes/Jez/jez3.rpy:105
translate russian jez3_7a8cf8a1:

    # det "Teleporting hula-hoops, diamond theft, using meth to speed up your heart rate."
    det "Телепортация хула-хупов, кража бриллиантов, употребление метамфетамина для ускорения сердцебиения."

# game/Scenes/Jez/jez3.rpy:106
translate russian jez3_8ebd5686:

    # det "That sounds like a bunch of nonsense to me."
    det "Для меня это звучит как полная чепуха."

# game/Scenes/Jez/jez3.rpy:107
translate russian jez3_c417e350:

    # pc "Yeah."
    pc "Да."

# game/Scenes/Jez/jez3.rpy:108
translate russian jez3_4c3ec6a3:

    # det "But the more we dig into it, the more likely we're going to find him."
    det "Но чем больше мы в этом копаемся, тем больше шансов, что мы его найдем."

# game/Scenes/Jez/jez3.rpy:109
translate russian jez3_e004b1ab:

    # det "So keep digging."
    det "Так что продолжай копать."

# game/Scenes/Jez/jez3.rpy:110
translate russian jez3_58f0fc2d:

    # det "Send me the info that you found on the laptop and I'll see if I can find this Whitney person."
    det "Пришли мне информацию, которую ты нашла на ноутбуке, и я посмотрю, смогу ли я найти эту Уитни."

# game/Scenes/Jez/jez3.rpy:111
translate russian jez3_955d194d:

    # det "Assuming that she's real and not somebody that your dad made up."
    det "Если, конечно, она реальная, а не выдумка твоего отца."

# game/Scenes/Jez/jez3.rpy:112
translate russian jez3_25bfd7d2:

    # pc "It seems like she's real to me, based on the e-mails."
    pc "Судя по электронным письмам, мне кажется, что она реальная."

# game/Scenes/Jez/jez3.rpy:113
translate russian jez3_2fc85b75:

    # det "Alright. Well let's find her."
    det "Ладно. Ну, давай найдем ее."

# game/Scenes/Jez/jez3.rpy:114
translate russian jez3_e70c1658:

    # pc "I could e-mail her from Dad's laptop."
    pc "Я мог бы написать ей с папиного ноутбука."

# game/Scenes/Jez/jez3.rpy:116
translate russian jez3_3997e2c3:

    # det "That's not a bad idea. Give it a shot. Start up a conversation with her, see if you can find out more about her."
    det "Неплохая идея. Попробуй. Заведи с ней разговор, посмотри, сможешь ли ты узнать о ней больше."

# game/Scenes/Jez/jez3.rpy:117
translate russian jez3_4d9bef33:

    # det "And let me know anything you find."
    det "И дай мне знать, если что-нибудь найдешь."

# game/Scenes/Jez/jez3.rpy:119
translate russian jez3_5bc44b07:

    # pc "I will."
    pc "Дам."

# game/Scenes/Jez/jez3.rpy:121
translate russian jez3_b734eba7:

    # det "Thanks for meeting me here. I needed this."
    det "Спасибо, что встретился со мной здесь. Мне это было нужно."

# game/Scenes/Jez/jez3.rpy:122
translate russian jez3_ba520f30:

    # det "Now I have to get home. I haven't seen my kid in two days."
    det "Теперь мне нужно домой. Я не видел своего ребенка два дня."

# game/Scenes/Jez/jez3.rpy:123
translate russian jez3_ce82357f:

    # pc "You have a kid?"
    pc "У тебя есть ребенок?"

# game/Scenes/Jez/jez3.rpy:125
translate russian jez3_71fc0e0c:

    # det "Yeah, Javi. He's seven. My mom's taking care of him right now."
    det "Да, Хави. Ему семь лет. Сейчас за ним присматривает моя мама."

# game/Scenes/Jez/jez3.rpy:126
translate russian jez3_798c23ff:

    # det "You surprised that I have a kid?"
    det "Ты удивлена, что у меня есть ребенок?"

# game/Scenes/Jez/jez3.rpy:130
translate russian jez3_632e262d:

    # det "Thanks. I had him when I was 17."
    det "Спасибо. Я родила его, когда мне было 17."

# game/Scenes/Jez/jez3.rpy:133
translate russian jez3_ae370b70:

    # det "I'm not. You don't have to be married to have a kid, you know."
    det "Нет, не удивлена. Не обязательно быть замужем, чтобы завести ребенка, ты же знаешь."

# game/Scenes/Jez/jez3.rpy:134
translate russian jez3_2356fff3:

    # pc "Right, I didn't mean anything by it."
    pc "Верно, я ничего не имела в виду."

# game/Scenes/Jez/jez3.rpy:137
translate russian jez3_a82f6cf9:

    # det "Oh, I thought you seemed surprised."
    det "О, мне показалось, что ты удивилась."

# game/Scenes/Jez/jez3.rpy:139
translate russian jez3_12633b63:

    # det "Anyway, I better get home."
    det "В любом случае, мне лучше домой."

# game/Scenes/Jez/jez3.rpy:140
translate russian jez3_d0fa7dfb:

    # det "I'll see you later, [pcname]."
    det "Увидимся позже, [pcname]."

# game/Scenes/Jez/jez3.rpy:141
translate russian jez3_7b4cad00:

    # pc "Bye Detective Rodriguez."
    pc "Пока, детектив Родригес."

# game/Scenes/Jez/jez3.rpy:144
translate russian jez3_d41d8cd9_2:

    # voice 'voices/jez_3_1.mp3'
    voice 'voices/jez_3_1.mp3'

# game/Scenes/Jez/jez3.rpy:145
translate russian jez3_e7adfac5:

    # det "You can call me Jez, okay? That's my first name."
    det "Можешь звать меня Джез, ладно? Это мое имя."

# game/Scenes/Jez/jez3.rpy:146
translate russian jez3_db79b546:

    # pc "Okay. Bye Jez."
    pc "Ладно. Пока, Джез."

# game/Scenes/Jez/jez3.rpy:151
