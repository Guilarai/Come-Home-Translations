translate russian jezenddate_d41d8cd9:

    # voice 'voices/jez_myplace.mp3'
    voice 'voices/jez_myplace.mp3'

# game/Scenes/Jez/JezDates/jezenddate.rpy:8
translate russian jezenddate_687d0176:

    # det "So, do you want to come back to my place for a while?"
    det "Ну, хочешь зайти ко мне на некоторое время?"

# game/Scenes/Jez/JezDates/jezenddate.rpy:9
translate russian jezenddate_30d6b817:

    # det "Mamá's got Javi for a bit. We could spend some time together."
    det "Мама на время забрала Хави. Мы могли бы провести немного времени вместе."

# game/Scenes/Jez/JezDates/jezenddate.rpy:12
translate russian jezenddate_3ba845d3:

    # det "Good, let's go."
    det "Хорошо, пойдем."

# game/Scenes/Jez/JezDates/jezenddate.rpy:15
translate russian jezenddate_588b9a6e:

    # "We get in our cars and I follow her back to her house, where we quickly make our way inside to her bedroom."
    "Мы садимся в машины, и я следую за ней до ее дома, где мы быстро пробираемся внутрь, в ее спальню."

# game/Scenes/Jez/JezDates/jezenddate.rpy:19
translate russian jezenddate_77b42da9:

    # det "Oh, alright then. Well I had a nice date anyway. I'll see you later, [pcname]."
    det "О, ладно. Ну, в любом случае, свидание было приятным. Увидимся позже, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:21
translate russian jezenddate_b4d69820:

    # "I lean in and we kiss, my arms wrapped around her."
    "Я наклоняюсь, и мы целуемся, я обнимаю ее."

# game/Scenes/Jez/JezDates/jezenddate.rpy:22
translate russian jezenddate_3091dff1:

    # pc "Bye, Jez. See you again soon."
    pc "Пока, Джез. Скоро увидимся."

# game/Scenes/Jez/JezDates/jezenddate.rpy:25
translate russian jezenddate_f48c2630:

    # "She leaves, and I go back out to my car and drive away."
    "Она уходит, а я возвращаюсь к своей машине и уезжаю."

# game/Scenes/Jez/JezDates/jezenddate.rpy:29
translate russian jezenddate_716db417:

    # det "I had a really good time. I'm looking forward to doing this again soon."
    det "Я отлично провел время. С нетерпением жду, когда мы скоро повторим это."

# game/Scenes/Jez/JezDates/jezenddate.rpy:30
translate russian jezenddate_03eaad50:

    # pc "Me too."
    pc "Я тоже."

# game/Scenes/Jez/JezDates/jezenddate.rpy:33
translate russian jezenddate_398aacb4:

    # det "I'd invite you over to my place, but I'm not quite ready for my son to meet you yet."
    det "Я бы пригласила тебя к себе, но я еще не готова к тому, чтобы мой сын с тобой познакомился."

# game/Scenes/Jez/JezDates/jezenddate.rpy:34
translate russian jezenddate_70367ea3:

    # det "I don't want him to get confused by male figures being in his life for only a short time."
    det "Я не хочу, чтобы он запутался из-за того, что мужчины появляются в его жизни на короткое время."

# game/Scenes/Jez/JezDates/jezenddate.rpy:35
translate russian jezenddate_6cf8b822:

    # det "I want to make sure that this thing between me and you is real before we do that. I hope you understand."
    det "Я хочу убедиться, что то, что между нами, реально, прежде чем мы это сделаем. Надеюсь, ты понимаешь."

# game/Scenes/Jez/JezDates/jezenddate.rpy:36
translate russian jezenddate_cca20d9e:

    # pc "I do understand."
    pc "Я понимаю."

# game/Scenes/Jez/JezDates/jezenddate.rpy:38
translate russian jezenddate_3239d4cf:

    # det "Thanks."
    det "Спасибо."

# game/Scenes/Jez/JezDates/jezenddate.rpy:41
translate russian jezenddate_b4d69820_1:

    # "I lean in and we kiss, my arms wrapped around her."
    "Я наклоняюсь, и мы целуемся, я обнимаю её."

# game/Scenes/Jez/JezDates/jezenddate.rpy:43
translate russian jezenddate_ef81804e:

    # det "Wow, that was nice. Making it really hard for me to say goodbye."
    det "Вау, это было приятно. Мне очень трудно прощаться."

# game/Scenes/Jez/JezDates/jezenddate.rpy:44
translate russian jezenddate_c18fe3a7:

    # det "But I have to. Bye, [pcname]."
    det "Но я должен. Пока, [pcname]."

# game/Scenes/Jez/JezDates/jezenddate.rpy:45
translate russian jezenddate_3091dff1_1:

    # pc "Bye, Jez. See you again soon."
    pc "Пока, Джез. Увидимся скоро."

# game/Scenes/Jez/JezDates/jezenddate.rpy:48
translate russian jezenddate_f48c2630_1:

    # "She leaves, and I go back out to my car and drive away."
    "Она уходит, а я возвращаюсь к машине и уезжаю."

