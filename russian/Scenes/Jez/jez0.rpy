    old "in the morning on day 2."
    new "утром второго дня."

    # game/Scenes/Jez/jez0.rpy:53
    old "I don't mind"
    new "Я не против"

    # game/Scenes/Jez/jez0.rpy:56
    old "I'd rather not"
    new "Я бы предпочел нет"

    # game/Scenes/Jez/jez0.rpy:63
    old "Who else have you interviewed?"
    new "Кого еще ты допрашивал?"

    # game/Scenes/Jez/jez0.rpy:79
    old "Have you looked at his work any?"
    new "Ты смотрел его работы?"

    # game/Scenes/Jez/jez0.rpy:99
