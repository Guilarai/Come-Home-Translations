    new "Ты думаешь, его убили?"

    # game/Scenes/Jez/jez0.rpy:124
    old "So, you have no real leads?"
    new "Значит, у тебя нет реальных зацепок?"

    # game/Scenes/Jez/jez0.rpy:140
    old "Nothing else right now."
    new "Пока ничего больше."

