translate russian jez13_d62b2984:

    # det "Bad people doing bad things, you know?"
    det "Плохие люди, делающие плохие вещи, понимаешь?"

# game/Scenes/Jez/jez13.rpy:98
translate russian jez13_d41d8cd9_3:

    # voice 'voices/jez_13_4.mp3'
    voice 'voices/jez_13_4.mp3'

