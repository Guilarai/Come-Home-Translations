    # det "I couldn't breathe, I couldn't stand. I just wanted to scream and cry."
    det "Я не могла дышать, не могла стоять. Мне просто хотелось кричать и плакать."

# game/Scenes/Jez/jez13.rpy:129
translate russian jez13_d41d8cd9_12:

    # voice 'voices/jez_13_13.mp3'
    voice 'voices/jez_13_13.mp3'

