    # det "Wake up, papi."
    det "Проснись, папи."

# game/Scenes/Jez/jez13.rpy:155
translate russian jez13_fe0bdf4c:

    # pc "Good morning."
    pc "Доброе утро."

# game/Scenes/Jez/jez13.rpy:156
translate russian jez13_99f2649e:

    # det "I put your clothes on the bed there. They should be all dry."
    det "Я положила твою одежду на кровать. Она должна быть уже сухая."

# game/Scenes/Jez/jez13.rpy:157
translate russian jez13_d8cdc3e9:

    # pc "Oh thanks."
    pc "О, спасибо."

# game/Scenes/Jez/jez13.rpy:160
translate russian jez13_c6cc6092:

    # det "My mamá is here, in the kitchen with Javi. Are you okay with meeting them?"
    det "Моя мама здесь, на кухне с Хави. Ты не против с ними познакомиться?"

# game/Scenes/Jez/jez13.rpy:161
translate russian jez13_0b87cffe:

    # pc "Are {i}you{/i} okay with it?"
    pc "А {i}ты{/i} не против?"

# game/Scenes/Jez/jez13.rpy:162
translate russian jez13_e0caa061:

    # det "Yeah, I think I am. I already told Mamá you were here."
    det "Да, думаю, не против. Я уже сказала маме, что ты здесь."

# game/Scenes/Jez/jez13.rpy:163
translate russian jez13_5069ef9a:

    # pc "Then yeah, let's do this."
    pc "Тогда да, давай так и сделаем."

# game/Scenes/Jez/jez13.rpy:164
translate russian jez13_4b90fc82:

    # det "Good. Mamá is making revoltillo. I'm sure you'll love it."
    det "Хорошо. Мама готовит револьтильо. Уверена, тебе понравится."

# game/Scenes/Jez/jez13.rpy:165
translate russian jez13_ff89b162:

    # pc "I don't know what that means, but it sounds delicious when you say it."
    pc "Не знаю, что это значит, но когда ты это говоришь, звучит вкусно."

# game/Scenes/Jez/jez13.rpy:168
translate russian jez13_2f2eb37e:

    # det "Mamá is probably going to drill you some. It's just what she does, sorry."
    det "Мама, наверное, тебя немного просверлит. Она всегда так делает, извини."

# game/Scenes/Jez/jez13.rpy:169
translate russian jez13_8994460a:

    # pc "I think I'll be okay."
    pc "Думаю, я справлюсь."

# game/Scenes/Jez/jez13.rpy:170
