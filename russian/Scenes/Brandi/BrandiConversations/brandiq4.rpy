translate russian brandiq4_a409a33e:

    # fd "My lease is up in August. I don't think I'll renew."
    fd "Мой договор аренды заканчивается в августе. Не думаю, что буду его продлевать."

# game/Scenes/Brandi/BrandiConversations/brandiq4.rpy:33
translate russian brandiq4_260077f4:

