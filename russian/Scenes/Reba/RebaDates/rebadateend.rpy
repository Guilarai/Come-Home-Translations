# game/Scenes/Reba/RebaDates/rebadateend.rpy:5
translate russian rebadateend_4407114d:

    # rb "That was fun, I had a really good time."
    rb "Было весело, я отлично провела время."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:10
translate russian rebadateend_86e2c035:

    # "I step up and pull her into a kiss, which she returns enthusiastically."
    "Я подхожу к ней и притягиваю к себе, чтобы поцеловать, и она с энтузиазмом отвечает на поцелуй."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:11
translate russian rebadateend_39c7b3ca:

    # rb "Wow, I wish I could do more of that, but I gotta get home and make some supper for Mama."
    rb "Вау, хотелось бы побыть так подольше, но мне нужно домой, приготовить ужин для мамы."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:13
translate russian rebadateend_895c572b:

    # rb "I hope we can do this again soon. And maybe more. I want so much more."
    rb "Надеюсь, мы скоро повторим. И, может, не только это. Я хочу гораздо большего."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:16
translate russian rebadateend_744ec225:

    # "I step up and pull her into a hug. She wraps her arms around me and squeezes me close."
    "Я подхожу к ней и прижимаю ее к себе. Она обнимает меня и крепко прижимается."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:17
translate russian rebadateend_91433507:

    # rb "Thanks for taking me out. I hope we can do this again soon."
    rb "Спасибо, что пригласил меня. Надеюсь, мы скоро повторим."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:18
translate russian rebadateend_4f8314b3:

    # rb "But I better get home. Gotta make supper for Mama."
    rb "Но мне лучше домой. Надо приготовить ужин маме."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:21
translate russian rebadateend_24de817d:

    # pc "Do you want to come back to my house for a while?"
    pc "Хочешь зайти ко мне на минутку?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:23
translate russian rebadateend_c8f7ca44:

    # rb "You want a little hanky-panky?"
    rb "Хочешь немного пошалить?"

# game/Scenes/Reba/RebaDates/rebadateend.rpy:24
translate russian rebadateend_f4be2d3d:

    # rb "Good, because I {i}really{/i} do too. Let's go."
    rb "Хорошо, потому что я {i}действительно{/i} тоже хочу. Пойдем."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:28
translate russian rebadateend_ed307571:

    # "We drive back to my house and go up to my bedroom, where things quickly lead to us being naked on the bed."
    "Мы едем ко мне домой и поднимаемся в мою спальню, где все быстро заканчивается тем, что мы оказываемся голыми на кровати."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:32
translate russian rebadateend_52303b0f:

    # pc "Yeah, it was good. I'll see you later Reba."
    pc "Да, было хорошо. Увидимся позже, Реба."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:33
translate russian rebadateend_7657b93c:

    # rb "Uh, okay."
    rb "Э-э, ладно."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:34
translate russian rebadateend_46d8c374:

    # rb "I'll see you later, [pcname]."
    rb "Увидимся позже, [pcname]."

# game/Scenes/Reba/RebaDates/rebadateend.rpy:35
translate russian rebadateend_2fd019a4:

    # "She waves goodbye and gets into her truck and drives away."
    "Она машет на прощание, садится в свой пикап и уезжает."

translate russian strings:

    # game/Scenes/Reba/RebaDates/rebadateend.rpy:20
    old "Invite her back to your house"
    new "Пригласи ее к себе домой"

