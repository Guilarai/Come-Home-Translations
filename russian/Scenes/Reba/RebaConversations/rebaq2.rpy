# TODO: Translation updated at 2026-06-02 09:57

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:11
translate russian rebaq2_b891c78b:

    # rb "What is college like?"
    rb "Как там в колледже?"

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:12
translate russian rebaq2_6244f8db:

    # pc "It's all right, I guess."
    pc "Нормально, наверное."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:13
translate russian rebaq2_719dc368:

    # pc "Mostly just sitting in a class room listening to the professor talk."
    pc "В основном просто сидишь в аудитории и слушаешь, как говорит профессор."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:14
translate russian rebaq2_e0c189b3:

    # pc "Then endless homework."
    pc "А потом бесконечные домашние задания."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:15
translate russian rebaq2_43323896:

    # rb "So... do you think I should try to go?"
    rb "Так... как думаешь, мне стоит попробовать поступить?"

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:16
translate russian rebaq2_8fd2a0ea:

    # pc "I think you should do whatever you want to do and not worry about what other people want you to do."
    pc "Я думаю, ты должен делать то, что хочешь, и не беспокоиться о том, чего от тебя хотят другие."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:18
translate russian rebaq2_85d502e1:

    # rb "Yeah. That's hard for me. I don't like making people upset. Especially Mama."
    rb "Да. Мне это сложно. Я не люблю расстраивать людей. Особенно маму."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:19
translate russian rebaq2_30db647b:

    # rb "I mostly just want to meet new people."
    rb "В основном я просто хочу познакомиться с новыми людьми."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:20
translate russian rebaq2_843cc0b8:

    # rb "Sometimes I feel like there's only ten people in the world and they're all pretty much the same."
    rb "Иногда мне кажется, что в мире всего десять человек, и все они практически одинаковые."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:22
translate russian rebaq2_442529e9:

    # rb "Except you. You're my only friend who is different."
    rb "Кроме тебя. Ты мой единственный друг, который отличается от других."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:23
translate russian rebaq2_e7806fc6:

    # pc "How so?"
    pc "В каком смысле?"

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:25
translate russian rebaq2_54035ca5:

    # rb "Well they're all... you know... country."
    rb "Ну, они все... ну, ты знаешь... деревенские."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:26
translate russian rebaq2_6b173532:

    # pc "You seem different too though. How did that happen?"
    pc "Но ты тоже кажешься другим. Как так вышло?"

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:27
translate russian rebaq2_bd929529:

    # rb "I don't know. The internet, I guess?"
    rb "Не знаю. Интернет, наверное?"

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:28
translate russian rebaq2_f48276a2:

    # rb "Mama said it corrupted me."
    rb "Мама сказала, что он меня испортил."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:30
translate russian rebaq2_c880b9b2:

    # rb "But I really want to learn more about... well everything."
    rb "Но я действительно хочу узнать больше о... ну, обо всем."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:31
translate russian rebaq2_8f81a3ff:

    # pc "Which is why you want to go to college."
    pc "Вот почему ты хочешь поступить в колледж."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:33
translate russian rebaq2_8575c669:

    # rb "Right."
    rb "Верно."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:34
translate russian rebaq2_51fe313a:

    # pc "You should. Seriously. Sign up for classes next semester."
    pc "Тебе стоит. Серьезно. Запишись на курсы в следующем семестре."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:35
translate russian rebaq2_dfcb3e6e:

    # pc "Your mom will be upset at first probably, but she'll get over it and you will be much happier."
    pc "Твоя мама, наверное, сначала расстроится, но она переживет это, а ты станешь гораздо счастливее."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:36
translate russian rebaq2_9653df68:

    # pc "And that's what really matters."
    pc "И это то, что действительно важно."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:37
translate russian rebaq2_fe66a45e:

    # pc "Don't hold yourself back to please others."
    pc "Не сдерживай себя, чтобы угодить другим."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:39
translate russian rebaq2_2fd9e78d:

    # rb "You're right. If I'm capable of doing something, and I don't allow myself to do it, that's kind of a waste huh?"
    rb "Ты прав. Если я способна на что-то, но не позволяю себе это сделать, это же трата времени, да?"

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:40
translate russian rebaq2_5de1aa8c:

    # rb "And Daddy said, \"Don't waste the life God gave ya.\""
    rb "И папа говорил: «Не трать впустую жизнь, которую дал тебе Бог»."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:42
translate russian rebaq2_9f107aa5:

    # rb "I'll think about this. Really. Thanks, [pcname]."
    rb "Я об этом подумаю. Правда. Спасибо, [pcname]."

# game/Scenes/Reba/RebaConversations/rebaq2.rpy:43
translate russian rebaq2_4be405a5:

    # pc "No problem."
    pc "Не за что."

