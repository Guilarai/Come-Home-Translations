    mk "Ты пытаешься трахнуть мою сестру!"

# game/Scenes/Reba/reba8.rpy:227
translate russian reba8mudding_a40a4d44:

    # rb "We didn't do nothing, Mickey! Stop!"
    rb "Мы ничего не делали, Микки! Хватит!"

# game/Scenes/Reba/reba8.rpy:228
translate russian reba8mudding_54567e75_1:

    # rb "Just go, [pcname]. I'll talk to you later."
    rb "Просто уходи, [pcname]. Поговорим позже."

# game/Scenes/Reba/reba8.rpy:229
translate russian reba8mudding_61f77a4c_1:

