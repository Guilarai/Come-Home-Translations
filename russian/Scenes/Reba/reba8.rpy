translate russian reba8mudding_b0ef0d77:

    # rb "No! Mickey don't, he didn't do anything!"
    rb "Нет! Микки, не делай этого, он ничего не сделал!"

# game/Scenes/Reba/reba8.rpy:242
translate russian reba8mudding_c7a337dd:

    # mk "He's out here trying to fuck you."
    mk "Он тут пытается тебя трахнуть."

# game/Scenes/Reba/reba8.rpy:243
translate russian reba8mudding_cf33bf08:

    # pc "No, I--"
    pc "Нет, я..."

# game/Scenes/Reba/reba8.rpy:244
translate russian reba8mudding_f8c3269f:

    # rb "We didn't do nothing, Mickey!"
    rb "Мы ничего не делали, Микки!"

# game/Scenes/Reba/reba8.rpy:245
translate russian reba8mudding_54567e75_2:

    # rb "Just go, [pcname]. I'll talk to you later."
    rb "Просто уходи, [pcname]. Поговорим позже."

# game/Scenes/Reba/reba8.rpy:246
translate russian reba8mudding_61f77a4c_2:

    # pc "Sure."
    pc "Конечно."

# game/Scenes/Reba/reba8.rpy:250
translate russian reba8mudding_e5760220:

    # "I walk back towards my car, annoyed at the whole situation."
    "Я иду обратно к своей машине, раздраженный всей этой ситуацией."

# game/Scenes/Reba/reba8.rpy:251
translate russian reba8mudding_47832cf5:

    # mk "Yeah you better leave city boy. You come out here and mess with my sister again and I'll fucking kill you."
    mk "Да, тебе лучше убираться, городской мальчик. Если ты еще раз приедешь сюда и будешь связываться с моей сестрой, я тебя, блядь, убью."

# game/Scenes/Reba/reba8.rpy:252
translate russian reba8mudding_de895dda:

