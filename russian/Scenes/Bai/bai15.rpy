    # bai "Oh, good! I know this is kind of a whole thing. Coming out to my parents. Meeting my parents."
    bai "О, хорошо! Я знаю, что это довольно серьезно. Признаться родителям. Познакомиться с родителями."

# game/Scenes/Bai/bai15.rpy:29
translate russian bai15_2ecdb735:

    # bai "I know it's a little awkward."
    bai "Я знаю, что это немного неловко."

# game/Scenes/Bai/bai15.rpy:30
translate russian bai15_62b2a1d1:

    # pc "It's no problem really. I'd love to meet them. And I want to be there with you."
    pc "На самом деле, это не проблема. Я с удовольствием с ними познакомлюсь. И я хочу быть там с тобой."

# game/Scenes/Bai/bai15.rpy:31
translate russian bai15_9c6957e3:

    # pc "You have all of my support."
    pc "Ты можешь рассчитывать на мою полную поддержку."

# game/Scenes/Bai/bai15.rpy:33
translate russian bai15_8dbd62cc:

    # bai "Thanks, [pcname]. Really. It means a lot."
    bai "Спасибо, [pcname]. Правда. Это очень много значит для меня."

# game/Scenes/Bai/bai15.rpy:34
translate russian bai15_e9fe102b:

    # bai "Hopefully, with you there, I'll have the courage to go through with this."
    bai "Надеюсь, с тобой рядом у меня хватит смелости пройти через это."

# game/Scenes/Bai/bai15.rpy:35
translate russian bai15_1f6808e2:

    # pc "I know it's tough. We can do it though."
    pc "Я знаю, что это тяжело. Но мы справимся."

# game/Scenes/Bai/bai15.rpy:37
translate russian bai15_94319605:

    # bai "We're going to go to Luigi's at 6pm. Do you know where that is?"
    bai "Мы собираемся пойти в «Луиджи» в 18:00. Ты знаешь, где это?"

# game/Scenes/Bai/bai15.rpy:38
translate russian bai15_8e508689:

    # pc "Sure. I can meet you there."
    pc "Конечно. Я могу встретиться с тобой там."

# game/Scenes/Bai/bai15.rpy:39
translate russian bai15_41b7a831:

    # bai "Yeah, that'd be perfect."
    bai "Да, это было бы идеально."

# game/Scenes/Bai/bai15.rpy:41
translate russian bai15_f4fe4a57:

    # bai "Thanks again, [pcname]."
    bai "Еще раз спасибо, [pcname]."

# game/Scenes/Bai/bai15.rpy:42
translate russian bai15_df401732:

    # pc "No problem. I'll see you then."
    pc "Не за что. Увидимся тогда."

# game/Scenes/Bai/bai15.rpy:43
translate russian bai15_5ea5aa90:

    # bai "See ya!"
    bai "Увидимся!"

# game/Scenes/Bai/bai15.rpy:46
