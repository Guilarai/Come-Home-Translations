translate russian bai15_bc35e5a2:

    # pc "I'm sorry, am I late?"
    pc "Извини, я опоздал?"

# game/Scenes/Bai/bai15.rpy:54
translate russian bai15_d881598d:

    # bai "No, we just got here a little early."
    bai "Нет, мы просто пришли немного раньше."

# game/Scenes/Bai/bai15.rpy:57
translate russian bai15_4bd90501:

    # bai "Mom, Dad, this is my friend, [pcname]."
    bai "Мама, папа, это мой друг, [pcname]."

# game/Scenes/Bai/bai15.rpy:58
translate russian bai15_0d66f124:

    # bai "[pcname], these are my parents, Mr. and Mrs. Wáng."
    bai "[pcname], это мои родители, мистер и миссис Ван."

# game/Scenes/Bai/bai15.rpy:59
translate russian bai15_6561806e:

    # pc "It's really nice to meet you."
    pc "Очень приятно познакомиться."

# game/Scenes/Bai/bai15.rpy:62
translate russian bai15_72bd522f:

    # "I'm not sure if I should bow or what, but Mr. Wáng saves me the awkwardness by putting out his hand."
    "Я не уверен, стоит ли мне поклониться или как, но мистер Ван избавляет меня от неловкости, протягивая руку."

# game/Scenes/Bai/bai15.rpy:63
translate russian bai15_1010f7f8:

    # "Mr. Wáng" "It's nice to meet you, [pcname]."
    "Mr. Wáng" "Приятно познакомиться, [pcname]."

# game/Scenes/Bai/bai15.rpy:64
translate russian bai15_9f61af91:

    # pc "Very nice to meet you too. And you, Mrs. Wáng."
    pc "Мне тоже очень приятно познакомиться. И с вами, миссис Ван."

# game/Scenes/Bai/bai15.rpy:65
translate russian bai15_5017a9ed:

    # "Mr. Wáng" "Sit, sit, Bai was just telling us about his school work."
    "Mr. Wáng" "Садитесь, садитесь, Бай как раз рассказывал нам о своих школьных занятиях."

# game/Scenes/Bai/bai15.rpy:68
translate russian bai15_85af3f14:

    # "Mr. Wáng" "He's going to be a doctor, right son?"
    "Mr. Wáng" "Он станет врачом, верно, сынок?"

# game/Scenes/Bai/bai15.rpy:69
translate russian bai15_fb3ec878:

    # bai "Well, a physical therapist."
    bai "Ну, физиотерапевтом."

# game/Scenes/Bai/bai15.rpy:70
translate russian bai15_fc08db4e:

    # "Mrs. Wáng" "Same thing."
    "Mrs. Wáng" "Это одно и то же."

# game/Scenes/Bai/bai15.rpy:71
translate russian bai15_90b16dec:

    # "Mr. Wáng" "Yes, it is basically a doctor."
    "Mr. Wáng" "Да, по сути, это врач."

# game/Scenes/Bai/bai15.rpy:72
translate russian bai15_354f7ad1:

    # "Mr. Wáng" "You help injured people. That is what doctors do, right [pcname]?"
    "Mr. Wáng" "Ты помогаешь раненым людям. Это же то, чем занимаются врачи, верно, [pcname]?"

# game/Scenes/Bai/bai15.rpy:73
translate russian bai15_97f396d1:

    # pc "Sounds right to me."
    pc "Мне кажется, это верно."

# game/Scenes/Bai/bai15.rpy:74
translate russian bai15_2cf478a4:

    # "Mrs. Wáng" "Ming Bai has always been smart. He can do anything he wants."
    "Mrs. Wáng" "Мин Бай всегда был умным. Он может делать все, что захочет."

# game/Scenes/Bai/bai15.rpy:77
translate russian bai15_3a71c4c0:

    # pc "Ming Bai?"
    pc "Мин Бай?"

# game/Scenes/Bai/bai15.rpy:78
translate russian bai15_831647d4:

    # bai "That's my full name. Wáng Ming Bai."
    bai "Это мое полное имя. Ван Мин Бай."

# game/Scenes/Bai/bai15.rpy:81
translate russian bai15_f174e123:

    # "Mrs. Wáng" "Bai means white and pure. He's my pure boy."
    "Mrs. Wáng" "Бай означает «белый» и «чистый». Он мой чистый мальчик."

# game/Scenes/Bai/bai15.rpy:82
translate russian bai15_e488fece:

    # "Mr. Wáng" "But it is girl's name."
    "Mr. Wáng" "Но это девичье имя."

# game/Scenes/Bai/bai15.rpy:83
translate russian bai15_3020f103:

    # "Mrs. Wáng" "It can go both ways."
    "Mrs. Wáng" "Оно подходит и для мальчиков, и для девочек."

# game/Scenes/Bai/bai15.rpy:84
translate russian bai15_bec55e4d:

    # "Mr. Wáng" "It is mostly a girl's name. So I named him Ming. A strong boy's name. It means bright."
    "Mr. Wáng" "В основном это девичье имя. Поэтому я назвала его Мин. Сильное мужское имя. Оно означает «яркий»."

# game/Scenes/Bai/bai15.rpy:85
translate russian bai15_cc0f7e52:

    # "Mrs. Wáng" "Yes, so he is bright and pure. The light in my life."
    "Mrs. Wáng" "Да, так что он яркий и чистый. Свет в моей жизни."

# game/Scenes/Bai/bai15.rpy:88
translate russian bai15_5eab4fbe:

    # bai "Aw Mom, stop."
    bai "Ой, мам, хватит."

# game/Scenes/Bai/bai15.rpy:89
translate russian bai15_73788646:

    # "We keep talking for a while and I wait for Bai to bring up the topic. The elephant in the room."
    "Мы еще немного болтаем, и я жду, пока Бай затронет эту тему. Слона в комнате."

# game/Scenes/Bai/bai15.rpy:90
translate russian bai15_d56ba29f:

    # "Surely they realize that he didn't just invite me here as a friend."
    "Наверняка они понимают, что он пригласил меня сюда не просто как друга."

# game/Scenes/Bai/bai15.rpy:93
translate russian bai15_67ec92e0:

    # "Eventually... he coughs and chokes out the words."
    "В конце концов... он кашляет и с трудом выдавливает из себя слова."

# game/Scenes/Bai/bai15.rpy:94
translate russian bai15_f8709a15:

    # bai "Mom... Dad... There's something I need to talk to you about."
    bai "Мама... Папа... Мне нужно с вами поговорить."

# game/Scenes/Bai/bai15.rpy:97
translate russian bai15_c8442c8e:

    # "I give his hand a reassuring squeeze under the table."
    "Я успокаивающе сжимаю его руку под столом."

# game/Scenes/Bai/bai15.rpy:98
translate russian bai15_be278660:

    # "Mr. Wáng" "What is it, son?"
    "Mr. Wáng" "В чем дело, сынок?"

# game/Scenes/Bai/bai15.rpy:101
translate russian bai15_954bc39c:

    # bai "I'm... uh... I'm bi."
    bai "Я... э-э... я би."

# game/Scenes/Bai/bai15.rpy:102
translate russian bai15_fe0ef88f:

    # "Mr. Wáng" "I know you're Bai. Who you think named you that?"
    "Mr. Wáng" "Я знаю, что ты Бай. А кто, по-твоему, дал тебе такое имя?"

# game/Scenes/Bai/bai15.rpy:103
translate russian bai15_90b22383:

    # bai "No, Dad. I'm bisexual."
    bai "Нет, папа. Я бисексуал."

# game/Scenes/Bai/bai15.rpy:104
translate russian bai15_94ad15b4:

    # bai "I like girls... but I also like boys."
    bai "Мне нравятся девушки... но мне нравятся и парни."

# game/Scenes/Bai/bai15.rpy:105
translate russian bai15_358a4695:

    # bai "[pcname] is not just my friend. He's my boyfriend."
    bai "[pcname] — не просто мой друг. Он мой парень."

# game/Scenes/Bai/bai15.rpy:108
translate russian bai15_33884c3f:

    # "A few moments pass and nobody talks."
    "Проходит несколько мгновений, и никто не говорит."

# game/Scenes/Bai/bai15.rpy:109
translate russian bai15_fbd8d2a0:

    # "Even the other people in the restaurant seem to get quieter."
    "Даже остальные посетители ресторана, кажется, затихли."

# game/Scenes/Bai/bai15.rpy:112
translate russian bai15_d2c120b1:

    # "Mrs. Wáng" "We know that. You think we're stupid?"
    "Mrs. Wáng" "Мы это знаем. Ты думаешь, мы дураки?"

# game/Scenes/Bai/bai15.rpy:113
translate russian bai15_b2d3df9a:

    # "Mrs. Wáng" "We love you no matter what."
    "Mrs. Wáng" "Мы любим тебя несмотря ни на что."

# game/Scenes/Bai/bai15.rpy:114
translate russian bai15_83b82ca9:

    # "Mrs. Wáng" "If you like boys, and you find a boy that likes you back, that's great."
    "Mrs. Wáng" "Если тебе нравятся мальчики, и ты нашел мальчика, которому ты тоже нравишься, это замечательно."

# game/Scenes/Bai/bai15.rpy:115
translate russian bai15_272024f0:

    # bai "Really, Mom?"
    bai "Правда, мам?"

# game/Scenes/Bai/bai15.rpy:116
translate russian bai15_158f0fe3:

    # "Mrs. Wáng" "Yes, really."
    "Mrs. Wáng" "Да, правда."

# game/Scenes/Bai/bai15.rpy:119
translate russian bai15_fd86eb81:

    # "Mr. Wáng" "I hope you weren't nervous about telling us this. I hope you know that nothing would make us stop loving you."
    "Mr. Wáng" "Надеюсь, ты не нервничал, рассказывая нам об этом. Надеюсь, ты знаешь, что ничто не заставит нас перестать любить тебя."

# game/Scenes/Bai/bai15.rpy:120
translate russian bai15_ca9fc704:

    # "Mr. Wáng" "You are an absolute joy to have as a son. I am so proud of you."
    "Mr. Wáng" "Ты — настоящая радость для нас как сын. Я так тобой горжусь."

# game/Scenes/Bai/bai15.rpy:123
translate russian bai15_51678d55:

    # bai "Thank you so much."
    bai "Спасибо вам огромное."

# game/Scenes/Bai/bai15.rpy:124
translate russian bai15_0d02d68c:

    # bai "You are the best parents ever, holy crap."
    bai "Вы лучшие родители на свете, черт возьми."

# game/Scenes/Bai/bai15.rpy:126
translate russian bai15_2500edfb:

    # "Mr. Wáng" "You remember that when we get old and you have to take care of us."
    "Mr. Wáng" "Запомните это, когда мы состаримся и вам придется о нас заботиться."

# game/Scenes/Bai/bai15.rpy:128
translate russian bai15_f44e14a7:

    # "Mrs. Wáng" "Yes, stop crying, Ming Bai. I want to see your smile."
    "Mrs. Wáng" "Да, перестань плакать, Мин Бай. Я хочу увидеть твою улыбку."

# game/Scenes/Bai/bai15.rpy:131
translate russian bai15_073b52bf:

    # bai "I'm so happy."
    bai "Я так счастлив."

# game/Scenes/Bai/bai15.rpy:132
translate russian bai15_50bd8c22:

    # bai "This went way better than I thought it would."
    bai "Все прошло гораздо лучше, чем я думал."

# game/Scenes/Bai/bai15.rpy:133
translate russian bai15_5bfadc88:

    # "Mrs. Wáng" "You think that we are monsters? That we would be upset that you love a man?"
    "Mrs. Wáng" "Ты думаешь, что мы монстры? Что мы расстроимся из-за того, что ты любишь мужчину?"

# game/Scenes/Bai/bai15.rpy:134
translate russian bai15_dffb885d:

    # bai "I didn't know."
    bai "Я не знал."

# game/Scenes/Bai/bai15.rpy:135
translate russian bai15_0519aada:

    # "Mr. Wáng" "If you told us you are switching to a liberal arts major, then we would have issue."
    "Mr. Wáng" "Если бы ты сказал нам, что переходишь на гуманитарную специальность, тогда у нас были бы проблемы."

# game/Scenes/Bai/bai15.rpy:138
translate russian bai15_8e5fa26f:

    # "After nearly two hours of eating and chatting, where they pepper me with questions about myself, they announce that they have to leave."
    "После почти двух часов еды и разговоров, во время которых они засыпали меня вопросами обо мне, они объявили, что им пора уходить."

# game/Scenes/Bai/bai15.rpy:139
translate russian bai15_cb7cfe75:

    # "Mr. Wáng" "It was nice meeting you, [pcname]."
    "Mr. Wáng" "Было приятно познакомиться с тобой, [pcname]."

# game/Scenes/Bai/bai15.rpy:140
translate russian bai15_48048864:

    # pc "Nice to meet you too, Mr. Wáng."
    pc "Мне тоже было приятно познакомиться, мистер Ван."

# game/Scenes/Bai/bai15.rpy:143
translate russian bai15_1005ee8b:

    # "Mrs. Wáng" "You treat my son well, okay? He is everything to us."
    "Mrs. Wáng" "Относись к моему сыну хорошо, ладно? Он для нас все."

# game/Scenes/Bai/bai15.rpy:144
translate russian bai15_db1ed0fe:

    # pc "I will, Mrs. Wáng."
    pc "Обязательно, миссис Ван."

# game/Scenes/Bai/bai15.rpy:145
translate russian bai15_bfe014f5:

    # "Mrs. Wáng" "And maybe we get wedding soon, huh?"
    "Mrs. Wáng" "И, может, скоро у нас будет свадьба, а?"

# game/Scenes/Bai/bai15.rpy:146
translate russian bai15_e2ee86ba:

    # pc "Uhh..."
    pc "Э-э..."

# game/Scenes/Bai/bai15.rpy:147
translate russian bai15_f6b18e48:

    # "Mrs. Wáng" "I'm joking. No rush."
    "Mrs. Wáng" "Я шучу. Не торопитесь."

# game/Scenes/Bai/bai15.rpy:150
translate russian bai15_6b860891:

    # "Mrs. Wáng" "Goodbye Ming Bai. {font=fonts/yrdzst semibold.ttf}我会一直陪着你 {/font}"
    "Mrs. Wáng" "До свидания, Мин Бай. {font=fonts/yrdzst semibold.ttf}Я всегда буду с тобой {/font}"

# game/Scenes/Bai/bai15.rpy:152
translate russian bai15_e5290e82:

    # bai "{font=fonts/yrdzst semibold.ttf}妈, 我爱你{/font}"
    bai "{font=fonts/yrdzst semibold.ttf}Мама, я люблю тебя{/font}"

# game/Scenes/Bai/bai15.rpy:155
translate russian bai15_af1459aa:

    # "When his parents leave, Bai turns to me."
    "Когда его родители уходят, Бай поворачивается ко мне."

# game/Scenes/Bai/bai15.rpy:156
translate russian bai15_57a4ab8c:

    # bai "Thanks for being here with me for this."
    bai "Спасибо, что была со мной в этот момент."

# game/Scenes/Bai/bai15.rpy:157
translate russian bai15_08ab74ef:

    # bai "I don't know why I was so afraid to tell them."
    bai "Не знаю, почему я так боялся им сказать."

# game/Scenes/Bai/bai15.rpy:158
translate russian bai15_f15c7675:

    # pc "Yeah, your parents are great."
    pc "Да, твои родители классные."

# game/Scenes/Bai/bai15.rpy:159
translate russian bai15_5134b355:

    # bai "They're amazing."
    bai "Они потрясающие."

# game/Scenes/Bai/bai15.rpy:162
translate russian bai15_31f3ad75:

    # bai "You're amazing too."
