# game/Scenes/Bai/BaiConversations/bais1.rpy:13
translate russian bais1_9c7f2465:

    # bai "I moved here from Dallas."
    bai "Я переехал сюда из Далласа."

# game/Scenes/Bai/BaiConversations/bais1.rpy:14
translate russian bais1_ff8c2611:

    # pc "Did you like it there?"
    pc "Тебе там нравилось?"

# game/Scenes/Bai/BaiConversations/bais1.rpy:15
translate russian bais1_91293519:

    # bai "I love Dallas. I've lived there my whole life. Had a lot of friends there too."
    bai "Я люблю Даллас. Я прожил там всю свою жизнь. У меня там тоже было много друзей."

# game/Scenes/Bai/BaiConversations/bais1.rpy:16
translate russian bais1_857b3766:

    # pc "Why move then? Skyhill isn't exactly the most prestigious college or anything."
    pc "Почему же тогда переехал? Скайхилл не самый престижный колледж или что-то в этом роде."

# game/Scenes/Bai/BaiConversations/bais1.rpy:18
translate russian bais1_a54e3187:

    # bai "I just needed to get away, you know?"
    bai "Мне просто нужно было уехать, понимаешь?"

# game/Scenes/Bai/BaiConversations/bais1.rpy:19
translate russian bais1_e29967b5:

    # bai "My family is a little overbearing."
    bai "Моя семья немного властная."

# game/Scenes/Bai/BaiConversations/bais1.rpy:21
translate russian bais1_d868ea4f:

    # bai "I needed to go somewhere where nobody knew me."
    bai "Мне нужно было уехать туда, где меня никто не знает."

# game/Scenes/Bai/BaiConversations/bais1.rpy:22
translate russian bais1_2b219ea3:

    # bai "Somewhere I could start over."
    bai "Туда, где я смогу начать с нуля."

# game/Scenes/Bai/BaiConversations/bais1.rpy:24
translate russian bais1_03273598:

    # bai "You understand?"
    bai "Ты понимаешь?"

# game/Scenes/Bai/BaiConversations/bais1.rpy:25
translate russian bais1_b8e7a0ec:

    # pc "Yeah, I think so."
    pc "Да, думаю, да."

# game/Scenes/Bai/BaiConversations/bais1.rpy:27
translate russian bais1_5a42b0ca:

    # bai "It's been going okay here so far though."
    bai "Хотя пока здесь все идет неплохо."

# game/Scenes/Bai/BaiConversations/bais1.rpy:28
translate russian bais1_08af1ce0:

    # bai "A little lonely, but that'll get better."
    bai "Немного одиноко, но это пройдет."

# game/Scenes/Bai/BaiConversations/bais1.rpy:29
translate russian bais1_63f71381:

    # bai "I have one friend now at least."
    bai "По крайней мере, у меня теперь есть один друг."

# game/Scenes/Bai/BaiConversations/bais1.rpy:30
translate russian bais1_ab78ffa7:

    # pc "Yeah, man. I'm here for you."
    pc "Да, чувак. Я здесь ради тебя."

# game/Scenes/Bai/BaiConversations/bais1.rpy:31
translate russian bais1_badd9121:

    # bai "Thanks, [pcname]."
    bai "Спасибо, [pcname]."

