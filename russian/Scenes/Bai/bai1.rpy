translate russian bai1d_39f795d2:

    # "A little bit later, Izzy brings our plates out and we dig in."
    "Чуть позже Иззи приносит нам тарелки, и мы приступаем к еде."

# game/Scenes/Bai/bai1.rpy:231
translate russian bai1d_6b766726:

    # "The waitress comes over and takes our orders, then returns a few minutes later with the food."
    "Официантка подходит и принимает наш заказ, а через несколько минут возвращается с едой."

# game/Scenes/Bai/bai1.rpy:233
translate russian bai1d_bace05fb:

    # bai "Man you weren't kidding. This is like the best burger I've ever tasted."
    bai "Чувак, ты не шутил. Это лучший бургер, который я когда-либо пробовал."

# game/Scenes/Bai/bai1.rpy:234
translate russian bai1d_a6a2e950:

    # bai "I had a great time tonight."
    bai "Я отлично провел время сегодня вечером."

# game/Scenes/Bai/bai1.rpy:235
translate russian bai1d_03eaad50:

    # pc "Me too."
    pc "Я тоже."

# game/Scenes/Bai/bai1.rpy:238
translate russian bai1d_8c24f368:

    # bai "So would you be up for one of these little dates again?"
    bai "Так ты готов на еще одно такое свидание?"

# game/Scenes/Bai/bai1.rpy:242
translate russian bai1d_802bd748:

    # bai "I'm glad to hear it. Can't wait for our next one."
    bai "Рад это слышать. Жду не дождусь следующего раза."

# game/Scenes/Bai/bai1.rpy:245
translate russian bai1d_3c769f7a:

    # bai "I mean we don't have to call it that, I was just joking."
    bai "В смысле, не обязательно так это называть, я просто пошутил."

# game/Scenes/Bai/bai1.rpy:249
translate russian bai1d_96804e49:

    # bai "Okay."
    bai "Ладно."

# game/Scenes/Bai/bai1.rpy:250
translate russian bai1d_b5ad529f:

    # bai "Well I can't wait for our next one then."
    bai "Ну, тогда я с нетерпением жду следующего раза."

# game/Scenes/Bai/bai1.rpy:254
translate russian bai1d_8844c594:

    # bai "Okay, that's cool."
    bai "Ладно, это круто."

# game/Scenes/Bai/bai1.rpy:255
translate russian bai1d_681f0b18:

    # bai "Well I'm looking forward to the next time we can hang out then."
    bai "Ну, тогда я с нетерпением жду, когда мы снова сможем потусоваться."

# game/Scenes/Bai/bai1.rpy:257
translate russian bai1d_d0ca3261:

    # bai "Hope we can hang out like this again soon."
    bai "Надеюсь, мы скоро сможем снова так потусоваться."

# game/Scenes/Bai/bai1.rpy:258
translate russian bai1d_03eaad50_1:

    # pc "Me too."
    pc "Я тоже."

# game/Scenes/Bai/bai1.rpy:260
translate russian bai1d_30423311:

    # bai "Hey before we leave, let me give you my phone number."
    bai "Эй, прежде чем мы уйдем, дай я дам тебе свой номер телефона."

# game/Scenes/Bai/bai1.rpy:261
translate russian bai1d_0b8345e6:

    # bai "I don't have a lot of friends around here, so I'd love to just chat with you whenever you feel up to it."
    bai "У меня здесь не так много друзей, так что я с удовольствием поболтаю с тобой, когда тебе захочется."

# game/Scenes/Bai/bai1.rpy:262
translate russian bai1d_465c988e:

    # bai "And maybe we can go out again sometime soon."
    bai "И, может, мы сможем скоро снова куда-нибудь сходить."

# game/Scenes/Bai/bai1.rpy:263
translate russian bai1d_50eb93b7:

    # pc "Okay, sounds good."
    pc "Ладно, звучит неплохо."

# game/Scenes/Bai/bai1.rpy:270
translate russian bai1d_0e8a2008:

    # "We finish up our food, he leaves some money on the table, then we head outside."
    "Мы доедаем, он оставляет деньги на столе, а потом мы выходим на улицу."

# game/Scenes/Bai/bai1.rpy:271
translate russian bai1d_630eae85:

    # bai "Well that was the most fun I've had in a while."
    bai "Ну, это было самое веселое время, которое у меня было за последнее время."

# game/Scenes/Bai/bai1.rpy:272
translate russian bai1d_a96bfd7d:

    # bai "Thanks again for hanging out with me tonight."
    bai "Еще раз спасибо, что провел со мной вечер."

# game/Scenes/Bai/bai1.rpy:273
translate russian bai1d_fe5246ec:

    # pc "No problem. I had fun too."
    pc "Не за что. Мне тоже было весело."

# game/Scenes/Bai/bai1.rpy:274
translate russian bai1d_b6980062:

    # bai "Alright, well I better head home."
    bai "Ладно, мне лучше пойти домой."

# game/Scenes/Bai/bai1.rpy:276
translate russian bai1d_5d4a4d14:

    # bai "I'll see you later."
    bai "Увидимся позже."

# game/Scenes/Bai/bai1.rpy:277
translate russian bai1d_1aff6c8c:

    # pc "See ya, Bai."
    pc "Увидимся, Бай."

# game/Scenes/Bai/bai1.rpy:278
translate russian bai1d_ba9439b8:

    # "He goes to his car and drives off and I walk to mine."
    "Он идет к своей машине и уезжает, а я иду к своей."

