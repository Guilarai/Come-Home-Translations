# game/Scenes/Bai/bai2.rpy:10
translate russian bai2_98ca1a51:

    # "My phone buzzes in my pocket."
    "Мой телефон вибрирует в кармане."

# game/Scenes/Bai/bai2.rpy:14
translate russian bai2_a13b13a8:

    # "It's Bai. I guess I have time to chat a bit."
    "Это Бай. Похоже, у меня есть время немного поболтать."

# game/Scenes/Bai/bai2.rpy:17
translate russian bai2_c0d6b27a:

    # pc "Hey Bai, what's up?"
    pc "Привет, Бай, как дела?"

# game/Scenes/Bai/bai2.rpy:18
translate russian bai2_ca2e0cd6:

    # bai "Hey, [pcname]. I was just lying here bored and wondered what you were up to?"
    bai "Привет, [pcname]. Я просто лежал здесь, скучал и подумал, чем ты занимаешься?"

# game/Scenes/Bai/bai2.rpy:19
translate russian bai2_f020dde3:

    # pc "Just getting ready for bed, but I can talk for a while."
    pc "Просто готовлюсь ко сну, но могу поговорить немного."

# game/Scenes/Bai/bai2.rpy:20
translate russian bai2_b9768b08:

    # bai "That's cool. I've just been thinking a lot."
    bai "Круто. Я просто много думал."

# game/Scenes/Bai/bai2.rpy:21
translate russian bai2_e61255db:

    # pc "About what?"
    pc "О чем?"

# game/Scenes/Bai/bai2.rpy:23
translate russian bai2_67224ed1:

    # bai "Just stuff mostly."
    bai "Просто о всякой всячине."

# game/Scenes/Bai/bai2.rpy:24
translate russian bai2_19828c08:

    # pc "You're going to have to be a little more specific than that or this conversation isn't going to go anywhere."
    pc "Тебе придется быть немного конкретнее, иначе этот разговор ни к чему не приведет."

# game/Scenes/Bai/bai2.rpy:25
translate russian bai2_64de84cd:

    # bai "Okay, well."
    bai "Ладно, ну..."

# game/Scenes/Bai/bai2.rpy:26
translate russian bai2_d7d9d996:

    # bai "I uh... I've only dated girls in the past."
    bai "Я... я раньше встречался только с девушками."

# game/Scenes/Bai/bai2.rpy:27
translate russian bai2_36470b3e:

    # bai "I've had sex and stuff. With girls."
    bai "У меня был секс и все такое. С девушками."

# game/Scenes/Bai/bai2.rpy:28
translate russian bai2_41c2c9e2:

    # bai "But uh... I think I might be into guys too."
    bai "Но... я думаю, что мне, возможно, нравятся и парни."

# game/Scenes/Bai/bai2.rpy:30
translate russian bai2_8833a2ab:

    # pc "So, you're bisexual?"
    pc "Так ты бисексуал?"

# game/Scenes/Bai/bai2.rpy:31
translate russian bai2_61b09772:

    # bai "Maybe?"
    bai "Может быть?"

# game/Scenes/Bai/bai2.rpy:32
translate russian bai2_0e63d7c1:

    # bai "What about you? Are you into guys at all?"
    bai "А ты? Тебе вообще нравятся парни?"

# game/Scenes/Bai/bai2.rpy:36
translate russian bai2_bde64ebd:

    # bai "Oh okay. I thought maybe we had a thing. It's okay though."
    bai "О, ладно. Я думал, может, у нас что-то есть. Но ничего страшного."

# game/Scenes/Bai/bai2.rpy:37
translate russian bai2_0fe323b5:

    # pc "Sorry, man. Chicks only for me."
    pc "Извини, чувак. Мне нравятся только девчонки."

# game/Scenes/Bai/bai2.rpy:38
translate russian bai2_83d8b883:

    # bai "It's cool. I understand."
    bai "Ничего страшного. Я понимаю."

# game/Scenes/Bai/bai2.rpy:40
translate russian bai2_ecf05d77:

    # bai "Still friends though?"
    bai "Но мы останемся друзьями?"

# game/Scenes/Bai/bai2.rpy:41
translate russian bai2_71d4cebe:

    # pc "Sure, we're still friends."
    pc "Конечно, мы останемся друзьями."

# game/Scenes/Bai/bai2.rpy:44
translate russian bai2_e26b3f90:

    # bai "Cool."
    bai "Круто."

# game/Scenes/Bai/bai2.rpy:47
translate russian bai2_b66cc0ac:

    # bai "Really? I thought maybe we had a thing, but I wasn't sure."
    bai "Правда? Я думал, может, у нас что-то есть, но не был уверен."

# game/Scenes/Bai/bai2.rpy:49
translate russian bai2_f39ae0a2:

    # bai "Are you into me?"
    bai "Я тебе нравлюсь?"

# game/Scenes/Bai/bai2.rpy:53
translate russian bai2_99a03550:

    # bai "That makes me so happy."
    bai "Это меня так радует."

# game/Scenes/Bai/bai2.rpy:55
translate russian bai2_99b1838b:

    # bai "So do you maybe want to actually go on a date sometime?"
    bai "Так может, ты хочешь как-нибудь пойти на свидание?"

# game/Scenes/Bai/bai2.rpy:56
translate russian bai2_39757b54:

    # pc "Yeah, let's do it."
    pc "Да, давай."

# game/Scenes/Bai/bai2.rpy:57
translate russian bai2_8c98f2da:

    # bai "Okay, just give me a call in the evening sometime then. I'm available almost every day."
    bai "Ладно, тогда просто позвони мне как-нибудь вечером. Я свободен почти каждый день."

# game/Scenes/Bai/bai2.rpy:58
translate russian bai2_58a87bc2:

    # pc "Sounds good. I'm looking forward to it."
    pc "Звучит хорошо. С нетерпением жду."

# game/Scenes/Bai/bai2.rpy:59
translate russian bai2_10a70856:

    # bai "Me too. Really."
    bai "Я тоже. Правда."

# game/Scenes/Bai/bai2.rpy:60
translate russian bai2_4d74a398:

    # bai "This is new territory for me, but I'm really looking forward to exploring it with you."
    bai "Для меня это новая территория, но я с нетерпением жду, чтобы исследовать её вместе с тобой."

# game/Scenes/Bai/bai2.rpy:63
translate russian bai2_c0a43543:

    # bai "Oh, so you're into guys, but you're not into me."
    bai "О, так ты любишь парней, но я тебе не нравлюсь."

# game/Scenes/Bai/bai2.rpy:64
translate russian bai2_27247fe1:

    # bai "Gotta say, that hurts man."
    bai "Должен сказать, это больно, чувак."

# game/Scenes/Bai/bai2.rpy:65
translate russian bai2_c31c7975:

    # pc "Sorry, just being honest."
    pc "Извини, просто честен."

# game/Scenes/Bai/bai2.rpy:66
translate russian bai2_40a3eff2:

    # bai "Yeah okay. Well that sucks."
    bai "Да, ладно. Ну, это отстойно."

# game/Scenes/Bai/bai2.rpy:67
translate russian bai2_0cce2b18:

    # pc "We can still be friends though."
    pc "Но мы все равно можем остаться друзьями."

# game/Scenes/Bai/bai2.rpy:68
translate russian bai2_46106a33:

    # bai "Yeah, okay. I'm going to bed."
    bai "Да, ладно. Я ложусь спать."

# game/Scenes/Bai/bai2.rpy:70
translate russian bai2_14a17911:

    # "He hangs up. I guess that didn't go so well."
    "Он вешает трубку. Похоже, все прошло не очень хорошо."

# game/Scenes/Bai/bai2.rpy:71
translate russian bai2_a0d6f0f3:

    # "Oh well. He'll get over it. Or not, whatever."
    "Ну и ладно. Он переживет. Или нет, какая разница."

# game/Scenes/Bai/bai2.rpy:72
translate russian bai2_ef88129a:

    # "I put the phone away and get ready for bed."
    "Я убираю телефон и готовлюсь ко сну."

# game/Scenes/Bai/bai2.rpy:75
translate russian bai2_17d3424c:

    # "We chat a little longer about our days, until we are both tired."
    "Мы еще немного болтаем о том, как прошел день, пока оба не устаем."

# game/Scenes/Bai/bai2.rpy:77
translate russian bai2_3898d259:

    # bai "I better get some sleep man."
    bai "Мне лучше поспать, чувак."

# game/Scenes/Bai/bai2.rpy:78
translate russian bai2_89c07fc5:

    # bai "I'll talk to you later."
    bai "Поговорим позже."

# game/Scenes/Bai/bai2.rpy:79
translate russian bai2_d2381b62:

    # pc "Okay. See ya, Bai."
    pc "Ладно. Увидимся, Бай."

# game/Scenes/Bai/bai2.rpy:82
translate russian bai2_52d6e3cf:

    # "We hang up and I get ready for bed."
    "Мы вешаем трубку, и я готовлюсь ко сну."

