translate russian baibeachdate_caf334cd:

    # "I pick Bai up and we drive out towards the beach."
    "Я забираю Бая, и мы едем к пляжу."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:21
translate russian baibeachdate_8ebfb187:

    # pc "Have you been out here before?"
    pc "Ты раньше бывал здесь?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:22
translate russian baibeachdate_64336c0b:

    # bai "Yeah, I sometimes come out here to run in the mornings."
    bai "Да, я иногда приезжаю сюда бегать по утрам."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:23
translate russian baibeachdate_5f0b57d2:

    # bai "But I've never been out here with a cute guy before."
    bai "Но я никогда раньше не был здесь с симпатичным парнем."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:29
translate russian baibeachdate_e914bd34:

    # "When we get to the beach, Bai pulls his shirt off."
    "Когда мы добираемся до пляжа, Бай снимает рубашку."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:30
translate russian baibeachdate_835e0f75:

    # "He's already put suntan lotion on and his skin glistens in the light."
    "Он уже нанес солнцезащитный крем, и его кожа блестит на солнце."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:31
translate russian baibeachdate_4cb4deb6:

    # bai "Ready to get in the water?"
    bai "Готов зайти в воду?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:32
translate russian baibeachdate_39757b54:

    # pc "Yeah, let's do it."
    pc "Да, давай."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:35
translate russian baibeachdate_67fe8962:

    # "We swim around for a while. Bai gets really into it."
    "Мы немного поплавали. Бай очень увлекся."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:36
translate russian baibeachdate_eaa7bafe:

    # "We try racing a bit, but even though I'm a good swimmer, Bai is way too fast for me to keep up with."
    "Мы попробовали немного поплавать наперегонки, но, хотя я и хороший пловец, Бай был слишком быстр, и я не смог за ним угнаться."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:39
translate russian baibeachdate_c4765999:

    # "After a while, we're both tired from swimming and the sun is starting to set, so we lie on the beach and dry off."
    "Через некоторое время мы оба устали от плавания, а солнце начало садиться, поэтому мы легли на пляже и высушились."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:40
translate russian baibeachdate_3d2f7709:

    # "We lean back and talk for a while about whatever comes to mind."
    "Мы откинулись назад и поболтали о том, что пришло в голову."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:47
translate russian baibeachdate_fb5239af:

    # bai "Well, I guess we should head back."
    bai "Ну, пожалуй, нам пора возвращаться."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:48
translate russian baibeachdate_e0511e98:

    # bai "This was fun though, man. Maybe next time there will be more girls out here, you know?"
    bai "Но было весело, чувак. Может, в следующий раз здесь будет больше девушек, знаешь?"

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:51
translate russian baibeachdate_9291d328:

    # "I drive Bai back to his apartment, then leave to go on with the rest of my day."
    "Я подвожу Бая к его квартире, а потом уезжаю, чтобы продолжить свой день."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:62
translate russian baibeachdate_67f91a9e:

    # "When the sun starts to dip below the horizon, we take a moment to watch it together."
    "Когда солнце начинает опускаться за горизонт, мы на мгновение останавливаемся, чтобы посмотреть на него вместе."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:64
translate russian baibeachdate_c710bd77:

    # bai "This is so beautiful."
    bai "Это так красиво."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:65
translate russian baibeachdate_409aa835:

    # "I can see his eyes tear up a bit."
    "Я вижу, как его глаза слегка наполняются слезами."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:66
translate russian baibeachdate_7a029997:

    # bai "You make me feel so safe."
    bai "С тобой я чувствую себя в полной безопасности."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:67
translate russian baibeachdate_fe07fc02:

    # pc "You're always safe with me."
    pc "Со мной ты всегда в безопасности."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:72
translate russian baibeachdate_e1672a1f:

    # bai "I'm so happy that we found each other."
    bai "Я так рад, что мы нашли друг друга."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:73
translate russian baibeachdate_afdaf298:

    # bai "I can't wait to get you back to my place."
    bai "Не могу дождаться, когда мы вернемся ко мне."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:78
translate russian baibeachdate_123df4e4:

    # bai "After the sun sets though."
    bai "Но только после заката."

# game/Scenes/Bai/BaiDates/baibeachdate.rpy:79
translate russian baibeachdate_63409295:

