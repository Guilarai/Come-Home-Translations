    # bai "Yeah."
    bai "Да."

# game/Scenes/Bai/bai9.rpy:186
translate russian bai9menu_3d75bc65:

    # bai "Okay, no problem."
    bai "Ладно, без проблем."

# game/Scenes/Bai/bai9.rpy:189
translate russian bai9menu_4f2d75d2:

    # bai "Thanks for hanging out with me. I hope we can do this again soon."
    bai "Спасибо, что провел со мной время. Надеюсь, мы скоро повторим."

# game/Scenes/Bai/bai9.rpy:190
