# game/Scenes/Juliana/juliana4.rpy:59
translate russian juliana4_4867b2f0:

    # bn "I'm so glad you were here."
    bn "Я так рада, что ты был здесь."

# game/Scenes/Juliana/juliana4.rpy:61
