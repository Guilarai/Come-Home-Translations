# game/Scenes/Juliana/juliana4.rpy:112
translate russian juliana4_63023601:

    # pc "Okay."
    pc "Хорошо."

# game/Scenes/Juliana/juliana4.rpy:115
translate russian juliana4_b5b3d01e:

    # "I follow her inside the house and up a narrow set of stairs to the right to the second floor, which is split between a bathroom and her bedroom."
    "Я следую за ней в дом и поднимаюсь по узкой лестнице направо на второй этаж, где находятся ванная комната и ее спальня."

# game/Scenes/Juliana/juliana4.rpy:119
translate russian juliana4_db649f95:

    # bn "So, this is my bedroom."
    bn "Итак, это моя спальня."

# game/Scenes/Juliana/juliana4.rpy:120
