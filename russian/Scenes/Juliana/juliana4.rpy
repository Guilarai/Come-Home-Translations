# game/Scenes/Juliana/juliana4.rpy:78
translate russian juliana4_26310dbb:

    # bn "Vanilla latte right?"
    bn "Ванильный латте, верно?"

# game/Scenes/Juliana/juliana4.rpy:79
translate russian juliana4_0ce9e5be:

    # pc "You got it. Thank you."
    pc "Точно. Спасибо."

# game/Scenes/Juliana/juliana4.rpy:81
translate russian juliana4_41cb1b7a:

    # bn "It's the least I could do."
