translate russian mrsmcgeephone_fff2f3d4:

    # "After a few rings, Mrs. McGee picks up."
    "После нескольких гудков миссис Макги берет трубку."

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:11
translate russian mrsmcgeephone_09e37605:

    # et "Hello, [pcname]. How are you doing?"
    et "Привет, [pcname]. Как дела?"

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:15
translate russian mrsmcgeephone_5779887f:

    # et "Oh, well I'm kind of busy to just talk on the phone."
    et "О, ну, я сейчас немного занята, чтобы просто болтать по телефону."

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:17
translate russian mrsmcgeephone_90997951:

    # et "But if you'd like to come over for some play time, we could do that."
    et "Но если хочешь зайти ко мне, чтобы немного поиграть, мы можем это сделать."

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:20
translate russian mrsmcgeephone_9be6ae23:

    # pc "I'll head right over."
    pc "Я сразу же приду."

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:21
translate russian mrsmcgeephone_1be94a7e:

    # et "Great. See you then."
    et "Отлично. Увидимся."

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:24
translate russian mrsmcgeephone_1cd51328:

    # "We hang up."
    "Мы вешаем трубку."

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:27
translate russian mrsmcgeephone_b4c7ae2a:

    # et "Okay then. Let me know if you change your mind."
    et "Хорошо. Дай знать, если передумаешь."

# game/Scenes/MrsMcGee/mrsmcgeephone.rpy:28
translate russian mrsmcgeephone_7900f820:

    # et "Talk to you later, [pcname]."
    et "Поговорим позже, [pcname]."

