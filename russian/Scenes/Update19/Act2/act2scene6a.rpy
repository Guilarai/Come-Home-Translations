    # sg "Your dancing was so pretty! I want to see more!"
    sg "Ты так красиво танцевала! Хочу увидеть еще!"

# game/Scenes/Update19/Act2/act2scene6a.rpy:165
translate russian u19a2s6a_b3d79b50:

    # mc "Thank you. I'm sure you dance very pretty as well."
    mc "Спасибо. Уверена, ты тоже очень красиво танцуешь."

