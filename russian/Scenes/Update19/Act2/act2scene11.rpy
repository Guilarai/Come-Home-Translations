# game/Scenes/Update19/Act2/act2scene11.rpy:177
translate russian u19a2s11_81bda1bf:

    # pc "You're good at it though."
    pc "Но у тебя хорошо получается."

# game/Scenes/Update19/Act2/act2scene11.rpy:178
