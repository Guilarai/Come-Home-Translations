# game/Scenes/Update19/Act2/act2scene11.rpy:170
translate russian u19a2s11_b7404c90:

    # pc "I'm much more clumsy underwater than you are on land."
    pc "Я гораздо более неуклюжая под водой, чем ты на суше."

# game/Scenes/Update19/Act2/act2scene11.rpy:171
