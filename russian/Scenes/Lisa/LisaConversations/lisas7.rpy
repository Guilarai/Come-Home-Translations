# game/Scenes/Lisa/LisaConversations/lisas7.rpy:13
translate russian lisas7_12b936bc:

    # sp "I have no idea."
    sp "Понятия не имею."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:14
translate russian lisas7_fac783e5:

    # sp "We never found any of your dad's things."
    sp "Мы так и не нашли вещи твоего отца."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:15
translate russian lisas7_ffb8bf5d:

    # sp "Keys, wallet, cellphone..."
    sp "Ключи, кошелек, мобильный..."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:16
translate russian lisas7_73a4be35:

    # sp "I'm guessing they're with him, wherever he is."
    sp "Думаю, они с ним, где бы он ни был."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:17
translate russian lisas7_f3add17d:

    # pc "He didn't have a spare key or anything?"
    pc "У него не было запасного ключа или чего-то еще?"

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:19
translate russian lisas7_0492d10c:

    # sp "Not that I know of."
    sp "Насколько я знаю, нет."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:20
translate russian lisas7_8cb469de:

    # pc "Damn, I was hoping to be able to drive the car sometime."
    pc "Черт, я надеялся когда-нибудь прокатиться на этой машине."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:22
translate russian lisas7_25e4ef4b:

    # sp "It {i}is{/i} weird that your father would take his keys, but not his car."
    sp "Странно, что твой отец взял с собой ключи, но не машину."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:23
translate russian lisas7_089341e4:

    # sp "He loved that car. He always said it reminded him of you, because you helped him work on it all the time."
    sp "Он обожал эту машину. Всегда говорил, что она ему напоминает тебя, потому что ты все время помогал ему с ней."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:24
translate russian lisas7_e3e50748:

    # pc "Well... not all the time. But sometimes."
    pc "Ну... не все время. Но иногда."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:25
translate russian lisas7_a358955d:

    # pc "Well, thanks anyways, [mom]."
    pc "Ну, все равно спасибо, [mom]."

# game/Scenes/Lisa/LisaConversations/lisas7.rpy:27
translate russian lisas7_72386295:

    # sp "If I happen to find any of his keys, I'll let you know."
    sp "Если вдруг найду какие-нибудь его ключи, дам тебе знать."

